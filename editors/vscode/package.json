{
  "name": "quantalang",
  "displayName": "QuantaLang",
  "description": "Language support for QuantaLang — The Effects Language for game engines and GPU shaders",
  "version": "0.1.0",
  "publisher": "quantalang",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "activationEvents": [
    "onLanguage:quantalang"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "quantalang",
        "aliases": [
          "QuantaLang",
          "quanta"
        ],
        "extensions": [
          ".quanta"
        ],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "./icons/quanta-light.png",
          "dark": "./icons/quanta-dark.png"
        }
      }
    ],
    "grammars": [
      {
        "language": "quantalang",
        "scopeName": "source.quanta",
        "path": "./syntaxes/quantalang.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "quantalang",
        "path": "./snippets/quantalang.json"
      }
    ],
    "configuration": {
      "title": "QuantaLang",
      "properties": {
        "quantalang.serverPath": {
          "type": "string",
          "default": "quantac",
          "description": "Path to the quantac compiler binary"
        },
        "quantalang.target": {
          "type": "string",
          "default": "c",
          "enum": [
            "c",
            "hlsl",
            "glsl",
            "spirv",
            "llvm",
            "wasm",
            "x86-64",
            "arm64"
          ],
          "description": "Default compilation target"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  }
}
