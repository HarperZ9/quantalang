{
  "Function": {
    "prefix": "fn",
    "body": [
      "fn ${1:name}(${2:params}) -> ${3:ReturnType} {",
      "    ${0}",
      "}"
    ],
    "description": "Function definition"
  },
  "Fragment Shader": {
    "prefix": ["fragment", "pixel"],
    "body": [
      "#[fragment]",
      "fn ${1:PS_Main}(uv: vec2) -> vec4 {",
      "    let color = tex2d(uv);",
      "    ${0}",
      "    vec4(color.x, color.y, color.z, 1.0)",
      "}"
    ],
    "description": "Fragment (pixel) shader entry point"
  },
  "Vertex Shader": {
    "prefix": "vertex",
    "body": [
      "#[vertex]",
      "fn ${1:VS_Main}(vertex_id: i32) -> vec4 {",
      "    ${0}",
      "    vec4(0.0, 0.0, 0.0, 1.0)",
      "}"
    ],
    "description": "Vertex shader entry point"
  },
  "Uniform": {
    "prefix": "uniform",
    "body": [
      "#[uniform]",
      "const ${1:name}: ${2:f64} = ${3:1.0};"
    ],
    "description": "Shader uniform constant (becomes a ReShade slider)"
  },
  "Struct": {
    "prefix": "struct",
    "body": [
      "struct ${1:Name} {",
      "    ${2:field}: ${3:Type},",
      "}"
    ],
    "description": "Struct definition"
  },
  "Impl Block": {
    "prefix": "impl",
    "body": [
      "impl ${1:Type} {",
      "    fn ${2:method}(self${3}) -> ${4:ReturnType} {",
      "        ${0}",
      "    }",
      "}"
    ],
    "description": "Implementation block"
  },
  "Effect": {
    "prefix": "effect",
    "body": [
      "effect ${1:Name} {",
      "    fn ${2:operation}(${3:params}) -> ${4:ReturnType};",
      "}"
    ],
    "description": "Effect definition"
  },
  "Color Space Annotation": {
    "prefix": "with",
    "body": "with ${1|ColorSpace<Linear>,ColorSpace<sRGB>,Precision<Full>,Precision<Half>|}",
    "description": "Type annotation (color space, precision)"
  },
  "While Loop": {
    "prefix": "while",
    "body": [
      "while ${1:condition} {",
      "    ${0}",
      "}"
    ],
    "description": "While loop"
  },
  "For Range Loop": {
    "prefix": "for",
    "body": [
      "for ${1:i} in ${2:0}..${3:10} {",
      "    ${0}",
      "}"
    ],
    "description": "For loop over range"
  },
  "Match Expression": {
    "prefix": "match",
    "body": [
      "match ${1:value} {",
      "    ${2:pattern} => ${3:expr},",
      "    _ => ${0},",
      "}"
    ],
    "description": "Match expression"
  },
  "sRGB to Linear": {
    "prefix": "srgb2lin",
    "body": [
      "fn srgb_to_linear(c: f64) -> f64 {",
      "    if c <= 0.04045 {",
      "        c / 12.92",
      "    } else {",
      "        pow((c + 0.055) / 1.055, 2.4)",
      "    }",
      "}"
    ],
    "description": "sRGB to linear color conversion"
  },
  "Hash Noise": {
    "prefix": "hash",
    "body": [
      "fn hash(n: f64) -> f64 {",
      "    let x = sin(n) * 43758.5453;",
      "    fract(x)",
      "}"
    ],
    "description": "Hash-based pseudo-random noise function"
  },
  "Vignette": {
    "prefix": "vignette",
    "body": [
      "fn vignette(uv_x: f64, uv_y: f64, strength: f64, softness: f64) -> f64 {",
      "    let dx = uv_x - 0.5;",
      "    let dy = uv_y - 0.5;",
      "    let dist = sqrt(dx * dx + dy * dy);",
      "    let vig = smoothstep(0.5, 0.5 * softness, dist);",
      "    1.0 - strength * (1.0 - vig)",
      "}"
    ],
    "description": "Vignette effect function"
  }
}
