{
  "Function": {
    "prefix": "fn",
    "body": [
      "fn ${1:name}(${2:params}) -> ${3:ReturnType} {",
      "    ${0}",
      "}"
    ],
    "description": "Function definition"
  },
  "Method with self": {
    "prefix": "fnm",
    "body": [
      "fn ${1:name}(&self${2:, params}) -> ${3:ReturnType} {",
      "    ${0}",
      "}"
    ],
    "description": "Method with &self"
  },
  "Struct": {
    "prefix": ["st", "struct"],
    "body": [
      "struct ${1:Name} {",
      "    ${2:field}: ${3:Type},",
      "}"
    ],
    "description": "Struct definition"
  },
  "Impl Block": {
    "prefix": "impl",
    "body": [
      "impl ${1:Type} {",
      "    fn ${2:method}(&self${3}) -> ${4:ReturnType} {",
      "        ${0}",
      "    }",
      "}"
    ],
    "description": "Implementation block"
  },
  "Enum": {
    "prefix": "enum",
    "body": [
      "enum ${1:Name} {",
      "    ${2:Variant1},",
      "    ${3:Variant2},",
      "}"
    ],
    "description": "Enum definition"
  },
  "Trait": {
    "prefix": "trait",
    "body": [
      "trait ${1:Name} {",
      "    fn ${2:method}(&self${3}) -> ${4:ReturnType};",
      "}"
    ],
    "description": "Trait definition"
  },
  "For Range Loop": {
    "prefix": "for",
    "body": [
      "for ${1:i} in ${2:0}..${3:10} {",
      "    ${0}",
      "}"
    ],
    "description": "For loop over range"
  },
  "Match Expression": {
    "prefix": "match",
    "body": [
      "match ${1:value} {",
      "    ${2:pattern} => ${3:expr},",
      "    _ => ${0},",
      "}"
    ],
    "description": "Match expression"
  },
  "Let Binding": {
    "prefix": "let",
    "body": "let ${1:name} = ${0};",
    "description": "Let binding"
  },
  "Let Mut Binding": {
    "prefix": "letm",
    "body": "let mut ${1:name} = ${0};",
    "description": "Mutable let binding"
  },
  "Test Function": {
    "prefix": "test",
    "body": [
      "#[test]",
      "fn ${1:test_name}() {",
      "    ${0}",
      "}"
    ],
    "description": "Test function"
  },
  "Module": {
    "prefix": "mod",
    "body": [
      "mod ${1:name} {",
      "    ${0}",
      "}"
    ],
    "description": "Module definition"
  },
  "Vec Macro": {
    "prefix": "vec",
    "body": "vec![${0}]",
    "description": "vec! macro"
  },
  "Println Macro": {
    "prefix": "println",
    "body": "println!(\"${1:{}}\", ${0});",
    "description": "println! macro"
  },
  "While Loop": {
    "prefix": "while",
    "body": [
      "while ${1:condition} {",
      "    ${0}",
      "}"
    ],
    "description": "While loop"
  },
  "Effect": {
    "prefix": "effect",
    "body": [
      "effect ${1:Name} {",
      "    fn ${2:operation}(${3:params}) -> ${4:ReturnType};",
      "}"
    ],
    "description": "Effect definition"
  },
  "Fragment Shader": {
    "prefix": ["fragment", "pixel"],
    "body": [
      "#[fragment]",
      "fn ${1:PS_Main}(uv: vec2) -> vec4 {",
      "    let color = tex2d(uv);",
      "    ${0}",
      "    vec4(color.x, color.y, color.z, 1.0)",
      "}"
    ],
    "description": "Fragment (pixel) shader entry point"
  },
  "Vertex Shader": {
    "prefix": "vertex",
    "body": [
      "#[vertex]",
      "fn ${1:VS_Main}(vertex_id: i32) -> vec4 {",
      "    ${0}",
      "    vec4(0.0, 0.0, 0.0, 1.0)",
      "}"
    ],
    "description": "Vertex shader entry point"
  },
  "Uniform": {
    "prefix": "uniform",
    "body": [
      "#[uniform]",
      "const ${1:name}: ${2:f64} = ${3:1.0};"
    ],
    "description": "Shader uniform constant"
  }
}
