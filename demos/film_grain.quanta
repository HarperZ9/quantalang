// QuantaLang Film Grain Overlay Shader
// Pseudo-random noise based on UV coordinates and a time seed.
// Mixes grain with the original image for a cinematic film look.
//
// Compile: quantac film_grain.quanta --target hlsl -o film_grain.fx

// === Uniforms ===

#[uniform]
const grain_amount: f64 = 0.08;

#[uniform]
const grain_size: f64 = 1.0;

#[uniform]
const frame_time: f64 = 0.0;

// === Pseudo-random hash functions ===

fn hash(n: f64) -> f64 {
    let x = sin(n) * 43758.5453;
    fract(x)
}

fn hash2d(x: f64, y: f64) -> f64 {
    hash(x * 12.9898 + y * 78.233 + frame_time * 5.7831)
}

// === Grain noise generation ===
// Quantizes UVs by grain_size to create visible grain structure,
// then generates a noise value in [-1, 1] range.

fn grain_noise(uv_x: f64, uv_y: f64) -> f64 {
    let scale = 512.0 / grain_size;
    let qx = floor(uv_x * scale) / scale;
    let qy = floor(uv_y * scale) / scale;
    let noise = hash2d(qx, qy);
    (noise - 0.5) * 2.0
}

// === Apply grain to a single channel ===
// Grain is added proportionally so dark areas stay dark.

fn apply_grain(color: f64, noise: f64) -> f64 {
    let grained = color + noise * grain_amount * (1.0 - color * 0.5);
    clamp(grained, 0.0, 1.0)
}

// === Pixel shader entry point ===

#[fragment]
fn PS_FilmGrain(uv: vec2) -> vec4 {
    let color = tex2d(uv);
    let noise = grain_noise(uv.x, uv.y);

    let r = apply_grain(color.x, noise);
    let g = apply_grain(color.y, noise);
    let b = apply_grain(color.z, noise);

    vec4(r, g, b, 1.0)
}
