// QuantaLang Fragment Shader — Triangle Demo
// Compiles to SPIR-V via: quantac triangle_fragment.quanta --target spirv

#[fragment]
fn fragment_main(frag_x: f64, frag_y: f64) -> f64 {
    // Output color based on fragment position
    // Creates a gradient across the triangle
    let r = frag_x;
    let g = frag_y;
    let b = 1.0 - frag_x;
    r + g + b
}
