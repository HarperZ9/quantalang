// QuantaLang Screen-Space Ambient Occlusion (SSAO)
// The Killer Demo — a real post-processing effect written entirely in QuantaLang.
//
// Algorithm: disc-based SSAO with depth comparison and range-weighted occlusion.
// For each pixel, samples N points in a random disc around it, compares depth,
// and darkens crevices where geometry occludes ambient light.
//
// Compile: quantac ssao.quanta --target hlsl -o ssao.fx

// === Uniforms (ReShade UI sliders) ===

#[uniform]
const ao_radius: f64 = 0.005;

#[uniform]
const ao_intensity: f64 = 2.0;

#[uniform]
const ao_bias: f64 = 0.001;

#[uniform]
const ao_samples: f64 = 16.0;

// === Pseudo-random noise ===

fn hash(n: f64) -> f64 {
    let x = sin(n) * 43758.5453;
    fract(x)
}

fn hash2(a: f64, b: f64) -> f64 {
    hash(a * 127.1 + b * 311.7)
}

// === Core SSAO computation ===

fn compute_ao(uv_x: f64, uv_y: f64) -> f64 {
    let center_depth = tex2d_depth(vec2(uv_x, uv_y));

    // Early out for sky (depth ~1.0)
    if center_depth > 0.999 {
        1.0
    } else {
        let mut occlusion = 0.0;
        let mut i = 0.0;
        while i < ao_samples {
            // Pseudo-random angle and radius per sample
            let angle = hash2(uv_x * 100.0 + i, uv_y * 100.0) * 6.2831853;
            let dist = hash2(i * 7.3, uv_x + uv_y) * ao_radius;

            // Offset UV
            let sample_x = uv_x + cos(angle) * dist;
            let sample_y = uv_y + sin(angle) * dist;

            // Compare depths
            let sample_depth = tex2d_depth(vec2(sample_x, sample_y));
            let diff = center_depth - sample_depth;

            // Occluded if sample is closer to camera and within range
            if diff > ao_bias {
                let range = smoothstep(0.0, 1.0, ao_radius / abs(diff));
                occlusion = occlusion + range;
                i = i + 1.0;
            } else {
                i = i + 1.0;
            }
        }

        // Normalize and clamp: 0 = fully occluded, 1 = no occlusion
        let ao = 1.0 - (occlusion / ao_samples) * ao_intensity;
        clamp(ao, 0.0, 1.0)
    }
}

// === Pixel shader entry point ===

#[fragment]
fn PS_SSAO(uv: vec2) -> vec4 {
    let color = tex2d(uv);
    let ao = compute_ao(uv.x, uv.y);
    vec4(color.x * ao, color.y * ao, color.z * ao, 1.0)
}
