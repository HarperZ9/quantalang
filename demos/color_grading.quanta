// QuantaLang Color Grading Shader
// Three-way color correction: Lift (shadows), Gamma (midtones), Gain (highlights)
// Plus saturation and color temperature adjustment.
//
// Compile: quantac color_grading.quanta --target hlsl -o color_grading.fx

#[uniform]
const lift: f64 = 0.0;

#[uniform]
const gamma: f64 = 1.0;

#[uniform]
const gain: f64 = 1.0;

#[uniform]
const saturation: f64 = 1.0;

#[uniform]
const temperature: f64 = 0.0;

fn srgb_to_linear(c: f64) -> f64 {
    if c <= 0.04045 {
        c / 12.92
    } else {
        pow((c + 0.055) / 1.055, 2.4)
    }
}

fn linear_to_srgb(c: f64) -> f64 {
    if c <= 0.0031308 {
        c * 12.92
    } else {
        1.055 * pow(c, 0.416667) - 0.055
    }
}

fn lift_gamma_gain(c: f64) -> f64 {
    let lifted = c * (1.0 - lift) + lift;
    let gained = lifted * gain;
    pow(gained, 1.0 / gamma)
}

fn apply_saturation(r: f64, g: f64, b: f64) -> f64 {
    let luma = r * 0.2126 + g * 0.7152 + b * 0.0722;
    luma + (r - luma) * saturation
}

fn apply_temperature(r: f64, b: f64) -> f64 {
    // Positive = warm (boost red), negative = cool (boost blue)
    r + temperature * 0.1
}

#[fragment]
fn PS_ColorGrade(uv: vec2) -> vec4 {
    let color = tex2d(uv);

    // Linearize
    let lr = srgb_to_linear(color.x);
    let lg = srgb_to_linear(color.y);
    let lb = srgb_to_linear(color.z);

    // Lift-Gamma-Gain
    let gr = lift_gamma_gain(lr);
    let gg = lift_gamma_gain(lg);
    let gb = lift_gamma_gain(lb);

    // Saturation
    let sr = apply_saturation(gr, gg, gb);
    let sg = apply_saturation(gg, gr, gb);
    let sb = apply_saturation(gb, gr, gg);

    // Temperature shift
    let tr = sr + temperature * 0.05;
    let tb = sb - temperature * 0.05;

    // Back to sRGB
    let fr = linear_to_srgb(tr);
    let fg = linear_to_srgb(sg);
    let fb = linear_to_srgb(tb);

    vec4(fr, fg, fb, 1.0)
}
