// QuantaLang Chromatic Aberration Shader
// Simulates lens fringing by offsetting RGB channels radially from center.
// Red shifts outward, blue shifts inward, green stays centered.
//
// Compile: quantac chromatic_aberration.quanta --target hlsl -o chromatic_aberration.fx

// === Uniforms ===

#[uniform]
const strength: f64 = 0.005;

// === Radial UV offset ===
// Computes an offset UV that shifts toward or away from center.
// direction > 0 pushes outward, direction < 0 pushes inward.

fn offset_uv_x(uv_x: f64, uv_y: f64, direction: f64) -> f64 {
    let dx = uv_x - 0.5;
    let dy = uv_y - 0.5;
    let dist = sqrt(dx * dx + dy * dy);
    if dist > 0.001 {
        uv_x + (dx / dist) * dist * strength * direction
    } else {
        uv_x
    }
}

fn offset_uv_y(uv_x: f64, uv_y: f64, direction: f64) -> f64 {
    let dx = uv_x - 0.5;
    let dy = uv_y - 0.5;
    let dist = sqrt(dx * dx + dy * dy);
    if dist > 0.001 {
        uv_y + (dy / dist) * dist * strength * direction
    } else {
        uv_y
    }
}

// === Pixel shader entry point ===

#[fragment]
fn PS_ChromaticAberration(uv: vec2) -> vec4 {
    // Red channel: offset outward (positive direction)
    let red_x = offset_uv_x(uv.x, uv.y, 1.0);
    let red_y = offset_uv_y(uv.x, uv.y, 1.0);
    let red_sample = tex2d(vec2(red_x, red_y));

    // Green channel: no offset (original position)
    let green_sample = tex2d(uv);

    // Blue channel: offset inward (negative direction)
    let blue_x = offset_uv_x(uv.x, uv.y, -1.0);
    let blue_y = offset_uv_y(uv.x, uv.y, -1.0);
    let blue_sample = tex2d(vec2(blue_x, blue_y));

    vec4(red_sample.x, green_sample.y, blue_sample.z, 1.0)
}
