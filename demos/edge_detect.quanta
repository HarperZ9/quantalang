// QuantaLang Sobel Edge Detection Shader
// Detects edges using depth differences — a core building block for outlines.
//
// Compile: quantac edge_detect.quanta --target hlsl -o edge_detect.fx

#[uniform]
const edge_threshold: f64 = 0.001;

#[uniform]
const edge_intensity: f64 = 5.0;

#[uniform]
const outline_only: f64 = 0.0;

fn sample_depth(uv_x: f64, uv_y: f64) -> f64 {
    tex2d_depth(vec2(uv_x, uv_y))
}

fn sobel_edge(uv_x: f64, uv_y: f64, texel: f64) -> f64 {
    // 3x3 Sobel kernel on depth buffer
    let tl = sample_depth(uv_x - texel, uv_y - texel);
    let tc = sample_depth(uv_x, uv_y - texel);
    let tr = sample_depth(uv_x + texel, uv_y - texel);
    let ml = sample_depth(uv_x - texel, uv_y);
    let mr = sample_depth(uv_x + texel, uv_y);
    let bl = sample_depth(uv_x - texel, uv_y + texel);
    let bc = sample_depth(uv_x, uv_y + texel);
    let br = sample_depth(uv_x + texel, uv_y + texel);

    // Horizontal gradient (Gx)
    let gx = (tr + 2.0 * mr + br) - (tl + 2.0 * ml + bl);
    // Vertical gradient (Gy)
    let gy = (bl + 2.0 * bc + br) - (tl + 2.0 * tc + tr);

    // Edge magnitude
    sqrt(gx * gx + gy * gy)
}

#[fragment]
fn PS_EdgeDetect(uv: vec2) -> vec4 {
    let color = tex2d(uv);
    let edge = sobel_edge(uv.x, uv.y, 0.001) * edge_intensity;

    // Threshold
    let mask = smoothstep(edge_threshold, edge_threshold * 2.0, edge);

    // Blend: outline_only=1 shows only edges, outline_only=0 darkens scene at edges
    let r = color.x * (1.0 - mask * outline_only) - mask * (1.0 - outline_only) * 0.5;
    let g = color.y * (1.0 - mask * outline_only) - mask * (1.0 - outline_only) * 0.5;
    let b = color.z * (1.0 - mask * outline_only) - mask * (1.0 - outline_only) * 0.5;

    vec4(r, g, b, 1.0)
}
