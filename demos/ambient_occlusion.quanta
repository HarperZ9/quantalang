// QuantaLang Screen-Space Ambient Occlusion
// Hemisphere-sampled SSAO with 8-tap kernel, radius, and intensity controls.
//
// Compile: quantac ambient_occlusion.quanta --target hlsl -o ambient_occlusion.fx

// === Uniforms ===

#[uniform]
const ao_radius: f64 = 0.01;

#[uniform]
const ao_intensity: f64 = 1.5;

// === Pseudo-random noise for sample distribution ===

fn hash(n: f64) -> f64 {
    let x = sin(n) * 43758.5453;
    fract(x)
}

fn hash2(a: f64, b: f64) -> f64 {
    hash(a * 127.1 + b * 311.7)
}

// === Hemisphere sample offset ===
// Returns an angular offset for sample i in a hemisphere disc.

fn sample_offset_x(i: f64, uv_x: f64, uv_y: f64) -> f64 {
    let angle = hash2(i * 3.17, uv_x + uv_y) * 6.2831853;
    let dist = hash2(uv_x * 50.0 + i, uv_y * 50.0) * ao_radius;
    cos(angle) * dist
}

fn sample_offset_y(i: f64, uv_x: f64, uv_y: f64) -> f64 {
    let angle = hash2(i * 3.17, uv_x + uv_y) * 6.2831853;
    let dist = hash2(uv_x * 50.0 + i, uv_y * 50.0) * ao_radius;
    sin(angle) * dist
}

// === Depth comparison for a single sample ===

fn compare_depth(center_d: f64, sample_x: f64, sample_y: f64) -> f64 {
    let sample_d = tex2d_depth(vec2(sample_x, sample_y));
    let diff = center_d - sample_d;
    if diff > 0.0005 {
        let range = smoothstep(0.0, 1.0, ao_radius / abs(diff));
        range
    } else {
        0.0
    }
}

// === Core SSAO with 8 hemisphere samples ===

fn compute_ssao(uv_x: f64, uv_y: f64) -> f64 {
    let center_d = tex2d_depth(vec2(uv_x, uv_y));

    // Skip sky pixels
    if center_d > 0.999 {
        1.0
    } else {
        let mut occlusion = 0.0;
        let mut i = 0.0;
        while i < 8.0 {
            let ox = sample_offset_x(i, uv_x, uv_y);
            let oy = sample_offset_y(i, uv_x, uv_y);
            occlusion = occlusion + compare_depth(center_d, uv_x + ox, uv_y + oy);
            i = i + 1.0;
        }

        let ao = 1.0 - (occlusion / 8.0) * ao_intensity;
        clamp(ao, 0.0, 1.0)
    }
}

// === Pixel shader entry point ===

#[fragment]
fn PS_AmbientOcclusion(uv: vec2) -> vec4 {
    let color = tex2d(uv);
    let ao = compute_ssao(uv.x, uv.y);
    vec4(color.x * ao, color.y * ao, color.z * ao, 1.0)
}
