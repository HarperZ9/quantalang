// QuantaLang Vertex Shader â€” compiled through ASTâ†’MIRâ†’SPIR-V pipeline
// Returns vec4 which maps to gl_Position

#[vertex]
fn main(vertex_id: i32) -> vec4 {
    // Triangle positions in clip space
    let x = if vertex_id == 0 { 0.0 }
        else { if vertex_id == 1 { 0.5 } else { -0.5 } };
    let y = if vertex_id == 0 { -0.5 }
        else { 0.5 };
    vec4(x, y, 0.0, 1.0)
}
