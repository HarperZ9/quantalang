// QuantaLang Triangle Demo
// Demonstrates: FFI to graphics library + effects for rendering control
//
// This program would render a colored triangle using Vulkan.
// Currently uses a stub graphics library that prints operations.
// When connected to real Vulkan, the same QuantaLang code renders to screen.

extern "C" {
    fn quanta_gfx_init(width: i32, height: i32, title: &str) -> i32;
    fn quanta_gfx_load_shader(path: &str, stage: i32) -> i32;
    fn quanta_gfx_create_pipeline(vs: i32, fs: i32) -> i32;
    fn quanta_gfx_begin_frame();
    fn quanta_gfx_clear(r: f32, g: f32, b: f32, a: f32);
    fn quanta_gfx_draw(vertex_count: i32);
    fn quanta_gfx_end_frame();
    fn quanta_gfx_should_close() -> i32;
    fn quanta_gfx_shutdown();
}

// Render effect -- the same pattern works with real Vulkan or the stub
effect Render {
    fn clear(r: f32, g: f32, b: f32) -> (),
    fn draw_triangles(count: i32) -> (),
    fn present() -> (),
}

// The game loop -- effect-controlled, testable, backend-agnostic
fn render_loop(pipeline: i32) ~ Render {
    while quanta_gfx_should_close() == 0 {
        perform Render.clear(0.1, 0.1, 0.15);
        perform Render.draw_triangles(3);
        perform Render.present();
    }
}

fn main() {
    // Initialize graphics
    let ok = quanta_gfx_init(800, 600, "QuantaLang Triangle");

    if ok == 0 {
        println!("Failed to initialize graphics");
    }

    // Load shaders (compiled from QuantaLang to SPIR-V)
    let vs = quanta_gfx_load_shader("vertex.spv", 0);
    let fs = quanta_gfx_load_shader("fragment.spv", 1);
    let pipeline = quanta_gfx_create_pipeline(vs, fs);

    // Run the render loop with the graphics handler
    handle {
        render_loop(pipeline)
    } with {
        Render.clear(r, g, b) => {
            quanta_gfx_begin_frame();
            quanta_gfx_clear(r, g, b, 1.0);
        },
        Render.draw_triangles(count) => {
            quanta_gfx_draw(count);
        },
        Render.present() => {
            quanta_gfx_end_frame();
        },
    }

    quanta_gfx_shutdown();
}
