/// Example: JSON API Client
/// Demonstrates HTTP requests, JSON parsing, and error handling

use std::net::http::{Client, Request, Method};
use std::json::{self, Value};
use std::io::{File, Write};
use std::time::Duration;

/// API configuration
const API_BASE: &str = "https://jsonplaceholder.typicode.com";

/// User data structure
#[derive(Debug, Clone)]
struct User {
    id: u64,
    name: String,
    username: String,
    email: String,
}

impl User {
    fn from_json(value: &Value) -> Option<Self> {
        Some(User {
            id: value["id"].as_u64()?,
            name: value["name"].as_str()?.to_string(),
            username: value["username"].as_str()?.to_string(),
            email: value["email"].as_str()?.to_string(),
        })
    }
}

/// Post data structure
#[derive(Debug, Clone)]
struct Post {
    id: u64,
    user_id: u64,
    title: String,
    body: String,
}

impl Post {
    fn from_json(value: &Value) -> Option<Self> {
        Some(Post {
            id: value["id"].as_u64()?,
            user_id: value["userId"].as_u64()?,
            title: value["title"].as_str()?.to_string(),
            body: value["body"].as_str()?.to_string(),
        })
    }
    
    fn to_json(&self) -> Value {
        json::json!({
            "userId": self.user_id,
            "title": self.title,
            "body": self.body
        })
    }
}

/// API client with error handling
struct ApiClient {
    client: Client,
    base_url: String,
}

impl ApiClient {
    fn new(base_url: &str) -> Self {
        ApiClient {
            client: Client::builder()
                .timeout(Duration::from_secs(30))
                .build(),
            base_url: base_url.to_string(),
        }
    }
    
    /// Fetch all users
    fn get_users(&self) -> Result<Vec<User>, ApiError> {
        let url = format!("{}/users", self.base_url);
        let response = self.client.get(&url).send()?;
        
        if !response.is_success() {
            return Err(ApiError::HttpError(response.status()));
        }
        
        let json: Value = response.json()?;
        let users = json.as_array()
            .ok_or(ApiError::ParseError("Expected array".into()))?
            .iter()
            .filter_map(User::from_json)
            .collect();
        
        Ok(users)
    }
    
    /// Fetch a single user by ID
    fn get_user(&self, id: u64) -> Result<User, ApiError> {
        let url = format!("{}/users/{}", self.base_url, id);
        let response = self.client.get(&url).send()?;
        
        if response.status() == 404 {
            return Err(ApiError::NotFound);
        }
        
        if !response.is_success() {
            return Err(ApiError::HttpError(response.status()));
        }
        
        let json: Value = response.json()?;
        User::from_json(&json)
            .ok_or(ApiError::ParseError("Invalid user data".into()))
    }
    
    /// Fetch posts by user ID
    fn get_posts_by_user(&self, user_id: u64) -> Result<Vec<Post>, ApiError> {
        let url = format!("{}/posts?userId={}", self.base_url, user_id);
        let response = self.client.get(&url).send()?;
        
        if !response.is_success() {
            return Err(ApiError::HttpError(response.status()));
        }
        
        let json: Value = response.json()?;
        let posts = json.as_array()
            .ok_or(ApiError::ParseError("Expected array".into()))?
            .iter()
            .filter_map(Post::from_json)
            .collect();
        
        Ok(posts)
    }
    
    /// Create a new post
    fn create_post(&self, post: &Post) -> Result<Post, ApiError> {
        let url = format!("{}/posts", self.base_url);
        let response = self.client
            .post(&url)
            .json(&post.to_json())
            .send()?;
        
        if !response.is_success() {
            return Err(ApiError::HttpError(response.status()));
        }
        
        let json: Value = response.json()?;
        Post::from_json(&json)
            .ok_or(ApiError::ParseError("Invalid post data".into()))
    }
}

/// API errors
#[derive(Debug)]
enum ApiError {
    HttpError(u16),
    NetworkError(String),
    ParseError(String),
    NotFound,
}

impl std::fmt::Display for ApiError {
    fn fmt(&self, f: &mut std::fmt::Formatter<'_>) -> std::fmt::Result {
        match self {
            ApiError::HttpError(status) => write!(f, "HTTP error: {}", status),
            ApiError::NetworkError(msg) => write!(f, "Network error: {}", msg),
            ApiError::ParseError(msg) => write!(f, "Parse error: {}", msg),
            ApiError::NotFound => write!(f, "Resource not found"),
        }
    }
}

impl From<std::io::Error> for ApiError {
    fn from(e: std::io::Error) -> Self {
        ApiError::NetworkError(e.to_string())
    }
}

impl From<json::Error> for ApiError {
    fn from(e: json::Error) -> Self {
        ApiError::ParseError(e.to_string())
    }
}

fn main() -> Result<(), Box<dyn std::error::Error>> {
    println!("=== JSON API Client Example ===\n");
    
    let client = ApiClient::new(API_BASE);
    
    // Fetch and display all users
    println!("📋 Fetching users...");
    let users = client.get_users()?;
    println!("Found {} users:\n", users.len());
    
    for user in &users[..3.min(users.len())] {
        println!("  👤 {} (@{})", user.name, user.username);
        println!("     Email: {}", user.email);
        println!();
    }
    
    // Fetch a specific user
    println!("🔍 Fetching user #1...");
    match client.get_user(1) {
        Ok(user) => {
            println!("Found: {} <{}>\n", user.name, user.email);
        }
        Err(e) => {
            println!("Error: {}\n", e);
        }
    }
    
    // Fetch posts by user
    println!("📝 Fetching posts by user #1...");
    let posts = client.get_posts_by_user(1)?;
    println!("Found {} posts:\n", posts.len());
    
    for post in &posts[..3.min(posts.len())] {
        println!("  📄 {}", post.title);
        let preview: String = post.body.chars().take(50).collect();
        println!("     {}...\n", preview);
    }
    
    // Create a new post
    println!("✏️ Creating a new post...");
    let new_post = Post {
        id: 0,
        user_id: 1,
        title: "My New Post".to_string(),
        body: "This is the content of my new post created with QuantaLang!".to_string(),
    };
    
    let created = client.create_post(&new_post)?;
    println!("Created post with ID: {}\n", created.id);
    
    // Export data to JSON file
    println!("💾 Exporting users to JSON...");
    let users_json = json::json!({
        "users": users.iter().map(|u| json::json!({
            "id": u.id,
            "name": u.name,
            "username": u.username,
            "email": u.email
        })).collect::<Vec<_>>()
    });
    
    let mut file = File::create("users_export.json")?;
    file.write_all(json::to_string_pretty(&users_json)?.as_bytes())?;
    println!("Exported to users_export.json\n");
    
    println!("✅ Done!");
    Ok(())
}
