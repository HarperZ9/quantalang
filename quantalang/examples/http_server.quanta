/// HTTP Server Example
/// A simple web server using the standard library.

use std::net::http::{Server, Request, Response, StatusCode};
use std::sync::{Arc, Mutex};
use std::collections::HashMap;

/// In-memory key-value store
struct Store {
    data: HashMap<String, String>,
}

impl Store {
    fn new() -> Self {
        Store {
            data: HashMap::new(),
        }
    }
    
    fn get(&self, key: &str) -> Option<&String> {
        self.data.get(key)
    }
    
    fn set(&mut self, key: String, value: String) {
        self.data.insert(key, value);
    }
    
    fn delete(&mut self, key: &str) -> bool {
        self.data.remove(key).is_some()
    }
}

fn main() -> Result<(), std::io::Error> {
    let store = Arc::new(Mutex::new(Store::new()));
    let addr = "127.0.0.1:8080";
    
    println!("Starting server on http://{}", addr);
    println!("Endpoints:");
    println!("  GET  /           - Home page");
    println!("  GET  /api/:key   - Get value");
    println!("  POST /api/:key   - Set value");
    println!("  DELETE /api/:key - Delete value");
    
    let server = Server::bind(addr)?;
    
    server.listen(move |req: Request| -> Response {
        let store = Arc::clone(&store);
        route(req, store)
    })
}

fn route(req: Request, store: Arc<Mutex<Store>>) -> Response {
    match (req.method(), req.path()) {
        // Home page
        ("GET", "/") => {
            Response::html(r#"
                <!DOCTYPE html>
                <html>
                <head>
                    <title>QuantaLang Server</title>
                    <style>
                        body { font-family: system-ui; max-width: 600px; margin: 2rem auto; }
                        code { background: #f0f0f0; padding: 2px 6px; border-radius: 4px; }
                    </style>
                </head>
                <body>
                    <h1>🚀 QuantaLang HTTP Server</h1>
                    <p>A simple key-value store API.</p>
                    <h2>Endpoints</h2>
                    <ul>
                        <li><code>GET /api/:key</code> - Get a value</li>
                        <li><code>POST /api/:key</code> - Set a value (body = value)</li>
                        <li><code>DELETE /api/:key</code> - Delete a value</li>
                    </ul>
                </body>
                </html>
            "#)
        }
        
        // API endpoints
        ("GET", path) if path.starts_with("/api/") => {
            let key = &path[5..];
            let store = store.lock().unwrap();
            
            match store.get(key) {
                Some(value) => Response::json(&json!({
                    "key": key,
                    "value": value
                })),
                None => Response::status(StatusCode::NOT_FOUND)
                    .json(&json!({ "error": "Key not found" })),
            }
        }
        
        ("POST", path) if path.starts_with("/api/") => {
            let key = path[5..].to_string();
            let value = req.body_string().unwrap_or_default();
            
            let mut store = store.lock().unwrap();
            store.set(key.clone(), value.clone());
            
            Response::status(StatusCode::CREATED)
                .json(&json!({
                    "key": key,
                    "value": value,
                    "message": "Created"
                }))
        }
        
        ("DELETE", path) if path.starts_with("/api/") => {
            let key = &path[5..];
            let mut store = store.lock().unwrap();
            
            if store.delete(key) {
                Response::json(&json!({ "message": "Deleted" }))
            } else {
                Response::status(StatusCode::NOT_FOUND)
                    .json(&json!({ "error": "Key not found" }))
            }
        }
        
        // 404 for everything else
        _ => Response::status(StatusCode::NOT_FOUND)
            .json(&json!({ "error": "Not found" })),
    }
}
