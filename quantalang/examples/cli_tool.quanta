/// CLI Tool Example
/// A command-line word counting utility similar to `wc`.

use std::env;
use std::io::{self, File, Read, BufReader, BufRead, stdin};
use std::path::Path;

/// Statistics for a file
#[derive(Default, Clone)]
struct Stats {
    lines: usize,
    words: usize,
    chars: usize,
    bytes: usize,
}

impl Stats {
    fn add(&mut self, other: &Stats) {
        self.lines += other.lines;
        self.words += other.words;
        self.chars += other.chars;
        self.bytes += other.bytes;
    }
}

/// Command-line options
struct Options {
    show_lines: bool,
    show_words: bool,
    show_chars: bool,
    show_bytes: bool,
    files: Vec<String>,
}

impl Options {
    fn parse(args: Vec<String>) -> Result<Self, String> {
        let mut opts = Options {
            show_lines: false,
            show_words: false,
            show_chars: false,
            show_bytes: false,
            files: Vec::new(),
        };
        
        let mut explicit_flags = false;
        
        for arg in args.into_iter().skip(1) {
            if arg.starts_with('-') && arg.len() > 1 && !arg.starts_with("--") {
                explicit_flags = true;
                for c in arg[1..].chars() {
                    match c {
                        'l' => opts.show_lines = true,
                        'w' => opts.show_words = true,
                        'm' => opts.show_chars = true,
                        'c' => opts.show_bytes = true,
                        'h' => return Err("help".to_string()),
                        _ => return Err(format!("Unknown option: -{}", c)),
                    }
                }
            } else if arg == "--help" {
                return Err("help".to_string());
            } else if arg == "--version" {
                return Err("version".to_string());
            } else {
                opts.files.push(arg);
            }
        }
        
        // Default: show all if no flags specified
        if !explicit_flags {
            opts.show_lines = true;
            opts.show_words = true;
            opts.show_bytes = true;
        }
        
        Ok(opts)
    }
}

fn main() {
    let args: Vec<String> = env::args().collect();
    
    let opts = match Options::parse(args) {
        Ok(opts) => opts,
        Err(msg) if msg == "help" => {
            print_help();
            return;
        }
        Err(msg) if msg == "version" => {
            println!("qwc 1.0.0");
            return;
        }
        Err(msg) => {
            eprintln!("Error: {}", msg);
            eprintln!("Try 'qwc --help' for more information.");
            std::process::exit(1);
        }
    };
    
    let result = if opts.files.is_empty() {
        // Read from stdin
        process_stdin(&opts)
    } else {
        // Process files
        process_files(&opts)
    };
    
    if let Err(e) = result {
        eprintln!("Error: {}", e);
        std::process::exit(1);
    }
}

fn print_help() {
    println!("qwc - QuantaLang Word Count");
    println!();
    println!("USAGE:");
    println!("    qwc [OPTIONS] [FILE]...");
    println!();
    println!("OPTIONS:");
    println!("    -l          Print line count");
    println!("    -w          Print word count");
    println!("    -m          Print character count");
    println!("    -c          Print byte count");
    println!("    -h, --help  Print help information");
    println!("    --version   Print version");
    println!();
    println!("EXAMPLES:");
    println!("    qwc file.txt");
    println!("    qwc -l file1.txt file2.txt");
    println!("    cat file.txt | qwc");
}

fn process_stdin(opts: &Options) -> io::Result<()> {
    let stdin = stdin();
    let reader = BufReader::new(stdin.lock());
    let stats = count_stats(reader)?;
    
    print_stats(&stats, opts, None);
    Ok(())
}

fn process_files(opts: &Options) -> io::Result<()> {
    let mut total = Stats::default();
    let mut had_error = false;
    
    for filename in &opts.files {
        match process_file(filename) {
            Ok(stats) => {
                print_stats(&stats, opts, Some(filename));
                total.add(&stats);
            }
            Err(e) => {
                eprintln!("qwc: {}: {}", filename, e);
                had_error = true;
            }
        }
    }
    
    // Print total if multiple files
    if opts.files.len() > 1 {
        print_stats(&total, opts, Some("total"));
    }
    
    if had_error {
        std::process::exit(1);
    }
    
    Ok(())
}

fn process_file(filename: &str) -> io::Result<Stats> {
    let file = File::open(filename)?;
    let reader = BufReader::new(file);
    count_stats(reader)
}

fn count_stats<R: BufRead>(reader: R) -> io::Result<Stats> {
    let mut stats = Stats::default();
    
    for line in reader.lines() {
        let line = line?;
        stats.lines += 1;
        stats.bytes += line.len() + 1; // +1 for newline
        stats.chars += line.chars().count() + 1;
        stats.words += line.split_whitespace().count();
    }
    
    Ok(stats)
}

fn print_stats(stats: &Stats, opts: &Options, filename: Option<&str>) {
    let mut parts = Vec::new();
    
    if opts.show_lines {
        parts.push(format!("{:>8}", stats.lines));
    }
    if opts.show_words {
        parts.push(format!("{:>8}", stats.words));
    }
    if opts.show_chars {
        parts.push(format!("{:>8}", stats.chars));
    }
    if opts.show_bytes {
        parts.push(format!("{:>8}", stats.bytes));
    }
    
    let output = parts.join(" ");
    
    match filename {
        Some(name) => println!("{} {}", output, name),
        None => println!("{}", output),
    }
}
