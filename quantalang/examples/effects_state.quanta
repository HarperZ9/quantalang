// QuantaLang — Mutable State as an Effect
// State is explicit, trackable, and pure.

effect State<S> {
    fn get() -> S,
    fn set(value: S) -> (),
}

// A counter that uses state effect — pure function!
fn count_up(n: i32) ~ State<i32> -> i32 {
    let mut i = 0;
    while i < n {
        let current = perform State.get();
        perform State.set(current + 1);
        i = i + 1;
    }
    perform State.get()
}

fn main() {
    // Provide the state handler — YOU choose the implementation
    let mut state: i32 = 0;

    handle {
        let final_count = count_up(10);
        println!("Final count: {}", final_count);
    } with {
        State.get() => |resume| {
            resume(state)
        },
        State.set(value) => |resume| {
            state = value;
            resume(())
        },
    }
}
