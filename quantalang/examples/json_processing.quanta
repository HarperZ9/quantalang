/// JSON Processing Example
/// Demonstrates parsing, manipulation, and serialization of JSON data.

use std::json::{self, Value, json};
use std::io::{File, Read, Write};
use std::collections::HashMap;

/// User data structure
#[derive(Debug)]
struct User {
    id: u64,
    name: String,
    email: String,
    active: bool,
    roles: Vec<String>,
}

impl User {
    fn from_json(value: &Value) -> Option<User> {
        Some(User {
            id: value["id"].as_u64()?,
            name: value["name"].as_str()?.to_string(),
            email: value["email"].as_str()?.to_string(),
            active: value["active"].as_bool().unwrap_or(true),
            roles: value["roles"].as_array()?
                .iter()
                .filter_map(|v| v.as_str().map(String::from))
                .collect(),
        })
    }
    
    fn to_json(&self) -> Value {
        json!({
            "id": self.id,
            "name": self.name,
            "email": self.email,
            "active": self.active,
            "roles": self.roles
        })
    }
}

fn main() -> Result<(), Box<dyn std::error::Error>> {
    println!("=== JSON Processing Demo ===\n");
    
    // Demo 1: Parse JSON string
    demo_parse_json();
    
    // Demo 2: Create JSON programmatically
    demo_create_json();
    
    // Demo 3: Modify JSON data
    demo_modify_json();
    
    // Demo 4: Work with nested data
    demo_nested_json();
    
    // Demo 5: JSON Pointer access
    demo_json_pointer();
    
    // Demo 6: Serialize to file
    demo_file_io()?;
    
    Ok(())
}

fn demo_parse_json() {
    println!("1. Parsing JSON");
    println!("---------------");
    
    let json_str = r#"
    {
        "id": 1,
        "name": "Alice",
        "email": "alice@example.com",
        "active": true,
        "roles": ["admin", "user"]
    }
    "#;
    
    let value: Value = json::from_str(json_str).expect("Failed to parse JSON");
    
    println!("  Parsed user:");
    println!("    Name: {}", value["name"].as_str().unwrap());
    println!("    Email: {}", value["email"].as_str().unwrap());
    println!("    Active: {}", value["active"].as_bool().unwrap());
    println!("    Roles: {:?}", value["roles"].as_array().unwrap());
    
    // Convert to struct
    if let Some(user) = User::from_json(&value) {
        println!("  As struct: {:?}", user);
    }
    
    println!();
}

fn demo_create_json() {
    println!("2. Creating JSON");
    println!("----------------");
    
    // Using the json! macro
    let user = json!({
        "id": 2,
        "name": "Bob",
        "email": "bob@example.com",
        "metadata": {
            "created_at": "2024-01-15T10:30:00Z",
            "login_count": 42
        },
        "tags": ["developer", "remote"]
    });
    
    println!("  Created JSON:");
    println!("{}", json::to_string_pretty(&user).unwrap());
    println!();
}

fn demo_modify_json() {
    println!("3. Modifying JSON");
    println!("-----------------");
    
    let mut user = json!({
        "name": "Charlie",
        "score": 100
    });
    
    println!("  Original: {}", json::to_string(&user).unwrap());
    
    // Modify existing field
    user["score"] = json!(150);
    
    // Add new field
    user["level"] = json!("advanced");
    
    // Add nested object
    user["stats"] = json!({
        "wins": 10,
        "losses": 3
    });
    
    println!("  Modified: {}", json::to_string_pretty(&user).unwrap());
    println!();
}

fn demo_nested_json() {
    println!("4. Nested JSON");
    println!("--------------");
    
    let data = json!({
        "company": "Acme Corp",
        "departments": [
            {
                "name": "Engineering",
                "employees": [
                    {"name": "Alice", "role": "Lead"},
                    {"name": "Bob", "role": "Senior"}
                ]
            },
            {
                "name": "Marketing",
                "employees": [
                    {"name": "Carol", "role": "Manager"}
                ]
            }
        ]
    });
    
    println!("  Company: {}", data["company"].as_str().unwrap());
    
    if let Some(departments) = data["departments"].as_array() {
        for dept in departments {
            println!("\n  Department: {}", dept["name"].as_str().unwrap());
            
            if let Some(employees) = dept["employees"].as_array() {
                for emp in employees {
                    println!("    - {} ({})", 
                        emp["name"].as_str().unwrap(),
                        emp["role"].as_str().unwrap());
                }
            }
        }
    }
    
    println!();
}

fn demo_json_pointer() {
    println!("5. JSON Pointer Access");
    println!("----------------------");
    
    let data = json!({
        "users": [
            {"name": "Alice", "address": {"city": "Seattle"}},
            {"name": "Bob", "address": {"city": "Portland"}}
        ],
        "meta": {
            "version": "1.0"
        }
    });
    
    // Access using JSON Pointer syntax
    let first_user = data.pointer("/users/0/name");
    let second_city = data.pointer("/users/1/address/city");
    let version = data.pointer("/meta/version");
    
    println!("  /users/0/name = {:?}", first_user);
    println!("  /users/1/address/city = {:?}", second_city);
    println!("  /meta/version = {:?}", version);
    println!();
}

fn demo_file_io() -> Result<(), Box<dyn std::error::Error>> {
    println!("6. File I/O");
    println!("-----------");
    
    let users = json!({
        "users": [
            {"id": 1, "name": "Alice", "active": true},
            {"id": 2, "name": "Bob", "active": false},
            {"id": 3, "name": "Carol", "active": true}
        ],
        "total": 3
    });
    
    // Write to file
    let filename = "/tmp/users.json";
    let mut file = File::create(filename)?;
    let json_string = json::to_string_pretty(&users)?;
    file.write_all(json_string.as_bytes())?;
    println!("  Wrote {} bytes to {}", json_string.len(), filename);
    
    // Read back
    let mut file = File::open(filename)?;
    let mut contents = String::new();
    file.read_to_string(&mut contents)?;
    
    let parsed: Value = json::from_str(&contents)?;
    println!("  Read back {} users", parsed["total"].as_i64().unwrap());
    
    // Filter active users
    let active_users: Vec<_> = parsed["users"]
        .as_array()
        .unwrap()
        .iter()
        .filter(|u| u["active"].as_bool().unwrap_or(false))
        .collect();
    
    println!("  Active users: {}", active_users.len());
    for user in active_users {
        println!("    - {}", user["name"].as_str().unwrap());
    }
    
    Ok(())
}
