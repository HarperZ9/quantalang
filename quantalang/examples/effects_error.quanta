// QuantaLang — Error Handling with Effects
// Better than Rust's Result<T, E>: no ? operator needed, no unwrap, no panic.

effect Fail<E> {
    fn fail(error: E) -> !,  // never returns (handled by resumption)
}

// Division that might fail — no Result needed
fn safe_divide(a: f64, b: f64) ~ Fail<str> -> f64 {
    if b == 0.0 {
        perform Fail.fail("division by zero")
    } else {
        a / b
    }
}

// Compose effectful functions naturally — no ? chains
fn compute(x: f64, y: f64, z: f64) ~ Fail<str> -> f64 {
    let a = safe_divide(x, y);   // no ? needed!
    let b = safe_divide(a, z);   // just call it
    a + b
}

fn main() {
    // Handle errors at the boundary
    handle {
        let result = compute(100.0, 5.0, 2.0);
        println!("Result: {}", result);
    } with {
        Fail.fail(error) => |_resume| {
            println!("Error: {}", error);
        },
    }
}
