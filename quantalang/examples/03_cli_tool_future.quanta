/// Example: File Processing CLI
/// A command-line tool that processes text files

use std::env;
use std::io::{File, Read, Write, BufReader, BufRead};
use std::path::Path;
use std::collections::HashMap;

#[derive(Debug)]
enum Command {
    Count,
    Stats,
    Search { pattern: String },
    Replace { from: String, to: String },
    Head { lines: usize },
    Tail { lines: usize },
    Help,
}

fn main() -> Result<(), Box<dyn std::error::Error>> {
    let args: Vec<String> = env::args().collect();
    
    if args.len() < 2 {
        print_usage(&args[0]);
        return Ok(());
    }
    
    let command = parse_command(&args[1..]);
    
    match command {
        Command::Help => print_usage(&args[0]),
        Command::Count => count_files(&args[2..])?,
        Command::Stats => file_stats(&args[2..])?,
        Command::Search { pattern } => search_files(&pattern, &args[3..])?,
        Command::Replace { from, to } => replace_in_files(&from, &to, &args[4..])?,
        Command::Head { lines } => head_files(lines, &args[3..])?,
        Command::Tail { lines } => tail_files(lines, &args[3..])?,
    }
    
    Ok(())
}

fn parse_command(args: &[String]) -> Command {
    match args.get(0).map(|s| s.as_str()) {
        Some("count") => Command::Count,
        Some("stats") => Command::Stats,
        Some("search") => Command::Search {
            pattern: args.get(1).cloned().unwrap_or_default(),
        },
        Some("replace") => Command::Replace {
            from: args.get(1).cloned().unwrap_or_default(),
            to: args.get(2).cloned().unwrap_or_default(),
        },
        Some("head") => Command::Head {
            lines: args.get(1).and_then(|s| s.parse().ok()).unwrap_or(10),
        },
        Some("tail") => Command::Tail {
            lines: args.get(1).and_then(|s| s.parse().ok()).unwrap_or(10),
        },
        _ => Command::Help,
    }
}

fn print_usage(program: &str) {
    println!("File Processing CLI");
    println!();
    println!("Usage: {} <command> [options] <files...>", program);
    println!();
    println!("Commands:");
    println!("  count                    Count lines, words, and characters");
    println!("  stats                    Show detailed file statistics");
    println!("  search <pattern>         Search for pattern in files");
    println!("  replace <from> <to>      Replace text in files");
    println!("  head <n>                 Show first n lines (default: 10)");
    println!("  tail <n>                 Show last n lines (default: 10)");
    println!("  help                     Show this help message");
    println!();
    println!("Examples:");
    println!("  {} count *.txt", program);
    println!("  {} search \"error\" log.txt", program);
    println!("  {} replace \"foo\" \"bar\" config.txt", program);
}

fn count_files(files: &[String]) -> Result<(), Box<dyn std::error::Error>> {
    let mut total_lines = 0;
    let mut total_words = 0;
    let mut total_chars = 0;
    
    println!("{:>8} {:>8} {:>8}  {}", "lines", "words", "chars", "file");
    println!("{}", "-".repeat(50));
    
    for filename in files {
        let content = std::io::read_to_string(filename)?;
        
        let lines = content.lines().count();
        let words = content.split_whitespace().count();
        let chars = content.len();
        
        println!("{:>8} {:>8} {:>8}  {}", lines, words, chars, filename);
        
        total_lines += lines;
        total_words += words;
        total_chars += chars;
    }
    
    if files.len() > 1 {
        println!("{}", "-".repeat(50));
        println!("{:>8} {:>8} {:>8}  total", total_lines, total_words, total_chars);
    }
    
    Ok(())
}

fn file_stats(files: &[String]) -> Result<(), Box<dyn std::error::Error>> {
    for filename in files {
        println!("=== {} ===", filename);
        
        let content = std::io::read_to_string(filename)?;
        let lines: Vec<&str> = content.lines().collect();
        
        // Basic counts
        let line_count = lines.len();
        let word_count = content.split_whitespace().count();
        let char_count = content.len();
        let byte_count = content.as_bytes().len();
        
        // Line length statistics
        let line_lengths: Vec<usize> = lines.iter().map(|l| l.len()).collect();
        let avg_line_len = if !lines.is_empty() {
            line_lengths.iter().sum::<usize>() / lines.len()
        } else { 0 };
        let max_line_len = line_lengths.iter().max().copied().unwrap_or(0);
        let min_line_len = line_lengths.iter().min().copied().unwrap_or(0);
        
        // Word frequency
        let mut word_freq: HashMap<String, usize> = HashMap::new();
        for word in content.split_whitespace() {
            let word = word.to_lowercase();
            *word_freq.entry(word).or_insert(0) += 1;
        }
        
        // Top words
        let mut words: Vec<_> = word_freq.into_iter().collect();
        words.sort_by(|a, b| b.1.cmp(&a.1));
        let top_words: Vec<_> = words.into_iter().take(5).collect();
        
        // Empty lines
        let empty_lines = lines.iter().filter(|l| l.trim().is_empty()).count();
        
        println!("  Lines:          {}", line_count);
        println!("  Words:          {}", word_count);
        println!("  Characters:     {}", char_count);
        println!("  Bytes:          {}", byte_count);
        println!("  Empty lines:    {}", empty_lines);
        println!("  Avg line len:   {}", avg_line_len);
        println!("  Max line len:   {}", max_line_len);
        println!("  Min line len:   {}", min_line_len);
        println!("  Top words:");
        for (word, count) in top_words {
            println!("    {:>12}: {}", word, count);
        }
        println!();
    }
    
    Ok(())
}

fn search_files(pattern: &str, files: &[String]) -> Result<(), Box<dyn std::error::Error>> {
    let mut total_matches = 0;
    
    for filename in files {
        let file = File::open(filename)?;
        let reader = BufReader::new(file);
        
        for (line_num, line) in reader.lines().enumerate() {
            let line = line?;
            if line.contains(pattern) {
                println!("{}:{}: {}", filename, line_num + 1, line);
                total_matches += 1;
            }
        }
    }
    
    println!();
    println!("Found {} matches", total_matches);
    
    Ok(())
}

fn replace_in_files(from: &str, to: &str, files: &[String]) -> Result<(), Box<dyn std::error::Error>> {
    for filename in files {
        let content = std::io::read_to_string(filename)?;
        let count = content.matches(from).count();
        
        if count > 0 {
            let new_content = content.replace(from, to);
            let mut file = File::create(filename)?;
            file.write_all(new_content.as_bytes())?;
            println!("{}: {} replacements", filename, count);
        } else {
            println!("{}: no matches", filename);
        }
    }
    
    Ok(())
}

fn head_files(n: usize, files: &[String]) -> Result<(), Box<dyn std::error::Error>> {
    for (i, filename) in files.iter().enumerate() {
        if files.len() > 1 {
            if i > 0 { println!(); }
            println!("==> {} <==", filename);
        }
        
        let file = File::open(filename)?;
        let reader = BufReader::new(file);
        
        for line in reader.lines().take(n) {
            println!("{}", line?);
        }
    }
    
    Ok(())
}

fn tail_files(n: usize, files: &[String]) -> Result<(), Box<dyn std::error::Error>> {
    for (i, filename) in files.iter().enumerate() {
        if files.len() > 1 {
            if i > 0 { println!(); }
            println!("==> {} <==", filename);
        }
        
        let content = std::io::read_to_string(filename)?;
        let lines: Vec<&str> = content.lines().collect();
        let start = lines.len().saturating_sub(n);
        
        for line in &lines[start..] {
            println!("{}", line);
        }
    }
    
    Ok(())
}
