//
// Time handling:
// - Duration (time span)
// - Instant (monotonic clock)
// - SystemTime (wall clock)
//
// ═══════════════════════════════════════════════════════════════════════════════

module std::time

pub use core::time::Duration;

use core::ops::{Add, Sub, AddAssign, SubAssign};
use core::fmt;
use crate::io::{self, Error, ErrorKind};

// ═══════════════════════════════════════════════════════════════════════════════
// INSTANT (MONOTONIC CLOCK)
// ═══════════════════════════════════════════════════════════════════════════════

/// A measurement of a monotonically increasing clock
#[derive(Clone, Copy, PartialEq, Eq, PartialOrd, Ord, Hash)]
pub struct Instant {
    inner: crate::sys::Instant,
}

impl Instant {
    /// Returns an instant corresponding to "now"
    pub fn now() -> Instant {
        Instant {
            inner: crate::sys::Instant::now(),
        }
    }
    
    /// Returns the duration since this instant
    pub fn elapsed(&self) -> Duration {
        Instant::now().duration_since(*self)
    }
    
    /// Returns the duration since an earlier instant
    pub fn duration_since(&self, earlier: Instant) -> Duration {
        self.inner.duration_since(&earlier.inner)
    }
    
    /// Returns the duration since an earlier instant, or None if earlier is later
    pub fn checked_duration_since(&self, earlier: Instant) -> Option<Duration> {
        self.inner.checked_duration_since(&earlier.inner)
    }
    
    /// Returns the duration since an earlier instant, saturating at zero
    pub fn saturating_duration_since(&self, earlier: Instant) -> Duration {
        self.checked_duration_since(earlier).unwrap_or(Duration::ZERO)
    }
    
    /// Returns an instant with the given duration added
    pub fn checked_add(&self, duration: Duration) -> Option<Instant> {
        self.inner.checked_add(duration).map(|inner| Instant { inner })
    }
    
    /// Returns an instant with the given duration subtracted
    pub fn checked_sub(&self, duration: Duration) -> Option<Instant> {
        self.inner.checked_sub(duration).map(|inner| Instant { inner })
    }
}

impl Add<Duration> for Instant {
    type Output = Instant;
    
    fn add(self, other: Duration) -> Instant {
        self.checked_add(other).expect("overflow when adding duration to instant")
    }
}

impl AddAssign<Duration> for Instant {
    fn add_assign(&mut self, other: Duration) {
        *self = *self + other;
    }
}

impl Sub<Duration> for Instant {
    type Output = Instant;
    
    fn sub(self, other: Duration) -> Instant {
        self.checked_sub(other).expect("overflow when subtracting duration from instant")
    }
}

impl SubAssign<Duration> for Instant {
    fn sub_assign(&mut self, other: Duration) {
        *self = *self - other;
    }
}

impl Sub<Instant> for Instant {
    type Output = Duration;
    
    fn sub(self, other: Instant) -> Duration {
        self.duration_since(other)
    }
}

impl fmt::Debug for Instant {
    fn fmt(&self, f: &mut fmt::Formatter<'_>) -> fmt::Result {
        self.inner.fmt(f)
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// SYSTEM TIME (WALL CLOCK)
// ═══════════════════════════════════════════════════════════════════════════════

/// A measurement of the system clock
#[derive(Clone, Copy, PartialEq, Eq, PartialOrd, Ord, Hash)]
pub struct SystemTime {
    inner: crate::sys::SystemTime,
}

impl SystemTime {
    /// The Unix epoch (January 1, 1970 00:00:00 UTC)
    pub const UNIX_EPOCH: SystemTime = SystemTime {
        inner: crate::sys::SystemTime::UNIX_EPOCH,
    };
    
    /// Returns the system time corresponding to "now"
    pub fn now() -> SystemTime {
        SystemTime {
            inner: crate::sys::SystemTime::now(),
        }
    }
    
    /// Returns the duration since this time
    pub fn elapsed(&self) -> io::Result<Duration> {
        SystemTime::now().duration_since(*self)
    }
    
    /// Returns the duration since an earlier time
    pub fn duration_since(&self, earlier: SystemTime) -> io::Result<Duration> {
        self.inner.duration_since(&earlier.inner)
            .map_err(|e| Error::new(ErrorKind::Other, "time went backwards"))
    }
    
    /// Returns a time with the given duration added
    pub fn checked_add(&self, duration: Duration) -> Option<SystemTime> {
        self.inner.checked_add(duration).map(|inner| SystemTime { inner })
    }
    
    /// Returns a time with the given duration subtracted
    pub fn checked_sub(&self, duration: Duration) -> Option<SystemTime> {
        self.inner.checked_sub(duration).map(|inner| SystemTime { inner })
    }
}

impl Add<Duration> for SystemTime {
    type Output = SystemTime;
    
    fn add(self, other: Duration) -> SystemTime {
        self.checked_add(other).expect("overflow when adding duration to system time")
    }
}

impl AddAssign<Duration> for SystemTime {
    fn add_assign(&mut self, other: Duration) {
        *self = *self + other;
    }
}

impl Sub<Duration> for SystemTime {
    type Output = SystemTime;
    
    fn sub(self, other: Duration) -> SystemTime {
        self.checked_sub(other).expect("overflow when subtracting duration from system time")
    }
}

impl SubAssign<Duration> for SystemTime {
    fn sub_assign(&mut self, other: Duration) {
        *self = *self - other;
    }
}

impl fmt::Debug for SystemTime {
    fn fmt(&self, f: &mut fmt::Formatter<'_>) -> fmt::Result {
        self.inner.fmt(f)
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// SYSTEM TIME ERROR
// ═══════════════════════════════════════════════════════════════════════════════

/// Error returned when system time goes backwards
#[derive(Clone, Debug)]
pub struct SystemTimeError {
    pub(crate) duration: Duration,
}

impl SystemTimeError {
    /// Returns the positive duration which represents how far the time went backwards
    pub fn duration(&self) -> Duration {
        self.duration
    }
}

impl fmt::Display for SystemTimeError {
    fn fmt(&self, f: &mut fmt::Formatter<'_>) -> fmt::Result {
        write!(f, "second time provided was later than first")
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// DURATION EXTENSIONS
// ═══════════════════════════════════════════════════════════════════════════════

/// Extension trait for Duration
pub trait DurationExt {
    /// Create a duration from hours
    fn from_hours(hours: u64) -> Self;
    
    /// Create a duration from minutes
    fn from_minutes(mins: u64) -> Self;
    
    /// Create a duration from days
    fn from_days(days: u64) -> Self;
    
    /// Get total hours
    fn as_hours(&self) -> u64;
    
    /// Get total minutes
    fn as_minutes(&self) -> u64;
    
    /// Get total days
    fn as_days(&self) -> u64;
}

impl DurationExt for Duration {
    fn from_hours(hours: u64) -> Self {
        Duration::from_secs(hours * 3600)
    }
    
    fn from_minutes(mins: u64) -> Self {
        Duration::from_secs(mins * 60)
    }
    
    fn from_days(days: u64) -> Self {
        Duration::from_secs(days * 86400)
    }
    
    fn as_hours(&self) -> u64 {
        self.as_secs() / 3600
    }
    
    fn as_minutes(&self) -> u64 {
        self.as_secs() / 60
    }
    
    fn as_days(&self) -> u64 {
        self.as_secs() / 86400
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// TESTS
// ═══════════════════════════════════════════════════════════════════════════════

#[cfg(test)]
mod tests {
    use super::*;
    
    #[test]
    fn test_instant_elapsed() {
        let start = Instant::now();
        // Do some work
        for _ in 0..1000 {}
        let elapsed = start.elapsed();
        // Elapsed time should be non-negative
        assert!(elapsed >= Duration::ZERO);
    }
    
    #[test]
    fn test_duration_arithmetic() {
        let d1 = Duration::from_secs(5);
        let d2 = Duration::from_secs(3);
        
        assert_eq!(d1 + d2, Duration::from_secs(8));
        assert_eq!(d1 - d2, Duration::from_secs(2));
        assert_eq!(d1 * 2, Duration::from_secs(10));
        assert_eq!(d1 / 5, Duration::from_secs(1));
    }
    
    #[test]
    fn test_system_time() {
        let now = SystemTime::now();
        let unix_epoch = SystemTime::UNIX_EPOCH;
        
        // Current time should be after Unix epoch
        assert!(now > unix_epoch);
        
        // Duration since epoch should be positive
        let since_epoch = now.duration_since(unix_epoch).unwrap();
        assert!(since_epoch > Duration::ZERO);
    }
    
    #[test]
    fn test_instant_ordering() {
        let t1 = Instant::now();
        let t2 = Instant::now();
        
        assert!(t2 >= t1);
    }
}
