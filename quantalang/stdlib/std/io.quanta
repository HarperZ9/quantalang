module std::io

use alloc::string::String;
use alloc::vec::Vec;
use alloc::boxed::Box;
use core::fmt;
use crate::error::Error as StdError;

// ═══════════════════════════════════════════════════════════════════════════════
// RESULT & ERROR
// ═══════════════════════════════════════════════════════════════════════════════

/// I/O Result type
pub type Result<T> = core::result::Result<T, Error>;

/// I/O Error
#[derive(Debug)]
pub struct Error {
    kind: ErrorKind,
    message: Option<String>,
    source: Option<Box<dyn StdError + Send + Sync>>,
}

/// I/O Error kinds
#[derive(Debug, Clone, Copy, PartialEq, Eq)]
#[non_exhaustive]
pub enum ErrorKind {
    /// File or resource not found
    NotFound,
    /// Permission denied
    PermissionDenied,
    /// Connection refused
    ConnectionRefused,
    /// Connection reset
    ConnectionReset,
    /// Connection aborted
    ConnectionAborted,
    /// Not connected
    NotConnected,
    /// Address in use
    AddrInUse,
    /// Address not available
    AddrNotAvailable,
    /// Broken pipe
    BrokenPipe,
    /// Resource already exists
    AlreadyExists,
    /// Invalid input data
    InvalidInput,
    /// Invalid data
    InvalidData,
    /// Operation timed out
    TimedOut,
    /// Write zero bytes
    WriteZero,
    /// Interrupted
    Interrupted,
    /// Unexpected end of file
    UnexpectedEof,
    /// Would block
    WouldBlock,
    /// Out of memory
    OutOfMemory,
    /// Other error
    Other,
    /// Uncategorized error
    Uncategorized,
}

impl Error {
    /// Create a new I/O error
    pub fn new(kind: ErrorKind, message: impl Into<String>) -> Self {
        Error {
            kind,
            message: Some(message.into()),
            source: None,
        }
    }
    
    /// Create an error from a kind
    pub fn from_kind(kind: ErrorKind) -> Self {
        Error {
            kind,
            message: None,
            source: None,
        }
    }
    
    /// Create an error from raw OS error code
    pub fn from_raw_os_error(code: i32) -> Self {
        let kind = match code {
            2 => ErrorKind::NotFound,           // ENOENT
            13 => ErrorKind::PermissionDenied,  // EACCES
            17 => ErrorKind::AlreadyExists,     // EEXIST
            22 => ErrorKind::InvalidInput,      // EINVAL
            32 => ErrorKind::BrokenPipe,        // EPIPE
            104 => ErrorKind::ConnectionReset,  // ECONNRESET
            111 => ErrorKind::ConnectionRefused, // ECONNREFUSED
            _ => ErrorKind::Other,
        };
        Error {
            kind,
            message: Some(format!("OS error {}", code)),
            source: None,
        }
    }
    
    /// Get the error kind
    pub fn kind(&self) -> ErrorKind {
        self.kind
    }
    
    /// Get the raw OS error code, if any
    pub fn raw_os_error(&self) -> Option<i32> {
        None // Simplified
    }
    
    /// Returns a reference to the inner error wrapped by this error (if any)
    pub fn get_ref(&self) -> Option<&(dyn StdError + Send + Sync + 'static)> {
        self.source.as_ref().map(|e| e.as_ref())
    }
    
    /// Consumes the error, returning the inner error (if any)
    pub fn into_inner(self) -> Option<Box<dyn StdError + Send + Sync>> {
        self.source
    }
}

impl fmt::Display for Error {
    fn fmt(&self, f: &mut fmt::Formatter<'_>) -> fmt::Result {
        if let Some(ref msg) = self.message {
            write!(f, "{}", msg)
        } else {
            write!(f, "{:?}", self.kind)
        }
    }
}

impl StdError for Error {
    fn source(&self) -> Option<&(dyn StdError + 'static)> {
        self.source.as_ref().map(|e| e.as_ref() as &(dyn StdError + 'static))
    }
}

impl From<ErrorKind> for Error {
    fn from(kind: ErrorKind) -> Self {
        Error::from_kind(kind)
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// READ TRAIT
// ═══════════════════════════════════════════════════════════════════════════════

/// Read bytes from a source
pub trait Read {
    /// Read bytes into a buffer
    fn read(&mut self, buf: &mut [u8]) -> Result<usize>;
    
    /// Read the exact number of bytes to fill the buffer
    fn read_exact(&mut self, mut buf: &mut [u8]) -> Result<()> {
        while !buf.is_empty() {
            match self.read(buf) {
                Ok(0) => return Err(Error::from_kind(ErrorKind::UnexpectedEof)),
                Ok(n) => buf = &mut buf[n..],
                Err(ref e) if e.kind() == ErrorKind::Interrupted => {}
                Err(e) => return Err(e),
            }
        }
        Ok(())
    }
    
    /// Read all bytes to end of stream
    fn read_to_end(&mut self, buf: &mut Vec<u8>) -> Result<usize> {
        let mut total = 0;
        let mut chunk = [0u8; 4096];
        
        loop {
            match self.read(&mut chunk) {
                Ok(0) => return Ok(total),
                Ok(n) => {
                    buf.extend_from_slice(&chunk[..n]);
                    total += n;
                }
                Err(ref e) if e.kind() == ErrorKind::Interrupted => {}
                Err(e) => return Err(e),
            }
        }
    }
    
    /// Read all bytes into a string
    fn read_to_string(&mut self, buf: &mut String) -> Result<usize> {
        let mut bytes = Vec::new();
        let n = self.read_to_end(&mut bytes)?;
        
        match String::from_utf8(bytes) {
            Ok(s) => {
                buf.push_str(&s);
                Ok(n)
            }
            Err(_) => Err(Error::new(ErrorKind::InvalidData, "invalid UTF-8")),
        }
    }
    
    /// Create a buffered reader
    fn buffered(self) -> BufReader<Self>
    where
        Self: Sized,
    {
        BufReader::new(self)
    }
    
    /// Create a "by reference" adapter
    fn by_ref(&mut self) -> &mut Self {
        self
    }
    
    /// Read a single byte
    fn read_u8(&mut self) -> Result<u8> {
        let mut buf = [0u8; 1];
        self.read_exact(&mut buf)?;
        Ok(buf[0])
    }
    
    /// Read a little-endian u16
    fn read_u16_le(&mut self) -> Result<u16> {
        let mut buf = [0u8; 2];
        self.read_exact(&mut buf)?;
        Ok(u16::from_le_bytes(buf))
    }
    
    /// Read a little-endian u32
    fn read_u32_le(&mut self) -> Result<u32> {
        let mut buf = [0u8; 4];
        self.read_exact(&mut buf)?;
        Ok(u32::from_le_bytes(buf))
    }
    
    /// Read a little-endian u64
    fn read_u64_le(&mut self) -> Result<u64> {
        let mut buf = [0u8; 8];
        self.read_exact(&mut buf)?;
        Ok(u64::from_le_bytes(buf))
    }
    
    /// Chain with another reader
    fn chain<R: Read>(self, next: R) -> Chain<Self, R>
    where
        Self: Sized,
    {
        Chain { first: self, second: next, done_first: false }
    }
    
    /// Take at most n bytes
    fn take(self, limit: u64) -> Take<Self>
    where
        Self: Sized,
    {
        Take { inner: self, limit }
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// WRITE TRAIT
// ═══════════════════════════════════════════════════════════════════════════════

/// Write bytes to a sink
pub trait Write {
    /// Write a buffer
    fn write(&mut self, buf: &[u8]) -> Result<usize>;
    
    /// Flush buffered data
    fn flush(&mut self) -> Result<()>;
    
    /// Write all bytes
    fn write_all(&mut self, mut buf: &[u8]) -> Result<()> {
        while !buf.is_empty() {
            match self.write(buf) {
                Ok(0) => return Err(Error::from_kind(ErrorKind::WriteZero)),
                Ok(n) => buf = &buf[n..],
                Err(ref e) if e.kind() == ErrorKind::Interrupted => {}
                Err(e) => return Err(e),
            }
        }
        Ok(())
    }
    
    /// Write a formatted string
    fn write_fmt(&mut self, fmt: fmt::Arguments<'_>) -> Result<()> {
        // Use a helper struct
        struct Adapter<'a, T: Write + ?Sized>(&'a mut T);
        
        impl<T: Write + ?Sized> fmt::Write for Adapter<'_, T> {
            fn write_str(&mut self, s: &str) -> fmt::Result {
                self.0.write_all(s.as_bytes()).map_err(|_| fmt::Error)
            }
        }
        
        fmt::write(&mut Adapter(self), fmt).map_err(|_| Error::from_kind(ErrorKind::Other))
    }
    
    /// Create a buffered writer
    fn buffered(self) -> BufWriter<Self>
    where
        Self: Sized,
    {
        BufWriter::new(self)
    }
    
    /// Create a "by reference" adapter
    fn by_ref(&mut self) -> &mut Self {
        self
    }
    
    /// Write a single byte
    fn write_u8(&mut self, value: u8) -> Result<()> {
        self.write_all(&[value])
    }
    
    /// Write a little-endian u16
    fn write_u16_le(&mut self, value: u16) -> Result<()> {
        self.write_all(&value.to_le_bytes())
    }
    
    /// Write a little-endian u32
    fn write_u32_le(&mut self, value: u32) -> Result<()> {
        self.write_all(&value.to_le_bytes())
    }
    
    /// Write a little-endian u64
    fn write_u64_le(&mut self, value: u64) -> Result<()> {
        self.write_all(&value.to_le_bytes())
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// BUFREAD TRAIT
// ═══════════════════════════════════════════════════════════════════════════════

/// Buffered reading
pub trait BufRead: Read {
    /// Fill the internal buffer
    fn fill_buf(&mut self) -> Result<&[u8]>;
    
    /// Consume bytes from the buffer
    fn consume(&mut self, amt: usize);
    
    /// Read until a delimiter
    fn read_until(&mut self, delim: u8, buf: &mut Vec<u8>) -> Result<usize> {
        let mut total = 0;
        
        loop {
            let (done, used) = {
                let available = self.fill_buf()?;
                if available.is_empty() {
                    return Ok(total);
                }
                
                match available.iter().position(|&b| b == delim) {
                    Some(i) => {
                        buf.extend_from_slice(&available[..=i]);
                        (true, i + 1)
                    }
                    None => {
                        buf.extend_from_slice(available);
                        (false, available.len())
                    }
                }
            };
            
            self.consume(used);
            total += used;
            
            if done {
                return Ok(total);
            }
        }
    }
    
    /// Read a line
    fn read_line(&mut self, buf: &mut String) -> Result<usize> {
        let mut bytes = Vec::new();
        let n = self.read_until(b'\n', &mut bytes)?;
        
        match String::from_utf8(bytes) {
            Ok(s) => {
                buf.push_str(&s);
                Ok(n)
            }
            Err(_) => Err(Error::new(ErrorKind::InvalidData, "invalid UTF-8")),
        }
    }
    
    /// Split by delimiter
    fn split(self, delim: u8) -> Split<Self>
    where
        Self: Sized,
    {
        Split { reader: self, delim }
    }
    
    /// Iterate over lines
    fn lines(self) -> Lines<Self>
    where
        Self: Sized,
    {
        Lines { reader: self }
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// SEEK TRAIT
// ═══════════════════════════════════════════════════════════════════════════════

/// Seek within a stream
pub trait Seek {
    /// Seek to a position
    fn seek(&mut self, pos: SeekFrom) -> Result<u64>;
    
    /// Rewind to the beginning
    fn rewind(&mut self) -> Result<()> {
        self.seek(SeekFrom::Start(0))?;
        Ok(())
    }
    
    /// Get current position
    fn stream_position(&mut self) -> Result<u64> {
        self.seek(SeekFrom::Current(0))
    }
    
    /// Get stream length
    fn stream_len(&mut self) -> Result<u64> {
        let old_pos = self.stream_position()?;
        let len = self.seek(SeekFrom::End(0))?;
        if old_pos != len {
            self.seek(SeekFrom::Start(old_pos))?;
        }
        Ok(len)
    }
}

/// Seek position
#[derive(Debug, Clone, Copy, PartialEq, Eq)]
pub enum SeekFrom {
    /// Seek from the beginning
    Start(u64),
    /// Seek from the end
    End(i64),
    /// Seek from current position
    Current(i64),
}

// ═══════════════════════════════════════════════════════════════════════════════
// BUFFERED READER
// ═══════════════════════════════════════════════════════════════════════════════

/// Buffered reader
pub struct BufReader<R> {
    inner: R,
    buf: Vec<u8>,
    pos: usize,
    cap: usize,
}

impl<R: Read> BufReader<R> {
    /// Create a new buffered reader
    pub fn new(inner: R) -> Self {
        BufReader::with_capacity(8192, inner)
    }
    
    /// Create with specific capacity
    pub fn with_capacity(capacity: usize, inner: R) -> Self {
        let mut buf = Vec::with_capacity(capacity);
        buf.resize(capacity, 0);
        BufReader {
            inner,
            buf,
            pos: 0,
            cap: 0,
        }
    }
    
    /// Get a reference to the inner reader
    pub fn get_ref(&self) -> &R {
        &self.inner
    }
    
    /// Get a mutable reference to the inner reader
    pub fn get_mut(&mut self) -> &mut R {
        &mut self.inner
    }
    
    /// Get the buffer contents
    pub fn buffer(&self) -> &[u8] {
        &self.buf[self.pos..self.cap]
    }
    
    /// Get remaining buffer capacity
    pub fn capacity(&self) -> usize {
        self.buf.len()
    }
    
    /// Consume the reader, returning the inner reader
    pub fn into_inner(self) -> R {
        self.inner
    }
}

impl<R: Read> Read for BufReader<R> {
    fn read(&mut self, buf: &mut [u8]) -> Result<usize> {
        // If buffer is empty, fill it
        if self.pos >= self.cap {
            if buf.len() >= self.buf.len() {
                // Read directly into output buffer
                return self.inner.read(buf);
            }
            
            self.cap = self.inner.read(&mut self.buf)?;
            self.pos = 0;
        }
        
        // Copy from buffer
        let n = core::cmp::min(buf.len(), self.cap - self.pos);
        buf[..n].copy_from_slice(&self.buf[self.pos..self.pos + n]);
        self.pos += n;
        Ok(n)
    }
}

impl<R: Read> BufRead for BufReader<R> {
    fn fill_buf(&mut self) -> Result<&[u8]> {
        if self.pos >= self.cap {
            self.cap = self.inner.read(&mut self.buf)?;
            self.pos = 0;
        }
        Ok(&self.buf[self.pos..self.cap])
    }
    
    fn consume(&mut self, amt: usize) {
        self.pos = core::cmp::min(self.pos + amt, self.cap);
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// BUFFERED WRITER
// ═══════════════════════════════════════════════════════════════════════════════

/// Buffered writer
pub struct BufWriter<W: Write> {
    inner: W,
    buf: Vec<u8>,
    panicked: bool,
}

impl<W: Write> BufWriter<W> {
    /// Create a new buffered writer
    pub fn new(inner: W) -> Self {
        BufWriter::with_capacity(8192, inner)
    }
    
    /// Create with specific capacity
    pub fn with_capacity(capacity: usize, inner: W) -> Self {
        BufWriter {
            inner,
            buf: Vec::with_capacity(capacity),
            panicked: false,
        }
    }
    
    /// Get a reference to the inner writer
    pub fn get_ref(&self) -> &W {
        &self.inner
    }
    
    /// Get a mutable reference to the inner writer
    pub fn get_mut(&mut self) -> &mut W {
        &mut self.inner
    }
    
    /// Get the buffer contents
    pub fn buffer(&self) -> &[u8] {
        &self.buf
    }
    
    /// Get buffer capacity
    pub fn capacity(&self) -> usize {
        self.buf.capacity()
    }
    
    /// Consume the writer, returning the inner writer
    pub fn into_inner(mut self) -> Result<W> {
        self.flush()?;
        Ok(self.inner)
    }
    
    fn flush_buf(&mut self) -> Result<()> {
        let mut written = 0;
        let len = self.buf.len();
        
        while written < len {
            self.panicked = true;
            let r = self.inner.write(&self.buf[written..]);
            self.panicked = false;
            
            match r {
                Ok(0) => return Err(Error::from_kind(ErrorKind::WriteZero)),
                Ok(n) => written += n,
                Err(ref e) if e.kind() == ErrorKind::Interrupted => {}
                Err(e) => return Err(e),
            }
        }
        
        self.buf.clear();
        Ok(())
    }
}

impl<W: Write> Write for BufWriter<W> {
    fn write(&mut self, buf: &[u8]) -> Result<usize> {
        if self.buf.len() + buf.len() > self.buf.capacity() {
            self.flush_buf()?;
        }
        
        if buf.len() >= self.buf.capacity() {
            self.panicked = true;
            let r = self.inner.write(buf);
            self.panicked = false;
            r
        } else {
            self.buf.extend_from_slice(buf);
            Ok(buf.len())
        }
    }
    
    fn flush(&mut self) -> Result<()> {
        self.flush_buf()?;
        self.inner.flush()
    }
}

impl<W: Write> Drop for BufWriter<W> {
    fn drop(&mut self) {
        if !self.panicked {
            let _ = self.flush_buf();
        }
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// CURSOR
// ═══════════════════════════════════════════════════════════════════════════════

/// In-memory buffer cursor
pub struct Cursor<T> {
    inner: T,
    pos: u64,
}

impl<T> Cursor<T> {
    /// Create a new cursor
    pub fn new(inner: T) -> Self {
        Cursor { inner, pos: 0 }
    }
    
    /// Get a reference to the inner value
    pub fn get_ref(&self) -> &T {
        &self.inner
    }
    
    /// Get a mutable reference to the inner value
    pub fn get_mut(&mut self) -> &mut T {
        &mut self.inner
    }
    
    /// Get current position
    pub fn position(&self) -> u64 {
        self.pos
    }
    
    /// Set current position
    pub fn set_position(&mut self, pos: u64) {
        self.pos = pos;
    }
    
    /// Consume the cursor, returning the inner value
    pub fn into_inner(self) -> T {
        self.inner
    }
}

impl<T: AsRef<[u8]>> Read for Cursor<T> {
    fn read(&mut self, buf: &mut [u8]) -> Result<usize> {
        let slice = self.inner.as_ref();
        let pos = self.pos as usize;
        
        if pos >= slice.len() {
            return Ok(0);
        }
        
        let remaining = &slice[pos..];
        let n = core::cmp::min(buf.len(), remaining.len());
        buf[..n].copy_from_slice(&remaining[..n]);
        self.pos += n as u64;
        Ok(n)
    }
}

impl Write for Cursor<Vec<u8>> {
    fn write(&mut self, buf: &[u8]) -> Result<usize> {
        let pos = self.pos as usize;
        
        // Extend if necessary
        if pos + buf.len() > self.inner.len() {
            self.inner.resize(pos + buf.len(), 0);
        }
        
        self.inner[pos..pos + buf.len()].copy_from_slice(buf);
        self.pos += buf.len() as u64;
        Ok(buf.len())
    }
    
    fn flush(&mut self) -> Result<()> {
        Ok(())
    }
}

impl<T: AsRef<[u8]>> Seek for Cursor<T> {
    fn seek(&mut self, pos: SeekFrom) -> Result<u64> {
        let (base, offset) = match pos {
            SeekFrom::Start(n) => {
                self.pos = n;
                return Ok(n);
            }
            SeekFrom::End(n) => (self.inner.as_ref().len() as u64, n),
            SeekFrom::Current(n) => (self.pos, n),
        };
        
        let new_pos = if offset >= 0 {
            base.checked_add(offset as u64)
        } else {
            base.checked_sub((-offset) as u64)
        };
        
        match new_pos {
            Some(n) => {
                self.pos = n;
                Ok(n)
            }
            None => Err(Error::new(ErrorKind::InvalidInput, "invalid seek")),
        }
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// ADAPTER TYPES
// ═══════════════════════════════════════════════════════════════════════════════

/// Chain two readers
pub struct Chain<T, U> {
    first: T,
    second: U,
    done_first: bool,
}

impl<T: Read, U: Read> Read for Chain<T, U> {
    fn read(&mut self, buf: &mut [u8]) -> Result<usize> {
        if !self.done_first {
            match self.first.read(buf)? {
                0 => self.done_first = true,
                n => return Ok(n),
            }
        }
        self.second.read(buf)
    }
}

/// Take at most n bytes
pub struct Take<T> {
    inner: T,
    limit: u64,
}

impl<T: Read> Read for Take<T> {
    fn read(&mut self, buf: &mut [u8]) -> Result<usize> {
        if self.limit == 0 {
            return Ok(0);
        }
        
        let max = core::cmp::min(buf.len() as u64, self.limit) as usize;
        let n = self.inner.read(&mut buf[..max])?;
        self.limit -= n as u64;
        Ok(n)
    }
}

impl<T> Take<T> {
    /// Get remaining limit
    pub fn limit(&self) -> u64 {
        self.limit
    }
    
    /// Set limit
    pub fn set_limit(&mut self, limit: u64) {
        self.limit = limit;
    }
}

/// Split by delimiter iterator
pub struct Split<B> {
    reader: B,
    delim: u8,
}

impl<B: BufRead> Iterator for Split<B> {
    type Item = Result<Vec<u8>>;
    
    fn next(&mut self) -> Option<Self::Item> {
        let mut buf = Vec::new();
        match self.reader.read_until(self.delim, &mut buf) {
            Ok(0) => None,
            Ok(_) => {
                if buf.last() == Some(&self.delim) {
                    buf.pop();
                }
                Some(Ok(buf))
            }
            Err(e) => Some(Err(e)),
        }
    }
}

/// Lines iterator
pub struct Lines<B> {
    reader: B,
}

impl<B: BufRead> Iterator for Lines<B> {
    type Item = Result<String>;
    
    fn next(&mut self) -> Option<Self::Item> {
        let mut buf = String::new();
        match self.reader.read_line(&mut buf) {
            Ok(0) => None,
            Ok(_) => {
                if buf.ends_with('\n') {
                    buf.pop();
                    if buf.ends_with('\r') {
                        buf.pop();
                    }
                }
                Some(Ok(buf))
            }
            Err(e) => Some(Err(e)),
        }
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// STANDARD STREAMS
// ═══════════════════════════════════════════════════════════════════════════════

/// Handle to standard input
pub struct Stdin {
    inner: crate::sys::Stdin,
}

/// Handle to standard output
pub struct Stdout {
    inner: crate::sys::Stdout,
}

/// Handle to standard error
pub struct Stderr {
    inner: crate::sys::Stderr,
}

/// Get standard input
pub fn stdin() -> Stdin {
    Stdin { inner: crate::sys::stdin() }
}

/// Get standard output
pub fn stdout() -> Stdout {
    Stdout { inner: crate::sys::stdout() }
}

/// Get standard error
pub fn stderr() -> Stderr {
    Stderr { inner: crate::sys::stderr() }
}

impl Read for Stdin {
    fn read(&mut self, buf: &mut [u8]) -> Result<usize> {
        self.inner.read(buf)
    }
}

impl Write for Stdout {
    fn write(&mut self, buf: &[u8]) -> Result<usize> {
        self.inner.write(buf)
    }
    
    fn flush(&mut self) -> Result<()> {
        self.inner.flush()
    }
}

impl Write for Stderr {
    fn write(&mut self, buf: &[u8]) -> Result<usize> {
        self.inner.write(buf)
    }
    
    fn flush(&mut self) -> Result<()> {
        self.inner.flush()
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// UTILITY FUNCTIONS
// ═══════════════════════════════════════════════════════════════════════════════

/// Copy from reader to writer
pub fn copy<R: Read + ?Sized, W: Write + ?Sized>(reader: &mut R, writer: &mut W) -> Result<u64> {
    let mut buf = [0u8; 8192];
    let mut total = 0u64;
    
    loop {
        let n = match reader.read(&mut buf) {
            Ok(0) => return Ok(total),
            Ok(n) => n,
            Err(ref e) if e.kind() == ErrorKind::Interrupted => continue,
            Err(e) => return Err(e),
        };
        
        writer.write_all(&buf[..n])?;
        total += n as u64;
    }
}

/// Create an empty reader
pub fn empty() -> Empty {
    Empty
}

/// Create a reader that repeats a byte
pub fn repeat(byte: u8) -> Repeat {
    Repeat { byte }
}

/// Create a sink that discards all data
pub fn sink() -> Sink {
    Sink
}

/// Empty reader
pub struct Empty;

impl Read for Empty {
    fn read(&mut self, _buf: &mut [u8]) -> Result<usize> {
        Ok(0)
    }
}

/// Repeating reader
pub struct Repeat {
    byte: u8,
}

impl Read for Repeat {
    fn read(&mut self, buf: &mut [u8]) -> Result<usize> {
        for b in buf.iter_mut() {
            *b = self.byte;
        }
        Ok(buf.len())
    }
}

/// Sink that discards data
pub struct Sink;

impl Write for Sink {
    fn write(&mut self, buf: &[u8]) -> Result<usize> {
        Ok(buf.len())
    }

    fn flush(&mut self) -> Result<()> {
        Ok(())
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// BYTES ITERATOR
// ═══════════════════════════════════════════════════════════════════════════════

/// Iterator over bytes
pub struct Bytes<R> {
    inner: R,
}

impl<R: Read> Iterator for Bytes<R> {
    type Item = Result<u8>;

    fn next(&mut self) -> Option<Self::Item> {
        let mut buf = [0u8; 1];
        match self.inner.read(&mut buf) {
            Ok(0) => None,
            Ok(_) => Some(Ok(buf[0])),
            Err(e) => Some(Err(e)),
        }
    }
}

/// Extension to get a bytes iterator
impl<R: Read> Read for R {
    fn bytes(self) -> Bytes<Self>
    where
        Self: Sized,
    {
        Bytes { inner: self }
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// LINE WRITER
// ═══════════════════════════════════════════════════════════════════════════════

/// Line-buffered writer that flushes on newlines
pub struct LineWriter<W: Write> {
    inner: BufWriter<W>,
}

impl<W: Write> LineWriter<W> {
    /// Create a new line writer
    pub fn new(inner: W) -> Self {
        LineWriter::with_capacity(1024, inner)
    }

    /// Create with specific capacity
    pub fn with_capacity(capacity: usize, inner: W) -> Self {
        LineWriter {
            inner: BufWriter::with_capacity(capacity, inner),
        }
    }

    /// Get a reference to the inner writer
    pub fn get_ref(&self) -> &W {
        self.inner.get_ref()
    }

    /// Get a mutable reference to the inner writer
    pub fn get_mut(&mut self) -> &mut W {
        self.inner.get_mut()
    }

    /// Consume and return the inner writer
    pub fn into_inner(self) -> Result<W> {
        self.inner.into_inner()
    }
}

impl<W: Write> Write for LineWriter<W> {
    fn write(&mut self, buf: &[u8]) -> Result<usize> {
        // Find the last newline
        let newline_pos = buf.iter().rposition(|&b| b == b'\n');

        match newline_pos {
            Some(pos) => {
                // Write up to and including the newline
                let n = self.inner.write(&buf[..=pos])?;
                self.inner.flush()?;

                // Write the rest
                if pos + 1 < buf.len() {
                    let m = self.inner.write(&buf[pos + 1..])?;
                    Ok(n + m)
                } else {
                    Ok(n)
                }
            }
            None => self.inner.write(buf),
        }
    }

    fn flush(&mut self) -> Result<()> {
        self.inner.flush()
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// TEE READER
// ═══════════════════════════════════════════════════════════════════════════════

/// A reader that writes everything it reads to a writer
pub struct Tee<R, W> {
    reader: R,
    writer: W,
}

impl<R: Read, W: Write> Tee<R, W> {
    /// Create a new tee reader
    pub fn new(reader: R, writer: W) -> Self {
        Tee { reader, writer }
    }

    /// Get references to the inner reader and writer
    pub fn get_ref(&self) -> (&R, &W) {
        (&self.reader, &self.writer)
    }

    /// Get mutable references to the inner reader and writer
    pub fn get_mut(&mut self) -> (&mut R, &mut W) {
        (&mut self.reader, &mut self.writer)
    }

    /// Consume and return the inner reader and writer
    pub fn into_inner(self) -> (R, W) {
        (self.reader, self.writer)
    }
}

impl<R: Read, W: Write> Read for Tee<R, W> {
    fn read(&mut self, buf: &mut [u8]) -> Result<usize> {
        let n = self.reader.read(buf)?;
        if n > 0 {
            self.writer.write_all(&buf[..n])?;
        }
        Ok(n)
    }
}

/// Create a tee reader
pub fn tee<R: Read, W: Write>(reader: R, writer: W) -> Tee<R, W> {
    Tee::new(reader, writer)
}

// ═══════════════════════════════════════════════════════════════════════════════
// READ BUF
// ═══════════════════════════════════════════════════════════════════════════════

/// A wrapper around a byte buffer for efficient reading
///
/// This is similar to Rust's ReadBuf and provides:
/// - Tracking of initialized vs uninitialized portions
/// - Safe filling of uninitialized memory
pub struct ReadBuf<'a> {
    buf: &'a mut [u8],
    /// The portion that has been filled with data
    filled: usize,
    /// The portion that has been initialized
    initialized: usize,
}

impl<'a> ReadBuf<'a> {
    /// Create a new ReadBuf from a fully initialized slice
    pub fn new(buf: &'a mut [u8]) -> Self {
        let len = buf.len();
        ReadBuf {
            buf,
            filled: 0,
            initialized: len,
        }
    }

    /// Create a ReadBuf from an uninitialized slice
    ///
    /// # Safety
    /// The caller must ensure that the buffer is valid for writes.
    pub unsafe fn uninit(buf: &'a mut [core::mem::MaybeUninit<u8>]) -> Self {
        ReadBuf {
            buf: core::slice::from_raw_parts_mut(
                buf.as_mut_ptr() as *mut u8,
                buf.len(),
            ),
            filled: 0,
            initialized: 0,
        }
    }

    /// Get the total capacity of the buffer
    pub fn capacity(&self) -> usize {
        self.buf.len()
    }

    /// Get the filled portion of the buffer
    pub fn filled(&self) -> &[u8] {
        &self.buf[..self.filled]
    }

    /// Get the filled portion as mutable
    pub fn filled_mut(&mut self) -> &mut [u8] {
        &mut self.buf[..self.filled]
    }

    /// Get the unfilled portion that has been initialized
    pub fn initialized_unfilled(&mut self) -> &mut [u8] {
        &mut self.buf[self.filled..self.initialized]
    }

    /// Get the portion that is neither filled nor initialized
    ///
    /// # Safety
    /// The returned slice may contain uninitialized bytes.
    pub unsafe fn unfilled_mut(&mut self) -> &mut [u8] {
        &mut self.buf[self.filled..]
    }

    /// Returns the number of bytes that have been filled
    pub fn len(&self) -> usize {
        self.filled
    }

    /// Returns true if no bytes have been filled
    pub fn is_empty(&self) -> bool {
        self.filled == 0
    }

    /// Returns the remaining capacity
    pub fn remaining(&self) -> usize {
        self.capacity() - self.filled
    }

    /// Clear the buffer
    pub fn clear(&mut self) {
        self.filled = 0;
    }

    /// Set the number of bytes filled
    ///
    /// # Panics
    /// Panics if `n > self.initialized`.
    pub fn set_filled(&mut self, n: usize) {
        assert!(n <= self.initialized);
        self.filled = n;
    }

    /// Mark additional bytes as filled
    ///
    /// # Panics
    /// Panics if the result would exceed initialized length.
    pub fn advance(&mut self, n: usize) {
        let new_filled = self.filled.checked_add(n).expect("overflow");
        assert!(new_filled <= self.initialized);
        self.filled = new_filled;
    }

    /// Mark additional bytes as initialized
    ///
    /// # Safety
    /// The caller must ensure that the bytes have been initialized.
    pub unsafe fn assume_init(&mut self, n: usize) {
        let new_init = self.initialized.saturating_add(n);
        self.initialized = core::cmp::min(new_init, self.capacity());
    }

    /// Put a slice into the buffer
    pub fn put_slice(&mut self, src: &[u8]) {
        assert!(self.remaining() >= src.len());

        let dest = &mut self.buf[self.filled..self.filled + src.len()];
        dest.copy_from_slice(src);

        // The bytes are now initialized
        unsafe { self.assume_init(src.len()) };
        self.advance(src.len());
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// IO SLICE (VECTORED I/O)
// ═══════════════════════════════════════════════════════════════════════════════

/// A reference to a buffer for vectored I/O operations
#[repr(transparent)]
pub struct IoSlice<'a> {
    buf: &'a [u8],
}

impl<'a> IoSlice<'a> {
    /// Create a new IoSlice
    #[inline]
    pub fn new(buf: &'a [u8]) -> Self {
        IoSlice { buf }
    }

    /// Advance the internal cursor
    pub fn advance(&mut self, n: usize) {
        self.buf = &self.buf[n..];
    }

    /// Get the underlying slice
    #[inline]
    pub fn as_slice(&self) -> &[u8] {
        self.buf
    }
}

impl core::ops::Deref for IoSlice<'_> {
    type Target = [u8];

    fn deref(&self) -> &[u8] {
        self.buf
    }
}

/// A mutable reference to a buffer for vectored I/O operations
#[repr(transparent)]
pub struct IoSliceMut<'a> {
    buf: &'a mut [u8],
}

impl<'a> IoSliceMut<'a> {
    /// Create a new IoSliceMut
    #[inline]
    pub fn new(buf: &'a mut [u8]) -> Self {
        IoSliceMut { buf }
    }

    /// Advance the internal cursor
    pub fn advance(&mut self, n: usize) {
        let buf = core::mem::take(&mut self.buf);
        self.buf = &mut buf[n..];
    }

    /// Get the underlying slice
    #[inline]
    pub fn as_slice(&self) -> &[u8] {
        self.buf
    }

    /// Get the underlying slice mutably
    #[inline]
    pub fn as_mut_slice(&mut self) -> &mut [u8] {
        self.buf
    }
}

impl core::ops::Deref for IoSliceMut<'_> {
    type Target = [u8];

    fn deref(&self) -> &[u8] {
        self.buf
    }
}

impl core::ops::DerefMut for IoSliceMut<'_> {
    fn deref_mut(&mut self) -> &mut [u8] {
        self.buf
    }
}

/// Advance multiple IO slices
pub fn advance_slices(bufs: &mut &mut [IoSlice<'_>], n: usize) {
    let mut remaining = n;
    let mut i = 0;

    while i < bufs.len() && remaining > 0 {
        let buf_len = bufs[i].len();
        if buf_len > remaining {
            bufs[i].advance(remaining);
            break;
        }
        remaining -= buf_len;
        i += 1;
    }

    *bufs = &mut (*bufs)[i..];
}

// ═══════════════════════════════════════════════════════════════════════════════
// ASYNC I/O TRAITS
// ═══════════════════════════════════════════════════════════════════════════════

use core::task::{Context, Poll, Pin};

/// Async read trait
pub trait AsyncRead {
    /// Attempt to read bytes, returning Poll::Pending if not ready
    fn poll_read(
        self: Pin<&mut Self>,
        cx: &mut Context<'_>,
        buf: &mut [u8],
    ) -> Poll<Result<usize>>;

    /// Attempt to read with a ReadBuf
    fn poll_read_buf(
        self: Pin<&mut Self>,
        cx: &mut Context<'_>,
        buf: &mut ReadBuf<'_>,
    ) -> Poll<Result<()>> {
        let slice = unsafe { buf.unfilled_mut() };
        match self.poll_read(cx, slice) {
            Poll::Ready(Ok(n)) => {
                unsafe { buf.assume_init(n) };
                buf.advance(n);
                Poll::Ready(Ok(()))
            }
            Poll::Ready(Err(e)) => Poll::Ready(Err(e)),
            Poll::Pending => Poll::Pending,
        }
    }
}

/// Async write trait
pub trait AsyncWrite {
    /// Attempt to write bytes, returning Poll::Pending if not ready
    fn poll_write(
        self: Pin<&mut Self>,
        cx: &mut Context<'_>,
        buf: &[u8],
    ) -> Poll<Result<usize>>;

    /// Attempt to flush, returning Poll::Pending if not ready
    fn poll_flush(
        self: Pin<&mut Self>,
        cx: &mut Context<'_>,
    ) -> Poll<Result<()>>;

    /// Attempt to shutdown the writer
    fn poll_shutdown(
        self: Pin<&mut Self>,
        cx: &mut Context<'_>,
    ) -> Poll<Result<()>>;

    /// Attempt to write all bytes
    fn poll_write_all(
        mut self: Pin<&mut Self>,
        cx: &mut Context<'_>,
        mut buf: &[u8],
    ) -> Poll<Result<()>> {
        while !buf.is_empty() {
            match self.as_mut().poll_write(cx, buf) {
                Poll::Ready(Ok(0)) => {
                    return Poll::Ready(Err(Error::from_kind(ErrorKind::WriteZero)));
                }
                Poll::Ready(Ok(n)) => buf = &buf[n..],
                Poll::Ready(Err(e)) => return Poll::Ready(Err(e)),
                Poll::Pending => return Poll::Pending,
            }
        }
        Poll::Ready(Ok(()))
    }
}

/// Async buffered read trait
pub trait AsyncBufRead: AsyncRead {
    /// Attempt to fill the internal buffer
    fn poll_fill_buf(
        self: Pin<&mut Self>,
        cx: &mut Context<'_>,
    ) -> Poll<Result<&[u8]>>;

    /// Consume bytes from the buffer
    fn consume(self: Pin<&mut Self>, amt: usize);
}

/// Async seek trait
pub trait AsyncSeek {
    /// Attempt to seek to a position
    fn poll_seek(
        self: Pin<&mut Self>,
        cx: &mut Context<'_>,
        pos: SeekFrom,
    ) -> Poll<Result<u64>>;

    /// Start a seek operation (for futures-based API)
    fn start_seek(self: Pin<&mut Self>, pos: SeekFrom) -> Result<()>;

    /// Complete a seek operation
    fn poll_complete(
        self: Pin<&mut Self>,
        cx: &mut Context<'_>,
    ) -> Poll<Result<u64>>;
}

// ═══════════════════════════════════════════════════════════════════════════════
// ASYNC READ EXTENSIONS
// ═══════════════════════════════════════════════════════════════════════════════

/// Extension trait for AsyncRead with utility methods
pub trait AsyncReadExt: AsyncRead {
    /// Read some bytes
    fn read<'a>(&'a mut self, buf: &'a mut [u8]) -> ReadFuture<'a, Self>
    where
        Self: Unpin,
    {
        ReadFuture { reader: self, buf }
    }

    /// Read exact number of bytes
    fn read_exact<'a>(&'a mut self, buf: &'a mut [u8]) -> ReadExactFuture<'a, Self>
    where
        Self: Unpin,
    {
        ReadExactFuture { reader: self, buf, pos: 0 }
    }

    /// Read to end
    fn read_to_end<'a>(&'a mut self, buf: &'a mut Vec<u8>) -> ReadToEndFuture<'a, Self>
    where
        Self: Unpin,
    {
        ReadToEndFuture { reader: self, buf }
    }

    /// Read to string
    fn read_to_string<'a>(&'a mut self, buf: &'a mut String) -> ReadToStringFuture<'a, Self>
    where
        Self: Unpin,
    {
        ReadToStringFuture { reader: self, buf, bytes: Vec::new() }
    }
}

impl<T: AsyncRead + ?Sized> AsyncReadExt for T {}

/// Future for `read`
pub struct ReadFuture<'a, R: ?Sized> {
    reader: &'a mut R,
    buf: &'a mut [u8],
}

impl<'a, R: AsyncRead + Unpin + ?Sized> core::future::Future for ReadFuture<'a, R> {
    type Output = Result<usize>;

    fn poll(mut self: Pin<&mut Self>, cx: &mut Context<'_>) -> Poll<Self::Output> {
        let this = &mut *self;
        Pin::new(&mut *this.reader).poll_read(cx, this.buf)
    }
}

/// Future for `read_exact`
pub struct ReadExactFuture<'a, R: ?Sized> {
    reader: &'a mut R,
    buf: &'a mut [u8],
    pos: usize,
}

impl<'a, R: AsyncRead + Unpin + ?Sized> core::future::Future for ReadExactFuture<'a, R> {
    type Output = Result<()>;

    fn poll(mut self: Pin<&mut Self>, cx: &mut Context<'_>) -> Poll<Self::Output> {
        let this = &mut *self;
        while this.pos < this.buf.len() {
            match Pin::new(&mut *this.reader).poll_read(cx, &mut this.buf[this.pos..]) {
                Poll::Ready(Ok(0)) => {
                    return Poll::Ready(Err(Error::from_kind(ErrorKind::UnexpectedEof)));
                }
                Poll::Ready(Ok(n)) => this.pos += n,
                Poll::Ready(Err(e)) => return Poll::Ready(Err(e)),
                Poll::Pending => return Poll::Pending,
            }
        }
        Poll::Ready(Ok(()))
    }
}

/// Future for `read_to_end`
pub struct ReadToEndFuture<'a, R: ?Sized> {
    reader: &'a mut R,
    buf: &'a mut Vec<u8>,
}

/// Future for `read_to_string`
pub struct ReadToStringFuture<'a, R: ?Sized> {
    reader: &'a mut R,
    buf: &'a mut String,
    bytes: Vec<u8>,
}

// ═══════════════════════════════════════════════════════════════════════════════
// ASYNC WRITE EXTENSIONS
// ═══════════════════════════════════════════════════════════════════════════════

/// Extension trait for AsyncWrite with utility methods
pub trait AsyncWriteExt: AsyncWrite {
    /// Write some bytes
    fn write<'a>(&'a mut self, buf: &'a [u8]) -> WriteFuture<'a, Self>
    where
        Self: Unpin,
    {
        WriteFuture { writer: self, buf }
    }

    /// Write all bytes
    fn write_all<'a>(&'a mut self, buf: &'a [u8]) -> WriteAllFuture<'a, Self>
    where
        Self: Unpin,
    {
        WriteAllFuture { writer: self, buf, pos: 0 }
    }

    /// Flush the writer
    fn flush(&mut self) -> FlushFuture<'_, Self>
    where
        Self: Unpin,
    {
        FlushFuture { writer: self }
    }

    /// Shutdown the writer
    fn shutdown(&mut self) -> ShutdownFuture<'_, Self>
    where
        Self: Unpin,
    {
        ShutdownFuture { writer: self }
    }
}

impl<T: AsyncWrite + ?Sized> AsyncWriteExt for T {}

/// Future for `write`
pub struct WriteFuture<'a, W: ?Sized> {
    writer: &'a mut W,
    buf: &'a [u8],
}

impl<'a, W: AsyncWrite + Unpin + ?Sized> core::future::Future for WriteFuture<'a, W> {
    type Output = Result<usize>;

    fn poll(mut self: Pin<&mut Self>, cx: &mut Context<'_>) -> Poll<Self::Output> {
        let this = &mut *self;
        Pin::new(&mut *this.writer).poll_write(cx, this.buf)
    }
}

/// Future for `write_all`
pub struct WriteAllFuture<'a, W: ?Sized> {
    writer: &'a mut W,
    buf: &'a [u8],
    pos: usize,
}

impl<'a, W: AsyncWrite + Unpin + ?Sized> core::future::Future for WriteAllFuture<'a, W> {
    type Output = Result<()>;

    fn poll(mut self: Pin<&mut Self>, cx: &mut Context<'_>) -> Poll<Self::Output> {
        let this = &mut *self;
        while this.pos < this.buf.len() {
            match Pin::new(&mut *this.writer).poll_write(cx, &this.buf[this.pos..]) {
                Poll::Ready(Ok(0)) => {
                    return Poll::Ready(Err(Error::from_kind(ErrorKind::WriteZero)));
                }
                Poll::Ready(Ok(n)) => this.pos += n,
                Poll::Ready(Err(e)) => return Poll::Ready(Err(e)),
                Poll::Pending => return Poll::Pending,
            }
        }
        Poll::Ready(Ok(()))
    }
}

/// Future for `flush`
pub struct FlushFuture<'a, W: ?Sized> {
    writer: &'a mut W,
}

impl<'a, W: AsyncWrite + Unpin + ?Sized> core::future::Future for FlushFuture<'a, W> {
    type Output = Result<()>;

    fn poll(mut self: Pin<&mut Self>, cx: &mut Context<'_>) -> Poll<Self::Output> {
        Pin::new(&mut *self.writer).poll_flush(cx)
    }
}

/// Future for `shutdown`
pub struct ShutdownFuture<'a, W: ?Sized> {
    writer: &'a mut W,
}

impl<'a, W: AsyncWrite + Unpin + ?Sized> core::future::Future for ShutdownFuture<'a, W> {
    type Output = Result<()>;

    fn poll(mut self: Pin<&mut Self>, cx: &mut Context<'_>) -> Poll<Self::Output> {
        Pin::new(&mut *self.writer).poll_shutdown(cx)
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// PIPE
// ═══════════════════════════════════════════════════════════════════════════════

/// An in-memory pipe for async communication
///
/// Creates a pair of connected AsyncRead and AsyncWrite handles.
pub struct Pipe {
    buffer: alloc::sync::Arc<crate::sync::Mutex<PipeBuffer>>,
}

struct PipeBuffer {
    data: Vec<u8>,
    closed: bool,
    read_waker: Option<core::task::Waker>,
    write_waker: Option<core::task::Waker>,
    capacity: usize,
}

/// Reader half of a pipe
pub struct PipeReader {
    buffer: alloc::sync::Arc<crate::sync::Mutex<PipeBuffer>>,
}

/// Writer half of a pipe
pub struct PipeWriter {
    buffer: alloc::sync::Arc<crate::sync::Mutex<PipeBuffer>>,
}

/// Create a new pipe with the specified buffer capacity
pub fn pipe(capacity: usize) -> (PipeReader, PipeWriter) {
    let buffer = alloc::sync::Arc::new(crate::sync::Mutex::new(PipeBuffer {
        data: Vec::new(),
        closed: false,
        read_waker: None,
        write_waker: None,
        capacity,
    }));

    (
        PipeReader { buffer: buffer.clone() },
        PipeWriter { buffer },
    )
}

impl AsyncRead for PipeReader {
    fn poll_read(
        self: Pin<&mut Self>,
        cx: &mut Context<'_>,
        buf: &mut [u8],
    ) -> Poll<Result<usize>> {
        let mut inner = self.buffer.lock();

        if !inner.data.is_empty() {
            let n = core::cmp::min(buf.len(), inner.data.len());
            buf[..n].copy_from_slice(&inner.data[..n]);
            inner.data.drain(..n);

            // Wake writer if it was waiting
            if let Some(waker) = inner.write_waker.take() {
                waker.wake();
            }

            Poll::Ready(Ok(n))
        } else if inner.closed {
            Poll::Ready(Ok(0))
        } else {
            inner.read_waker = Some(cx.waker().clone());
            Poll::Pending
        }
    }
}

impl AsyncWrite for PipeWriter {
    fn poll_write(
        self: Pin<&mut Self>,
        cx: &mut Context<'_>,
        buf: &[u8],
    ) -> Poll<Result<usize>> {
        let mut inner = self.buffer.lock();

        if inner.closed {
            return Poll::Ready(Err(Error::from_kind(ErrorKind::BrokenPipe)));
        }

        if inner.data.len() < inner.capacity {
            let available = inner.capacity - inner.data.len();
            let n = core::cmp::min(buf.len(), available);
            inner.data.extend_from_slice(&buf[..n]);

            // Wake reader if it was waiting
            if let Some(waker) = inner.read_waker.take() {
                waker.wake();
            }

            Poll::Ready(Ok(n))
        } else {
            inner.write_waker = Some(cx.waker().clone());
            Poll::Pending
        }
    }

    fn poll_flush(self: Pin<&mut Self>, _cx: &mut Context<'_>) -> Poll<Result<()>> {
        Poll::Ready(Ok(()))
    }

    fn poll_shutdown(self: Pin<&mut Self>, _cx: &mut Context<'_>) -> Poll<Result<()>> {
        let mut inner = self.buffer.lock();
        inner.closed = true;
        if let Some(waker) = inner.read_waker.take() {
            waker.wake();
        }
        Poll::Ready(Ok(()))
    }
}

impl Drop for PipeWriter {
    fn drop(&mut self) {
        let mut inner = self.buffer.lock();
        inner.closed = true;
        if let Some(waker) = inner.read_waker.take() {
            waker.wake();
        }
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// DUPLEX
// ═══════════════════════════════════════════════════════════════════════════════

/// A full-duplex async stream (both read and write)
pub struct Duplex {
    read_half: PipeReader,
    write_half: PipeWriter,
}

/// Create a pair of connected duplex streams
pub fn duplex(capacity: usize) -> (Duplex, Duplex) {
    let (r1, w1) = pipe(capacity);
    let (r2, w2) = pipe(capacity);

    (
        Duplex { read_half: r1, write_half: w2 },
        Duplex { read_half: r2, write_half: w1 },
    )
}

impl AsyncRead for Duplex {
    fn poll_read(
        mut self: Pin<&mut Self>,
        cx: &mut Context<'_>,
        buf: &mut [u8],
    ) -> Poll<Result<usize>> {
        Pin::new(&mut self.read_half).poll_read(cx, buf)
    }
}

impl AsyncWrite for Duplex {
    fn poll_write(
        mut self: Pin<&mut Self>,
        cx: &mut Context<'_>,
        buf: &[u8],
    ) -> Poll<Result<usize>> {
        Pin::new(&mut self.write_half).poll_write(cx, buf)
    }

    fn poll_flush(mut self: Pin<&mut Self>, cx: &mut Context<'_>) -> Poll<Result<()>> {
        Pin::new(&mut self.write_half).poll_flush(cx)
    }

    fn poll_shutdown(mut self: Pin<&mut Self>, cx: &mut Context<'_>) -> Poll<Result<()>> {
        Pin::new(&mut self.write_half).poll_shutdown(cx)
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// SPLIT
// ═══════════════════════════════════════════════════════════════════════════════

/// Split an AsyncRead + AsyncWrite into separate halves
pub fn split<T: AsyncRead + AsyncWrite>(stream: T) -> (ReadHalf<T>, WriteHalf<T>)
where
    T: Unpin,
{
    let stream = alloc::sync::Arc::new(crate::sync::Mutex::new(stream));
    (
        ReadHalf { inner: stream.clone() },
        WriteHalf { inner: stream },
    )
}

/// Read half of a split stream
pub struct ReadHalf<T> {
    inner: alloc::sync::Arc<crate::sync::Mutex<T>>,
}

/// Write half of a split stream
pub struct WriteHalf<T> {
    inner: alloc::sync::Arc<crate::sync::Mutex<T>>,
}

impl<T: AsyncRead + Unpin> AsyncRead for ReadHalf<T> {
    fn poll_read(
        self: Pin<&mut Self>,
        cx: &mut Context<'_>,
        buf: &mut [u8],
    ) -> Poll<Result<usize>> {
        let mut guard = self.inner.lock();
        Pin::new(&mut *guard).poll_read(cx, buf)
    }
}

impl<T: AsyncWrite + Unpin> AsyncWrite for WriteHalf<T> {
    fn poll_write(
        self: Pin<&mut Self>,
        cx: &mut Context<'_>,
        buf: &[u8],
    ) -> Poll<Result<usize>> {
        let mut guard = self.inner.lock();
        Pin::new(&mut *guard).poll_write(cx, buf)
    }

    fn poll_flush(self: Pin<&mut Self>, cx: &mut Context<'_>) -> Poll<Result<()>> {
        let mut guard = self.inner.lock();
        Pin::new(&mut *guard).poll_flush(cx)
    }

    fn poll_shutdown(self: Pin<&mut Self>, cx: &mut Context<'_>) -> Poll<Result<()>> {
        let mut guard = self.inner.lock();
        Pin::new(&mut *guard).poll_shutdown(cx)
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// TESTS
// ═══════════════════════════════════════════════════════════════════════════════

#[cfg(test)]
mod tests {
    use super::*;

    #[test]
    fn test_cursor_read_write() {
        let mut cursor = Cursor::new(Vec::new());
        cursor.write_all(b"Hello, World!").unwrap();

        cursor.set_position(0);
        let mut buf = [0u8; 13];
        cursor.read_exact(&mut buf).unwrap();
        assert_eq!(&buf, b"Hello, World!");
    }

    #[test]
    fn test_cursor_seek() {
        let mut cursor = Cursor::new(b"Hello");
        cursor.seek(SeekFrom::End(-2)).unwrap();
        assert_eq!(cursor.position(), 3);
    }

    #[test]
    fn test_chain() {
        let data1 = Cursor::new(b"Hello, ");
        let data2 = Cursor::new(b"World!");
        let mut chain = data1.chain(data2);

        let mut buf = String::new();
        chain.read_to_string(&mut buf).unwrap();
        assert_eq!(buf, "Hello, World!");
    }

    #[test]
    fn test_take() {
        let data = Cursor::new(b"Hello, World!");
        let mut take = data.take(5);

        let mut buf = [0u8; 10];
        let n = take.read(&mut buf).unwrap();
        assert_eq!(n, 5);
        assert_eq!(&buf[..5], b"Hello");
    }

    #[test]
    fn test_read_buf() {
        let mut buffer = [0u8; 10];
        let mut read_buf = ReadBuf::new(&mut buffer);

        assert_eq!(read_buf.capacity(), 10);
        assert_eq!(read_buf.len(), 0);
        assert!(read_buf.is_empty());

        read_buf.put_slice(b"test");
        assert_eq!(read_buf.len(), 4);
        assert_eq!(read_buf.filled(), b"test");
    }

    #[test]
    fn test_tee() {
        let reader = Cursor::new(b"Hello");
        let mut capture = Vec::new();

        {
            let mut tee = tee(reader, &mut capture);
            let mut buf = [0u8; 5];
            tee.read_exact(&mut buf).unwrap();
        }

        assert_eq!(capture, b"Hello");
    }

    #[test]
    fn test_io_slice() {
        let data = b"Hello, World!";
        let slice = IoSlice::new(data);

        assert_eq!(slice.len(), 13);
        assert_eq!(slice.as_slice(), data);
    }
}
