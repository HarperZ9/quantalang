}

// ═══════════════════════════════════════════════════════════════════════════════
// RAW SYSCALL INTERFACE
// ═══════════════════════════════════════════════════════════════════════════════

#[cfg(target_arch = "x86_64")]
#[inline(always)]
unsafe fn syscall0(n: usize) -> isize {
    let ret: isize;
    core::arch::asm!(
        "syscall",
        in("rax") n,
        lateout("rax") ret,
        out("rcx") _,
        out("r11") _,
        options(nostack)
    );
    ret
}

#[cfg(target_arch = "x86_64")]
#[inline(always)]
unsafe fn syscall1(n: usize, a1: usize) -> isize {
    let ret: isize;
    core::arch::asm!(
        "syscall",
        in("rax") n,
        in("rdi") a1,
        lateout("rax") ret,
        out("rcx") _,
        out("r11") _,
        options(nostack)
    );
    ret
}

#[cfg(target_arch = "x86_64")]
#[inline(always)]
unsafe fn syscall2(n: usize, a1: usize, a2: usize) -> isize {
    let ret: isize;
    core::arch::asm!(
        "syscall",
        in("rax") n,
        in("rdi") a1,
        in("rsi") a2,
        lateout("rax") ret,
        out("rcx") _,
        out("r11") _,
        options(nostack)
    );
    ret
}

#[cfg(target_arch = "x86_64")]
#[inline(always)]
unsafe fn syscall3(n: usize, a1: usize, a2: usize, a3: usize) -> isize {
    let ret: isize;
    core::arch::asm!(
        "syscall",
        in("rax") n,
        in("rdi") a1,
        in("rsi") a2,
        in("rdx") a3,
        lateout("rax") ret,
        out("rcx") _,
        out("r11") _,
        options(nostack)
    );
    ret
}

#[cfg(target_arch = "x86_64")]
#[inline(always)]
unsafe fn syscall4(n: usize, a1: usize, a2: usize, a3: usize, a4: usize) -> isize {
    let ret: isize;
    core::arch::asm!(
        "syscall",
        in("rax") n,
        in("rdi") a1,
        in("rsi") a2,
        in("rdx") a3,
        in("r10") a4,
        lateout("rax") ret,
        out("rcx") _,
        out("r11") _,
        options(nostack)
    );
    ret
}

#[cfg(target_arch = "x86_64")]
#[inline(always)]
unsafe fn syscall6(n: usize, a1: usize, a2: usize, a3: usize, a4: usize, a5: usize, a6: usize) -> isize {
    let ret: isize;
    core::arch::asm!(
        "syscall",
        in("rax") n,
        in("rdi") a1,
        in("rsi") a2,
        in("rdx") a3,
        in("r10") a4,
        in("r8") a5,
        in("r9") a6,
        lateout("rax") ret,
        out("rcx") _,
        out("r11") _,
        options(nostack)
    );
    ret
}

/// Convert syscall return value to Result
fn check_err(ret: isize) -> Result<usize> {
    if ret < 0 && ret >= -4095 {
        Err(Error::from_raw_os_error(-ret as i32))
    } else {
        Ok(ret as usize)
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// FILE OPERATIONS
// ═══════════════════════════════════════════════════════════════════════════════

/// File descriptor wrapper
pub struct File {
    fd: i32,
}

impl File {
    pub fn read(&mut self, buf: &mut [u8]) -> Result<usize> {
        unsafe {
            check_err(syscall3(
                syscall::SYS_READ,
                self.fd as usize,
                buf.as_mut_ptr() as usize,
                buf.len(),
            ))
        }
    }
    
    pub fn write(&mut self, buf: &[u8]) -> Result<usize> {
        unsafe {
            check_err(syscall3(
                syscall::SYS_WRITE,
                self.fd as usize,
                buf.as_ptr() as usize,
                buf.len(),
            ))
        }
    }
    
    pub fn flush(&mut self) -> Result<()> {
        // Linux doesn't have a flush syscall; fsync is closest
        Ok(())
    }
    
    pub fn seek(&mut self, pos: SeekFrom) -> Result<u64> {
        let (offset, whence) = match pos {
            SeekFrom::Start(n) => (n as i64, 0),    // SEEK_SET
            SeekFrom::Current(n) => (n, 1),         // SEEK_CUR
            SeekFrom::End(n) => (n, 2),             // SEEK_END
        };
        
        unsafe {
            check_err(syscall3(
                syscall::SYS_LSEEK,
                self.fd as usize,
                offset as usize,
                whence,
            )).map(|n| n as u64)
        }
    }
    
    pub fn sync_all(&self) -> Result<()> {
        unsafe {
            check_err(syscall1(74, self.fd as usize))?; // fsync
            Ok(())
        }
    }
    
    pub fn sync_data(&self) -> Result<()> {
        unsafe {
            check_err(syscall1(75, self.fd as usize))?; // fdatasync
            Ok(())
        }
    }
    
    pub fn set_len(&self, size: u64) -> Result<()> {
        unsafe {
            check_err(syscall2(
                syscall::SYS_FTRUNCATE,
                self.fd as usize,
                size as usize,
            ))?;
            Ok(())
        }
    }
    
    pub fn metadata(&self) -> Result<Metadata> {
        let mut stat = Stat::zeroed();
        unsafe {
            check_err(syscall2(
                syscall::SYS_FSTAT,
                self.fd as usize,
                &mut stat as *mut Stat as usize,
            ))?;
        }
        Ok(Metadata { stat })
    }
    
    pub fn try_clone(&self) -> Result<File> {
        unsafe {
            check_err(syscall1(syscall::SYS_DUP, self.fd as usize))
                .map(|fd| File { fd: fd as i32 })
        }
    }
    
    pub fn set_permissions(&self, perm: crate::fs::Permissions) -> Result<()> {
        unsafe {
            check_err(syscall2(
                91, // fchmod
                self.fd as usize,
                perm.mode() as usize,
            ))?;
            Ok(())
        }
    }
}

impl Drop for File {
    fn drop(&mut self) {
        unsafe {
            syscall1(syscall::SYS_CLOSE, self.fd as usize);
        }
    }
}

/// Open a file
pub fn open(path: &Path, options: &crate::fs::OpenOptions) -> Result<File> {
    let mut flags = 0i32;
    
    if options.read && options.write {
        flags |= 2; // O_RDWR
    } else if options.write {
        flags |= 1; // O_WRONLY
    } else {
        flags |= 0; // O_RDONLY
    }
    
    if options.append { flags |= 0o2000; }    // O_APPEND
    if options.truncate { flags |= 0o1000; }  // O_TRUNC
    if options.create { flags |= 0o100; }     // O_CREAT
    if options.create_new { flags |= 0o200; } // O_EXCL
    
    let path_bytes = path.as_str().as_bytes();
    let mut path_buf = Vec::with_capacity(path_bytes.len() + 1);
    path_buf.extend_from_slice(path_bytes);
    path_buf.push(0);
    
    unsafe {
        check_err(syscall3(
            syscall::SYS_OPEN,
            path_buf.as_ptr() as usize,
            flags as usize,
            options.mode as usize,
        )).map(|fd| File { fd: fd as i32 })
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// STAT STRUCTURE
// ═══════════════════════════════════════════════════════════════════════════════

#[repr(C)]
struct Stat {
    st_dev: u64,
    st_ino: u64,
    st_nlink: u64,
    st_mode: u32,
    st_uid: u32,
    st_gid: u32,
    __pad0: u32,
    st_rdev: u64,
    st_size: i64,
    st_blksize: i64,
    st_blocks: i64,
    st_atime: i64,
    st_atime_nsec: i64,
    st_mtime: i64,
    st_mtime_nsec: i64,
    st_ctime: i64,
    st_ctime_nsec: i64,
    __unused: [i64; 3],
}

impl Stat {
    fn zeroed() -> Self {
        unsafe { core::mem::zeroed() }
    }
}

/// Metadata wrapper
pub struct Metadata {
    stat: Stat,
}

impl Metadata {
    pub fn is_file(&self) -> bool {
        (self.stat.st_mode & 0o170000) == 0o100000 // S_IFREG
    }
    
    pub fn is_dir(&self) -> bool {
        (self.stat.st_mode & 0o170000) == 0o040000 // S_IFDIR
    }
    
    pub fn is_symlink(&self) -> bool {
        (self.stat.st_mode & 0o170000) == 0o120000 // S_IFLNK
    }
    
    pub fn len(&self) -> u64 {
        self.stat.st_size as u64
    }
    
    pub fn permissions(&self) -> crate::fs::Permissions {
        crate::fs::Permissions::from_mode(self.stat.st_mode)
    }
    
    pub fn modified(&self) -> Result<crate::time::SystemTime> {
        Ok(crate::time::SystemTime::UNIX_EPOCH + Duration::new(
            self.stat.st_mtime as u64,
            self.stat.st_mtime_nsec as u32,
        ))
    }
    
    pub fn accessed(&self) -> Result<crate::time::SystemTime> {
        Ok(crate::time::SystemTime::UNIX_EPOCH + Duration::new(
            self.stat.st_atime as u64,
            self.stat.st_atime_nsec as u32,
        ))
    }
    
    pub fn created(&self) -> Result<crate::time::SystemTime> {
        // Linux doesn't have creation time in stat; return modified
        self.modified()
    }
    
    pub fn file_type(&self) -> crate::fs::FileType {
        FileType { mode: self.stat.st_mode }
    }
}

pub struct FileType {
    mode: u32,
}

impl FileType {
    pub fn is_file(&self) -> bool { (self.mode & 0o170000) == 0o100000 }
    pub fn is_dir(&self) -> bool { (self.mode & 0o170000) == 0o040000 }
    pub fn is_symlink(&self) -> bool { (self.mode & 0o170000) == 0o120000 }
}

// ═══════════════════════════════════════════════════════════════════════════════
// DIRECTORY OPERATIONS
// ═══════════════════════════════════════════════════════════════════════════════

pub struct DirEntry {
    path: PathBuf,
    name: String,
}

impl DirEntry {
    pub fn path(&self) -> PathBuf { self.path.clone() }
    pub fn file_name(&self) -> String { self.name.clone() }
    pub fn metadata(&self) -> Result<Metadata> { crate::sys::metadata(&self.path) }
    pub fn file_type(&self) -> Result<crate::fs::FileType> {
        self.metadata().map(|m| m.file_type())
    }
}

pub struct ReadDir {
    fd: i32,
    base_path: PathBuf,
    buf: Vec<u8>,
    pos: usize,
    len: usize,
}

impl Iterator for ReadDir {
    type Item = Result<DirEntry>;
    
    fn next(&mut self) -> Option<Self::Item> {
        // Read directory entries using getdents64
        // Simplified implementation
        None
    }
}

pub fn read_dir(path: &Path) -> Result<ReadDir> {
    // Open directory
    let path_bytes = path.as_str().as_bytes();
    let mut path_buf = Vec::with_capacity(path_bytes.len() + 1);
    path_buf.extend_from_slice(path_bytes);
    path_buf.push(0);
    
    unsafe {
        let fd = check_err(syscall3(
            syscall::SYS_OPEN,
            path_buf.as_ptr() as usize,
            0o200000, // O_DIRECTORY
            0,
        ))? as i32;
        
        Ok(ReadDir {
            fd,
            base_path: path.to_path_buf(),
            buf: vec![0u8; 4096],
            pos: 0,
            len: 0,
        })
    }
}

pub fn create_dir(path: &Path) -> Result<()> {
    let path_bytes = path.as_str().as_bytes();
    let mut path_buf = Vec::with_capacity(path_bytes.len() + 1);
    path_buf.extend_from_slice(path_bytes);
    path_buf.push(0);
    
    unsafe {
        check_err(syscall2(
            syscall::SYS_MKDIR,
            path_buf.as_ptr() as usize,
            0o755,
        ))?;
        Ok(())
    }
}

pub fn remove_dir(path: &Path) -> Result<()> {
    let path_bytes = path.as_str().as_bytes();
    let mut path_buf = Vec::with_capacity(path_bytes.len() + 1);
    path_buf.extend_from_slice(path_bytes);
    path_buf.push(0);
    
    unsafe {
        check_err(syscall1(syscall::SYS_RMDIR, path_buf.as_ptr() as usize))?;
        Ok(())
    }
}

pub fn remove_file(path: &Path) -> Result<()> {
    let path_bytes = path.as_str().as_bytes();
    let mut path_buf = Vec::with_capacity(path_bytes.len() + 1);
    path_buf.extend_from_slice(path_bytes);
    path_buf.push(0);
    
    unsafe {
        check_err(syscall1(syscall::SYS_UNLINK, path_buf.as_ptr() as usize))?;
        Ok(())
    }
}

pub fn rename(from: &Path, to: &Path) -> Result<()> {
    let from_bytes = from.as_str().as_bytes();
    let to_bytes = to.as_str().as_bytes();
    
    let mut from_buf = Vec::with_capacity(from_bytes.len() + 1);
    from_buf.extend_from_slice(from_bytes);
    from_buf.push(0);
    
    let mut to_buf = Vec::with_capacity(to_bytes.len() + 1);
    to_buf.extend_from_slice(to_bytes);
    to_buf.push(0);
    
    unsafe {
        check_err(syscall2(
            syscall::SYS_RENAME,
            from_buf.as_ptr() as usize,
            to_buf.as_ptr() as usize,
        ))?;
        Ok(())
    }
}

pub fn metadata(path: &Path) -> Result<Metadata> {
    let path_bytes = path.as_str().as_bytes();
    let mut path_buf = Vec::with_capacity(path_bytes.len() + 1);
    path_buf.extend_from_slice(path_bytes);
    path_buf.push(0);
    
    let mut stat = Stat::zeroed();
    unsafe {
        check_err(syscall2(
            syscall::SYS_STAT,
            path_buf.as_ptr() as usize,
            &mut stat as *mut Stat as usize,
        ))?;
    }
    Ok(Metadata { stat })
}

pub fn symlink_metadata(path: &Path) -> Result<Metadata> {
    let path_bytes = path.as_str().as_bytes();
    let mut path_buf = Vec::with_capacity(path_bytes.len() + 1);
    path_buf.extend_from_slice(path_bytes);
    path_buf.push(0);
    
    let mut stat = Stat::zeroed();
    unsafe {
        check_err(syscall2(
            syscall::SYS_LSTAT,
            path_buf.as_ptr() as usize,
            &mut stat as *mut Stat as usize,
        ))?;
    }
    Ok(Metadata { stat })
}

pub fn canonicalize(path: &Path) -> Result<PathBuf> {
    // Use realpath or manual resolution
    let path_bytes = path.as_str().as_bytes();
    let mut path_buf = Vec::with_capacity(path_bytes.len() + 1);
    path_buf.extend_from_slice(path_bytes);
    path_buf.push(0);
    
    let mut result = vec![0u8; 4096];
    
    // For now, return the path as-is if absolute
    if path.is_absolute() {
        Ok(path.to_path_buf())
    } else {
        let cwd = getcwd()?;
        Ok(cwd.join(path))
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// STANDARD STREAMS
// ═══════════════════════════════════════════════════════════════════════════════

pub struct Stdin;
pub struct Stdout;
pub struct Stderr;

impl Stdin {
    pub fn read(&mut self, buf: &mut [u8]) -> Result<usize> {
        unsafe {
            check_err(syscall3(syscall::SYS_READ, 0, buf.as_mut_ptr() as usize, buf.len()))
        }
    }
}

impl Stdout {
    pub fn write(&mut self, buf: &[u8]) -> Result<usize> {
        unsafe {
            check_err(syscall3(syscall::SYS_WRITE, 1, buf.as_ptr() as usize, buf.len()))
        }
    }
    
    pub fn flush(&mut self) -> Result<()> { Ok(()) }
}

impl Stderr {
    pub fn write(&mut self, buf: &[u8]) -> Result<usize> {
        unsafe {
            check_err(syscall3(syscall::SYS_WRITE, 2, buf.as_ptr() as usize, buf.len()))
        }
    }
    
    pub fn flush(&mut self) -> Result<()> { Ok(()) }
}

pub fn stdin() -> Stdin { Stdin }
pub fn stdout() -> Stdout { Stdout }
pub fn stderr() -> Stderr { Stderr }

// ═══════════════════════════════════════════════════════════════════════════════
// ENVIRONMENT
// ═══════════════════════════════════════════════════════════════════════════════

extern "C" {
    static environ: *const *const i8;
}

pub fn getenv(key: &str) -> Option<String> {
    // Search through environ
    unsafe {
        let mut ptr = environ;
        while !(*ptr).is_null() {
            let entry = core::ffi::CStr::from_ptr(*ptr);
            if let Ok(s) = entry.to_str() {
                if let Some((k, v)) = s.split_once('=') {
                    if k == key {
                        return Some(v.to_string());
                    }
                }
            }
            ptr = ptr.add(1);
        }
    }
    None
}

pub fn setenv(key: &str, value: &str) {
    // Would need to modify environ
    let _ = (key, value);
}

pub fn unsetenv(key: &str) {
    // Would need to modify environ
    let _ = key;
}

pub struct Environ {
    pos: usize,
}

impl Iterator for Environ {
    type Item = (String, String);
    
    fn next(&mut self) -> Option<Self::Item> {
        unsafe {
            let ptr = environ.add(self.pos);
            if (*ptr).is_null() {
                return None;
            }
            
            self.pos += 1;
            
            let entry = core::ffi::CStr::from_ptr(*ptr);
            if let Ok(s) = entry.to_str() {
                if let Some((k, v)) = s.split_once('=') {
                    return Some((k.to_string(), v.to_string()));
                }
            }
            
            self.next()
        }
    }
    
    fn size_hint(&self) -> (usize, Option<usize>) {
        (0, None)
    }
}

pub fn environ() -> Environ {
    Environ { pos: 0 }
}

pub fn getcwd() -> Result<PathBuf> {
    let mut buf = vec![0u8; 4096];
    unsafe {
        check_err(syscall2(
            syscall::SYS_GETCWD,
            buf.as_mut_ptr() as usize,
            buf.len(),
        ))?;
    }
    
    let len = buf.iter().position(|&b| b == 0).unwrap_or(buf.len());
    Ok(PathBuf::from(String::from_utf8_lossy(&buf[..len]).to_string()))
}

pub fn chdir(path: &Path) -> Result<()> {
    let path_bytes = path.as_str().as_bytes();
    let mut path_buf = Vec::with_capacity(path_bytes.len() + 1);
    path_buf.extend_from_slice(path_bytes);
    path_buf.push(0);
    
    unsafe {
        check_err(syscall1(syscall::SYS_CHDIR, path_buf.as_ptr() as usize))?;
        Ok(())
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// PROCESS
// ═══════════════════════════════════════════════════════════════════════════════

pub fn getpid() -> u32 {
    unsafe { syscall0(syscall::SYS_GETPID) as u32 }
}

pub fn exit(code: i32) -> ! {
    unsafe {
        syscall1(syscall::SYS_EXIT_GROUP, code as usize);
        core::hint::unreachable_unchecked()
    }
}

pub fn abort() -> ! {
    unsafe {
        syscall2(syscall::SYS_KILL, getpid() as usize, 6); // SIGABRT
        exit(134)
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// TIME
// ═══════════════════════════════════════════════════════════════════════════════

#[repr(C)]
struct Timespec {
    tv_sec: i64,
    tv_nsec: i64,
}

pub struct Instant {
    secs: u64,
    nanos: u32,
}

impl Instant {
    pub fn now() -> Self {
        let mut ts = Timespec { tv_sec: 0, tv_nsec: 0 };
        unsafe {
            syscall2(syscall::SYS_CLOCK_GETTIME, 1, &mut ts as *mut Timespec as usize); // CLOCK_MONOTONIC
        }
        Instant {
            secs: ts.tv_sec as u64,
            nanos: ts.tv_nsec as u32,
        }
    }
    
    pub fn duration_since(&self, earlier: &Self) -> Duration {
        let secs = self.secs.saturating_sub(earlier.secs);
        let nanos = if self.nanos >= earlier.nanos {
            self.nanos - earlier.nanos
        } else {
            1_000_000_000 - (earlier.nanos - self.nanos)
        };
        Duration::new(secs, nanos)
    }
    
    pub fn checked_duration_since(&self, earlier: &Self) -> Option<Duration> {
        if self.secs > earlier.secs || (self.secs == earlier.secs && self.nanos >= earlier.nanos) {
            Some(self.duration_since(earlier))
        } else {
            None
        }
    }
    
    pub fn checked_add(&self, duration: Duration) -> Option<Self> {
        let secs = self.secs.checked_add(duration.as_secs())?;
        let nanos = self.nanos + duration.subsec_nanos();
        let (secs, nanos) = if nanos >= 1_000_000_000 {
            (secs.checked_add(1)?, nanos - 1_000_000_000)
        } else {
            (secs, nanos)
        };
        Some(Instant { secs, nanos })
    }
    
    pub fn checked_sub(&self, duration: Duration) -> Option<Self> {
        let secs = self.secs.checked_sub(duration.as_secs())?;
        let nanos = if self.nanos >= duration.subsec_nanos() {
            self.nanos - duration.subsec_nanos()
        } else {
            let secs = secs.checked_sub(1)?;
            return Some(Instant {
                secs,
                nanos: 1_000_000_000 - (duration.subsec_nanos() - self.nanos),
            });
        };
        Some(Instant { secs, nanos })
    }
}

impl core::fmt::Debug for Instant {
    fn fmt(&self, f: &mut core::fmt::Formatter<'_>) -> core::fmt::Result {
        write!(f, "Instant {{ secs: {}, nanos: {} }}", self.secs, self.nanos)
    }
}

pub struct SystemTime {
    secs: u64,
    nanos: u32,
}

impl SystemTime {
    pub const UNIX_EPOCH: Self = SystemTime { secs: 0, nanos: 0 };
    
    pub fn now() -> Self {
        let mut ts = Timespec { tv_sec: 0, tv_nsec: 0 };
        unsafe {
            syscall2(syscall::SYS_CLOCK_GETTIME, 0, &mut ts as *mut Timespec as usize); // CLOCK_REALTIME
        }
        SystemTime {
            secs: ts.tv_sec as u64,
            nanos: ts.tv_nsec as u32,
        }
    }
    
    pub fn duration_since(&self, earlier: &Self) -> core::result::Result<Duration, ()> {
        if self.secs > earlier.secs || (self.secs == earlier.secs && self.nanos >= earlier.nanos) {
            let secs = self.secs - earlier.secs;
            let nanos = if self.nanos >= earlier.nanos {
                self.nanos - earlier.nanos
            } else {
                1_000_000_000 - (earlier.nanos - self.nanos)
            };
            Ok(Duration::new(secs, nanos))
        } else {
            Err(())
        }
    }
    
    pub fn checked_add(&self, duration: Duration) -> Option<Self> {
        let secs = self.secs.checked_add(duration.as_secs())?;
        let nanos = self.nanos + duration.subsec_nanos();
        let (secs, nanos) = if nanos >= 1_000_000_000 {
            (secs.checked_add(1)?, nanos - 1_000_000_000)
        } else {
            (secs, nanos)
        };
        Some(SystemTime { secs, nanos })
    }
    
    pub fn checked_sub(&self, duration: Duration) -> Option<Self> {
        let secs = self.secs.checked_sub(duration.as_secs())?;
        let nanos = if self.nanos >= duration.subsec_nanos() {
            self.nanos - duration.subsec_nanos()
        } else {
            let secs = secs.checked_sub(1)?;
            return Some(SystemTime {
                secs,
                nanos: 1_000_000_000 - (duration.subsec_nanos() - self.nanos),
            });
        };
        Some(SystemTime { secs, nanos })
    }
}

impl core::fmt::Debug for SystemTime {
    fn fmt(&self, f: &mut core::fmt::Formatter<'_>) -> core::fmt::Result {
        write!(f, "SystemTime {{ secs: {}, nanos: {} }}", self.secs, self.nanos)
    }
}

pub fn sleep(dur: Duration) {
    let ts = Timespec {
        tv_sec: dur.as_secs() as i64,
        tv_nsec: dur.subsec_nanos() as i64,
    };
    unsafe {
        syscall2(syscall::SYS_NANOSLEEP, &ts as *const Timespec as usize, 0);
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// RANDOM
// ═══════════════════════════════════════════════════════════════════════════════

pub fn random_u64() -> u64 {
    let mut buf = [0u8; 8];
    unsafe {
        syscall3(syscall::SYS_GETRANDOM, buf.as_mut_ptr() as usize, 8, 0);
    }
    u64::from_le_bytes(buf)
}

pub fn temp_dir() -> PathBuf {
    getenv("TMPDIR")
        .or_else(|| getenv("TMP"))
        .or_else(|| getenv("TEMP"))
        .unwrap_or_else(|| "/tmp".to_string())
        .into()
}

pub fn current_exe() -> Result<PathBuf> {
    let mut buf = vec![0u8; 4096];
    unsafe {
        let ret = syscall3(
            syscall::SYS_READLINK,
            "/proc/self/exe\0".as_ptr() as usize,
            buf.as_mut_ptr() as usize,
            buf.len(),
        );
        if ret < 0 {
            return Err(Error::from_raw_os_error(-ret as i32));
        }
        let len = ret as usize;
        Ok(PathBuf::from(String::from_utf8_lossy(&buf[..len]).to_string()))
    }
}
