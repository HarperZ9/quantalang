module std::env

use alloc::string::String;
use alloc::vec::Vec;
use alloc::collections::BTreeMap;
use core::fmt;
use crate::io::{self, Error, ErrorKind, Result};
use crate::path::{Path, PathBuf};

// ═══════════════════════════════════════════════════════════════════════════════
// ENVIRONMENT VARIABLES
// ═══════════════════════════════════════════════════════════════════════════════

/// Get an environment variable
pub fn var<K: AsRef<str>>(key: K) -> Result<String> {
    _var(key.as_ref())
}

fn _var(key: &str) -> Result<String> {
    crate::sys::getenv(key)
        .ok_or_else(|| Error::new(ErrorKind::NotFound, format!("environment variable '{}' not found", key)))
}

/// Get an environment variable as OsString
pub fn var_os<K: AsRef<str>>(key: K) -> Option<String> {
    crate::sys::getenv(key.as_ref())
}

/// Set an environment variable
pub fn set_var<K: AsRef<str>, V: AsRef<str>>(key: K, value: V) {
    _set_var(key.as_ref(), value.as_ref())
}

fn _set_var(key: &str, value: &str) {
    crate::sys::setenv(key, value);
}

/// Remove an environment variable
pub fn remove_var<K: AsRef<str>>(key: K) {
    _remove_var(key.as_ref())
}

fn _remove_var(key: &str) {
    crate::sys::unsetenv(key);
}

/// Iterate over environment variables
pub fn vars() -> Vars {
    Vars { inner: crate::sys::environ() }
}

/// Iterate over environment variables as OsStrings
pub fn vars_os() -> VarsOs {
    VarsOs { inner: crate::sys::environ() }
}

/// Environment variable iterator
pub struct Vars {
    inner: crate::sys::Environ,
}

impl Iterator for Vars {
    type Item = (String, String);
    
    fn next(&mut self) -> Option<Self::Item> {
        self.inner.next()
    }
    
    fn size_hint(&self) -> (usize, Option<usize>) {
        self.inner.size_hint()
    }
}

/// Environment variable iterator (OsString version)
pub struct VarsOs {
    inner: crate::sys::Environ,
}

impl Iterator for VarsOs {
    type Item = (String, String);
    
    fn next(&mut self) -> Option<Self::Item> {
        self.inner.next()
    }
    
    fn size_hint(&self) -> (usize, Option<usize>) {
        self.inner.size_hint()
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// CURRENT DIRECTORY
// ═══════════════════════════════════════════════════════════════════════════════

/// Get the current working directory
pub fn current_dir() -> Result<PathBuf> {
    crate::sys::getcwd()
}

/// Set the current working directory
pub fn set_current_dir<P: AsRef<Path>>(path: P) -> Result<()> {
    crate::sys::chdir(path.as_ref())
}

// ═══════════════════════════════════════════════════════════════════════════════
// COMMAND LINE ARGUMENTS
// ═══════════════════════════════════════════════════════════════════════════════

/// Get command line arguments
pub fn args() -> Args {
    Args { inner: crate::sys::args() }
}

/// Get command line arguments as OsStrings
pub fn args_os() -> ArgsOs {
    ArgsOs { inner: crate::sys::args() }
}

/// Command line argument iterator
pub struct Args {
    inner: crate::sys::Args,
}

impl Iterator for Args {
    type Item = String;
    
    fn next(&mut self) -> Option<Self::Item> {
        self.inner.next()
    }
    
    fn size_hint(&self) -> (usize, Option<usize>) {
        self.inner.size_hint()
    }
}

impl ExactSizeIterator for Args {
    fn len(&self) -> usize {
        self.inner.len()
    }
}

impl DoubleEndedIterator for Args {
    fn next_back(&mut self) -> Option<Self::Item> {
        self.inner.next_back()
    }
}

/// Command line argument iterator (OsString version)
pub struct ArgsOs {
    inner: crate::sys::Args,
}

impl Iterator for ArgsOs {
    type Item = String;
    
    fn next(&mut self) -> Option<Self::Item> {
        self.inner.next()
    }
    
    fn size_hint(&self) -> (usize, Option<usize>) {
        self.inner.size_hint()
    }
}

impl ExactSizeIterator for ArgsOs {
    fn len(&self) -> usize {
        self.inner.len()
    }
}

impl DoubleEndedIterator for ArgsOs {
    fn next_back(&mut self) -> Option<Self::Item> {
        self.inner.next_back()
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// PATHS
// ═══════════════════════════════════════════════════════════════════════════════

/// Get the current executable path
pub fn current_exe() -> Result<PathBuf> {
    crate::sys::current_exe()
}

/// Get the temporary directory
pub fn temp_dir() -> PathBuf {
    crate::sys::temp_dir()
}

/// Get the home directory
pub fn home_dir() -> Option<PathBuf> {
    #[cfg(unix)]
    {
        var_os("HOME").map(PathBuf::from)
    }
    
    #[cfg(windows)]
    {
        var_os("USERPROFILE").map(PathBuf::from)
    }
}

/// Join paths from the PATH environment variable
pub fn join_paths<I, T>(paths: I) -> Result<String>
where
    I: IntoIterator<Item = T>,
    T: AsRef<Path>,
{
    let sep = if cfg!(windows) { ';' } else { ':' };
    
    let mut result = String::new();
    for (i, path) in paths.into_iter().enumerate() {
        if i > 0 {
            result.push(sep);
        }
        
        let path_str = path.as_ref().as_str();
        
        // Check for invalid characters
        if path_str.contains(sep) {
            return Err(Error::new(
                ErrorKind::InvalidInput,
                format!("path contains separator: {}", path_str),
            ));
        }
        
        result.push_str(path_str);
    }
    
    Ok(result)
}

/// Split the PATH environment variable
pub fn split_paths<T: AsRef<str>>(unparsed: T) -> SplitPaths<'_> {
    SplitPaths {
        inner: unparsed.as_ref(),
    }
}

/// Iterator over split paths
pub struct SplitPaths<'a> {
    inner: &'a str,
}

impl<'a> Iterator for SplitPaths<'a> {
    type Item = PathBuf;
    
    fn next(&mut self) -> Option<Self::Item> {
        if self.inner.is_empty() {
            return None;
        }
        
        let sep = if cfg!(windows) { ';' } else { ':' };
        
        let (path, rest) = match self.inner.find(sep) {
            Some(pos) => (&self.inner[..pos], &self.inner[pos + 1..]),
            None => (self.inner, ""),
        };
        
        self.inner = rest;
        
        if path.is_empty() {
            self.next()
        } else {
            Some(PathBuf::from(path))
        }
    }
}

