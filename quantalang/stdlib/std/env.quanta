/// Get OS information
pub fn consts() -> &'static Consts {
    static CONSTS: Consts = Consts {
        arch: ARCH,
        family: FAMILY,
        os: OS,
        dll_prefix: DLL_PREFIX,
        dll_suffix: DLL_SUFFIX,
        dll_extension: DLL_EXTENSION,
        exe_suffix: EXE_SUFFIX,
        exe_extension: EXE_EXTENSION,
    };
    &CONSTS
}

/// Platform constants
pub struct Consts {
    pub arch: &'static str,
    pub family: &'static str,
    pub os: &'static str,
    pub dll_prefix: &'static str,
    pub dll_suffix: &'static str,
    pub dll_extension: &'static str,
    pub exe_suffix: &'static str,
    pub exe_extension: &'static str,
}

/// DLL prefix
#[cfg(unix)]
pub const DLL_PREFIX: &str = "lib";
#[cfg(windows)]
pub const DLL_PREFIX: &str = "";
#[cfg(not(any(unix, windows)))]
pub const DLL_PREFIX: &str = "";

/// DLL suffix
#[cfg(target_os = "linux")]
pub const DLL_SUFFIX: &str = ".so";
#[cfg(target_os = "macos")]
pub const DLL_SUFFIX: &str = ".dylib";
#[cfg(target_os = "windows")]
pub const DLL_SUFFIX: &str = ".dll";
#[cfg(not(any(target_os = "linux", target_os = "macos", target_os = "windows")))]
pub const DLL_SUFFIX: &str = "";

/// DLL extension
#[cfg(target_os = "linux")]
pub const DLL_EXTENSION: &str = "so";
#[cfg(target_os = "macos")]
pub const DLL_EXTENSION: &str = "dylib";
#[cfg(target_os = "windows")]
pub const DLL_EXTENSION: &str = "dll";
#[cfg(not(any(target_os = "linux", target_os = "macos", target_os = "windows")))]
pub const DLL_EXTENSION: &str = "";

/// Executable suffix
#[cfg(windows)]
pub const EXE_SUFFIX: &str = ".exe";
#[cfg(not(windows))]
pub const EXE_SUFFIX: &str = "";

/// Executable extension
#[cfg(windows)]
pub const EXE_EXTENSION: &str = "exe";
#[cfg(not(windows))]
pub const EXE_EXTENSION: &str = "";

// ═══════════════════════════════════════════════════════════════════════════════
// TESTS
// ═══════════════════════════════════════════════════════════════════════════════

#[cfg(test)]
mod tests {
    use super::*;
    
    #[test]
    fn test_var() {
        set_var("TEST_VAR", "test_value");
        assert_eq!(var("TEST_VAR").unwrap(), "test_value");
        
        remove_var("TEST_VAR");
        assert!(var("TEST_VAR").is_err());
    }
    
    #[test]
    fn test_join_paths() {
        let paths = vec!["/usr/bin", "/bin", "/usr/local/bin"];
        let joined = join_paths(&paths).unwrap();
        
        #[cfg(unix)]
        assert_eq!(joined, "/usr/bin:/bin:/usr/local/bin");
        
        #[cfg(windows)]
        assert_eq!(joined, "/usr/bin;/bin;/usr/local/bin");
    }
    
    #[test]
    fn test_split_paths() {
        #[cfg(unix)]
        let path = "/usr/bin:/bin:/usr/local/bin";
        
        #[cfg(windows)]
        let path = "/usr/bin;/bin;/usr/local/bin";
        
        let paths: Vec<_> = split_paths(path).collect();
        assert_eq!(paths.len(), 3);
        assert_eq!(paths[0].as_str(), "/usr/bin");
        assert_eq!(paths[1].as_str(), "/bin");
        assert_eq!(paths[2].as_str(), "/usr/local/bin");
    }
    
    #[test]
    fn test_current_dir() {
        let cwd = current_dir().unwrap();
        assert!(cwd.is_absolute());
    }
}
