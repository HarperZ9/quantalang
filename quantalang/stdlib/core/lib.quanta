//
// The core library provides fundamental types and traits for QuantaLang.
// Unlike `std`, `core` does not require an operating system or allocator.
//
// This crate is the foundation for:
// - `alloc`: Heap allocation (Box, Vec, String, Rc, Arc)
// - `std`: Full standard library (IO, threads, networking)
// - Kernel development (Quanta OS)
// - Embedded systems (bare metal)
//
// ═══════════════════════════════════════════════════════════════════════════════

#![no_std]
#![feature(lang_items)]
#![feature(intrinsics)]
#![feature(const_intrinsic)]
#![feature(negative_impls)]
#![feature(auto_traits)]
#![feature(const_fn_trait_bound)]
#![feature(const_mut_refs)]
#![feature(const_ptr_offset)]
#![feature(const_slice_from_raw_parts)]
#![feature(exhaustive_patterns)]
#![feature(never_type)]
#![feature(rustc_attrs)]
#![allow(incomplete_features)]

