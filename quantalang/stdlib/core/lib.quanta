#[cfg(not(test))]
mod lang_items {
    use super::*;
    
    #[lang = "eh_personality"]
    extern "C" fn eh_personality() {}
    
    #[lang = "panic_impl"]
    fn panic_impl(_info: &PanicInfo) -> ! {
        loop {}
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// TESTS
// ═══════════════════════════════════════════════════════════════════════════════

#[cfg(test)]
mod tests {
    use super::*;
    
    #[test]
    fn test_size_of() {
        assert_eq!(size_of::<u8>(), 1);
        assert_eq!(size_of::<u16>(), 2);
        assert_eq!(size_of::<u32>(), 4);
        assert_eq!(size_of::<u64>(), 8);
        assert_eq!(size_of::<usize>(), 8);
    }
    
    #[test]
    fn test_align_of() {
        assert_eq!(align_of::<u8>(), 1);
        assert_eq!(align_of::<u16>(), 2);
        assert_eq!(align_of::<u32>(), 4);
        assert_eq!(align_of::<u64>(), 8);
    }
    
    #[test]
    fn test_option() {
        let x: Option<i32> = Some(5);
        assert!(x.is_some());
        assert_eq!(x.unwrap(), 5);
        
        let y: Option<i32> = None;
        assert!(y.is_none());
    }
    
    #[test]
    fn test_phys_addr() {
        let addr = PhysAddr::new(0x1000);
        assert_eq!(addr.as_u64(), 0x1000);
        assert!(addr.is_aligned(0x1000));
        
        let addr2 = PhysAddr::new(0x1234);
        assert_eq!(addr2.align_down(0x1000).as_u64(), 0x1000);
        assert_eq!(addr2.align_up(0x1000).as_u64(), 0x2000);
    }
    
    #[test]
    fn test_virt_addr() {
        let addr = VirtAddr::new(0xFFFF_8000_0000_0000);
        assert_eq!(addr.as_u64(), 0xFFFF_8000_0000_0000);
    }
    
    #[test]
    fn test_default() {
        assert_eq!(u32::default(), 0);
        assert_eq!(bool::default(), false);
        assert_eq!(char::default(), '\0');
    }
    
    #[test]
    fn test_from_into() {
        let x: u32 = 5u8.into();
        assert_eq!(x, 5);
        
        let y: u64 = u64::from(10u32);
        assert_eq!(y, 10);
    }
}
