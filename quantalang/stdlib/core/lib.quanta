// ═══════════════════════════════════════════════════════════════════════════════
// QUANTALANG-SPECIFIC TYPES
// ═══════════════════════════════════════════════════════════════════════════════

/// Physical address type (for kernel/embedded development).
#[repr(transparent)]
#[derive(Clone, Copy, PartialEq, Eq, PartialOrd, Ord, Hash)]
pub struct PhysAddr(pub u64);

impl PhysAddr {
    pub const fn new(addr: u64) -> Self {
        PhysAddr(addr)
    }
    
    pub const fn as_u64(self) -> u64 {
        self.0
    }
    
    pub const fn align_down(self, align: u64) -> Self {
        PhysAddr(self.0 & !(align - 1))
    }
    
    pub const fn align_up(self, align: u64) -> Self {
        PhysAddr((self.0 + align - 1) & !(align - 1))
    }
    
    pub const fn is_aligned(self, align: u64) -> bool {
        self.0 & (align - 1) == 0
    }
}

/// Virtual address type (for kernel/embedded development).
#[repr(transparent)]
#[derive(Clone, Copy, PartialEq, Eq, PartialOrd, Ord, Hash)]
pub struct VirtAddr(pub u64);

impl VirtAddr {
    pub const fn new(addr: u64) -> Self {
        // x86_64: Canonical address check
        let sign_extend = (addr << 16) as i64 >> 16;
        if sign_extend as u64 != addr {
            // Non-canonical address
            panic!("non-canonical virtual address");
        }
        VirtAddr(addr)
    }
    
    pub const fn new_truncate(addr: u64) -> Self {
        VirtAddr(((addr << 16) as i64 >> 16) as u64)
    }
    
    pub const fn as_u64(self) -> u64 {
        self.0
    }
    
    pub const fn as_ptr<T>(self) -> *const T {
        self.0 as *const T
    }
    
    pub const fn as_mut_ptr<T>(self) -> *mut T {
        self.0 as *mut T
    }
    
    pub const fn align_down(self, align: u64) -> Self {
        VirtAddr::new_truncate(self.0 & !(align - 1))
    }
    
    pub const fn align_up(self, align: u64) -> Self {
        VirtAddr::new_truncate((self.0 + align - 1) & !(align - 1))
    }
    
    pub const fn page_offset(self) -> u64 {
        self.0 & 0xFFF
    }
    
    pub const fn p4_index(self) -> u64 {
        (self.0 >> 39) & 0x1FF
    }
    
    pub const fn p3_index(self) -> u64 {
        (self.0 >> 30) & 0x1FF
    }
    
    pub const fn p2_index(self) -> u64 {
        (self.0 >> 21) & 0x1FF
    }
    
    pub const fn p1_index(self) -> u64 {
        (self.0 >> 12) & 0x1FF
    }
}

/// Page size constant.
pub const PAGE_SIZE: usize = 4096;

/// Large page size (2 MiB).
pub const LARGE_PAGE_SIZE: usize = 2 * 1024 * 1024;

/// Huge page size (1 GiB).
pub const HUGE_PAGE_SIZE: usize = 1024 * 1024 * 1024;

// ═══════════════════════════════════════════════════════════════════════════════
// PANIC HANDLING
// ═══════════════════════════════════════════════════════════════════════════════

/// Panic location information.
#[derive(Debug)]
pub struct PanicInfo<'a> {
    message: Option<&'a str>,
    location: Option<Location<'a>>,
}

impl<'a> PanicInfo<'a> {
    pub fn message(&self) -> Option<&str> {
        self.message
    }
    
    pub fn location(&self) -> Option<&Location<'a>> {
        self.location.as_ref()
    }
}

/// Source code location.
#[derive(Debug)]
pub struct Location<'a> {
    file: &'a str,
    line: u32,
    column: u32,
}

impl<'a> Location<'a> {
    #[inline]
    pub const fn caller() -> &'static Location<'static> {
        // Compiler builtin
        &Location { file: "<unknown>", line: 0, column: 0 }
    }
    
    pub const fn file(&self) -> &str {
        self.file
    }
    
    pub const fn line(&self) -> u32 {
        self.line
    }
    
    pub const fn column(&self) -> u32 {
        self.column
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// HINTS
// ═══════════════════════════════════════════════════════════════════════════════

/// Compiler and CPU hints.
pub mod hint {
    use crate::intrinsics;
    
    /// Informs the compiler that this code path is unreachable.
    /// 
    /// # Safety
    /// Reaching this function is undefined behavior.
    #[inline]
    pub const unsafe fn unreachable_unchecked() -> ! {
        intrinsics::unreachable()
    }
    
    /// Emits a processor hint to spin-wait.
    /// 
    /// On x86, this emits `PAUSE`. On ARM, this emits `YIELD`.
    #[inline]
    pub fn spin_loop() {
        #[cfg(target_arch = "x86_64")]
        unsafe { intrinsics::pause(); }
        
        #[cfg(target_arch = "aarch64")]
        unsafe { core::arch::asm!("yield"); }
    }
    
    /// Prevents the value from being optimized away.
    /// 
    /// Useful for benchmarking to ensure computations aren't eliminated.
    #[inline]
    pub fn black_box<T>(x: T) -> T {
        intrinsics::black_box(x)
    }
    
    /// Hints that a condition is likely true.
    #[inline]
    #[must_use]
    pub const fn likely(b: bool) -> bool {
        intrinsics::likely(b)
    }
    
    /// Hints that a condition is likely false.
    #[inline]
    #[must_use]
    pub const fn unlikely(b: bool) -> bool {
        intrinsics::unlikely(b)
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// HASHING (minimal for core)
// ═══════════════════════════════════════════════════════════════════════════════

/// Minimal hash trait for core.
pub mod hash {
    pub trait Hash {
        fn hash<H: Hasher>(&self, state: &mut H);
    }
    
    pub trait Hasher {
        fn finish(&self) -> u64;
        fn write(&mut self, bytes: &[u8]);
        
        fn write_u8(&mut self, i: u8) {
            self.write(&[i]);
        }
        
        fn write_u16(&mut self, i: u16) {
            self.write(&i.to_ne_bytes());
        }
        
        fn write_u32(&mut self, i: u32) {
            self.write(&i.to_ne_bytes());
        }
        
        fn write_u64(&mut self, i: u64) {
            self.write(&i.to_ne_bytes());
        }
        
        fn write_u128(&mut self, i: u128) {
            self.write(&i.to_ne_bytes());
        }
        
        fn write_usize(&mut self, i: usize) {
            self.write(&i.to_ne_bytes());
        }
    }
    
    // Primitive implementations
    macro_rules! impl_hash_int {
        ($($t:ty)*) => {$(
            impl Hash for $t {
                fn hash<H: Hasher>(&self, state: &mut H) {
                    state.write(&self.to_ne_bytes());
                }
            }
        )*};
    }
    
    impl_hash_int!(u8 u16 u32 u64 u128 usize i8 i16 i32 i64 i128 isize);
    
    impl Hash for bool {
        fn hash<H: Hasher>(&self, state: &mut H) {
            state.write_u8(*self as u8);
        }
    }
    
    impl Hash for char {
        fn hash<H: Hasher>(&self, state: &mut H) {
            state.write_u32(*self as u32);
        }
    }
    
    impl<T: Hash> Hash for [T] {
        fn hash<H: Hasher>(&self, state: &mut H) {
            state.write_usize(self.len());
            for item in self {
                item.hash(state);
            }
        }
    }
    
    impl<T: Hash, const N: usize> Hash for [T; N] {
        fn hash<H: Hasher>(&self, state: &mut H) {
            Hash::hash(&self[..], state);
        }
    }
    
    impl<T: ?Sized> Hash for *const T {
        fn hash<H: Hasher>(&self, state: &mut H) {
            state.write_usize(*self as usize);
        }
    }
    
    impl<T: ?Sized> Hash for *mut T {
        fn hash<H: Hasher>(&self, state: &mut H) {
            state.write_usize(*self as usize);
        }
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// DEFAULT TRAIT
// ═══════════════════════════════════════════════════════════════════════════════

/// A trait for types with a default value.
pub trait Default: Sized {
    /// Returns the default value for a type.
    fn default() -> Self;
}

impl Default for () {
    fn default() -> Self { () }
}

impl Default for bool {
    fn default() -> Self { false }
}

impl Default for char {
    fn default() -> Self { '\0' }
}

macro_rules! impl_default_int {
    ($($t:ty)*) => {$(
        impl Default for $t {
            fn default() -> Self { 0 }
        }
    )*};
}

impl_default_int!(u8 u16 u32 u64 u128 usize i8 i16 i32 i64 i128 isize);

impl Default for f32 {
    fn default() -> Self { 0.0 }
}

impl Default for f64 {
    fn default() -> Self { 0.0 }
}

impl<T> Default for Option<T> {
    fn default() -> Self { None }
}

impl<T: Default, const N: usize> Default for [T; N] {
    fn default() -> Self {
        // Create array using default values
        let mut arr: [mem::MaybeUninit<T>; N] = unsafe { mem::MaybeUninit::uninit().assume_init() };
        for elem in &mut arr {
            elem.write(T::default());
        }
        unsafe { mem::transmute_copy(&arr) }
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// CONVERSION TRAITS
// ═══════════════════════════════════════════════════════════════════════════════

/// Conversion from a type.
pub trait From<T>: Sized {
    fn from(value: T) -> Self;
}

/// Conversion into a type.
pub trait Into<T>: Sized {
    fn into(self) -> T;
}

// From implies Into
impl<T, U> Into<U> for T
where
    U: From<T>,
{
    fn into(self) -> U {
        U::from(self)
    }
}

// Reflexive From
impl<T> From<T> for T {
    fn from(t: T) -> T {
        t
    }
}

/// Fallible conversion from a type.
pub trait TryFrom<T>: Sized {
    type Error;
    fn try_from(value: T) -> Result<Self, Self::Error>;
}

/// Fallible conversion into a type.
pub trait TryInto<T>: Sized {
    type Error;
    fn try_into(self) -> Result<T, Self::Error>;
}

// TryFrom implies TryInto
impl<T, U> TryInto<U> for T
where
    U: TryFrom<T>,
{
    type Error = U::Error;
    fn try_into(self) -> Result<U, U::Error> {
        U::try_from(self)
    }
}

/// Borrow as a reference.
pub trait AsRef<T: ?Sized> {
    fn as_ref(&self) -> &T;
}

/// Borrow as a mutable reference.
pub trait AsMut<T: ?Sized> {
    fn as_mut(&mut self) -> &mut T;
}

// Reflexive AsRef/AsMut
impl<T: ?Sized> AsRef<T> for T {
    fn as_ref(&self) -> &T {
        self
    }
}

impl<T: ?Sized> AsMut<T> for T {
    fn as_mut(&mut self) -> &mut T {
        self
    }
}

