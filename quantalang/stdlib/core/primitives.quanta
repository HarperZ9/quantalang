//
// Inherent methods for primitive types. The compiler treats these specially,
// allowing method calls on primitives without trait dispatch.
//
// ═══════════════════════════════════════════════════════════════════════════════

#![no_std]

module core::primitives

use crate::intrinsics;

// ═══════════════════════════════════════════════════════════════════════════════
// INTEGER TRAIT (shared behavior)
// ═══════════════════════════════════════════════════════════════════════════════

/// Common integer operations.
/// 
/// This trait is sealed and implemented only for built-in integer types.
pub trait Integer: Sized + Copy + Ord + Eq {
    const BITS: u32;
    const MIN: Self;
    const MAX: Self;
    const ZERO: Self;
    const ONE: Self;
    
    fn count_ones(self) -> u32;
    fn count_zeros(self) -> u32;
    fn leading_zeros(self) -> u32;
    fn trailing_zeros(self) -> u32;
    fn leading_ones(self) -> u32;
    fn trailing_ones(self) -> u32;
    fn rotate_left(self, n: u32) -> Self;
    fn rotate_right(self, n: u32) -> Self;
    fn swap_bytes(self) -> Self;
    fn reverse_bits(self) -> Self;
    fn from_be(x: Self) -> Self;
    fn from_le(x: Self) -> Self;
    fn to_be(self) -> Self;
    fn to_le(self) -> Self;
    fn checked_add(self, rhs: Self) -> Option<Self>;
    fn checked_sub(self, rhs: Self) -> Option<Self>;
    fn checked_mul(self, rhs: Self) -> Option<Self>;
    fn checked_div(self, rhs: Self) -> Option<Self>;
    fn saturating_add(self, rhs: Self) -> Self;
    fn saturating_sub(self, rhs: Self) -> Self;
    fn wrapping_add(self, rhs: Self) -> Self;
    fn wrapping_sub(self, rhs: Self) -> Self;
    fn wrapping_mul(self, rhs: Self) -> Self;
    fn overflowing_add(self, rhs: Self) -> (Self, bool);
    fn overflowing_sub(self, rhs: Self) -> (Self, bool);
    fn overflowing_mul(self, rhs: Self) -> (Self, bool);
    fn pow(self, exp: u32) -> Self;
    fn is_power_of_two(self) -> bool;
}

// ═══════════════════════════════════════════════════════════════════════════════
// UNSIGNED INTEGERS
// ═══════════════════════════════════════════════════════════════════════════════

macro_rules! impl_uint {
    ($ty:ty, $bits:expr) => {
        impl $ty {
            pub const BITS: u32 = $bits;
            pub const MIN: Self = 0;
            pub const MAX: Self = !0;
            
            #[inline]
            pub const fn count_ones(self) -> u32 {
                intrinsics::ctpop(self)
            }
            
            #[inline]
            pub const fn count_zeros(self) -> u32 {
                (!self).count_ones()
            }
            
            #[inline]
            pub const fn leading_zeros(self) -> u32 {
                intrinsics::ctlz(self)
            }
            
            #[inline]
            pub const fn trailing_zeros(self) -> u32 {
                intrinsics::cttz(self)
            }
            
            #[inline]
            pub const fn leading_ones(self) -> u32 {
                (!self).leading_zeros()
            }
            
            #[inline]
            pub const fn trailing_ones(self) -> u32 {
                (!self).trailing_zeros()
            }
            
            #[inline]
            pub const fn rotate_left(self, n: u32) -> Self {
                intrinsics::rotate_left(self, n)
            }
            
            #[inline]
            pub const fn rotate_right(self, n: u32) -> Self {
                intrinsics::rotate_right(self, n)
            }
            
            #[inline]
            pub const fn swap_bytes(self) -> Self {
                intrinsics::bswap(self)
            }
            
            #[inline]
            pub const fn reverse_bits(self) -> Self {
                intrinsics::bitreverse(self)
            }
            
            #[inline]
            pub const fn from_be(x: Self) -> Self {
                #[cfg(target_endian = "big")]
                { x }
                #[cfg(target_endian = "little")]
                { x.swap_bytes() }
            }
            
            #[inline]
            pub const fn from_le(x: Self) -> Self {
                #[cfg(target_endian = "little")]
                { x }
                #[cfg(target_endian = "big")]
                { x.swap_bytes() }
            }
            
            #[inline]
            pub const fn to_be(self) -> Self {
                #[cfg(target_endian = "big")]
                { self }
                #[cfg(target_endian = "little")]
                { self.swap_bytes() }
            }
            
            #[inline]
            pub const fn to_le(self) -> Self {
                #[cfg(target_endian = "little")]
                { self }
                #[cfg(target_endian = "big")]
                { self.swap_bytes() }
            }
            
            #[inline]
            pub const fn checked_add(self, rhs: Self) -> Option<Self> {
                let (result, overflow) = intrinsics::add_with_overflow(self, rhs);
                if overflow { None } else { Some(result) }
            }
            
            #[inline]
            pub const fn checked_sub(self, rhs: Self) -> Option<Self> {
                let (result, overflow) = intrinsics::sub_with_overflow(self, rhs);
                if overflow { None } else { Some(result) }
            }
            
            #[inline]
            pub const fn checked_mul(self, rhs: Self) -> Option<Self> {
                let (result, overflow) = intrinsics::mul_with_overflow(self, rhs);
                if overflow { None } else { Some(result) }
            }
            
            #[inline]
            pub const fn checked_div(self, rhs: Self) -> Option<Self> {
                if rhs == 0 { None } else { Some(self / rhs) }
            }
            
            #[inline]
            pub const fn checked_rem(self, rhs: Self) -> Option<Self> {
                if rhs == 0 { None } else { Some(self % rhs) }
            }
            
            #[inline]
            pub const fn checked_shl(self, rhs: u32) -> Option<Self> {
                if rhs >= Self::BITS { None } else { Some(self << rhs) }
            }
            
            #[inline]
            pub const fn checked_shr(self, rhs: u32) -> Option<Self> {
                if rhs >= Self::BITS { None } else { Some(self >> rhs) }
            }
            
            #[inline]
            pub const fn saturating_add(self, rhs: Self) -> Self {
                intrinsics::saturating_add(self, rhs)
            }
            
            #[inline]
            pub const fn saturating_sub(self, rhs: Self) -> Self {
                intrinsics::saturating_sub(self, rhs)
            }
            
            #[inline]
            pub const fn saturating_mul(self, rhs: Self) -> Self {
                match self.checked_mul(rhs) {
                    Some(x) => x,
                    None => Self::MAX,
                }
            }
            
            #[inline]
            pub const fn wrapping_add(self, rhs: Self) -> Self {
                intrinsics::wrapping_add(self, rhs)
            }
            
            #[inline]
            pub const fn wrapping_sub(self, rhs: Self) -> Self {
                intrinsics::wrapping_sub(self, rhs)
            }
            
            #[inline]
            pub const fn wrapping_mul(self, rhs: Self) -> Self {
                intrinsics::wrapping_mul(self, rhs)
            }
            
            #[inline]
            pub const fn wrapping_div(self, rhs: Self) -> Self {
                self / rhs
            }
            
            #[inline]
            pub const fn wrapping_shl(self, rhs: u32) -> Self {
                self << (rhs % Self::BITS)
            }
            
            #[inline]
            pub const fn wrapping_shr(self, rhs: u32) -> Self {
                self >> (rhs % Self::BITS)
            }
            
            #[inline]
            pub const fn overflowing_add(self, rhs: Self) -> (Self, bool) {
                intrinsics::add_with_overflow(self, rhs)
            }
            
            #[inline]
            pub const fn overflowing_sub(self, rhs: Self) -> (Self, bool) {
                intrinsics::sub_with_overflow(self, rhs)
            }
            
            #[inline]
            pub const fn overflowing_mul(self, rhs: Self) -> (Self, bool) {
                intrinsics::mul_with_overflow(self, rhs)
            }
            
            #[inline]
            pub const fn pow(self, mut exp: u32) -> Self {
                if exp == 0 { return 1; }
                let mut base = self;
                let mut acc: Self = 1;
                
                while exp > 1 {
                    if (exp & 1) == 1 {
                        acc = acc.wrapping_mul(base);
                    }
                    exp /= 2;
                    base = base.wrapping_mul(base);
                }
                
                acc.wrapping_mul(base)
            }
            
            #[inline]
            pub const fn is_power_of_two(self) -> bool {
                self != 0 && (self & (self - 1)) == 0
            }
            
            #[inline]
            pub const fn next_power_of_two(self) -> Self {
                if self == 0 { return 1; }
                let p = Self::BITS - self.wrapping_sub(1).leading_zeros();
                1 << p
            }
            
            #[inline]
            pub const fn checked_next_power_of_two(self) -> Option<Self> {
                if self == 0 { return Some(1); }
                let p = Self::BITS - self.wrapping_sub(1).leading_zeros();
                if p >= Self::BITS { None } else { Some(1 << p) }
            }
            
            #[inline]
            pub const fn ilog2(self) -> u32 {
                if self == 0 {
                    panic!("ilog2 of zero");
                }
                Self::BITS - 1 - self.leading_zeros()
            }
            
            #[inline]
            pub const fn ilog10(self) -> u32 {
                if self == 0 {
                    panic!("ilog10 of zero");
                }
                // Approximation using ilog2
                let log2 = self.ilog2();
                // log10(x) ≈ log2(x) * 0.30103
                // Use integer approximation: log10 ≈ log2 * 77 / 256
                (log2 * 77) / 256
            }
            
            /// Convert to bytes in big-endian order.
            #[inline]
            pub const fn to_be_bytes(self) -> [u8; $bits / 8] {
                self.to_be().to_ne_bytes()
            }
            
            /// Convert to bytes in little-endian order.
            #[inline]
            pub const fn to_le_bytes(self) -> [u8; $bits / 8] {
                self.to_le().to_ne_bytes()
            }
            
            /// Convert to bytes in native-endian order.
            #[inline]
            pub const fn to_ne_bytes(self) -> [u8; $bits / 8] {
                unsafe { intrinsics::transmute(self) }
            }
            
            /// Create from bytes in big-endian order.
            #[inline]
            pub const fn from_be_bytes(bytes: [u8; $bits / 8]) -> Self {
                Self::from_be(Self::from_ne_bytes(bytes))
            }
            
            /// Create from bytes in little-endian order.
            #[inline]
            pub const fn from_le_bytes(bytes: [u8; $bits / 8]) -> Self {
                Self::from_le(Self::from_ne_bytes(bytes))
            }
            
            /// Create from bytes in native-endian order.
            #[inline]
            pub const fn from_ne_bytes(bytes: [u8; $bits / 8]) -> Self {
                unsafe { intrinsics::transmute(bytes) }
            }
        }
    };
}

impl_uint!(u8, 8);
impl_uint!(u16, 16);
impl_uint!(u32, 32);
impl_uint!(u64, 64);
impl_uint!(u128, 128);

#[cfg(target_pointer_width = "64")]
impl_uint!(usize, 64);

#[cfg(target_pointer_width = "32")]
impl_uint!(usize, 32);

// ═══════════════════════════════════════════════════════════════════════════════
// SIGNED INTEGERS
// ═══════════════════════════════════════════════════════════════════════════════

macro_rules! impl_sint {
    ($ty:ty, $uty:ty, $bits:expr) => {
        impl $ty {
            pub const BITS: u32 = $bits;
            pub const MIN: Self = 1 << (Self::BITS - 1);
            pub const MAX: Self = !(1 << (Self::BITS - 1));
            
            #[inline]
            pub const fn count_ones(self) -> u32 {
                (self as $uty).count_ones()
            }
            
            #[inline]
            pub const fn count_zeros(self) -> u32 {
                (!self).count_ones()
            }
            
            #[inline]
            pub const fn leading_zeros(self) -> u32 {
                (self as $uty).leading_zeros()
            }
            
            #[inline]
            pub const fn trailing_zeros(self) -> u32 {
                (self as $uty).trailing_zeros()
            }
            
            #[inline]
            pub const fn leading_ones(self) -> u32 {
                (!self).leading_zeros()
            }
            
            #[inline]
            pub const fn trailing_ones(self) -> u32 {
                (!self).trailing_zeros()
            }
            
            #[inline]
            pub const fn rotate_left(self, n: u32) -> Self {
                (self as $uty).rotate_left(n) as Self
            }
            
            #[inline]
            pub const fn rotate_right(self, n: u32) -> Self {
                (self as $uty).rotate_right(n) as Self
            }
            
            #[inline]
            pub const fn swap_bytes(self) -> Self {
                (self as $uty).swap_bytes() as Self
            }
            
            #[inline]
            pub const fn reverse_bits(self) -> Self {
                (self as $uty).reverse_bits() as Self
            }
            
            #[inline]
            pub const fn from_be(x: Self) -> Self {
                (x as $uty).from_be() as Self
            }
            
            #[inline]
            pub const fn from_le(x: Self) -> Self {
                (x as $uty).from_le() as Self
            }
            
            #[inline]
            pub const fn to_be(self) -> Self {
                (self as $uty).to_be() as Self
            }
            
            #[inline]
            pub const fn to_le(self) -> Self {
                (self as $uty).to_le() as Self
            }
            
            #[inline]
            pub const fn checked_add(self, rhs: Self) -> Option<Self> {
                let (result, overflow) = intrinsics::add_with_overflow(self, rhs);
                if overflow { None } else { Some(result) }
            }
            
            #[inline]
            pub const fn checked_sub(self, rhs: Self) -> Option<Self> {
                let (result, overflow) = intrinsics::sub_with_overflow(self, rhs);
                if overflow { None } else { Some(result) }
            }
            
            #[inline]
            pub const fn checked_mul(self, rhs: Self) -> Option<Self> {
                let (result, overflow) = intrinsics::mul_with_overflow(self, rhs);
                if overflow { None } else { Some(result) }
            }
            
            #[inline]
            pub const fn checked_div(self, rhs: Self) -> Option<Self> {
                if rhs == 0 || (self == Self::MIN && rhs == -1) {
                    None
                } else {
                    Some(self / rhs)
                }
            }
            
            #[inline]
            pub const fn checked_neg(self) -> Option<Self> {
                if self == Self::MIN { None } else { Some(-self) }
            }
            
            #[inline]
            pub const fn checked_abs(self) -> Option<Self> {
                if self == Self::MIN { None } else { Some(self.abs()) }
            }
            
            #[inline]
            pub const fn saturating_add(self, rhs: Self) -> Self {
                intrinsics::saturating_add(self, rhs)
            }
            
            #[inline]
            pub const fn saturating_sub(self, rhs: Self) -> Self {
                intrinsics::saturating_sub(self, rhs)
            }
            
            #[inline]
            pub const fn saturating_neg(self) -> Self {
                if self == Self::MIN { Self::MAX } else { -self }
            }
            
            #[inline]
            pub const fn saturating_abs(self) -> Self {
                if self == Self::MIN { Self::MAX } else { self.abs() }
            }
            
            #[inline]
            pub const fn wrapping_add(self, rhs: Self) -> Self {
                intrinsics::wrapping_add(self, rhs)
            }
            
            #[inline]
            pub const fn wrapping_sub(self, rhs: Self) -> Self {
                intrinsics::wrapping_sub(self, rhs)
            }
            
            #[inline]
            pub const fn wrapping_mul(self, rhs: Self) -> Self {
                intrinsics::wrapping_mul(self, rhs)
            }
            
            #[inline]
            pub const fn wrapping_neg(self) -> Self {
                (0 as Self).wrapping_sub(self)
            }
            
            #[inline]
            pub const fn wrapping_abs(self) -> Self {
                if self.is_negative() { self.wrapping_neg() } else { self }
            }
            
            #[inline]
            pub const fn overflowing_add(self, rhs: Self) -> (Self, bool) {
                intrinsics::add_with_overflow(self, rhs)
            }
            
            #[inline]
            pub const fn overflowing_sub(self, rhs: Self) -> (Self, bool) {
                intrinsics::sub_with_overflow(self, rhs)
            }
            
            #[inline]
            pub const fn overflowing_mul(self, rhs: Self) -> (Self, bool) {
                intrinsics::mul_with_overflow(self, rhs)
            }
            
            #[inline]
            pub const fn overflowing_neg(self) -> (Self, bool) {
                if self == Self::MIN {
                    (Self::MIN, true)
                } else {
                    (-self, false)
                }
            }
            
            #[inline]
            pub const fn overflowing_abs(self) -> (Self, bool) {
                if self == Self::MIN {
                    (Self::MIN, true)
                } else {
                    (self.abs(), false)
                }
            }
            
            #[inline]
            pub const fn abs(self) -> Self {
                if self.is_negative() { -self } else { self }
            }
            
            #[inline]
            pub const fn signum(self) -> Self {
                if self > 0 { 1 }
                else if self < 0 { -1 }
                else { 0 }
            }
            
            #[inline]
            pub const fn is_positive(self) -> bool {
                self > 0
            }
            
            #[inline]
            pub const fn is_negative(self) -> bool {
                self < 0
            }
            
            #[inline]
            pub const fn pow(self, mut exp: u32) -> Self {
                if exp == 0 { return 1; }
                let mut base = self;
                let mut acc: Self = 1;
                
                while exp > 1 {
                    if (exp & 1) == 1 {
                        acc = acc.wrapping_mul(base);
                    }
                    exp /= 2;
                    base = base.wrapping_mul(base);
                }
                
                acc.wrapping_mul(base)
            }
            
            #[inline]
            pub const fn div_euclid(self, rhs: Self) -> Self {
                let q = self / rhs;
                if self % rhs < 0 {
                    if rhs > 0 { q - 1 } else { q + 1 }
                } else {
                    q
                }
            }
            
            #[inline]
            pub const fn rem_euclid(self, rhs: Self) -> Self {
                let r = self % rhs;
                if r < 0 {
                    if rhs > 0 { r + rhs } else { r - rhs }
                } else {
                    r
                }
            }
            
            #[inline]
            pub const fn to_be_bytes(self) -> [u8; $bits / 8] {
                self.to_be().to_ne_bytes()
            }
            
            #[inline]
            pub const fn to_le_bytes(self) -> [u8; $bits / 8] {
                self.to_le().to_ne_bytes()
            }
            
            #[inline]
            pub const fn to_ne_bytes(self) -> [u8; $bits / 8] {
                unsafe { intrinsics::transmute(self) }
            }
            
            #[inline]
            pub const fn from_be_bytes(bytes: [u8; $bits / 8]) -> Self {
                Self::from_be(Self::from_ne_bytes(bytes))
            }
            
            #[inline]
            pub const fn from_le_bytes(bytes: [u8; $bits / 8]) -> Self {
                Self::from_le(Self::from_ne_bytes(bytes))
            }
            
            #[inline]
            pub const fn from_ne_bytes(bytes: [u8; $bits / 8]) -> Self {
                unsafe { intrinsics::transmute(bytes) }
            }
        }
    };
}

impl_sint!(i8, u8, 8);
impl_sint!(i16, u16, 16);
impl_sint!(i32, u32, 32);
impl_sint!(i64, u64, 64);
impl_sint!(i128, u128, 128);

#[cfg(target_pointer_width = "64")]
impl_sint!(isize, usize, 64);

#[cfg(target_pointer_width = "32")]
impl_sint!(isize, usize, 32);

// ═══════════════════════════════════════════════════════════════════════════════
// FLOATING POINT
// ═══════════════════════════════════════════════════════════════════════════════

impl f32 {
    pub const RADIX: u32 = 2;
    pub const MANTISSA_DIGITS: u32 = 24;
    pub const DIGITS: u32 = 6;
    pub const EPSILON: f32 = 1.19209290e-07_f32;
    pub const MIN: f32 = -3.40282347e+38_f32;
    pub const MIN_POSITIVE: f32 = 1.17549435e-38_f32;
    pub const MAX: f32 = 3.40282347e+38_f32;
    pub const MIN_EXP: i32 = -125;
    pub const MAX_EXP: i32 = 128;
    pub const MIN_10_EXP: i32 = -37;
    pub const MAX_10_EXP: i32 = 38;
    pub const NAN: f32 = 0.0_f32 / 0.0_f32;
    pub const INFINITY: f32 = 1.0_f32 / 0.0_f32;
    pub const NEG_INFINITY: f32 = -1.0_f32 / 0.0_f32;
    
    #[inline]
    pub const fn is_nan(self) -> bool {
        self != self
    }
    
    #[inline]
    pub const fn is_infinite(self) -> bool {
        self == Self::INFINITY || self == Self::NEG_INFINITY
    }
    
    #[inline]
    pub const fn is_finite(self) -> bool {
        !self.is_nan() && !self.is_infinite()
    }
    
    #[inline]
    pub const fn is_subnormal(self) -> bool {
        let bits = self.to_bits();
        let exp = (bits >> 23) & 0xFF;
        let mantissa = bits & 0x7FFFFF;
        exp == 0 && mantissa != 0
    }
    
    #[inline]
    pub const fn is_normal(self) -> bool {
        let bits = self.to_bits();
        let exp = (bits >> 23) & 0xFF;
        exp != 0 && exp != 0xFF
    }
    
    #[inline]
    pub const fn is_sign_positive(self) -> bool {
        !self.is_sign_negative()
    }
    
    #[inline]
    pub const fn is_sign_negative(self) -> bool {
        self.to_bits() & (1 << 31) != 0
    }
    
    #[inline]
    pub fn floor(self) -> f32 {
        intrinsics::floorf32(self)
    }
    
    #[inline]
    pub fn ceil(self) -> f32 {
        intrinsics::ceilf32(self)
    }
    
    #[inline]
    pub fn round(self) -> f32 {
        intrinsics::roundf32(self)
    }
    
    #[inline]
    pub fn trunc(self) -> f32 {
        intrinsics::truncf32(self)
    }
    
    #[inline]
    pub fn fract(self) -> f32 {
        self - self.trunc()
    }
    
    #[inline]
    pub fn abs(self) -> f32 {
        intrinsics::fabsf32(self)
    }
    
    #[inline]
    pub fn signum(self) -> f32 {
        if self.is_nan() { Self::NAN }
        else { intrinsics::copysignf32(1.0, self) }
    }
    
    #[inline]
    pub fn copysign(self, sign: f32) -> f32 {
        intrinsics::copysignf32(self, sign)
    }
    
    #[inline]
    pub fn mul_add(self, a: f32, b: f32) -> f32 {
        intrinsics::fmaf32(self, a, b)
    }
    
    #[inline]
    pub fn sqrt(self) -> f32 {
        intrinsics::sqrtf32(self)
    }
    
    #[inline]
    pub fn exp(self) -> f32 {
        intrinsics::expf32(self)
    }
    
    #[inline]
    pub fn exp2(self) -> f32 {
        intrinsics::exp2f32(self)
    }
    
    #[inline]
    pub fn ln(self) -> f32 {
        intrinsics::logf32(self)
    }
    
    #[inline]
    pub fn log2(self) -> f32 {
        intrinsics::log2f32(self)
    }
    
    #[inline]
    pub fn log10(self) -> f32 {
        intrinsics::log10f32(self)
    }
    
    #[inline]
    pub fn powf(self, n: f32) -> f32 {
        intrinsics::powf32(self, n)
    }
    
    #[inline]
    pub fn powi(self, n: i32) -> i32 {
        // Use repeated squaring
        let mut result = 1.0_f32;
        let mut base = if n < 0 { 1.0 / self } else { self };
        let mut exp = if n < 0 { -n as u32 } else { n as u32 };
        
        while exp > 0 {
            if exp & 1 != 0 {
                result *= base;
            }
            base *= base;
            exp >>= 1;
        }
        
        result
    }
    
    #[inline]
    pub fn sin(self) -> f32 {
        intrinsics::sinf32(self)
    }
    
    #[inline]
    pub fn cos(self) -> f32 {
        intrinsics::cosf32(self)
    }
    
    #[inline]
    pub fn min(self, other: f32) -> f32 {
        intrinsics::minf32(self, other)
    }
    
    #[inline]
    pub fn max(self, other: f32) -> f32 {
        intrinsics::maxf32(self, other)
    }
    
    #[inline]
    pub fn clamp(self, min: f32, max: f32) -> f32 {
        self.max(min).min(max)
    }
    
    #[inline]
    pub const fn to_bits(self) -> u32 {
        unsafe { intrinsics::transmute(self) }
    }
    
    #[inline]
    pub const fn from_bits(bits: u32) -> f32 {
        unsafe { intrinsics::transmute(bits) }
    }
    
    #[inline]
    pub const fn to_be_bytes(self) -> [u8; 4] {
        self.to_bits().to_be_bytes()
    }
    
    #[inline]
    pub const fn to_le_bytes(self) -> [u8; 4] {
        self.to_bits().to_le_bytes()
    }
    
    #[inline]
    pub const fn to_ne_bytes(self) -> [u8; 4] {
        self.to_bits().to_ne_bytes()
    }
    
    #[inline]
    pub const fn from_be_bytes(bytes: [u8; 4]) -> f32 {
        Self::from_bits(u32::from_be_bytes(bytes))
    }
    
    #[inline]
    pub const fn from_le_bytes(bytes: [u8; 4]) -> f32 {
        Self::from_bits(u32::from_le_bytes(bytes))
    }
    
    #[inline]
    pub const fn from_ne_bytes(bytes: [u8; 4]) -> f32 {
        Self::from_bits(u32::from_ne_bytes(bytes))
    }
}

impl f64 {
    pub const RADIX: u32 = 2;
    pub const MANTISSA_DIGITS: u32 = 53;
    pub const DIGITS: u32 = 15;
    pub const EPSILON: f64 = 2.2204460492503131e-16_f64;
    pub const MIN: f64 = -1.7976931348623157e+308_f64;
    pub const MIN_POSITIVE: f64 = 2.2250738585072014e-308_f64;
    pub const MAX: f64 = 1.7976931348623157e+308_f64;
    pub const MIN_EXP: i32 = -1021;
    pub const MAX_EXP: i32 = 1024;
    pub const MIN_10_EXP: i32 = -307;
    pub const MAX_10_EXP: i32 = 308;
    pub const NAN: f64 = 0.0_f64 / 0.0_f64;
    pub const INFINITY: f64 = 1.0_f64 / 0.0_f64;
    pub const NEG_INFINITY: f64 = -1.0_f64 / 0.0_f64;
    
    // Mathematical constants
    pub const PI: f64 = 3.14159265358979323846264338327950288_f64;
    pub const TAU: f64 = 6.28318530717958647692528676655900577_f64;
    pub const E: f64 = 2.71828182845904523536028747135266250_f64;
    pub const SQRT_2: f64 = 1.41421356237309504880168872420969808_f64;
    pub const LN_2: f64 = 0.693147180559945309417232121458176568_f64;
    pub const LN_10: f64 = 2.30258509299404568401799145468436421_f64;
    
    #[inline]
    pub const fn is_nan(self) -> bool {
        self != self
    }
    
    #[inline]
    pub const fn is_infinite(self) -> bool {
        self == Self::INFINITY || self == Self::NEG_INFINITY
    }
    
    #[inline]
    pub const fn is_finite(self) -> bool {
        !self.is_nan() && !self.is_infinite()
    }
    
    #[inline]
    pub const fn is_sign_positive(self) -> bool {
        !self.is_sign_negative()
    }
    
    #[inline]
    pub const fn is_sign_negative(self) -> bool {
        self.to_bits() & (1 << 63) != 0
    }
    
    #[inline]
    pub fn floor(self) -> f64 { intrinsics::floorf64(self) }
    
    #[inline]
    pub fn ceil(self) -> f64 { intrinsics::ceilf64(self) }
    
    #[inline]
    pub fn round(self) -> f64 { intrinsics::roundf64(self) }
    
    #[inline]
    pub fn trunc(self) -> f64 { intrinsics::truncf64(self) }
    
    #[inline]
    pub fn fract(self) -> f64 { self - self.trunc() }
    
    #[inline]
    pub fn abs(self) -> f64 { intrinsics::fabsf64(self) }
    
    #[inline]
    pub fn sqrt(self) -> f64 { intrinsics::sqrtf64(self) }
    
    #[inline]
    pub fn exp(self) -> f64 { intrinsics::expf64(self) }
    
    #[inline]
    pub fn ln(self) -> f64 { intrinsics::logf64(self) }
    
    #[inline]
    pub fn log2(self) -> f64 { intrinsics::log2f64(self) }
    
    #[inline]
    pub fn log10(self) -> f64 { intrinsics::log10f64(self) }
    
    #[inline]
    pub fn powf(self, n: f64) -> f64 { intrinsics::powf64(self, n) }
    
    #[inline]
    pub fn sin(self) -> f64 { intrinsics::sinf64(self) }
    
    #[inline]
    pub fn cos(self) -> f64 { intrinsics::cosf64(self) }
    
    #[inline]
    pub fn min(self, other: f64) -> f64 { intrinsics::minf64(self, other) }
    
    #[inline]
    pub fn max(self, other: f64) -> f64 { intrinsics::maxf64(self, other) }
    
    #[inline]
    pub fn clamp(self, min: f64, max: f64) -> f64 { self.max(min).min(max) }
    
    #[inline]
    pub const fn to_bits(self) -> u64 {
        unsafe { intrinsics::transmute(self) }
    }
    
    #[inline]
    pub const fn from_bits(bits: u64) -> f64 {
        unsafe { intrinsics::transmute(bits) }
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// BOOL
// ═══════════════════════════════════════════════════════════════════════════════

impl bool {
    #[inline]
    pub const fn then_some<T>(self, t: T) -> Option<T> {
        if self { Some(t) } else { None }
    }
    
    #[inline]
    pub fn then<T, F: FnOnce() -> T>(self, f: F) -> Option<T> {
        if self { Some(f()) } else { None }
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// CHAR
// ═══════════════════════════════════════════════════════════════════════════════

impl char {
    pub const MAX: char = '\u{10FFFF}';
    pub const REPLACEMENT_CHARACTER: char = '\u{FFFD}';
    
    #[inline]
    pub const fn is_ascii(self) -> bool {
        (self as u32) <= 0x7F
    }
    
    #[inline]
    pub const fn is_alphabetic(self) -> bool {
        self.is_ascii_alphabetic() // Simplified
    }
    
    #[inline]
    pub const fn is_numeric(self) -> bool {
        self.is_ascii_digit() // Simplified
    }
    
    #[inline]
    pub const fn is_alphanumeric(self) -> bool {
        self.is_alphabetic() || self.is_numeric()
    }
    
    #[inline]
    pub const fn is_whitespace(self) -> bool {
        matches!(self, ' ' | '\t' | '\n' | '\r' | '\x0C')
    }
    
    #[inline]
    pub const fn is_ascii_alphabetic(self) -> bool {
        matches!(self, 'a'..='z' | 'A'..='Z')
    }
    
    #[inline]
    pub const fn is_ascii_uppercase(self) -> bool {
        matches!(self, 'A'..='Z')
    }
    
    #[inline]
    pub const fn is_ascii_lowercase(self) -> bool {
        matches!(self, 'a'..='z')
    }
    
    #[inline]
    pub const fn is_ascii_digit(self) -> bool {
        matches!(self, '0'..='9')
    }
    
    #[inline]
    pub const fn is_ascii_hexdigit(self) -> bool {
        matches!(self, '0'..='9' | 'a'..='f' | 'A'..='F')
    }
    
    #[inline]
    pub const fn is_ascii_punctuation(self) -> bool {
        matches!(self, '!'..='/' | ':'..='@' | '['..='`' | '{'..='~')
    }
    
    #[inline]
    pub const fn is_ascii_control(self) -> bool {
        matches!(self, '\0'..='\x1F' | '\x7F')
    }
    
    #[inline]
    pub const fn to_ascii_uppercase(self) -> char {
        if self.is_ascii_lowercase() {
            (self as u8 - 32) as char
        } else {
            self
        }
    }
    
    #[inline]
    pub const fn to_ascii_lowercase(self) -> char {
        if self.is_ascii_uppercase() {
            (self as u8 + 32) as char
        } else {
            self
        }
    }
    
    #[inline]
    pub const fn to_digit(self, radix: u32) -> Option<u32> {
        if radix > 36 { return None; }
        
        let digit = match self {
            '0'..='9' => self as u32 - '0' as u32,
            'a'..='z' => self as u32 - 'a' as u32 + 10,
            'A'..='Z' => self as u32 - 'A' as u32 + 10,
            _ => return None,
        };
        
        if digit < radix { Some(digit) } else { None }
    }
    
    #[inline]
    pub const fn from_digit(digit: u32, radix: u32) -> Option<char> {
        if radix > 36 || digit >= radix { return None; }
        
        let c = if digit < 10 {
            ('0' as u32 + digit) as u8 as char
        } else {
            ('a' as u32 + digit - 10) as u8 as char
        };
        
        Some(c)
    }
    
    #[inline]
    pub const fn len_utf8(self) -> usize {
        let code = self as u32;
        if code < 0x80 { 1 }
        else if code < 0x800 { 2 }
        else if code < 0x10000 { 3 }
        else { 4 }
    }
    
    #[inline]
    pub const fn len_utf16(self) -> usize {
        if (self as u32) < 0x10000 { 1 } else { 2 }
    }
    
    pub fn encode_utf8(self, dst: &mut [u8]) -> &mut str {
        let code = self as u32;
        let len = self.len_utf8();
        
        if dst.len() < len {
            panic!("buffer too small for char");
        }
        
        match len {
            1 => dst[0] = code as u8,
            2 => {
                dst[0] = (code >> 6 & 0x1F) as u8 | 0xC0;
                dst[1] = (code & 0x3F) as u8 | 0x80;
            }
            3 => {
                dst[0] = (code >> 12 & 0x0F) as u8 | 0xE0;
                dst[1] = (code >> 6 & 0x3F) as u8 | 0x80;
                dst[2] = (code & 0x3F) as u8 | 0x80;
            }
            4 => {
                dst[0] = (code >> 18 & 0x07) as u8 | 0xF0;
                dst[1] = (code >> 12 & 0x3F) as u8 | 0x80;
                dst[2] = (code >> 6 & 0x3F) as u8 | 0x80;
                dst[3] = (code & 0x3F) as u8 | 0x80;
            }
            _ => unreachable!(),
        }
        
        unsafe { &mut *(dst.get_unchecked_mut(..len) as *mut [u8] as *mut str) }
    }
}
