//
// This module defines the fundamental traits that the compiler knows about.
// These traits control:
// - Copy semantics (bitwise copy vs move)
// - Drop semantics (destructor behavior)
// - Sizing (dynamically sized types)
// - Thread safety (Send/Sync)
// - Linear type behavior
//
// ═══════════════════════════════════════════════════════════════════════════════

#![no_std]

module core::marker

// ═══════════════════════════════════════════════════════════════════════════════
// SIZED TRAIT
// ═══════════════════════════════════════════════════════════════════════════════

/// Types with a constant size known at compile time.
/// 
/// All type parameters have an implicit `Sized` bound. Use `?Sized` to opt out:
/// ```
/// fn foo<T: ?Sized>(x: &T) { ... }
/// ```
/// 
/// Dynamically sized types (DSTs) include:
/// - Slices: `[T]`
/// - Trait objects: `dyn Trait`
/// - Structs with a DST as the last field
#[lang = "sized"]
#[fundamental]
pub trait Sized {
    // No methods - this is a marker trait
}

// ═══════════════════════════════════════════════════════════════════════════════
// COPY TRAIT
// ═══════════════════════════════════════════════════════════════════════════════

/// Types that can be duplicated by simply copying bits.
/// 
/// Types implementing `Copy`:
/// - Are implicitly copied instead of moved on assignment
/// - Must not implement `Drop` (no custom destructor)
/// - Must have all fields implement `Copy`
/// 
/// Automatically derived for:
/// - All primitive types (integers, floats, bool, char)
/// - Raw pointers
/// - Function pointers
/// - Arrays and tuples of `Copy` types
/// - Shared references (&T)
/// 
/// NOT Copy:
/// - Mutable references (&mut T) - would violate aliasing rules
/// - Types with `Drop` - destructor must run exactly once
/// - Types containing non-Copy fields
/// - Linear types - by definition cannot be copied
#[lang = "copy"]
pub trait Copy: Clone {
    // No methods - this is a marker trait
    // The compiler implements the actual copy semantics
}

// ═══════════════════════════════════════════════════════════════════════════════
// CLONE TRAIT
// ═══════════════════════════════════════════════════════════════════════════════

/// Types that can be explicitly duplicated.
/// 
/// Differs from `Copy`:
/// - `Copy` is implicit and bitwise
/// - `Clone` is explicit and may be expensive (e.g., heap allocation)
/// 
/// `Clone` is a supertrait of `Copy`: all `Copy` types are `Clone`,
/// but not all `Clone` types are `Copy`.
#[lang = "clone"]
pub trait Clone: Sized {
    /// Returns a copy of the value.
    /// 
    /// # Performance
    /// This may involve heap allocation or other expensive operations.
    /// For cheap copies, implement `Copy` instead.
    fn clone(&self) -> Self;
    
    /// Performs copy-assignment from `source`.
    /// 
    /// Default implementation calls `clone()` and assigns.
    /// Override for types where in-place cloning is more efficient.
    fn clone_from(&mut self, source: &Self) {
        *self = source.clone();
    }
}

// Primitive implementations
impl Clone for bool {
    #[inline]
    fn clone(&self) -> Self { *self }
}

impl Clone for char {
    #[inline]
    fn clone(&self) -> Self { *self }
}

impl Clone for u8 {
    #[inline]
    fn clone(&self) -> Self { *self }
}

impl Clone for u16 {
    #[inline]
    fn clone(&self) -> Self { *self }
}

impl Clone for u32 {
    #[inline]
    fn clone(&self) -> Self { *self }
}

impl Clone for u64 {
    #[inline]
    fn clone(&self) -> Self { *self }
}

impl Clone for u128 {
    #[inline]
    fn clone(&self) -> Self { *self }
}

impl Clone for usize {
    #[inline]
    fn clone(&self) -> Self { *self }
}

impl Clone for i8 {
    #[inline]
    fn clone(&self) -> Self { *self }
}

impl Clone for i16 {
    #[inline]
    fn clone(&self) -> Self { *self }
}

impl Clone for i32 {
    #[inline]
    fn clone(&self) -> Self { *self }
}

impl Clone for i64 {
    #[inline]
    fn clone(&self) -> Self { *self }
}

impl Clone for i128 {
    #[inline]
    fn clone(&self) -> Self { *self }
}

impl Clone for isize {
    #[inline]
    fn clone(&self) -> Self { *self }
}

impl Clone for f32 {
    #[inline]
    fn clone(&self) -> Self { *self }
}

impl Clone for f64 {
    #[inline]
    fn clone(&self) -> Self { *self }
}

impl<T: ?Sized> Clone for *const T {
    #[inline]
    fn clone(&self) -> Self { *self }
}

impl<T: ?Sized> Clone for *mut T {
    #[inline]
    fn clone(&self) -> Self { *self }
}

impl<T: ?Sized> Clone for &T {
    #[inline]
    fn clone(&self) -> Self { *self }
}

// Copy implementations for primitives
impl Copy for bool {}
impl Copy for char {}
impl Copy for u8 {}
impl Copy for u16 {}
impl Copy for u32 {}
impl Copy for u64 {}
impl Copy for u128 {}
impl Copy for usize {}
impl Copy for i8 {}
impl Copy for i16 {}
impl Copy for i32 {}
impl Copy for i64 {}
impl Copy for i128 {}
impl Copy for isize {}
impl Copy for f32 {}
impl Copy for f64 {}
impl<T: ?Sized> Copy for *const T {}
impl<T: ?Sized> Copy for *mut T {}
impl<T: ?Sized> Copy for &T {}

// ═══════════════════════════════════════════════════════════════════════════════
// DROP TRAIT
// ═══════════════════════════════════════════════════════════════════════════════

/// Custom destructor logic.
/// 
/// When a value goes out of scope, `drop` is called (if implemented).
/// The compiler then recursively drops all fields.
/// 
/// # Drop Order
/// 1. The `drop` method is called (if implemented)
/// 2. Fields are dropped in declaration order
/// 3. For enums, only the active variant's fields are dropped
/// 
/// # Relationship with Copy
/// `Drop` and `Copy` are mutually exclusive. Types implementing `Copy`
/// must not implement `Drop`.
/// 
/// # Panics
/// Panicking in `drop` during unwinding causes a double panic (abort).
#[lang = "drop"]
pub trait Drop {
    /// Called when the value goes out of scope.
    /// 
    /// # Important
    /// - Do not call this method manually; use `drop(value)` instead
    /// - After this returns, fields are dropped automatically
    /// - Panicking here during unwinding will abort
    fn drop(&mut self);
}

/// Drops a value, running its destructor.
/// 
/// This is the idiomatic way to explicitly drop a value:
/// ```
/// let x = expensive_resource();
/// // ... use x ...
/// drop(x);  // Explicitly release now
/// // x is no longer accessible
/// ```
#[inline]
pub fn drop<T>(_x: T) {
    // Value is moved into this function and dropped at the end
}

// ═══════════════════════════════════════════════════════════════════════════════
// SEND AND SYNC TRAITS
// ═══════════════════════════════════════════════════════════════════════════════

/// Types that can be transferred across thread boundaries.
/// 
/// `Send` indicates that ownership of the type can be moved to another thread.
/// 
/// Automatically implemented for types where all components are `Send`.
/// 
/// NOT Send:
/// - `Rc<T>` - non-atomic reference counting
/// - `*const T`, `*mut T` - raw pointers (unsafe to send)
/// - Types with thread-local state
#[lang = "send"]
pub unsafe auto trait Send {
    // Auto trait - automatically implemented
}

/// Types for which shared references can be sent across threads.
/// 
/// `T: Sync` means `&T: Send` - a shared reference to T can be sent.
/// 
/// This implies that T can be safely accessed from multiple threads
/// via shared references.
/// 
/// Automatically implemented for types where all components are `Sync`.
/// 
/// NOT Sync:
/// - `Cell<T>`, `RefCell<T>` - interior mutability without synchronization
/// - `Rc<T>` - non-atomic reference counting
/// - Types with non-thread-safe interior mutability
#[lang = "sync"]
pub unsafe auto trait Sync {
    // Auto trait - automatically implemented
}

// Raw pointers are !Send and !Sync by default
impl<T: ?Sized> !Send for *const T {}
impl<T: ?Sized> !Send for *mut T {}
impl<T: ?Sized> !Sync for *const T {}
impl<T: ?Sized> !Sync for *mut T {}

// Shared references are Send if T is Sync
unsafe impl<T: ?Sized + Sync> Send for &T {}

// Mutable references are Send if T is Send
unsafe impl<T: ?Sized + Send> Send for &mut T {}

// Shared references are Sync if T is Sync
unsafe impl<T: ?Sized + Sync> Sync for &T {}

// Mutable references are Sync if T is Sync
unsafe impl<T: ?Sized + Sync> Sync for &mut T {}

// ═══════════════════════════════════════════════════════════════════════════════
// UNPIN TRAIT
// ═══════════════════════════════════════════════════════════════════════════════

/// Types that can be safely moved after being pinned.
/// 
/// Most types are `Unpin` because they don't contain self-references.
/// Types implementing `Future` with self-referential state must be `!Unpin`.
/// 
/// # Pin API
/// `Pin<P>` prevents moving the value pointed to by `P`.
/// For `Unpin` types, `Pin<&mut T>` behaves like `&mut T`.
#[lang = "unpin"]
pub auto trait Unpin {
    // Auto trait - automatically implemented for most types
}

/// Marker type that is `!Unpin`.
/// 
/// Used as a field in types that should not be `Unpin`:
/// ```
/// struct SelfReferential {
///     data: String,
///     ptr: *const u8,  // Points into data
///     _pin: PhantomPinned,
/// }
/// ```
#[derive(Debug, Copy, Clone, Eq, PartialEq, Ord, PartialOrd, Hash, Default)]
pub struct PhantomPinned;

impl !Unpin for PhantomPinned {}

// ═══════════════════════════════════════════════════════════════════════════════
// LINEAR TYPE MARKERS
// ═══════════════════════════════════════════════════════════════════════════════

/// Marker trait for linear types (must be used exactly once).
/// 
/// Linear types provide compile-time resource safety:
/// - Cannot be implicitly dropped
/// - Cannot be copied
/// - Must be explicitly consumed
/// 
/// Use cases:
/// - File handles that must be closed
/// - Network connections
/// - Locks that must be released
/// - Transaction contexts
#[lang = "linear"]
pub trait Linear {
    // Marker trait - the compiler enforces linearity
}

/// Marker trait for affine types (may be used at most once).
/// 
/// Affine types are like linear types but can be dropped without use.
/// They still cannot be copied.
/// 
/// Use cases:
/// - Optional cleanup resources
/// - Move-only types with Drop
#[lang = "affine"]
pub trait Affine {
    // Marker trait - the compiler enforces affinity
}

/// Wrapper to make any type linear.
/// 
/// ```
/// let handle = Linear::new(open_file("test.txt")?);
/// // handle MUST be consumed - compiler error if dropped
/// handle.consume(|f| f.close());
/// ```
#[repr(transparent)]
pub struct LinearWrapper<T> {
    inner: T,
}

impl<T> Linear for LinearWrapper<T> {}

impl<T> LinearWrapper<T> {
    /// Wrap a value in a linear wrapper.
    #[inline]
    pub const fn new(value: T) -> Self {
        LinearWrapper { inner: value }
    }
    
    /// Consume the linear wrapper, returning the inner value.
    /// 
    /// This is the ONLY way to access the inner value.
    #[inline]
    pub fn consume(self) -> T {
        self.inner
    }
    
    /// Consume with a function.
    #[inline]
    pub fn consume_with<F, R>(self, f: F) -> R
    where
        F: FnOnce(T) -> R,
    {
        f(self.inner)
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// PHANTOM DATA
// ═══════════════════════════════════════════════════════════════════════════════

/// Zero-sized marker type for phantom type parameters.
/// 
/// Use when:
/// - A type parameter is used for type checking but not stored
/// - You need to indicate ownership/variance of a type parameter
/// 
/// Common patterns:
/// ```
/// // Indicates T is owned (drop check, covariance)
/// struct MyBox<T> {
///     ptr: *const T,
///     _marker: PhantomData<T>,
/// }
/// 
/// // Indicates shared access to T
/// struct Ref<'a, T> {
///     ptr: *const T,
///     _marker: PhantomData<&'a T>,
/// }
/// 
/// // Indicates mutable access to T
/// struct RefMut<'a, T> {
///     ptr: *mut T,
///     _marker: PhantomData<&'a mut T>,
/// }
/// ```
#[lang = "phantom_data"]
#[derive(Copy, Clone, PartialEq, Eq, PartialOrd, Ord, Hash)]
pub struct PhantomData<T: ?Sized>;

impl<T: ?Sized> Default for PhantomData<T> {
    fn default() -> Self {
        PhantomData
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// DISCRIMINANT KIND
// ═══════════════════════════════════════════════════════════════════════════════

/// Marker trait for types that can be used as enum discriminants.
/// 
/// The compiler knows about this trait for `#[repr(int)]` enums.
#[lang = "discriminant_kind"]
pub trait DiscriminantKind {
    /// The type of the discriminant.
    type Discriminant: Clone + Copy + PartialEq + Eq + PartialOrd + Ord + Hash;
}

// ═══════════════════════════════════════════════════════════════════════════════
// DESTRUCT TRAIT
// ═══════════════════════════════════════════════════════════════════════════════

/// Marker trait for types that can be destructured in patterns.
/// 
/// This is automatically implemented for:
/// - Structs with public fields
/// - Enums with public variants
/// - Tuples
#[lang = "destruct"]
pub trait Destruct {
    // Marker trait
}

// ═══════════════════════════════════════════════════════════════════════════════
// TUPLE TRAIT
// ═══════════════════════════════════════════════════════════════════════════════

/// Marker trait for tuple types.
#[lang = "tuple_trait"]
pub trait Tuple {
    // Marker trait
}

// Implemented for all tuple types by the compiler
impl Tuple for () {}
impl<T0> Tuple for (T0,) {}
impl<T0, T1> Tuple for (T0, T1) {}
impl<T0, T1, T2> Tuple for (T0, T1, T2) {}
impl<T0, T1, T2, T3> Tuple for (T0, T1, T2, T3) {}
impl<T0, T1, T2, T3, T4> Tuple for (T0, T1, T2, T3, T4) {}
impl<T0, T1, T2, T3, T4, T5> Tuple for (T0, T1, T2, T3, T4, T5) {}
impl<T0, T1, T2, T3, T4, T5, T6> Tuple for (T0, T1, T2, T3, T4, T5, T6) {}
impl<T0, T1, T2, T3, T4, T5, T6, T7> Tuple for (T0, T1, T2, T3, T4, T5, T6, T7) {}
// ... and so on up to 12 elements

// ═══════════════════════════════════════════════════════════════════════════════
// FREEZE TRAIT
// ═══════════════════════════════════════════════════════════════════════════════

/// Marker for types without interior mutability.
/// 
/// Types that are `Freeze` have no way to mutate their contents through
/// shared references. This is used for optimization (placing in read-only memory).
/// 
/// `UnsafeCell` is the only primitive type that is `!Freeze`.
#[lang = "freeze"]
pub unsafe auto trait Freeze {
    // Auto trait
}

// UnsafeCell is the primitive !Freeze type
// impl<T: ?Sized> !Freeze for UnsafeCell<T> {}

