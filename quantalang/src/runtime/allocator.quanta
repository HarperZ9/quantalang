// CONFIGURATION
// ═══════════════════════════════════════════════════════════════════════════════

/// Allocator configuration
#[derive(Debug, Clone)]
pub struct AllocatorConfig {
    /// Page size (typically 4KB or 2MB for huge pages)
    pub page_size: usize,
    /// Small object threshold
    pub small_object_max: usize,
    /// Medium object threshold
    pub medium_object_max: usize,
    /// Large object threshold (above this -> LOS)
    pub large_object_min: usize,
    /// Thread cache size
    pub thread_cache_size: usize,
    /// Number of size classes
    pub num_size_classes: usize,
    /// Enable NUMA awareness
    pub numa_aware: bool,
    /// Enable huge pages
    pub huge_pages: bool,
    /// Arena size
    pub arena_size: usize,
}

impl Default for AllocatorConfig {
    fn default() -> Self {
        AllocatorConfig {
            page_size: 4096,
            small_object_max: 256,
            medium_object_max: 32768,
            large_object_min: 32768,
            thread_cache_size: 2 * 1024 * 1024, // 2MB
            num_size_classes: 68,
            numa_aware: false,
            huge_pages: false,
            arena_size: 64 * 1024 * 1024, // 64MB
        }
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// SIZE CLASSES
// ═══════════════════════════════════════════════════════════════════════════════

/// Size class for segregated allocation
#[derive(Debug, Clone, Copy)]
pub struct SizeClass {
    /// Size of objects in this class
    pub size: usize,
    /// Number of objects per slab
    pub objects_per_slab: usize,
    /// Slab size in pages
    pub pages_per_slab: usize,
    /// Index in size class table
    pub index: u8,
}

impl SizeClass {
    /// Compute size class for a given size
    pub fn for_size(size: usize) -> SizeClass {
        let aligned = Self::align_size(size);
        let index = Self::size_to_index(aligned);
        let class_size = Self::index_to_size(index);
        
        // Compute slab parameters
        let page_size = 4096;
        let min_objects = 8;
        let slab_size = ((class_size * min_objects + page_size - 1) / page_size) * page_size;
        
        SizeClass {
            size: class_size,
            objects_per_slab: slab_size / class_size,
            pages_per_slab: slab_size / page_size,
            index: index as u8,
        }
    }
    
    fn align_size(size: usize) -> usize {
        const MIN_ALIGN: usize = 16;
        let aligned = (size + MIN_ALIGN - 1) & !(MIN_ALIGN - 1);
        aligned.max(MIN_ALIGN)
    }
    
    fn size_to_index(size: usize) -> usize {
        if size <= 128 {
            // 16-byte increments: 16, 32, 48, 64, 80, 96, 112, 128
            (size + 15) / 16 - 1
        } else if size <= 256 {
            // 32-byte increments: 160, 192, 224, 256
            8 + (size - 128 + 31) / 32 - 1
        } else if size <= 512 {
            // 64-byte increments
            12 + (size - 256 + 63) / 64 - 1
        } else if size <= 1024 {
            // 128-byte increments
            16 + (size - 512 + 127) / 128 - 1
        } else if size <= 2048 {
            // 256-byte increments
            20 + (size - 1024 + 255) / 256 - 1
        } else if size <= 4096 {
            // 512-byte increments
            24 + (size - 2048 + 511) / 512 - 1
        } else if size <= 8192 {
            // 1024-byte increments
            28 + (size - 4096 + 1023) / 1024 - 1
        } else if size <= 16384 {
            // 2048-byte increments
            32 + (size - 8192 + 2047) / 2048 - 1
        } else if size <= 32768 {
            // 4096-byte increments
            36 + (size - 16384 + 4095) / 4096 - 1
        } else {
            // Large object
            40
        }
    }
    
    fn index_to_size(index: usize) -> usize {
        if index < 8 {
            (index + 1) * 16
        } else if index < 12 {
            128 + (index - 8 + 1) * 32
        } else if index < 16 {
            256 + (index - 12 + 1) * 64
        } else if index < 20 {
            512 + (index - 16 + 1) * 128
        } else if index < 24 {
            1024 + (index - 20 + 1) * 256
        } else if index < 28 {
            2048 + (index - 24 + 1) * 512
        } else if index < 32 {
            4096 + (index - 28 + 1) * 1024
        } else if index < 36 {
            8192 + (index - 32 + 1) * 2048
        } else if index < 40 {
            16384 + (index - 36 + 1) * 4096
        } else {
            32768
        }
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// FREE LIST
// ═══════════════════════════════════════════════════════════════════════════════

/// Lock-free free list node
#[repr(C)]
pub struct FreeNode {
    next: AtomicPtr<FreeNode>,
}

impl FreeNode {
    pub fn new() -> Self {
        FreeNode {
            next: AtomicPtr::new(core::ptr::null_mut()),
        }
    }
}

/// Lock-free free list
pub struct FreeList {
    head: AtomicPtr<FreeNode>,
    count: AtomicUsize,
}

impl FreeList {
    pub fn new() -> Self {
        FreeList {
            head: AtomicPtr::new(core::ptr::null_mut()),
            count: AtomicUsize::new(0),
        }
    }
    
    /// Push a node onto the free list
    pub fn push(&self, ptr: *mut u8) {
        let node = ptr as *mut FreeNode;
        
        loop {
            let old_head = self.head.load(Ordering::Acquire);
            unsafe { (*node).next.store(old_head, Ordering::Relaxed); }
            
            if self.head.compare_exchange_weak(
                old_head,
                node,
                Ordering::Release,
                Ordering::Relaxed,
            ).is_ok() {
                self.count.fetch_add(1, Ordering::Relaxed);
                return;
            }
        }
    }
    
    /// Pop a node from the free list
    pub fn pop(&self) -> Option<*mut u8> {
        loop {
            let head = self.head.load(Ordering::Acquire);
            
            if head.is_null() {
                return None;
            }
            
            let next = unsafe { (*head).next.load(Ordering::Relaxed) };
            
            if self.head.compare_exchange_weak(
                head,
                next,
                Ordering::Release,
                Ordering::Relaxed,
            ).is_ok() {
                self.count.fetch_sub(1, Ordering::Relaxed);
                return Some(head as *mut u8);
            }
        }
    }
    
    /// Get count
    pub fn len(&self) -> usize {
        self.count.load(Ordering::Relaxed)
    }
    
    pub fn is_empty(&self) -> bool {
        self.len() == 0
    }
}

impl Default for FreeList {
    fn default() -> Self {
        Self::new()
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// SLAB
// ═══════════════════════════════════════════════════════════════════════════════

/// Slab state
#[derive(Debug, Clone, Copy, PartialEq, Eq)]
pub enum SlabState {
    /// Slab has free objects
    Partial,
    /// Slab is completely full
    Full,
    /// Slab is completely empty
    Empty,
}

/// Slab header
#[repr(C)]
pub struct Slab {
    /// Size class
    pub size_class: SizeClass,
    /// State
    pub state: SlabState,
    /// Number of allocated objects
    pub allocated: usize,
    /// Free list within slab
    pub free_list: FreeList,
    /// Start of object area
    pub objects: *mut u8,
    /// Next slab in partial list
    pub next: *mut Slab,
    /// Previous slab in partial list
    pub prev: *mut Slab,
}

impl Slab {
    /// Initialize a new slab
    pub unsafe fn init(ptr: *mut u8, size_class: SizeClass) -> *mut Slab {
        let slab = ptr as *mut Slab;
        let header_size = mem::size_of::<Slab>();
        let aligned_header = (header_size + 15) & !15;
        
        (*slab).size_class = size_class;
        (*slab).state = SlabState::Empty;
        (*slab).allocated = 0;
        (*slab).free_list = FreeList::new();
        (*slab).objects = ptr.add(aligned_header);
        (*slab).next = core::ptr::null_mut();
        (*slab).prev = core::ptr::null_mut();
        
        // Initialize free list with all objects
        let object_size = size_class.size;
        let objects_start = (*slab).objects;
        
        for i in 0..size_class.objects_per_slab {
            let obj = objects_start.add(i * object_size);
            (*slab).free_list.push(obj);
        }
        
        slab
    }
    
    /// Allocate from slab
    pub fn alloc(&mut self) -> Option<*mut u8> {
        if let Some(ptr) = self.free_list.pop() {
            self.allocated += 1;
            
            if self.free_list.is_empty() {
                self.state = SlabState::Full;
            } else {
                self.state = SlabState::Partial;
            }
            
            Some(ptr)
        } else {
            None
        }
    }
    
    /// Free to slab
    pub fn free(&mut self, ptr: *mut u8) {
        self.free_list.push(ptr);
        self.allocated -= 1;
        
        if self.allocated == 0 {
            self.state = SlabState::Empty;
        } else {
            self.state = SlabState::Partial;
        }
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// THREAD CACHE
// ═══════════════════════════════════════════════════════════════════════════════

/// Per-thread allocation cache
pub struct ThreadCache {
    /// Free lists per size class
    free_lists: Vec<FreeList>,
    /// Maximum objects per size class
    max_objects: Vec<usize>,
    /// Current thread ID
    thread_id: usize,
    /// Statistics
    stats: ThreadCacheStats,
}

/// Thread cache statistics
#[derive(Debug, Clone, Default)]
pub struct ThreadCacheStats {
    pub allocations: usize,
    pub frees: usize,
    pub cache_hits: usize,
    pub cache_misses: usize,
}

impl ThreadCache {
    pub fn new(num_size_classes: usize) -> Self {
        let mut free_lists = Vec::with_capacity(num_size_classes);
        let mut max_objects = Vec::with_capacity(num_size_classes);
        
        for i in 0..num_size_classes {
            free_lists.push(FreeList::new());
            // Smaller size classes get more cached objects
            let size_class = SizeClass::for_size((i + 1) * 16);
            max_objects.push(32768 / size_class.size.max(1));
        }
        
        ThreadCache {
            free_lists,
            max_objects,
            thread_id: 0,
            stats: ThreadCacheStats::default(),
        }
    }
    
    /// Allocate from thread cache
    pub fn alloc(&mut self, size_class: &SizeClass) -> Option<*mut u8> {
        let idx = size_class.index as usize;
        
        if idx < self.free_lists.len() {
            if let Some(ptr) = self.free_lists[idx].pop() {
                self.stats.allocations += 1;
                self.stats.cache_hits += 1;
                return Some(ptr);
            }
            self.stats.cache_misses += 1;
        }
        
        None
    }
    
    /// Free to thread cache
    pub fn free(&mut self, ptr: *mut u8, size_class: &SizeClass) -> bool {
        let idx = size_class.index as usize;
        
        if idx < self.free_lists.len() {
            if self.free_lists[idx].len() < self.max_objects[idx] {
                self.free_lists[idx].push(ptr);
                self.stats.frees += 1;
                return true;
            }
        }
        
        false
    }
    
    /// Flush cache to central allocator
    pub fn flush(&mut self) -> Vec<(*mut u8, SizeClass)> {
        let mut flushed = Vec::new();
        
        for (idx, list) in self.free_lists.iter().enumerate() {
            while let Some(ptr) = list.pop() {
                let size_class = SizeClass::for_size((idx + 1) * 16);
                flushed.push((ptr, size_class));
            }
        }
        
        flushed
    }
    
    pub fn stats(&self) -> &ThreadCacheStats {
        &self.stats
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// ARENA
// ═══════════════════════════════════════════════════════════════════════════════

/// Memory arena
pub struct Arena {
    /// Arena base address
    pub base: *mut u8,
    /// Arena size
    pub size: usize,
    /// Current allocation offset
    pub offset: AtomicUsize,
    /// Arena ID
    pub id: usize,
    /// NUMA node (if applicable)
    pub numa_node: Option<usize>,
}

impl Arena {
    /// Create new arena (memory must be pre-allocated)
    pub unsafe fn new(base: *mut u8, size: usize, id: usize) -> Self {
        Arena {
            base,
            size,
            offset: AtomicUsize::new(0),
            id,
            numa_node: None,
        }
    }
    
    /// Bump allocate from arena
    pub fn bump_alloc(&self, size: usize, align: usize) -> Option<*mut u8> {
        loop {
            let current = self.offset.load(Ordering::Relaxed);
            let aligned = (current + align - 1) & !(align - 1);
            let new_offset = aligned + size;
            
            if new_offset > self.size {
                return None;
            }
            
            if self.offset.compare_exchange_weak(
                current,
                new_offset,
                Ordering::Release,
                Ordering::Relaxed,
            ).is_ok() {
                return Some(unsafe { self.base.add(aligned) });
            }
        }
    }
    
    /// Reset arena (bulk free)
    pub fn reset(&self) {
        self.offset.store(0, Ordering::Release);
    }
    
    /// Remaining space
    pub fn remaining(&self) -> usize {
        self.size - self.offset.load(Ordering::Relaxed)
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// LARGE OBJECT SPACE
// ═══════════════════════════════════════════════════════════════════════════════

/// Large object header
#[repr(C)]
pub struct LargeObject {
    /// Object size
    pub size: usize,
    /// Next in list
    pub next: *mut LargeObject,
    /// Previous in list
    pub prev: *mut LargeObject,
    /// Flags
    pub flags: u32,
}

/// Large Object Space
pub struct LOS {
    /// List of large objects
    head: AtomicPtr<LargeObject>,
    /// Total allocated
    total_allocated: AtomicUsize,
    /// Object count
    count: AtomicUsize,
}

impl LOS {
    pub fn new() -> Self {
        LOS {
            head: AtomicPtr::new(core::ptr::null_mut()),
            total_allocated: AtomicUsize::new(0),
            count: AtomicUsize::new(0),
        }
    }
    
    /// Allocate large object
    pub unsafe fn alloc(&self, size: usize) -> Option<*mut u8> {
        let total_size = size + mem::size_of::<LargeObject>();
        
        // Request memory from OS (simplified - real impl uses mmap)
        let ptr = Self::os_alloc(total_size)?;
        
        let header = ptr as *mut LargeObject;
        (*header).size = size;
        (*header).flags = 0;
        
        // Add to list
        loop {
            let old_head = self.head.load(Ordering::Acquire);
            (*header).next = old_head;
            (*header).prev = core::ptr::null_mut();
            
            if self.head.compare_exchange_weak(
                old_head,
                header,
                Ordering::Release,
                Ordering::Relaxed,
            ).is_ok() {
                if !old_head.is_null() {
                    (*old_head).prev = header;
                }
                break;
            }
        }
        
        self.total_allocated.fetch_add(total_size, Ordering::Relaxed);
        self.count.fetch_add(1, Ordering::Relaxed);
        
        Some(ptr.add(mem::size_of::<LargeObject>()))
    }
    
    /// Free large object
    pub unsafe fn free(&self, ptr: *mut u8) {
        let header = ptr.sub(mem::size_of::<LargeObject>()) as *mut LargeObject;
        let size = (*header).size;
        let total_size = size + mem::size_of::<LargeObject>();
        
        // Remove from list (simplified - needs proper synchronization)
        let prev = (*header).prev;
        let next = (*header).next;
        
        if !prev.is_null() {
            (*prev).next = next;
        } else {
            self.head.store(next, Ordering::Release);
        }
        
        if !next.is_null() {
            (*next).prev = prev;
        }
        
        self.total_allocated.fetch_sub(total_size, Ordering::Relaxed);
        self.count.fetch_sub(1, Ordering::Relaxed);
        
        Self::os_free(header as *mut u8, total_size);
    }
    
    fn os_alloc(size: usize) -> Option<*mut u8> {
        // Placeholder - real implementation uses platform APIs
        Some(core::ptr::null_mut())
    }
    
    fn os_free(ptr: *mut u8, size: usize) {
        // Placeholder - real implementation uses platform APIs
    }
    
    pub fn total_allocated(&self) -> usize {
        self.total_allocated.load(Ordering::Relaxed)
    }
    
    pub fn count(&self) -> usize {
        self.count.load(Ordering::Relaxed)
    }
}

impl Default for LOS {
    fn default() -> Self {
        Self::new()
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// CENTRAL ALLOCATOR
// ═══════════════════════════════════════════════════════════════════════════════

/// Central allocator
pub struct CentralAllocator {
    /// Configuration
    config: AllocatorConfig,
    /// Partial slabs per size class
    partial_slabs: Vec<AtomicPtr<Slab>>,
    /// Large object space
    los: LOS,
    /// Arenas
    arenas: Vec<Arena>,
    /// Statistics
    stats: AllocatorStats,
}

/// Allocator statistics
#[derive(Debug, Clone, Default)]
pub struct AllocatorStats {
    pub total_allocated: AtomicUsize,
    pub total_freed: AtomicUsize,
    pub allocations: AtomicUsize,
    pub frees: AtomicUsize,
    pub slabs_created: AtomicUsize,
    pub large_allocations: AtomicUsize,
}

impl CentralAllocator {
    pub fn new(config: AllocatorConfig) -> Self {
        let mut partial_slabs = Vec::with_capacity(config.num_size_classes);
        
        for _ in 0..config.num_size_classes {
            partial_slabs.push(AtomicPtr::new(core::ptr::null_mut()));
        }
        
        CentralAllocator {
            config,
            partial_slabs,
            los: LOS::new(),
            arenas: Vec::new(),
            stats: AllocatorStats::default(),
        }
    }
    
    /// Allocate memory
    pub fn alloc(&self, size: usize) -> Option<*mut u8> {
        if size == 0 {
            return None;
        }
        
        // Large object?
        if size >= self.config.large_object_min {
            self.stats.large_allocations.fetch_add(1, Ordering::Relaxed);
            return unsafe { self.los.alloc(size) };
        }
        
        let size_class = SizeClass::for_size(size);
        let idx = size_class.index as usize;
        
        // Try partial slab
        if idx < self.partial_slabs.len() {
            let slab_ptr = self.partial_slabs[idx].load(Ordering::Acquire);
            
            if !slab_ptr.is_null() {
                let slab = unsafe { &mut *slab_ptr };
                if let Some(ptr) = slab.alloc() {
                    self.stats.allocations.fetch_add(1, Ordering::Relaxed);
                    self.stats.total_allocated.fetch_add(size_class.size, Ordering::Relaxed);
                    return Some(ptr);
                }
            }
        }
        
        // Need new slab
        self.alloc_new_slab(size_class)
    }
    
    fn alloc_new_slab(&self, size_class: SizeClass) -> Option<*mut u8> {
        // Allocate slab from arena or OS
        let slab_size = size_class.pages_per_slab * self.config.page_size;
        
        // Simplified - real impl manages arena allocation
        let slab_mem = self.alloc_pages(size_class.pages_per_slab)?;
        
        let slab = unsafe { Slab::init(slab_mem, size_class) };
        self.stats.slabs_created.fetch_add(1, Ordering::Relaxed);
        
        // Add to partial list
        let idx = size_class.index as usize;
        if idx < self.partial_slabs.len() {
            self.partial_slabs[idx].store(slab, Ordering::Release);
        }
        
        // Allocate from new slab
        unsafe { (*slab).alloc() }
    }
    
    fn alloc_pages(&self, pages: usize) -> Option<*mut u8> {
        // Placeholder
        Some(core::ptr::null_mut())
    }
    
    /// Free memory
    pub fn free(&self, ptr: *mut u8, size: usize) {
        if ptr.is_null() || size == 0 {
            return;
        }
        
        // Large object?
        if size >= self.config.large_object_min {
            unsafe { self.los.free(ptr); }
            return;
        }
        
        let size_class = SizeClass::for_size(size);
        self.stats.frees.fetch_add(1, Ordering::Relaxed);
        self.stats.total_freed.fetch_add(size_class.size, Ordering::Relaxed);
        
        // Find owning slab and free (simplified)
        // Real implementation maintains slab metadata for lookup
    }
    
    pub fn stats(&self) -> &AllocatorStats {
        &self.stats
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// GLOBAL ALLOCATOR INTERFACE
// ═══════════════════════════════════════════════════════════════════════════════

/// Global allocator instance
static mut GLOBAL_ALLOCATOR: Option<CentralAllocator> = None;

/// Thread-local cache
#[thread_local]
static mut THREAD_CACHE: Option<ThreadCache> = None;

/// Initialize the allocator
pub fn init(config: AllocatorConfig) {
    unsafe {
        GLOBAL_ALLOCATOR = Some(CentralAllocator::new(config));
    }
}

/// Allocate memory
pub fn alloc(size: usize) -> *mut u8 {
    unsafe {
        // Try thread cache first
        if let Some(ref mut cache) = THREAD_CACHE {
            let size_class = SizeClass::for_size(size);
            if let Some(ptr) = cache.alloc(&size_class) {
                return ptr;
            }
        }
        
        // Fall back to central allocator
        if let Some(ref allocator) = GLOBAL_ALLOCATOR {
            allocator.alloc(size).unwrap_or(core::ptr::null_mut())
        } else {
            core::ptr::null_mut()
        }
    }
}

/// Free memory
pub fn free(ptr: *mut u8, size: usize) {
    unsafe {
        // Try thread cache first
        if let Some(ref mut cache) = THREAD_CACHE {
            let size_class = SizeClass::for_size(size);
            if cache.free(ptr, &size_class) {
                return;
            }
        }
        
        // Fall back to central allocator
        if let Some(ref allocator) = GLOBAL_ALLOCATOR {
            allocator.free(ptr, size);
        }
    }
}

/// Allocate zeroed memory
pub fn alloc_zeroed(size: usize) -> *mut u8 {
    let ptr = alloc(size);
    if !ptr.is_null() {
        unsafe { core::ptr::write_bytes(ptr, 0, size); }
    }
    ptr
}

/// Reallocate memory
pub fn realloc(ptr: *mut u8, old_size: usize, new_size: usize) -> *mut u8 {
    if ptr.is_null() {
        return alloc(new_size);
    }
    
    if new_size == 0 {
        free(ptr, old_size);
        return core::ptr::null_mut();
    }
    
    // Check if same size class
    let old_class = SizeClass::for_size(old_size);
    let new_class = SizeClass::for_size(new_size);
    
    if old_class.size >= new_size {
        return ptr;
    }
    
    // Allocate new and copy
    let new_ptr = alloc(new_size);
    if !new_ptr.is_null() {
        unsafe {
            core::ptr::copy_nonoverlapping(ptr, new_ptr, old_size.min(new_size));
        }
        free(ptr, old_size);
    }
    new_ptr
}

// ═══════════════════════════════════════════════════════════════════════════════
// TESTS
// ═══════════════════════════════════════════════════════════════════════════════

#[cfg(test)]
mod tests {
    use super::*;
    
    #[test]
    fn test_size_class() {
        let sc = SizeClass::for_size(24);
        assert!(sc.size >= 24);
        assert!(sc.size <= 32);
        
        let sc = SizeClass::for_size(100);
        assert!(sc.size >= 100);
        assert!(sc.size <= 128);
    }
    
    #[test]
    fn test_free_list() {
        let list = FreeList::new();
        assert!(list.is_empty());
        
        let mut buffer = [0u8; 64];
        list.push(buffer.as_mut_ptr());
        
        assert_eq!(list.len(), 1);
        
        let ptr = list.pop();
        assert!(ptr.is_some());
        assert!(list.is_empty());
    }
    
    #[test]
    fn test_allocator_config() {
        let config = AllocatorConfig::default();
        assert_eq!(config.page_size, 4096);
        assert!(config.arena_size > 0);
    }
}
