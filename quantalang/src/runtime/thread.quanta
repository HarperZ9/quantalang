#[cfg(test)]
mod tests {
    use super::*;
    
    #[test]
    fn test_thread_id() {
        let id1 = ThreadId::new();
        let id2 = ThreadId::new();
        
        assert_ne!(id1, id2);
        assert!(id1.is_valid());
        assert!(!ThreadId::INVALID.is_valid());
    }
    
    #[test]
    fn test_work_deque() {
        let mut deque = WorkDeque::new(16);
        
        let item = WorkItem {
            func: |_| {},
            data: core::ptr::null_mut(),
            priority: 0,
        };
        
        assert!(deque.is_empty());
        assert!(deque.push(item.clone()));
        assert_eq!(deque.len(), 1);
        
        let popped = deque.pop();
        assert!(popped.is_some());
        assert!(deque.is_empty());
    }
    
    #[test]
    fn test_safepoint() {
        let sp = SafepointManager::new();
        
        assert!(!sp.is_requested());
        
        sp.register_thread();
        sp.register_thread();
        
        // Would need full test with actual threads
    }
}
