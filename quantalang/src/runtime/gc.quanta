    /// Get current phase
    pub fn phase(&self) -> GCPhase {
        match self.phase.load(Ordering::Acquire) {
            0 => GCPhase::Idle,
            1 => GCPhase::Mark,
            2 => GCPhase::Sweep,
            _ => GCPhase::Compact,
        }
    }
    
    /// Get statistics
    pub fn stats(&self) -> &GCStats {
