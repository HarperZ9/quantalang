// ═══════════════════════════════════════════════════════════════════════════════
// CONCURRENT MARKER
// ═══════════════════════════════════════════════════════════════════════════════

/// Concurrent marking state
pub struct ConcurrentMarker {
    /// Mark stack for concurrent work
    work_stack: MarkStack,
    /// Bytes marked
    bytes_marked: AtomicUsize,
    /// Objects marked
    objects_marked: AtomicUsize,
    /// Is marking complete?
    complete: AtomicBool,
}

impl ConcurrentMarker {
    pub fn new() -> Self {
        ConcurrentMarker {
            work_stack: MarkStack::new(65536),
            bytes_marked: AtomicUsize::new(0),
            objects_marked: AtomicUsize::new(0),
            complete: AtomicBool::new(false),
        }
    }
    
    /// Do incremental marking work
    pub fn do_work(&mut self, max_work: usize) -> bool {
        let mut work_done = 0;
        
        while work_done < max_work {
            if let Some(obj) = self.work_stack.pop() {
                unsafe {
                    let header = ObjectHeader::from_ptr(obj);
                    work_done += (*header).size as usize;
                }
                self.objects_marked.fetch_add(1, Ordering::Relaxed);
            } else {
                self.complete.store(true, Ordering::Release);
                return true;
            }
        }
        
        false
    }
    
    pub fn is_complete(&self) -> bool {
        self.complete.load(Ordering::Acquire)
    }
}

impl Default for ConcurrentMarker {
    fn default() -> Self {
        Self::new()
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// FINALIZERS
// ═══════════════════════════════════════════════════════════════════════════════

/// Finalizer queue
pub struct FinalizerQueue {
    /// Objects pending finalization
    pending: Vec<*mut u8>,
    /// Objects being finalized
    running: Vec<*mut u8>,
}

impl FinalizerQueue {
    pub fn new() -> Self {
        FinalizerQueue {
            pending: Vec::new(),
            running: Vec::new(),
        }
    }
    
    /// Queue object for finalization
    pub fn enqueue(&mut self, obj: *mut u8) {
        self.pending.push(obj);
    }
    
    /// Run pending finalizers
    pub fn run_finalizers(&mut self) {
        mem::swap(&mut self.pending, &mut self.running);
        
        for obj in self.running.drain(..) {
            unsafe {
                let header = ObjectHeader::from_ptr(obj);
                let type_info = (*header).type_info;
                
                if !type_info.is_null() {
                    if let Some(finalizer) = (*type_info).finalizer {
                        finalizer(obj);
                    }
                }
            }
        }
    }
    
    pub fn has_pending(&self) -> bool {
        !self.pending.is_empty()
    }
}

impl Default for FinalizerQueue {
    fn default() -> Self {
        Self::new()
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// TESTS
// ═══════════════════════════════════════════════════════════════════════════════

#[cfg(test)]
mod tests {
    use super::*;
    
    #[test]
    fn test_object_flags() {
        let mut flags = ObjectFlags::new();
        
        assert_eq!(flags.mark_state(), MarkState::White);
        flags.set_mark_state(MarkState::Gray);
        assert_eq!(flags.mark_state(), MarkState::Gray);
        
        assert!(!flags.is_pinned());
        flags.set_pinned(true);
        assert!(flags.is_pinned());
        
        assert_eq!(flags.age(), 0);
        flags.increment_age();
        assert_eq!(flags.age(), 1);
    }
    
    #[test]
    fn test_card_table() {
        let table = CardTable::new(1024 * 1024, 9);
        
        table.mark_dirty(512);
        assert!(table.is_dirty(1));
        
        table.clear(1);
        assert!(!table.is_dirty(1));
    }
    
    #[test]
    fn test_mark_stack() {
        let mut stack = MarkStack::new(100);
        assert!(stack.is_empty());
        
        let ptr = 0x1000 as *mut u8;
        stack.push(ptr);
        
        assert_eq!(stack.len(), 1);
        assert_eq!(stack.pop(), Some(ptr));
        assert!(stack.is_empty());
    }
}
