// ═══════════════════════════════════════════════════════════════════════════════
// TESTS
// ═══════════════════════════════════════════════════════════════════════════════

#[cfg(test)]
mod tests {
    use super::*;
    
    #[test]
    fn test_config_minimal() {
        let config = HardeningConfig::minimal();
        assert!(!config.memory_safety);
        assert!(config.stack_canary);
        assert_eq!(config.cfi.level, CfiLevel::None);
    }
    
    #[test]
    fn test_config_standard() {
        let config = HardeningConfig::standard();
        assert!(config.memory_safety);
        assert!(config.stack_canary);
        assert_eq!(config.cfi.level, CfiLevel::Basic);
    }
    
    #[test]
    fn test_config_maximum() {
        let config = HardeningConfig::maximum();
        assert!(config.memory_safety);
        assert!(config.guard_pages.heap_guard);
        assert!(config.uaf_detection.quarantine_enabled);
        assert_eq!(config.cfi.level, CfiLevel::Full);
        assert!(config.cfi.shadow_stack);
    }
    
    #[test]
    fn test_config_builder() {
        let config = HardeningConfig::builder()
            .memory_safety(true)
            .cfi_level(CfiLevel::Strict)
            .shadow_stack(true)
            .uaf_detection(true)
            .build();
        
        assert!(config.memory_safety);
        assert_eq!(config.cfi.level, CfiLevel::Strict);
        assert!(config.cfi.shadow_stack);
        assert!(config.uaf_detection.enabled);
    }
    
    #[test]
    fn test_runtime_creation() {
        let runtime = HardeningRuntime::new(HardeningConfig::minimal());
        assert!(!runtime.is_initialized());
    }
    
    #[test]
    fn test_hardware_detection() {
        let hw = HardwareCfiSupport::detect();
        // Just verify it completes without panic
        let _ = hw.has_hardware_cfi();
    }
}
