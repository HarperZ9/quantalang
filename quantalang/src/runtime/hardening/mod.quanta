//
// Unified runtime hardening system:
// - Memory safety (stack canaries, guard pages, UAF detection)
// - Control flow integrity (CFI, shadow stack)
// - Integrity verification (code signing, memory protection)
// - Security monitoring and violation handling
//
// ═══════════════════════════════════════════════════════════════════════════════

//! # Runtime Hardening
//!
//! Comprehensive security hardening for QuantaLang runtime.
//!
//! ## Features
//!
//! - **Memory Safety**: Stack canaries, guard pages, UAF detection
//! - **Control Flow Integrity**: Forward/backward edge CFI, shadow stack
//! - **Code Integrity**: Verification of executable code
//! - **Security Monitoring**: Centralized violation handling
//!
//! ## Quick Start
//!
//! ```quanta
//! use quantalang::runtime::hardening::prelude::*;
//!
//! // Initialize with default configuration
//! let hardening = HardeningRuntime::new(HardeningConfig::default());
//! hardening.initialize();
//!
//! // Or with custom configuration
//! let config = HardeningConfig::builder()
//!     .memory_safety(true)
//!     .cfi_level(CfiLevel::Full)
//!     .shadow_stack(true)
//!     .build();
//!
//! let hardening = HardeningRuntime::new(config);
//! hardening.initialize();
//! ```

module quantalang::runtime::hardening

// Submodules
pub mod memory;
pub mod cfi;

// Re-exports from memory
pub use memory::{
    // Stack protection
    init_stack_canary, get_stack_canary, check_stack_canary,
    
    // Guard pages
    GuardPageConfig, GuardPageManager,
    
    // UAF detection
    UafDetectorConfig, UafDetector, MemoryState,
    
    // Buffer safety
    SafeBuffer,
    
    // ASLR
    AslrConfig, random_stack_offset, random_heap_offset,
    
    // Security monitoring
    SecurityViolation, SecurityHandler, SecurityMonitor,
    init_security_monitor, security_monitor,
};

// Re-exports from CFI
pub use cfi::{
    // Configuration
    CfiLevel, CfiConfig,
    
    // Type signatures
    TypeHash,
    
    // Call target registry
    CallTarget, CallTargetRegistry, CfiResult, CfiStats,
    
    // Shadow stack
    ShadowStack, init_thread_shadow_stack,
    shadow_push, shadow_pop_validate,
    
    // Jump tables
    JumpTable,
    
    // Enforcement
    CfiEnforcer,
    
    // Hardware support
    HardwareCfiSupport,
};

