module quantalang::diagnostics::renderer

use alloc::vec::Vec;
use alloc::string::String;
use alloc::format;
use alloc::sync::Arc;
use std::io::{self, Write, BufWriter};
use std::collections::BTreeMap;

use super::span::{
    Span, BytePos, FileId, LineNumber, ColumnNumber,
    SourceMap, SourceFile, LabeledSpan, SpanStyle,
};
