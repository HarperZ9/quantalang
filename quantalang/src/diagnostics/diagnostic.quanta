// ═══════════════════════════════════════════════════════════════════════════════
// DIAGNOSTIC
// ═══════════════════════════════════════════════════════════════════════════════

/// A complete diagnostic message
#[derive(Debug, Clone)]
pub struct Diagnostic {
    /// Severity level
    pub severity: Severity,
    
    /// Error code
    pub code: Option<ErrorCode>,
    
    /// Primary message
    pub message: String,
    
    /// Source spans
    pub spans: MultiSpan,
    
    /// Additional notes
    pub notes: Vec<String>,
    
    /// Suggested fixes
    pub suggestions: Vec<Suggestion>,
    
    /// Child diagnostics
    pub children: Vec<SubDiagnostic>,
}

impl Diagnostic {
    /// Create a new error diagnostic
    pub fn error(message: impl Into<String>) -> Self {
        Diagnostic {
            severity: Severity::Error,
            code: None,
            message: message.into(),
            spans: MultiSpan::new(),
            notes: Vec::new(),
            suggestions: Vec::new(),
            children: Vec::new(),
        }
    }
    
    /// Create a new warning diagnostic
    pub fn warning(message: impl Into<String>) -> Self {
        Diagnostic {
            severity: Severity::Warning,
            code: None,
            message: message.into(),
            spans: MultiSpan::new(),
            notes: Vec::new(),
            suggestions: Vec::new(),
            children: Vec::new(),
        }
    }
    
    /// Create an internal compiler error
    pub fn bug(message: impl Into<String>) -> Self {
        Diagnostic {
            severity: Severity::Bug,
            code: None,
            message: message.into(),
            spans: MultiSpan::new(),
            notes: Vec::new(),
            suggestions: Vec::new(),
            children: Vec::new(),
        }
    }
    
    /// Set error code
    pub fn with_code(mut self, code: ErrorCode) -> Self {
        self.code = Some(code);
        self
    }
    
    /// Add primary span
    pub fn with_span(mut self, span: Span, file_id: FileId) -> Self {
        self.spans.push_primary(span, file_id);
        self
    }
    
    /// Add labeled primary span
    pub fn with_labeled_span(
        mut self,
        span: Span,
        file_id: FileId,
        label: impl Into<String>,
    ) -> Self {
        self.spans.push_labeled(span, file_id, label);
        self
    }
    
    /// Add secondary span
    pub fn with_secondary_span(mut self, span: Span, file_id: FileId) -> Self {
        self.spans.push_secondary(span, file_id);
        self
    }
    
    /// Add note
    pub fn with_note(mut self, note: impl Into<String>) -> Self {
        self.notes.push(note.into());
        self
    }
    
    /// Add help message
    pub fn with_help(mut self, help: impl Into<String>) -> Self {
        self.children.push(SubDiagnostic {
            severity: Severity::Help,
            message: help.into(),
            spans: MultiSpan::new(),
        });
        self
    }
    
    /// Add suggestion
    pub fn with_suggestion(mut self, suggestion: Suggestion) -> Self {
        self.suggestions.push(suggestion);
        self
    }
    
    /// Add child diagnostic
    pub fn with_child(mut self, child: SubDiagnostic) -> Self {
        self.children.push(child);
        self
    }
    
    /// Check if this is an error
    pub fn is_error(&self) -> bool {
        self.severity.is_error()
    }
    
    /// Get error code string
    pub fn code_string(&self) -> Option<String> {
        self.code.map(|c| c.to_string())
    }
}

/// Sub-diagnostic (note or help)
#[derive(Debug, Clone)]
pub struct SubDiagnostic {
    pub severity: Severity,
    pub message: String,
    pub spans: MultiSpan,
}

impl SubDiagnostic {
    pub fn note(message: impl Into<String>) -> Self {
        SubDiagnostic {
            severity: Severity::Note,
            message: message.into(),
            spans: MultiSpan::new(),
        }
    }
    
    pub fn help(message: impl Into<String>) -> Self {
        SubDiagnostic {
            severity: Severity::Help,
            message: message.into(),
            spans: MultiSpan::new(),
        }
    }
    
    pub fn with_span(mut self, span: Span, file_id: FileId) -> Self {
        self.spans.push_primary(span, file_id);
        self
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// SUGGESTIONS
// ═══════════════════════════════════════════════════════════════════════════════

/// A suggested fix
#[derive(Debug, Clone)]
pub struct Suggestion {
    /// Description of the suggestion
    pub message: String,
    
    /// Code replacement
    pub replacement: SuggestionReplacement,
    
    /// Applicability (can this be auto-applied?)
    pub applicability: Applicability,
    
    /// Style of suggestion
    pub style: SuggestionStyle,
}

impl Suggestion {
    /// Create a new suggestion
    pub fn new(message: impl Into<String>, replacement: SuggestionReplacement) -> Self {
        Suggestion {
            message: message.into(),
            replacement,
            applicability: Applicability::MaybeIncorrect,
            style: SuggestionStyle::ShowCode,
        }
    }
    
    /// Set applicability
    pub fn with_applicability(mut self, applicability: Applicability) -> Self {
        self.applicability = applicability;
        self
    }
    
    /// Set style
    pub fn with_style(mut self, style: SuggestionStyle) -> Self {
        self.style = style;
        self
    }
}

/// Code replacement for suggestion
#[derive(Debug, Clone)]
pub struct SuggestionReplacement {
    /// Span to replace
    pub span: Span,
    
    /// File containing the span
    pub file_id: FileId,
    
    /// Replacement text
    pub replacement: String,
}

impl SuggestionReplacement {
    pub fn new(span: Span, file_id: FileId, replacement: impl Into<String>) -> Self {
        SuggestionReplacement {
            span,
            file_id,
            replacement: replacement.into(),
        }
    }
    
    /// Create an insertion (at a point)
    pub fn insert(pos: Span, file_id: FileId, text: impl Into<String>) -> Self {
        SuggestionReplacement {
            span: Span::new(pos.lo, pos.lo),
            file_id,
            replacement: text.into(),
        }
    }
    
    /// Create a deletion
    pub fn delete(span: Span, file_id: FileId) -> Self {
        SuggestionReplacement {
            span,
            file_id,
            replacement: String::new(),
        }
    }
}

/// How confident we are that the suggestion is correct
#[derive(Debug, Clone, Copy, PartialEq, Eq)]
pub enum Applicability {
    /// Can be applied automatically with high confidence
    MachineApplicable,
    /// Probably correct but needs human review
    MaybeIncorrect,
    /// Has placeholders that need to be filled in
    HasPlaceholders,
    /// Not meant to be applied (just illustrative)
    Unspecified,
}

/// How to display the suggestion
#[derive(Debug, Clone, Copy, PartialEq, Eq)]
pub enum SuggestionStyle {
    /// Show the full code suggestion
    ShowCode,
    /// Just show a short description
    HideCodeInline,
    /// Show as separate note
    CompletelyHidden,
}

// ═══════════════════════════════════════════════════════════════════════════════
// DIAGNOSTIC BUILDER
// ═══════════════════════════════════════════════════════════════════════════════

/// Builder for creating diagnostics
pub struct DiagnosticBuilder {
    diagnostic: Diagnostic,
}

impl DiagnosticBuilder {
    /// Create error builder
    pub fn error(message: impl Into<String>) -> Self {
        DiagnosticBuilder {
            diagnostic: Diagnostic::error(message),
        }
    }
    
    /// Create warning builder
    pub fn warning(message: impl Into<String>) -> Self {
        DiagnosticBuilder {
            diagnostic: Diagnostic::warning(message),
        }
    }
    
    /// Create bug builder
    pub fn bug(message: impl Into<String>) -> Self {
        DiagnosticBuilder {
            diagnostic: Diagnostic::bug(message),
        }
    }
    
    /// Set error code
    pub fn code(mut self, code: ErrorCode) -> Self {
        self.diagnostic.code = Some(code);
        self
    }
    
    /// Add primary span
    pub fn span(mut self, span: Span, file_id: FileId) -> Self {
        self.diagnostic.spans.push_primary(span, file_id);
        self
    }
    
    /// Add labeled span
    pub fn span_label(mut self, span: Span, file_id: FileId, label: impl Into<String>) -> Self {
        self.diagnostic.spans.spans.push(
            LabeledSpan::primary(span, file_id).with_label(label)
        );
        self
    }
    
    /// Add secondary span
    pub fn secondary_span(mut self, span: Span, file_id: FileId) -> Self {
        self.diagnostic.spans.push_secondary(span, file_id);
        self
    }
    
    /// Add secondary span with label
    pub fn secondary_label(
        mut self,
        span: Span,
        file_id: FileId,
        label: impl Into<String>,
    ) -> Self {
        self.diagnostic.spans.spans.push(
            LabeledSpan::secondary(span, file_id).with_label(label)
        );
        self
    }
    
    /// Add note
    pub fn note(mut self, note: impl Into<String>) -> Self {
        self.diagnostic.notes.push(note.into());
        self
    }
    
    /// Add help
    pub fn help(mut self, help: impl Into<String>) -> Self {
        self.diagnostic.children.push(SubDiagnostic::help(help));
        self
    }
    
    /// Add suggestion to replace code
    pub fn suggest_replace(
        mut self,
        message: impl Into<String>,
        span: Span,
        file_id: FileId,
        replacement: impl Into<String>,
    ) -> Self {
        self.diagnostic.suggestions.push(Suggestion::new(
            message,
            SuggestionReplacement::new(span, file_id, replacement),
        ));
        self
    }
    
    /// Add suggestion to insert code
    pub fn suggest_insert(
        mut self,
        message: impl Into<String>,
        span: Span,
        file_id: FileId,
        insertion: impl Into<String>,
    ) -> Self {
        self.diagnostic.suggestions.push(Suggestion::new(
            message,
            SuggestionReplacement::insert(span, file_id, insertion),
        ));
        self
    }
    
    /// Add suggestion to remove code
    pub fn suggest_remove(
        mut self,
        message: impl Into<String>,
        span: Span,
        file_id: FileId,
    ) -> Self {
        self.diagnostic.suggestions.push(Suggestion::new(
            message,
            SuggestionReplacement::delete(span, file_id),
        ));
        self
    }
    
    /// Build the diagnostic
    pub fn build(self) -> Diagnostic {
        self.diagnostic
    }
    
    /// Emit directly to handler (returns diagnostic for chaining)
    pub fn emit(self, handler: &DiagnosticHandler) -> Diagnostic {
        let diag = self.build();
        handler.emit(&diag);
        diag
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// DIAGNOSTIC HANDLER
// ═══════════════════════════════════════════════════════════════════════════════

use std::sync::atomic::{AtomicUsize, Ordering};
use std::sync::Mutex;

/// Handler for collecting and emitting diagnostics
pub struct DiagnosticHandler {
    /// Collected diagnostics
    diagnostics: Mutex<Vec<Diagnostic>>,
    
    /// Error count
    error_count: AtomicUsize,
    
    /// Warning count
    warning_count: AtomicUsize,
    
    /// Whether to treat warnings as errors
    warnings_as_errors: bool,
    
    /// Emitter
    emitter: Mutex<Box<dyn DiagnosticEmitter + Send>>,
}

impl DiagnosticHandler {
    /// Create a new handler
    pub fn new(emitter: impl DiagnosticEmitter + Send + 'static) -> Self {
        DiagnosticHandler {
            diagnostics: Mutex::new(Vec::new()),
            error_count: AtomicUsize::new(0),
            warning_count: AtomicUsize::new(0),
            warnings_as_errors: false,
            emitter: Mutex::new(Box::new(emitter)),
        }
    }
    
    /// Create with default stderr emitter
    pub fn stderr() -> Self {
        Self::new(StderrEmitter)
    }
    
    /// Set warnings as errors
    pub fn set_warnings_as_errors(&mut self, value: bool) {
        self.warnings_as_errors = value;
    }
    
    /// Emit a diagnostic
    pub fn emit(&self, diagnostic: &Diagnostic) {
        let severity = if self.warnings_as_errors && diagnostic.severity == Severity::Warning {
            Severity::Error
        } else {
            diagnostic.severity
        };
        
        match severity {
            Severity::Error | Severity::Bug => {
                self.error_count.fetch_add(1, Ordering::Relaxed);
            }
            Severity::Warning => {
                self.warning_count.fetch_add(1, Ordering::Relaxed);
            }
            _ => {}
        }
        
        self.emitter.lock().unwrap().emit(diagnostic);
        self.diagnostics.lock().unwrap().push(diagnostic.clone());
    }
    
    /// Get error count
    pub fn error_count(&self) -> usize {
        self.error_count.load(Ordering::Relaxed)
    }
    
    /// Get warning count
    pub fn warning_count(&self) -> usize {
        self.warning_count.load(Ordering::Relaxed)
    }
    
    /// Check if any errors occurred
    pub fn has_errors(&self) -> bool {
        self.error_count() > 0
    }
    
    /// Get all diagnostics
    pub fn diagnostics(&self) -> Vec<Diagnostic> {
        self.diagnostics.lock().unwrap().clone()
    }
    
    /// Clear all diagnostics
    pub fn clear(&self) {
        self.diagnostics.lock().unwrap().clear();
        self.error_count.store(0, Ordering::Relaxed);
        self.warning_count.store(0, Ordering::Relaxed);
    }
    
    /// Create error builder
    pub fn struct_error(&self, message: impl Into<String>) -> DiagnosticBuilder {
        DiagnosticBuilder::error(message)
    }
    
    /// Create warning builder
    pub fn struct_warning(&self, message: impl Into<String>) -> DiagnosticBuilder {
        DiagnosticBuilder::warning(message)
    }
    
    /// Abort if errors occurred
    pub fn abort_if_errors(&self) {
        if self.has_errors() {
            let count = self.error_count();
            eprintln!(
                "\x1b[1;31merror\x1b[0m: aborting due to {} previous error{}",
                count,
                if count == 1 { "" } else { "s" }
            );
            std::process::exit(1);
        }
    }
}

/// Trait for emitting diagnostics
pub trait DiagnosticEmitter {
    fn emit(&self, diagnostic: &Diagnostic);
}

/// Simple stderr emitter (just prints message)
pub struct StderrEmitter;

impl DiagnosticEmitter for StderrEmitter {
    fn emit(&self, diagnostic: &Diagnostic) {
        let code_str = diagnostic.code
            .map(|c| format!("[{}] ", c))
            .unwrap_or_default();
        
        eprintln!(
            "{}{}{}\x1b[0m: {}{}",
            diagnostic.severity.color(),
            diagnostic.severity.as_str(),
            "\x1b[0m",
            code_str,
            diagnostic.message
        );
        
        for note in &diagnostic.notes {
            eprintln!("  \x1b[1;36mnote\x1b[0m: {}", note);
        }
        
        for child in &diagnostic.children {
            eprintln!(
                "  {}{}\x1b[0m: {}",
                child.severity.color(),
                child.severity.as_str(),
                child.message
            );
        }
    }
}

/// Collecting emitter (stores for later)
pub struct CollectingEmitter {
    diagnostics: Mutex<Vec<Diagnostic>>,
}

impl CollectingEmitter {
    pub fn new() -> Self {
        CollectingEmitter {
            diagnostics: Mutex::new(Vec::new()),
        }
    }
    
    pub fn take(&self) -> Vec<Diagnostic> {
        std::mem::take(&mut *self.diagnostics.lock().unwrap())
    }
}

impl Default for CollectingEmitter {
    fn default() -> Self {
        Self::new()
    }
}

impl DiagnosticEmitter for CollectingEmitter {
    fn emit(&self, diagnostic: &Diagnostic) {
        self.diagnostics.lock().unwrap().push(diagnostic.clone());
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// TESTS
// ═══════════════════════════════════════════════════════════════════════════════

#[cfg(test)]
mod tests {
    use super::*;
    
    #[test]
    fn test_error_code() {
        let code = syntax::UNEXPECTED_TOKEN;
        assert_eq!(code.to_string(), "E0001");
        
        let code = lint::UNUSED_VARIABLE;
        assert_eq!(code.to_string(), "W0001");
    }
    
    #[test]
    fn test_diagnostic_builder() {
        let diag = DiagnosticBuilder::error("type mismatch")
            .code(types::TYPE_MISMATCH)
            .span(Span::new(BytePos(10), BytePos(20)), FileId(0))
            .note("expected `i32`, found `String`")
            .help("consider using `.parse()`")
            .build();
        
        assert!(diag.is_error());
        assert_eq!(diag.code, Some(types::TYPE_MISMATCH));
        assert_eq!(diag.notes.len(), 1);
        assert_eq!(diag.children.len(), 1);
    }
    
    #[test]
    fn test_diagnostic_handler() {
        let handler = DiagnosticHandler::new(CollectingEmitter::new());
        
        handler.emit(&Diagnostic::error("first error"));
        handler.emit(&Diagnostic::warning("a warning"));
        handler.emit(&Diagnostic::error("second error"));
        
        assert_eq!(handler.error_count(), 2);
        assert_eq!(handler.warning_count(), 1);
        assert!(handler.has_errors());
    }
    
    #[test]
    fn test_severity_ordering() {
        assert!(Severity::Bug > Severity::Error);
        assert!(Severity::Error > Severity::Warning);
        assert!(Severity::Warning > Severity::Note);
    }
    
    #[test]
    fn test_suggestion() {
        let suggestion = Suggestion::new(
            "add type annotation",
            SuggestionReplacement::new(
                Span::new(BytePos(4), BytePos(5)),
                FileId(0),
                "x: i32",
            ),
        ).with_applicability(Applicability::MachineApplicable);
        
        assert_eq!(suggestion.applicability, Applicability::MachineApplicable);
    }
}
