    use super::*;
    
    pub const UNEXPECTED_TOKEN: ErrorCode = ErrorCode::new(ErrorCategory::Syntax, 1);
    pub const UNEXPECTED_EOF: ErrorCode = ErrorCode::new(ErrorCategory::Syntax, 2);
    pub const INVALID_LITERAL: ErrorCode = ErrorCode::new(ErrorCategory::Syntax, 3);
    pub const UNTERMINATED_STRING: ErrorCode = ErrorCode::new(ErrorCategory::Syntax, 4);
    pub const UNTERMINATED_COMMENT: ErrorCode = ErrorCode::new(ErrorCategory::Syntax, 5);
    pub const INVALID_ESCAPE: ErrorCode = ErrorCode::new(ErrorCategory::Syntax, 6);
    pub const EXPECTED_EXPRESSION: ErrorCode = ErrorCode::new(ErrorCategory::Syntax, 7);
    pub const EXPECTED_STATEMENT: ErrorCode = ErrorCode::new(ErrorCategory::Syntax, 8);
    pub const EXPECTED_TYPE: ErrorCode = ErrorCode::new(ErrorCategory::Syntax, 9);
    pub const EXPECTED_PATTERN: ErrorCode = ErrorCode::new(ErrorCategory::Syntax, 10);
    pub const EXPECTED_IDENTIFIER: ErrorCode = ErrorCode::new(ErrorCategory::Syntax, 11);
    pub const MISSING_SEMICOLON: ErrorCode = ErrorCode::new(ErrorCategory::Syntax, 12);
    pub const MISSING_BRACE: ErrorCode = ErrorCode::new(ErrorCategory::Syntax, 13);
    pub const MISSING_PAREN: ErrorCode = ErrorCode::new(ErrorCategory::Syntax, 14);
    pub const MISSING_BRACKET: ErrorCode = ErrorCode::new(ErrorCategory::Syntax, 15);
    pub const DUPLICATE_MODIFIER: ErrorCode = ErrorCode::new(ErrorCategory::Syntax, 16);
    pub const INVALID_ATTRIBUTE: ErrorCode = ErrorCode::new(ErrorCategory::Syntax, 17);
}

