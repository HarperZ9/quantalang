module quantalang::diagnostics::diagnostic

use alloc::vec::Vec;
use alloc::string::String;
use alloc::boxed::Box;
use alloc::format;
use core::fmt;

use super::span::{Span, FileId, MultiSpan, LabeledSpan, SpanStyle};

// ═══════════════════════════════════════════════════════════════════════════════
// SEVERITY LEVEL
// ═══════════════════════════════════════════════════════════════════════════════

/// Diagnostic severity level
#[derive(Debug, Clone, Copy, PartialEq, Eq, PartialOrd, Ord, Hash)]
pub enum Severity {
    /// Internal compiler error (ICE)
    Bug,
    /// Compilation error - prevents successful compilation
    Error,
    /// Warning - potential issues that don't prevent compilation
    Warning,
    /// Note - additional information
    Note,
    /// Help - suggestions for fixing issues
    Help,
}

impl Severity {
    /// Get display string
    pub fn as_str(&self) -> &'static str {
        match self {
            Severity::Bug => "internal compiler error",
            Severity::Error => "error",
            Severity::Warning => "warning",
            Severity::Note => "note",
            Severity::Help => "help",
        }
    }
    
    /// Get ANSI color code
    pub fn color(&self) -> &'static str {
        match self {
            Severity::Bug => "\x1b[1;35m",    // Bold magenta
            Severity::Error => "\x1b[1;31m",   // Bold red
            Severity::Warning => "\x1b[1;33m", // Bold yellow
            Severity::Note => "\x1b[1;36m",    // Bold cyan
            Severity::Help => "\x1b[1;32m",    // Bold green
        }
    }
    
    /// Get prefix character for terminal
    pub fn glyph(&self) -> &'static str {
        match self {
            Severity::Bug => "💥",
            Severity::Error => "❌",
            Severity::Warning => "⚠️",
            Severity::Note => "ℹ️",
            Severity::Help => "💡",
        }
    }
    
    /// Check if this blocks compilation
    pub fn is_error(&self) -> bool {
        matches!(self, Severity::Bug | Severity::Error)
    }
}

impl fmt::Display for Severity {
    fn fmt(&self, f: &mut fmt::Formatter<'_>) -> fmt::Result {
        write!(f, "{}", self.as_str())
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// ERROR CODE
// ═══════════════════════════════════════════════════════════════════════════════

/// Error code with structured information
#[derive(Debug, Clone, Copy, PartialEq, Eq, Hash)]
pub struct ErrorCode {
    /// Category (E for error, W for warning)
    pub category: ErrorCategory,
    /// Numeric code
    pub code: u16,
}

impl ErrorCode {
    pub const fn new(category: ErrorCategory, code: u16) -> Self {
        ErrorCode { category, code }
    }
    
    /// Format as string (e.g., "E0001")
    pub fn to_string(&self) -> String {
        format!("{}{:04}", self.category.prefix(), self.code)
    }
    
    /// Get documentation URL
    pub fn doc_url(&self) -> String {
        format!(
            "https://docs.quantalang.dev/errors/{}{:04}",
            self.category.prefix().to_lowercase(),
            self.code
        )
    }
}

impl fmt::Display for ErrorCode {
    fn fmt(&self, f: &mut fmt::Formatter<'_>) -> fmt::Result {
        write!(f, "{}{:04}", self.category.prefix(), self.code)
    }
}

/// Error code category
#[derive(Debug, Clone, Copy, PartialEq, Eq, Hash)]
pub enum ErrorCategory {
    /// Syntax errors
    Syntax,
    /// Type errors
    Type,
    /// Name resolution errors
    Resolution,
    /// Borrow checker errors
    Borrow,
    /// Const evaluation errors
    Const,
    /// Lint warnings
    Lint,
    /// Internal compiler errors
    Internal,
}

impl ErrorCategory {
    pub fn prefix(&self) -> &'static str {
        match self {
            ErrorCategory::Syntax => "E",
            ErrorCategory::Type => "E",
            ErrorCategory::Resolution => "E",
            ErrorCategory::Borrow => "E",
            ErrorCategory::Const => "E",
            ErrorCategory::Lint => "W",
            ErrorCategory::Internal => "ICE",
        }
    }
}

