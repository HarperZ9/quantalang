#[cfg(test)]
mod tests {
    use super::*;
    
    #[test]
    fn test_severity() {
        assert!(Severity::Error > Severity::Warning);
        assert!(Severity::Warning > Severity::Info);
        assert!(Severity::Info > Severity::Hint);
    }
    
    #[test]
    fn test_diagnostic_code() {
        let code = DiagnosticCode::error(42);
        assert_eq!(code.to_string(), "E0042");
        
        let code = DiagnosticCode::warning(7);
        assert_eq!(code.to_string(), "W0007");
    }
    
    #[test]
    fn test_diagnostic_builder() {
        let span = LocatedSpan::new(FileId(0), Span::new(10, 20));
        
        let diag = DiagnosticBuilder::error("test error")
            .code("E", 1)
            .span(span)
            .note("this is a note")
            .help("try this instead")
            .build();
        
        assert!(diag.is_error());
        assert_eq!(diag.code.unwrap().number, 1);
        assert_eq!(diag.labels.len(), 1);
        assert_eq!(diag.notes.len(), 2);
    }
    
    #[test]
    fn test_handler() {
        let handler = DiagnosticHandler::new();
        
        handler.emit(Diagnostic::error("error 1"));
        handler.emit(Diagnostic::warning("warning 1"));
        handler.emit(Diagnostic::error("error 2"));
        
        assert!(handler.has_errors());
        assert_eq!(handler.error_count(), 2);
        assert_eq!(handler.warning_count(), 1);
    }
    
    #[test]
    fn test_suggestion() {
        let span = LocatedSpan::new(FileId(0), Span::new(5, 10));
        
        let suggestion = Suggestion::replace("rename to `foo`", span, "foo");
        
        assert!(suggestion.applicability.is_machine_applicable());
        assert_eq!(suggestion.substitutions.len(), 1);
    }
}
