//
// Quanta is a multi-paradigm systems programming language featuring:
// - Strong static typing with gradual inference
// - Memory safety without garbage collection (ownership + borrowing)
// - First-class effects system
// - Embedded DSLs (SQL, Regex, Math, Finance, Graphics)
// - Universal compilation (x86-64, ARM64, WASM, SPIR-V, C, JS)
// - AI-native constructs (@ai decorator, neural types)
// - Self-evolution through Axiom integration
//
// ═══════════════════════════════════════════════════════════════════════════════

module quanta

// Re-export all core modules
pub use lexer::*
pub use parser::*
pub use ast::*
pub use types::*
pub use codegen::*
pub use vm::*

// Standard library
pub use stdlib::*

// ═══════════════════════════════════════════════════════════════════════════════
// LANGUAGE VERSION & METADATA
// ═══════════════════════════════════════════════════════════════════════════════

pub const VERSION: Version = Version {
    major: 1,
    minor: 0,
    patch: 0,
    codename: "Genesis",
}

pub const AUTHOR: &str = "Zain Dana Quanta"
pub const LICENSE: &str = "Proprietary - All Rights Reserved"
pub const COPYRIGHT: &str = "Copyright © 2024-2025 Zain Dana Quanta"

// ═══════════════════════════════════════════════════════════════════════════════
// CORE TYPE DEFINITIONS
// ═══════════════════════════════════════════════════════════════════════════════

/// Primitive types
pub enum Primitive {
    // Integers
    I8, I16, I32, I64, I128, Isize,
    U8, U16, U32, U64, U128, Usize,
    
    // Floats
    F16, F32, F64,
    
    // Other
    Bool,
    Char,
    Str,
    Unit,    // ()
    Never,   // !
}

/// Type representation
pub enum Type {
    Primitive(Primitive),
    Array(Box<Type>, Option<usize>),      // [T] or [T; N]
    Slice(Box<Type>),                      // &[T]
    Tuple(Vec<Type>),                      // (T1, T2, ...)
    Function(Vec<Type>, Box<Type>),        // fn(T1, T2) -> R
    Generic(String, Vec<Type>),            // T<A, B>
    Reference(Box<Type>, Mutability),      // &T or &mut T
    Pointer(Box<Type>, Mutability),        // *const T or *mut T
    Option(Box<Type>),                     // Option<T>
    Result(Box<Type>, Box<Type>),          // Result<T, E>
    UserDefined(String),                   // Custom types
    Inferred,                              // Type to be inferred
    Effect(Box<Type>, Vec<Effect>),        // T with Effect1, Effect2
}

pub enum Mutability {
    Immutable,
    Mutable,
}

/// Effect types for the effect system
pub enum Effect {
    IO,
    Network,
    FileSystem,
    Database,
    Random,
    Time,
    Console,
    GPU,
    AI,
    Custom(String),
}

// ═══════════════════════════════════════════════════════════════════════════════
// AST NODE DEFINITIONS
// ═══════════════════════════════════════════════════════════════════════════════

/// Source location for error reporting
pub struct Span {
    pub file: String,
    pub start: Position,
    pub end: Position,
}

pub struct Position {
    pub line: u32,
    pub column: u32,
    pub offset: u32,
}

/// Top-level items
pub enum Item {
    Module(ModuleDecl),
    Use(UseDecl),
    Function(FunctionDecl),
    Struct(StructDecl),
    Enum(EnumDecl),
    Trait(TraitDecl),
    Impl(ImplDecl),
    TypeAlias(TypeAliasDecl),
    Const(ConstDecl),
    Static(StaticDecl),
    Macro(MacroDecl),
    Foreign(ForeignBlock),
}

pub struct ModuleDecl {
    pub name: String,
    pub visibility: Visibility,
    pub items: Vec<Item>,
    pub span: Span,
}

pub enum Visibility {
    Private,           // default
    Public,            // pub
    Crate,             // pub(crate)
    Super,             // pub(super)
    Path(String),      // pub(in path)
}

pub struct FunctionDecl {
    pub name: String,
    pub visibility: Visibility,
    pub generics: Vec<GenericParam>,
    pub params: Vec<Parameter>,
    pub return_type: Type,
    pub effects: Vec<Effect>,
    pub where_clause: Option<WhereClause>,
    pub body: Option<Block>,
    pub attributes: Vec<Attribute>,
    pub span: Span,
}

pub struct Parameter {
    pub pattern: Pattern,
    pub ty: Type,
    pub default: Option<Expr>,
}

pub struct GenericParam {
    pub name: String,
    pub bounds: Vec<TypeBound>,
    pub default: Option<Type>,
}

pub struct TypeBound {
    pub trait_path: String,
    pub generics: Vec<Type>,
}

pub struct WhereClause {
    pub predicates: Vec<WherePredicate>,
}

pub struct WherePredicate {
    pub ty: Type,
    pub bounds: Vec<TypeBound>,
}

pub struct StructDecl {
    pub name: String,
    pub visibility: Visibility,
    pub generics: Vec<GenericParam>,
    pub fields: StructFields,
    pub where_clause: Option<WhereClause>,
    pub attributes: Vec<Attribute>,
    pub span: Span,
}

pub enum StructFields {
    Named(Vec<FieldDecl>),
    Tuple(Vec<Type>),
    Unit,
}

pub struct FieldDecl {
    pub name: String,
    pub visibility: Visibility,
    pub ty: Type,
    pub default: Option<Expr>,
    pub attributes: Vec<Attribute>,
}

pub struct EnumDecl {
    pub name: String,
    pub visibility: Visibility,
    pub generics: Vec<GenericParam>,
    pub variants: Vec<EnumVariant>,
    pub where_clause: Option<WhereClause>,
    pub attributes: Vec<Attribute>,
    pub span: Span,
}

pub struct EnumVariant {
    pub name: String,
    pub fields: StructFields,
    pub discriminant: Option<Expr>,
    pub attributes: Vec<Attribute>,
}

pub struct TraitDecl {
    pub name: String,
    pub visibility: Visibility,
    pub generics: Vec<GenericParam>,
    pub supertraits: Vec<TypeBound>,
    pub items: Vec<TraitItem>,
    pub where_clause: Option<WhereClause>,
    pub attributes: Vec<Attribute>,
    pub span: Span,
}

pub enum TraitItem {
    Method(FunctionDecl),
    Type(TypeAliasDecl),
    Const(ConstDecl),
}

pub struct ImplDecl {
    pub generics: Vec<GenericParam>,
    pub trait_path: Option<String>,
    pub self_type: Type,
    pub items: Vec<ImplItem>,
    pub where_clause: Option<WhereClause>,
    pub span: Span,
}

pub enum ImplItem {
    Method(FunctionDecl),
    Type(TypeAliasDecl),
    Const(ConstDecl),
}

// ═══════════════════════════════════════════════════════════════════════════════
// EXPRESSION NODES
// ═══════════════════════════════════════════════════════════════════════════════

pub enum Expr {
    // Literals
    Literal(Literal),
    
    // Identifiers and paths
    Ident(String),
    Path(Vec<String>),
    
    // Compound expressions
    Array(Vec<Expr>),
    Tuple(Vec<Expr>),
    Struct(StructExpr),
    
    // Operations
    Unary(UnaryOp, Box<Expr>),
    Binary(Box<Expr>, BinaryOp, Box<Expr>),
    
    // Access
    Field(Box<Expr>, String),
    Index(Box<Expr>, Box<Expr>),
    Call(Box<Expr>, Vec<Expr>),
    MethodCall(Box<Expr>, String, Vec<Expr>),
    
    // Control flow
    If(Box<Expr>, Block, Option<Box<Expr>>),
    Match(Box<Expr>, Vec<MatchArm>),
    Loop(Block),
    While(Box<Expr>, Block),
    For(Pattern, Box<Expr>, Block),
    
    // Functions
    Closure(Vec<Parameter>, Option<Type>, Box<Expr>),
    Return(Option<Box<Expr>>),
    Break(Option<Box<Expr>>),
    Continue,
    
    // Memory
    Ref(Box<Expr>, Mutability),
    Deref(Box<Expr>),
    
    // Type operations
    Cast(Box<Expr>, Type),
    TypeAscription(Box<Expr>, Type),
    
    // Blocks
    Block(Block),
    Unsafe(Block),
    Async(Block),
    
    // Try operator
    Try(Box<Expr>),
    
    // Range
    Range(Option<Box<Expr>>, Option<Box<Expr>>, bool), // inclusive?
    
    // Await
    Await(Box<Expr>),
    
    // DSL macros
    Macro(MacroInvocation),
    
    // AI constructs
    AIQuery(String),
    AIInfer(Box<Expr>, Type),
}

pub enum Literal {
    Int(i128, Option<IntSuffix>),
    Float(f64, Option<FloatSuffix>),
    Bool(bool),
    Char(char),
    String(String),
    ByteString(Vec<u8>),
    RawString(String),
}

pub enum IntSuffix {
    I8, I16, I32, I64, I128, Isize,
    U8, U16, U32, U64, U128, Usize,
}

pub enum FloatSuffix {
    F16, F32, F64,
}

pub enum UnaryOp {
    Neg,     // -
    Not,     // !
    BitNot,  // ~
    Deref,   // *
    Ref,     // &
    RefMut,  // &mut
}

pub enum BinaryOp {
    // Arithmetic
    Add, Sub, Mul, Div, Rem, Pow,
    
    // Bitwise
    BitAnd, BitOr, BitXor, Shl, Shr,
    
    // Logical
    And, Or,
    
    // Comparison
    Eq, Ne, Lt, Le, Gt, Ge,
    
    // Assignment
    Assign,
    AddAssign, SubAssign, MulAssign, DivAssign, RemAssign,
    BitAndAssign, BitOrAssign, BitXorAssign, ShlAssign, ShrAssign,
    
    // Range
    Range, RangeInclusive,
    
    // Other
    Pipe,      // |>
    Compose,   // >>
}

pub struct StructExpr {
    pub path: Vec<String>,
    pub fields: Vec<FieldInit>,
    pub rest: Option<Box<Expr>>,
}

pub struct FieldInit {
    pub name: String,
    pub value: Option<Expr>,
}

pub struct Block {
    pub stmts: Vec<Stmt>,
    pub expr: Option<Box<Expr>>,
}

pub struct MatchArm {
    pub pattern: Pattern,
    pub guard: Option<Expr>,
    pub body: Expr,
}

// ═══════════════════════════════════════════════════════════════════════════════
// PATTERN NODES
// ═══════════════════════════════════════════════════════════════════════════════

pub enum Pattern {
    Wildcard,
    Ident(String, Mutability, Option<Box<Pattern>>),
    Literal(Literal),
    Tuple(Vec<Pattern>),
    Struct(Vec<String>, Vec<FieldPattern>, bool),  // rest?
    TupleStruct(Vec<String>, Vec<Pattern>),
    Slice(Vec<Pattern>, Option<Box<Pattern>>, Vec<Pattern>),
    Range(Option<Box<Pattern>>, Option<Box<Pattern>>, bool),
    Or(Vec<Pattern>),
    Ref(Box<Pattern>, Mutability),
    Path(Vec<String>),
}

pub struct FieldPattern {
    pub name: String,
    pub pattern: Pattern,
}

// ═══════════════════════════════════════════════════════════════════════════════
// STATEMENT NODES
// ═══════════════════════════════════════════════════════════════════════════════

pub enum Stmt {
    Let(LetStmt),
    Expr(Expr),
    Semi(Expr),
    Item(Item),
    Empty,
}

pub struct LetStmt {
    pub pattern: Pattern,
    pub ty: Option<Type>,
    pub init: Option<Expr>,
    pub attributes: Vec<Attribute>,
}

// ═══════════════════════════════════════════════════════════════════════════════
// ATTRIBUTES & MACROS
// ═══════════════════════════════════════════════════════════════════════════════

pub struct Attribute {
    pub path: Vec<String>,
    pub args: AttributeArgs,
    pub style: AttributeStyle,
}

pub enum AttributeStyle {
    Inner,  // #![...]
    Outer,  // #[...]
}

pub enum AttributeArgs {
    Empty,
    Delimited(Vec<TokenTree>),
    Eq(Literal),
}

pub struct MacroInvocation {
    pub path: Vec<String>,
    pub delimiter: Delimiter,
    pub tokens: Vec<TokenTree>,
}

pub enum Delimiter {
    Paren,
    Bracket,
    Brace,
}

pub enum TokenTree {
    Token(Token),
    Group(Delimiter, Vec<TokenTree>),
}

// ═══════════════════════════════════════════════════════════════════════════════
// EMBEDDED DSL SUPPORT
// ═══════════════════════════════════════════════════════════════════════════════

/// Built-in DSL macros
pub mod dsl {
    /// SQL DSL
    /// ```quanta
    /// let users = sql! {
    ///     SELECT name, email FROM users WHERE age > 18
    /// }
    /// ```
    pub macro sql($($tokens:tt)*) { /* compiler built-in */ }
    
    /// Regex DSL
    /// ```quanta
    /// let pattern = regex! { \d{4}-\d{2}-\d{2} }
    /// ```
    pub macro regex($($tokens:tt)*) { /* compiler built-in */ }
    
    /// Math DSL with LaTeX-like syntax
    /// ```quanta
    /// let sharpe = math! { μ_p / σ_p * √252 }
    /// ```
    pub macro math($($tokens:tt)*) { /* compiler built-in */ }
    
    /// Finance DSL
    /// ```quanta
    /// let ratio = finance! {
    ///     kelly = (p * b - q) / b
    /// }
    /// ```
    pub macro finance($($tokens:tt)*) { /* compiler built-in */ }
    
    /// Graphics/Shader DSL (GLSL-like)
    /// ```quanta
    /// let shader = glsl! {
    ///     void main() {
    ///         gl_FragColor = vec4(1.0, 0.0, 0.0, 1.0);
    ///     }
    /// }
    /// ```
    pub macro glsl($($tokens:tt)*) { /* compiler built-in */ }
    
    /// Shell DSL
    /// ```quanta
    /// let output = shell! { ls -la | grep ".quanta" }
    /// ```
    pub macro shell($($tokens:tt)*) { /* compiler built-in */ }
    
    /// JSON DSL
    /// ```quanta
    /// let config = json! {
    ///     "name": "Quanta",
    ///     "version": "1.0.0"
    /// }
    /// ```
    pub macro json($($tokens:tt)*) { /* compiler built-in */ }
}

// ═══════════════════════════════════════════════════════════════════════════════
// AI CONSTRUCTS
// ═══════════════════════════════════════════════════════════════════════════════

/// AI-native decorator for automatic inference
/// ```quanta
/// @ai
/// fn analyze_sentiment(text: String) -> Sentiment {
///     // Implementation auto-generated by AI
/// }
/// ```
pub attribute ai {
    model: Option<String>,      // "gpt-4", "claude", "local"
    temperature: Option<f32>,
    max_tokens: Option<u32>,
}

/// Neural type annotation
/// ```quanta
/// type ImageClassifier = Neural<Image, Vec<(String, f32)>>
/// ```
pub struct Neural<Input, Output> {
    model: NeuralModel,
    _phantom: PhantomData<(Input, Output)>,
}

// ═══════════════════════════════════════════════════════════════════════════════
// COMPILATION TARGETS
// ═══════════════════════════════════════════════════════════════════════════════

pub enum CompileTarget {
    // Native
    X86_64,
    ARM64,
    RISCV64,
    
    // Web
    WASM,
    JavaScript,
    
    // GPU
    SPIRV,
    DXIL,
    MetalSL,
    
    // Intermediate
    LLVM_IR,
    QuantaIR,
    
    // Source-to-source
    C,
    Cpp,
    Rust,
}

// ═══════════════════════════════════════════════════════════════════════════════
// COMPILER ENTRY POINTS
// ═══════════════════════════════════════════════════════════════════════════════

/// Compile Quanta source to target
pub fn compile(
    source: &str,
    target: CompileTarget,
    options: CompileOptions,
) -> Result<CompiledOutput, CompileError> {
    // 1. Lex
    let tokens = lexer::tokenize(source)?;
    
    // 2. Parse
    let ast = parser::parse(tokens)?;
    
    // 3. Type check
    let typed_ast = types::check(ast)?;
    
    // 4. Generate code
    let output = codegen::generate(typed_ast, target, options)?;
    
    Ok(output)
}

pub struct CompileOptions {
    pub optimization_level: OptLevel,
    pub debug_info: bool,
    pub warnings_as_errors: bool,
    pub emit_ir: bool,
    pub target_features: Vec<String>,
}

pub enum OptLevel {
    O0,  // No optimization
    O1,  // Basic optimization
    O2,  // Standard optimization
    O3,  // Aggressive optimization
    Os,  // Optimize for size
    Oz,  // Aggressively optimize for size
}

pub struct CompiledOutput {
    pub target: CompileTarget,
    pub code: Vec<u8>,
    pub symbols: SymbolTable,
    pub debug_info: Option<DebugInfo>,
}

// ═══════════════════════════════════════════════════════════════════════════════
// ERROR TYPES
// ═══════════════════════════════════════════════════════════════════════════════

pub enum CompileError {
    Lexer(LexerError),
    Parser(ParserError),
    Type(TypeError),
    Codegen(CodegenError),
}

pub struct LexerError {
    pub message: String,
    pub span: Span,
    pub kind: LexerErrorKind,
}

pub enum LexerErrorKind {
    UnexpectedChar(char),
    UnterminatedString,
    UnterminatedComment,
    InvalidNumber,
    InvalidEscape,
}

pub struct ParserError {
    pub message: String,
    pub span: Span,
    pub kind: ParserErrorKind,
    pub expected: Vec<String>,
    pub found: String,
}

pub enum ParserErrorKind {
    UnexpectedToken,
    UnexpectedEof,
    InvalidExpression,
    InvalidPattern,
    InvalidType,
    MissingToken,
}

pub struct TypeError {
    pub message: String,
    pub span: Span,
    pub kind: TypeErrorKind,
}

pub enum TypeErrorKind {
    Mismatch { expected: Type, found: Type },
    NotFound(String),
    Ambiguous,
    InfiniteType,
    BorrowConflict,
    LifetimeMismatch,
    MissingField(String),
    UnknownMethod(String),
}

// ═══════════════════════════════════════════════════════════════════════════════
// TESTS
// ═══════════════════════════════════════════════════════════════════════════════

#[cfg(test)]
mod tests {
    use super::*
    
    #[test]
    fn test_version() {
        assert_eq!(VERSION.major, 1);
        assert_eq!(VERSION.minor, 0);
        assert_eq!(VERSION.patch, 0);
    }
    
    #[test]
    fn test_compile_hello_world() {
        let source = r#"
            fn main() {
                println("Hello, Quanta!")
            }
        "#;
        
        let result = compile(source, CompileTarget::X86_64, CompileOptions::default());
        assert!(result.is_ok());
    }
}
