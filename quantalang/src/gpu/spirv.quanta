/// SPIR-V magic number
pub const SPIRV_MAGIC: u32 = 0x07230203;

/// SPIR-V version 1.6
pub const SPIRV_VERSION_1_6: u32 = 0x00010600;

/// Generator magic (QuantaLang = 0x514E5441)
pub const GENERATOR_MAGIC: u32 = 0x514E5441;

