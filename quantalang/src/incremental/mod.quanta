// TESTS
// ═══════════════════════════════════════════════════════════════════════════════

#[cfg(test)]
mod tests {
    use super::*;
    
    #[test]
    fn test_compilation_stats() {
        let stats = CompilationStats {
            total_files: 100,
            recompiled: 10,
            cached: 90,
            cache_hits: 90,
            cache_misses: 10,
            ..Default::default()
        };
        
        assert!((stats.hit_rate() - 0.9).abs() < 0.001);
        assert!((stats.recompile_rate() - 0.1).abs() < 0.001);
    }
    
    #[test]
    fn test_incremental_config() {
        let config = IncrementalConfig::default();
        assert!(config.parallel);
        assert!(config.fine_grained);
    }
}
