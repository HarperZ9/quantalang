// TESTS
// ═══════════════════════════════════════════════════════════════════════════════

#[cfg(test)]
mod tests {
    use super::*;
    
    #[test]
    fn test_add_zero() {
        let mut func = MirFunction {
            name: "test".to_string(),
            blocks: vec![
                MirBlock {
                    id: 0,
                    statements: vec![
                        MirStatement::BinaryOp {
                            dest: "y".to_string(),
                            op: BinOp::Add,
                            lhs: MirOperand::Variable("x".to_string()),
                            rhs: MirOperand::Constant(0),
                        },
                    ],
                    terminator: MirTerminator::Return { value: None },
                },
            ],
        };
        
        let mut opt = PeepholeOptimizer::new();
        opt.optimize(&mut func);
        
        // Should be simplified to just x
        if let MirStatement::Assign { value: MirOperand::Variable(v), .. } = &func.blocks[0].statements[0] {
            assert_eq!(v, "x");
        } else {
            panic!("Expected assignment to variable x");
        }
    }
    
    #[test]
    fn test_mul_zero() {
        let mut func = MirFunction {
            name: "test".to_string(),
            blocks: vec![
                MirBlock {
                    id: 0,
                    statements: vec![
                        MirStatement::BinaryOp {
                            dest: "y".to_string(),
                            op: BinOp::Mul,
                            lhs: MirOperand::Variable("x".to_string()),
                            rhs: MirOperand::Constant(0),
                        },
                    ],
                    terminator: MirTerminator::Return { value: None },
                },
            ],
        };
        
        let mut opt = PeepholeOptimizer::new();
        opt.optimize(&mut func);
        
        // Should be simplified to 0
        if let MirStatement::Assign { value: MirOperand::Constant(c), .. } = &func.blocks[0].statements[0] {
            assert_eq!(*c, 0);
        } else {
            panic!("Expected constant 0");
        }
    }
    
    #[test]
    fn test_predicate_is_power_of_2() {
        let matcher = PatternMatcher::new();
        let mut result = MatchResult::new();
        result.bind("c", MatchValue::Constant(8));
        
        assert!(matcher.check_predicate(&Predicate::IsPowerOf2("c".to_string()), &result));
        
        result.bind("c", MatchValue::Constant(7));
        assert!(!matcher.check_predicate(&Predicate::IsPowerOf2("c".to_string()), &result));
    }
}
