}

impl IVWidthening {
    pub fn new() -> Self {
        IVWidthening {
            stats: IVWidthStats::default(),
        }
    }
    
    /// Widen IVs to pointer width (eliminates sign extensions in address calculations)
    pub fn widen(&mut self, func: &mut MirFunction, loops: &[LoopInfo]) -> &IVWidthStats {
        self.stats = IVWidthStats::default();
        
        // Analyze and widen where beneficial
        for loop_info in loops {
            self.widen_loop(func, loop_info);
        }
        
        &self.stats
    }
    
