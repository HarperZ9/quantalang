module quantalang::opt::indvar

use alloc::vec::Vec;
use alloc::string::String;
use alloc::boxed::Box;
use alloc::collections::{BTreeMap, BTreeSet};

// ═══════════════════════════════════════════════════════════════════════════════
// INDUCTION VARIABLE REPRESENTATION
// ═══════════════════════════════════════════════════════════════════════════════

/// Type of induction variable
#[derive(Debug, Clone, Copy, PartialEq, Eq)]
pub enum IndVarKind {
    /// Basic induction variable: i = i + c
    Basic,
    /// Derived from basic: j = a*i + b
    Derived,
    /// Non-linear (geometric, etc.)
    NonLinear,
}

/// Induction variable information
#[derive(Debug, Clone)]
pub struct InductionVar {
    /// Variable name
    pub name: String,
    /// Kind of induction variable
    pub kind: IndVarKind,
    /// Initial value
    pub init: i64,
    /// Step per iteration
    pub step: i64,
    /// For derived: base IV
    pub base: Option<String>,
    /// For derived: multiplier
    pub multiplier: i64,
    /// For derived: offset
    pub offset: i64,
    /// Loop header
    pub loop_header: u32,
}

impl InductionVar {
    /// Create a basic induction variable
    pub fn basic(name: impl Into<String>, init: i64, step: i64, loop_header: u32) -> Self {
        InductionVar {
            name: name.into(),
            kind: IndVarKind::Basic,
            init,
            step,
            base: None,
            multiplier: 1,
            offset: 0,
            loop_header,
        }
    }
    
    /// Create a derived induction variable
    pub fn derived(
        name: impl Into<String>,
        base: impl Into<String>,
        multiplier: i64,
        offset: i64,
        loop_header: u32,
    ) -> Self {
        InductionVar {
            name: name.into(),
            kind: IndVarKind::Derived,
            init: 0,
            step: 0,
            base: Some(base.into()),
            multiplier,
            offset,
            loop_header,
        }
    }
    
    /// Compute value at iteration n
    pub fn value_at(&self, n: i64) -> i64 {
        match self.kind {
            IndVarKind::Basic => self.init + n * self.step,
            IndVarKind::Derived => {
                // Would need base IV value
                self.offset + n * self.multiplier
            }
            IndVarKind::NonLinear => {
                // Non-linear not handled
                0
            }
        }
    }
    
    /// Check if this IV is computable (can be calculated from iteration count)
    pub fn is_computable(&self) -> bool {
        matches!(self.kind, IndVarKind::Basic | IndVarKind::Derived)
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// INDUCTION VARIABLE ANALYSIS
// ═══════════════════════════════════════════════════════════════════════════════

/// Induction variable analyzer
pub struct IndVarAnalyzer {
    /// Detected induction variables per loop
    ind_vars: BTreeMap<u32, Vec<InductionVar>>,
    /// Phi nodes in loop headers
    phi_defs: BTreeMap<String, (u32, i64, String)>, // (block, init_val, back_edge_val)
}

impl IndVarAnalyzer {
    pub fn new() -> Self {
        IndVarAnalyzer {
            ind_vars: BTreeMap::new(),
            phi_defs: BTreeMap::new(),
        }
    }
    
    /// Analyze a function for induction variables
    pub fn analyze(&mut self, func: &MirFunction, loops: &[LoopInfo]) {
        self.ind_vars.clear();
        self.phi_defs.clear();
        
        // Collect phi definitions
        for block in &func.blocks {
            for stmt in &block.statements {
                if let MirStatement::Phi { dest, incoming } = stmt {
                    if incoming.len() == 2 {
                        // Potential loop phi
                        self.phi_defs.insert(dest.clone(), (
                            block.id,
                            self.extract_constant(&incoming[0].1),
                            self.extract_var(&incoming[1].1),
                        ));
                    }
                }
            }
        }
        
        // Analyze each loop
        for loop_info in loops {
            self.analyze_loop(func, loop_info);
        }
    }
    
    fn extract_constant(&self, op: &MirOperand) -> i64 {
        match op {
            MirOperand::Constant(c) => *c,
            _ => 0,
        }
    }
    
    fn extract_var(&self, op: &MirOperand) -> String {
        match op {
            MirOperand::Variable(v) => v.clone(),
            _ => String::new(),
        }
    }
    
    fn analyze_loop(&mut self, func: &MirFunction, loop_info: &LoopInfo) {
        let mut ivs = Vec::new();
        
        // Find basic IVs (from phi + add pattern)
        for block in &func.blocks {
            if block.id != loop_info.header {
                continue;
            }
            
            for stmt in &block.statements {
                if let MirStatement::Phi { dest, incoming } = stmt {
                    if let Some(iv) = self.analyze_phi_iv(func, loop_info, dest, incoming) {
                        ivs.push(iv);
                    }
                }
            }
        }
        
        // Find derived IVs
        let basic_ivs: Vec<_> = ivs.iter()
            .filter(|iv| iv.kind == IndVarKind::Basic)
            .map(|iv| iv.name.clone())
            .collect();
        
        for block in &func.blocks {
            if !loop_info.blocks.contains(&block.id) {
                continue;
            }
            
            for stmt in &block.statements {
                if let MirStatement::BinaryOp { dest, op, lhs, rhs } = stmt {
                    if let Some(iv) = self.analyze_derived_iv(loop_info, dest, *op, lhs, rhs, &basic_ivs) {
                        ivs.push(iv);
                    }
                }
            }
        }
        
        self.ind_vars.insert(loop_info.header, ivs);
    }
    
    fn analyze_phi_iv(
        &self,
        func: &MirFunction,
        loop_info: &LoopInfo,
        dest: &str,
        incoming: &[(u32, MirOperand)],
    ) -> Option<InductionVar> {
        if incoming.len() != 2 {
            return None;
        }
        
        // Identify preheader and back edge values
        let (init_val, back_val) = if loop_info.blocks.contains(&incoming[0].0) {
            (&incoming[1].1, &incoming[0].1)
        } else {
            (&incoming[0].1, &incoming[1].1)
        };
        
        // Initial value must be constant (for simplicity)
        let init = match init_val {
            MirOperand::Constant(c) => *c,
            _ => return None,
        };
        
        // Back edge value must be dest + constant
        let back_var = match back_val {
            MirOperand::Variable(v) => v,
            _ => return None,
        };
        
        // Find the definition of back_var
        let step = self.find_add_constant(func, loop_info, back_var, dest)?;
        
        Some(InductionVar::basic(dest, init, step, loop_info.header))
    }
    
    fn find_add_constant(
        &self,
        func: &MirFunction,
        loop_info: &LoopInfo,
        result: &str,
        iv_name: &str,
    ) -> Option<i64> {
        for block in &func.blocks {
            if !loop_info.blocks.contains(&block.id) {
                continue;
            }
            
            for stmt in &block.statements {
                if let MirStatement::BinaryOp { dest, op, lhs, rhs } = stmt {
                    if dest != result {
                        continue;
                    }
                    
                    if *op != BinOp::Add {
                        continue;
                    }
                    
                    // i + c or c + i
                    match (lhs, rhs) {
                        (MirOperand::Variable(v), MirOperand::Constant(c)) if v == iv_name => {
                            return Some(*c);
                        }
                        (MirOperand::Constant(c), MirOperand::Variable(v)) if v == iv_name => {
                            return Some(*c);
                        }
                        _ => {}
                    }
                }
            }
        }
        
        None
    }
    
    fn analyze_derived_iv(
        &self,
        loop_info: &LoopInfo,
        dest: &str,
        op: BinOp,
        lhs: &MirOperand,
        rhs: &MirOperand,
        basic_ivs: &[String],
    ) -> Option<InductionVar> {
        // a * iv or iv * a
        if op == BinOp::Mul {
            match (lhs, rhs) {
                (MirOperand::Variable(v), MirOperand::Constant(c)) if basic_ivs.contains(v) => {
                    return Some(InductionVar::derived(dest, v, *c, 0, loop_info.header));
                }
                (MirOperand::Constant(c), MirOperand::Variable(v)) if basic_ivs.contains(v) => {
                    return Some(InductionVar::derived(dest, v, *c, 0, loop_info.header));
                }
                _ => {}
            }
        }
        
        // iv + c or c + iv (as derived with multiplier 1)
        if op == BinOp::Add {
            match (lhs, rhs) {
                (MirOperand::Variable(v), MirOperand::Constant(c)) if basic_ivs.contains(v) => {
                    return Some(InductionVar::derived(dest, v, 1, *c, loop_info.header));
                }
                (MirOperand::Constant(c), MirOperand::Variable(v)) if basic_ivs.contains(v) => {
                    return Some(InductionVar::derived(dest, v, 1, *c, loop_info.header));
                }
                _ => {}
            }
        }
        
        None
    }
    
    /// Get induction variables for a loop
    pub fn get_ind_vars(&self, loop_header: u32) -> &[InductionVar] {
        static EMPTY: Vec<InductionVar> = Vec::new();
        self.ind_vars.get(&loop_header).unwrap_or(&EMPTY)
    }
    
    /// Check if variable is an induction variable
    pub fn is_ind_var(&self, loop_header: u32, var: &str) -> bool {
        self.ind_vars.get(&loop_header)
            .map(|ivs| ivs.iter().any(|iv| iv.name == var))
            .unwrap_or(false)
    }
}

impl Default for IndVarAnalyzer {
    fn default() -> Self {
        Self::new()
    }
}

