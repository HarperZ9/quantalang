// STRENGTH REDUCTION
// ═══════════════════════════════════════════════════════════════════════════════

/// Strength reduction pass
pub struct StrengthReduction {
    /// Analyzer
    analyzer: IndVarAnalyzer,
    /// Statistics
    stats: StrengthReductionStats,
}

/// Statistics for strength reduction
#[derive(Debug, Clone, Default)]
pub struct StrengthReductionStats {
    /// Loops analyzed
    pub loops_analyzed: usize,
    /// IVs found
    pub ivs_found: usize,
    /// Multiplications reduced
    pub muls_reduced: usize,
    /// Divisions reduced
    pub divs_reduced: usize,
}

impl StrengthReduction {
    pub fn new() -> Self {
        StrengthReduction {
            analyzer: IndVarAnalyzer::new(),
            stats: StrengthReductionStats::default(),
        }
    }
    
    /// Run strength reduction
    pub fn run(&mut self, func: &mut MirFunction, loops: &[LoopInfo]) -> &StrengthReductionStats {
        self.stats = StrengthReductionStats::default();
        
        // Analyze IVs
        self.analyzer.analyze(func, loops);
        
        // Apply strength reduction
        for loop_info in loops {
            self.reduce_loop(func, loop_info);
        }
        
        &self.stats
    }
    
    fn reduce_loop(&mut self, func: &mut MirFunction, loop_info: &LoopInfo) {
        self.stats.loops_analyzed += 1;
        
        let ivs = self.analyzer.get_ind_vars(loop_info.header);
        self.stats.ivs_found += ivs.len();
        
        // For each derived IV that's a multiplication, create an add chain
        for iv in ivs {
            if iv.kind == IndVarKind::Derived && iv.multiplier != 1 {
                self.reduce_multiplication(func, loop_info, iv);
            }
        }
    }
    
    fn reduce_multiplication(&mut self, func: &mut MirFunction, loop_info: &LoopInfo, iv: &InductionVar) {
        let base_iv = match &iv.base {
            Some(b) => b,
            None => return,
        };
        
        // Find the base IV's step
        let base_step = self.analyzer.get_ind_vars(loop_info.header)
            .iter()
            .find(|biv| biv.name == *base_iv)
            .map(|biv| biv.step)
            .unwrap_or(0);
        
        if base_step == 0 {
            return;
        }
        
        // The derived IV's step is multiplier * base_step
        let derived_step = iv.multiplier * base_step;
        
        // Create new IV: init = multiplier * base_init + offset
        // Step = multiplier * base_step
        let new_iv_name = format!("{}_sr", iv.name);
        
        // Add initialization in preheader (simplified - just mark for transformation)
        // Add increment in loop body
        
        self.stats.muls_reduced += 1;
    }
    
    /// Get statistics
    pub fn stats(&self) -> &StrengthReductionStats {
        &self.stats
    }
}

impl Default for StrengthReduction {
    fn default() -> Self {
        Self::new()
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// LINEAR FUNCTION TEST REPLACEMENT
// ═══════════════════════════════════════════════════════════════════════════════

/// Linear function test replacement
pub struct LFTR {
    /// Analyzer
    analyzer: IndVarAnalyzer,
    /// Statistics
    stats: LFTRStats,
}

/// Statistics for LFTR
#[derive(Debug, Clone, Default)]
pub struct LFTRStats {
    /// Loops analyzed
    pub loops_analyzed: usize,
    /// Tests replaced
    pub tests_replaced: usize,
}

impl LFTR {
    pub fn new() -> Self {
        LFTR {
            analyzer: IndVarAnalyzer::new(),
            stats: LFTRStats::default(),
        }
    }
    
    /// Run LFTR
    pub fn run(&mut self, func: &mut MirFunction, loops: &[LoopInfo]) -> &LFTRStats {
        self.stats = LFTRStats::default();
        
        // Analyze IVs
        self.analyzer.analyze(func, loops);
        
        // Apply LFTR
        for loop_info in loops {
            self.process_loop(func, loop_info);
        }
        
        &self.stats
    }
    
    fn process_loop(&mut self, func: &mut MirFunction, loop_info: &LoopInfo) {
        self.stats.loops_analyzed += 1;
        
        // Find the loop exit condition
        let latch = match loop_info.latches.first() {
            Some(l) => *l,
            None => return,
        };
        
        let latch_block = match func.blocks.iter().find(|b| b.id == latch) {
            Some(b) => b,
            None => return,
        };
        
        // Check if exit test uses a derived IV
        if let MirTerminator::Branch { cond, .. } = &latch_block.terminator {
            if let MirOperand::Variable(cond_var) = cond {
                // Find the comparison that defines cond_var
                if let Some(iv) = self.find_iv_in_test(func, loop_info, cond_var) {
                    if iv.kind == IndVarKind::Derived {
                        // Can replace test with base IV comparison
                        self.replace_test(func, loop_info, &iv);
                        self.stats.tests_replaced += 1;
                    }
                }
            }
        }
    }
    
    fn find_iv_in_test(&self, func: &MirFunction, loop_info: &LoopInfo, cond_var: &str) -> Option<&InductionVar> {
        // Find the comparison that produces cond_var
        for block in &func.blocks {
            if !loop_info.blocks.contains(&block.id) {
                continue;
            }
            
            for stmt in &block.statements {
                if let MirStatement::Compare { dest, lhs, .. } = stmt {
                    if dest == cond_var {
                        // Check if lhs is an IV
                        if let MirOperand::Variable(v) = lhs {
                            for iv in self.analyzer.get_ind_vars(loop_info.header) {
                                if iv.name == *v {
                                    return Some(iv);
                                }
                            }
                        }
                    }
                }
            }
        }
        
        None
    }
    
    fn replace_test(&mut self, _func: &mut MirFunction, _loop_info: &LoopInfo, _iv: &InductionVar) {
        // Replace test with base IV comparison
        // This is a placeholder - full implementation would:
        // 1. Compute equivalent limit for base IV
        // 2. Replace comparison with base IV comparison
    }
    
    /// Get statistics
    pub fn stats(&self) -> &LFTRStats {
        &self.stats
    }
}

impl Default for LFTR {
    fn default() -> Self {
        Self::new()
    }
}

