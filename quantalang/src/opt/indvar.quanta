// ═══════════════════════════════════════════════════════════════════════════════
// MIR TYPES
// ═══════════════════════════════════════════════════════════════════════════════

/// Loop information
#[derive(Debug, Clone)]
pub struct LoopInfo {
    /// Header block
    pub header: u32,
    /// Blocks in loop
    pub blocks: BTreeSet<u32>,
    /// Latch blocks (back edge sources)
    pub latches: Vec<u32>,
    /// Exit blocks
    pub exits: Vec<u32>,
}

#[derive(Debug, Clone)]
pub struct MirFunction {
    pub name: String,
    pub blocks: Vec<MirBlock>,
}

#[derive(Debug, Clone)]
pub struct MirBlock {
    pub id: u32,
    pub statements: Vec<MirStatement>,
    pub terminator: MirTerminator,
}

#[derive(Debug, Clone)]
pub enum MirStatement {
    Assign { dest: String, value: MirOperand },
    BinaryOp { dest: String, op: BinOp, lhs: MirOperand, rhs: MirOperand },
    Compare { dest: String, op: CmpOp, lhs: MirOperand, rhs: MirOperand },
    Load { dest: String, ptr: MirOperand },
    Store { ptr: MirOperand, value: MirOperand },
    Phi { dest: String, incoming: Vec<(u32, MirOperand)> },
    Nop,
}

#[derive(Debug, Clone, PartialEq)]
pub enum MirOperand {
    Variable(String),
    Constant(i64),
}

#[derive(Debug, Clone, Copy, PartialEq, Eq)]
pub enum BinOp {
    Add, Sub, Mul, Div, Rem,
    And, Or, Xor, Shl, Shr,
}

#[derive(Debug, Clone, Copy)]
pub enum CmpOp {
    Eq, Ne, Lt, Le, Gt, Ge,
}

#[derive(Debug, Clone)]
pub enum MirTerminator {
    Goto(u32),
    Branch { cond: MirOperand, then_bb: u32, else_bb: u32 },
    Return { value: Option<MirOperand> },
}

// ═══════════════════════════════════════════════════════════════════════════════
// TESTS
// ═══════════════════════════════════════════════════════════════════════════════

#[cfg(test)]
mod tests {
    use super::*;
    
    #[test]
    fn test_basic_iv() {
        let iv = InductionVar::basic("i", 0, 1, 0);
        assert_eq!(iv.kind, IndVarKind::Basic);
        assert_eq!(iv.value_at(5), 5);
    }
    
    #[test]
    fn test_derived_iv() {
        let iv = InductionVar::derived("j", "i", 4, 10, 0);
        assert_eq!(iv.kind, IndVarKind::Derived);
        assert_eq!(iv.multiplier, 4);
        assert_eq!(iv.offset, 10);
    }
    
    #[test]
    fn test_iv_value() {
        let iv = InductionVar::basic("i", 10, 2, 0);
        assert_eq!(iv.value_at(0), 10);
        assert_eq!(iv.value_at(1), 12);
        assert_eq!(iv.value_at(5), 20);
    }
}
