//
// The QuantaLang Build System provides compilation orchestration, incremental
// builds, parallel execution, and artifact caching.
//
// Features:
// - Dependency graph computation and topological ordering
// - Parallel compilation with configurable job count
// - Content-addressable fingerprinting for incremental builds
// - Artifact caching with SHA-256 verification
// - Multiple output formats (human, JSON, diagnostic)
// - Cross-compilation support (x86_64, AArch64, WASM)
//
// ═══════════════════════════════════════════════════════════════════════════════

//! # QuantaLang Build System
//!
//! Compilation orchestration for QuantaLang projects.
//!
//! ## Quick Start
//!
//! ```quanta
//! use quantalang::build::{Build, Profile};
//!
//! // Build with defaults
//! let result = Build::new()
//!     .profile(Profile::release())
//!     .run()?;
//!
//! // Build with custom configuration
//! let result = Build::new()
//!     .profile(Profile::dev())
//!     .jobs(8)
//!     .target("aarch64-apple-darwin")
//!     .features(&["serde", "async"])
//!     .run()?;
//! ```
//!
//! ## Modules
//!
//! - [`config`] - Build configuration and profiles
//! - [`graph`] - Dependency graph and topological ordering
//! - [`cache`] - Fingerprinting and artifact caching
//! - [`compiler`] - Compiler invocation
//! - [`executor`] - Build execution engine

module quantalang::build

