        Solver, SolverResult, SolverStats, Z3Solver,
        
        // Verification
        VerificationCondition, VcKind, VcResult, SourceLocation,
        Verifier, VerifierConfig, VerificationReport,
        
        // Properties
        Property, Contract,
    };
}

// ═══════════════════════════════════════════════════════════════════════════════
// TESTS
// ═══════════════════════════════════════════════════════════════════════════════

#[cfg(test)]
mod tests {
    use super::*;
    
    #[test]
    fn test_sort_display() {
        assert_eq!(Sort::Bool.to_string(), "Bool");
        assert_eq!(Sort::bv(32).to_string(), "(_ BitVec 32)");
        assert_eq!(
            Sort::array(Sort::Int, Sort::Bool).to_string(),
            "(Array Int Bool)"
        );
    }
    
    #[test]
    fn test_expr_construction() {
        let x = Expr::var("x", Sort::Int);
        let y = Expr::var("y", Sort::Int);
        let sum = Expr::add(vec![x.clone(), y.clone()]);
        let cond = Expr::gt(sum, Expr::int_const(0));
        
        // Just verify construction doesn't panic
        assert!(matches!(cond, Expr::Gt(_, _)));
    }
    
    #[test]
    fn test_solver_smtlib() {
        let mut solver = Z3Solver::new();
        solver.declare_const("x", &Sort::Int);
        solver.declare_const("y", &Sort::Int);
        
        let x = Expr::var("x", Sort::Int);
        let constraint = Expr::gt(x, Expr::int_const(0));
        solver.assert(&constraint);
        
        let smt = solver.to_smtlib2();
        assert!(smt.contains("declare-const x Int"));
        assert!(smt.contains("(assert (> x 0))"));
    }
    
    #[test]
    fn test_verifier() {
        let verifier = Verifier::with_z3();
        assert!(verifier.conditions().is_empty());
    }
    
    #[test]
    fn test_verification_report() {
        let mut report = VerificationReport::new();
        report.verified = 5;
        report.failed = 1;
        
        assert_eq!(report.total(), 6);
        assert!(!report.is_success());
    }
}
