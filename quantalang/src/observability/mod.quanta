// ═══════════════════════════════════════════════════════════════════════════════
// TESTS
// ═══════════════════════════════════════════════════════════════════════════════

#[cfg(test)]
mod tests {
    use super::*;
    
    #[test]
    fn test_version() {
        assert_eq!(VERSION, "1.0.0");
    }
    
    #[test]
    fn test_resource() {
        let resource = Resource::with_service("test-service", "1.0.0");
        assert!(!resource.attributes.is_empty());
    }
    
    #[test]
    fn test_builder() {
        let obs = Observability::builder()
            .service_name("test-service")
            .service_version("1.0.0")
            .log_level(Level::Debug)
            .sample_ratio(0.5)
            .build();
        
        // Verify we can get providers
        let _tracer = obs.tracer("test");
        let _meter = obs.meter("test");
        let _logger = obs.logger("test");
    }
    
    #[test]
    fn test_simple() {
        let obs = simple("test-service");
        let logger = obs.logger("test");
        logger.info("test message");
    }
    
    #[test]
    fn test_integration() {
        let obs = Observability::builder()
            .service_name("integration-test")
            .with_console_exporter()
            .build();
        
        let tracer = obs.tracer("test");
        let meter = obs.meter("test");
        let logger = obs.logger("test");
        
        let counter = meter.counter("requests")
            .with_description("Request count")
            .build();
        
        tracer.in_span("test-operation", |span| {
            span.set_attribute("test", "value");
            counter.increment();
            logger.info("Inside span");
        });
    }
}
