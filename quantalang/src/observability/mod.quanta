//
// Unified observability framework for QuantaLang:
// - OpenTelemetry-compatible distributed tracing
// - Metrics with Counter, Histogram, Gauge
// - Structured logging with trace correlation
// - OTLP export support
//
// ═══════════════════════════════════════════════════════════════════════════════

//! # QuantaLang Observability
//!
//! Complete observability stack with tracing, metrics, and logging.
//!
//! ## Quick Start
//!
//! ```quanta
//! use quantalang::observability::prelude::*;
//!
//! // Initialize observability
//! let obs = Observability::builder()
//!     .service_name("my-service")
//!     .with_console_exporter()
//!     .build();
//!
//! // Get a tracer
//! let tracer = obs.tracer("my-component");
//!
//! // Create a span
//! tracer.in_span("process_request", |span| {
//!     span.set_attribute("user_id", "12345");
//!     
//!     // Get a logger (automatically correlated with trace)
//!     let log = obs.logger("my-component");
//!     log.info("Processing request");
//!     
//!     // Record metrics
//!     let counter = obs.meter("my-component").counter("requests").build();
//!     counter.increment();
//!     
//!     do_work()
//! });
//! ```

module quantalang::observability

// Submodules
pub mod tracing;
pub mod metrics;
pub mod logging;

