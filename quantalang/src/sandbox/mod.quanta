// ═══════════════════════════════════════════════════════════════════════════════
// TESTS
// ═══════════════════════════════════════════════════════════════════════════════

#[cfg(test)]
mod tests {
    use super::*;
    
    #[test]
    fn test_version() {
        assert_eq!(VERSION, "1.0.0");
    }
    
    #[test]
    fn test_presets() {
        let _compute = Presets::compute_only();
        let _web = Presets::web_client();
        let _max = Presets::maximum_security();
    }
    
    #[test]
    fn test_capabilities() {
        let caps = capabilities();
        // Just ensure it runs without panic
        let _ = caps.seccomp;
    }
    
    #[test]
    fn test_sandbox_pool() {
        let pool = SandboxPool::new(SandboxConfig::default(), 4);
        
        let result = pool.execute(|| 42);
        assert!(result.is_ok());
        assert_eq!(result.unwrap(), 42);
    }
    
    #[test]
    fn test_violation_handler() {
        let handler = LoggingHandler;
        let violation = SecurityViolation {
            kind: ViolationKind::FileAccess("/etc/passwd".into()),
            description: "Access denied".into(),
            timestamp: std::time::SystemTime::now(),
            context: ViolationContext::default(),
        };
        
        handler.handle(&violation);
    }
}
