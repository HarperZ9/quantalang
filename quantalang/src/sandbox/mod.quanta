//
// Secure sandbox execution environment for QuantaLang.
//
// Features:
// - Capability-based security policies
// - Process isolation (Linux namespaces)
// - Syscall filtering (seccomp-bpf)
// - Resource limits and monitoring
// - Fine-grained filesystem and network access control
//
// ═══════════════════════════════════════════════════════════════════════════════

//! # QuantaLang Sandbox
//!
//! A secure execution environment for running untrusted code.
//!
//! ## Quick Start
//!
//! ```quanta
//! use quantalang::sandbox::{Sandbox, SecurityPolicy};
//!
//! // Create a sandbox with standard policy
//! let mut sandbox = Sandbox::standard()?;
//!
//! // Execute code in the sandbox
//! let result = sandbox.execute(|| {
//!     // This code runs with restricted permissions
//!     compute_something()
//! })?;
//! ```
//!
//! ## Custom Policies
//!
//! ```quanta
//! use quantalang::sandbox::{SecurityPolicy, Sandbox};
//!
//! // Build a custom policy
//! let policy = SecurityPolicy::builder()
//!     .id("my-policy")
//!     .allow_read("/tmp")
//!     .allow_network("api.example.com", 443)
//!     .max_memory(64 * 1024 * 1024)
//!     .max_cpu_time(Duration::from_secs(30))
//!     .build()?;
//!
//! let sandbox = Sandbox::new(SandboxConfig {
//!     policy,
//!     ..Default::default()
//! })?;
//! ```
//!
//! ## Process Isolation
//!
//! ```quanta
//! use quantalang::sandbox::{SandboxBuilder, NamespaceConfig};
//!
//! let sandbox = SandboxBuilder::new()
//!     .all_namespaces()  // Full isolation
//!     .root_fs("/sandbox/rootfs")
//!     .build()?;
//!
//! let process = sandbox.spawn_process("/bin/myapp", &["--config", "app.conf"])?;
//! let status = process.wait()?;
//! ```

module quantalang::sandbox

// Submodules
pub mod policy;
pub mod runtime;
pub mod seccomp;

// Re-exports from policy
