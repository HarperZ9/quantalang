module quantalang::sandbox::seccomp

use alloc::vec::Vec;
use alloc::string::String;
use alloc::collections::BTreeMap;

use super::policy::{SyscallPolicy, SyscallAction, SyscallRule, ArgFilter, FilterOp};

// ═══════════════════════════════════════════════════════════════════════════════
// BPF INSTRUCTION SET
// ═══════════════════════════════════════════════════════════════════════════════

/// BPF instruction
#[repr(C)]
#[derive(Debug, Clone, Copy)]
pub struct BpfInsn {
    /// Instruction code
    pub code: u16,
    /// Jump true offset
    pub jt: u8,
    /// Jump false offset
    pub jf: u8,
    /// Constant/offset
    pub k: u32,
}

impl BpfInsn {
    /// Load word from absolute offset
    pub const fn ld_abs(off: u32) -> Self {
        BpfInsn {
            code: BPF_LD | BPF_W | BPF_ABS,
            jt: 0,
            jf: 0,
            k: off,
        }
    }
    
    /// Load half-word from absolute offset
    pub const fn ldh_abs(off: u32) -> Self {
        BpfInsn {
            code: BPF_LD | BPF_H | BPF_ABS,
            jt: 0,
            jf: 0,
            k: off,
        }
    }
    
    /// Load byte from absolute offset
    pub const fn ldb_abs(off: u32) -> Self {
        BpfInsn {
            code: BPF_LD | BPF_B | BPF_ABS,
            jt: 0,
            jf: 0,
            k: off,
        }
    }
    
    /// Load immediate into accumulator
    pub const fn ld_imm(val: u32) -> Self {
        BpfInsn {
            code: BPF_LD | BPF_IMM,
            jt: 0,
            jf: 0,
            k: val,
        }
    }
    
    /// Jump if accumulator equals constant
    pub const fn jeq_k(k: u32, jt: u8, jf: u8) -> Self {
        BpfInsn {
            code: BPF_JMP | BPF_JEQ | BPF_K,
            jt,
            jf,
            k,
        }
    }
    
    /// Jump if accumulator >= constant
    pub const fn jge_k(k: u32, jt: u8, jf: u8) -> Self {
        BpfInsn {
            code: BPF_JMP | BPF_JGE | BPF_K,
            jt,
            jf,
            k,
        }
    }
    
    /// Jump if accumulator > constant
    pub const fn jgt_k(k: u32, jt: u8, jf: u8) -> Self {
        BpfInsn {
            code: BPF_JMP | BPF_JGT | BPF_K,
            jt,
            jf,
            k,
        }
    }
    
    /// Jump if (accumulator & constant) == constant
    pub const fn jset_k(k: u32, jt: u8, jf: u8) -> Self {
        BpfInsn {
            code: BPF_JMP | BPF_JSET | BPF_K,
            jt,
            jf,
            k,
        }
    }
    
    /// Unconditional jump
    pub const fn ja(k: u32) -> Self {
        BpfInsn {
            code: BPF_JMP | BPF_JA,
            jt: 0,
            jf: 0,
            k,
        }
    }
    
    /// Return with constant
    pub const fn ret_k(k: u32) -> Self {
        BpfInsn {
            code: BPF_RET | BPF_K,
            jt: 0,
            jf: 0,
            k,
        }
    }
    
    /// ALU AND with constant
    pub const fn and_k(k: u32) -> Self {
        BpfInsn {
            code: BPF_ALU | BPF_AND | BPF_K,
            jt: 0,
            jf: 0,
            k,
        }
    }
}

// BPF instruction class
const BPF_LD: u16 = 0x00;
const BPF_LDX: u16 = 0x01;
const BPF_ST: u16 = 0x02;
const BPF_STX: u16 = 0x03;
const BPF_ALU: u16 = 0x04;
const BPF_JMP: u16 = 0x05;
const BPF_RET: u16 = 0x06;
const BPF_MISC: u16 = 0x07;

// BPF ld/ldx size
const BPF_W: u16 = 0x00;
const BPF_H: u16 = 0x08;
const BPF_B: u16 = 0x10;

// BPF ld/ldx mode
const BPF_IMM: u16 = 0x00;
const BPF_ABS: u16 = 0x20;
const BPF_IND: u16 = 0x40;
const BPF_MEM: u16 = 0x60;

// BPF alu/jmp fields
const BPF_ADD: u16 = 0x00;
const BPF_SUB: u16 = 0x10;
const BPF_MUL: u16 = 0x20;
const BPF_DIV: u16 = 0x30;
const BPF_OR: u16 = 0x40;
const BPF_AND: u16 = 0x50;
const BPF_LSH: u16 = 0x60;
const BPF_RSH: u16 = 0x70;
const BPF_NEG: u16 = 0x80;

// BPF jmp type
const BPF_JA: u16 = 0x00;
const BPF_JEQ: u16 = 0x10;
const BPF_JGT: u16 = 0x20;
const BPF_JGE: u16 = 0x30;
const BPF_JSET: u16 = 0x40;

// BPF src
const BPF_K: u16 = 0x00;
const BPF_X: u16 = 0x08;

// ═══════════════════════════════════════════════════════════════════════════════
// SECCOMP RETURN VALUES
// ═══════════════════════════════════════════════════════════════════════════════

/// Seccomp return action
#[repr(u32)]
#[derive(Debug, Clone, Copy, PartialEq, Eq)]
pub enum SeccompAction {
    /// Kill the thread
    KillThread = 0x00000000,
    /// Kill the process
    KillProcess = 0x80000000,
    /// Send SIGSYS
    Trap = 0x00030000,
    /// Return errno
    Errno(u16) = 0x00050000,
    /// Notify userspace
    UserNotif = 0x7fc00000,
    /// Log the syscall
    Log = 0x7ffc0000,
    /// Allow the syscall
    Allow = 0x7fff0000,
}

impl SeccompAction {
    pub fn to_ret_val(self) -> u32 {
        match self {
            SeccompAction::KillThread => 0x00000000,
            SeccompAction::KillProcess => 0x80000000,
            SeccompAction::Trap => 0x00030000,
            SeccompAction::Errno(e) => 0x00050000 | (e as u32),
            SeccompAction::UserNotif => 0x7fc00000,
            SeccompAction::Log => 0x7ffc0000,
            SeccompAction::Allow => 0x7fff0000,
        }
    }
}

impl From<SyscallAction> for SeccompAction {
    fn from(action: SyscallAction) -> Self {
        match action {
            SyscallAction::Allow => SeccompAction::Allow,
            SyscallAction::Kill => SeccompAction::KillProcess,
            SyscallAction::Trap => SeccompAction::Trap,
            SyscallAction::Errno(e) => SeccompAction::Errno(e as u16),
            SyscallAction::Log => SeccompAction::Log,
        }
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// SECCOMP DATA STRUCTURE
// ═══════════════════════════════════════════════════════════════════════════════

/// Seccomp data structure offsets (for BPF loads)
#[repr(C)]
pub struct SeccompData {
    /// Syscall number
    pub nr: i32,
    /// Architecture
    pub arch: u32,
    /// Instruction pointer
    pub instruction_pointer: u64,
    /// Syscall arguments
    pub args: [u64; 6],
}

// Field offsets in seccomp_data
const OFF_NR: u32 = 0;
const OFF_ARCH: u32 = 4;
const OFF_IP_LO: u32 = 8;
const OFF_IP_HI: u32 = 12;
const OFF_ARGS: u32 = 16;

fn arg_offset(n: usize) -> u32 {
    OFF_ARGS + (n as u32) * 8
}

fn arg_offset_lo(n: usize) -> u32 {
    arg_offset(n)
}

fn arg_offset_hi(n: usize) -> u32 {
    arg_offset(n) + 4
}

// ═══════════════════════════════════════════════════════════════════════════════
// ARCHITECTURE CONSTANTS
// ═══════════════════════════════════════════════════════════════════════════════

/// Supported architectures
#[derive(Debug, Clone, Copy, PartialEq, Eq)]
pub enum Arch {
    X86_64,
    X86,
    Arm,
    Arm64,
    Riscv64,
}

impl Arch {
    /// Get audit arch value
    pub fn audit_arch(self) -> u32 {
        match self {
            Arch::X86_64 => AUDIT_ARCH_X86_64,
            Arch::X86 => AUDIT_ARCH_I386,
            Arch::Arm => AUDIT_ARCH_ARM,
            Arch::Arm64 => AUDIT_ARCH_AARCH64,
            Arch::Riscv64 => AUDIT_ARCH_RISCV64,
        }
    }
    
    /// Detect current architecture
    pub fn current() -> Self {
        #[cfg(target_arch = "x86_64")]
        { Arch::X86_64 }
        #[cfg(target_arch = "x86")]
        { Arch::X86 }
        #[cfg(target_arch = "arm")]
        { Arch::Arm }
        #[cfg(target_arch = "aarch64")]
        { Arch::Arm64 }
        #[cfg(target_arch = "riscv64")]
        { Arch::Riscv64 }
    }
}

// Audit architecture constants
const AUDIT_ARCH_X86_64: u32 = 0xc000003e;
const AUDIT_ARCH_I386: u32 = 0x40000003;
const AUDIT_ARCH_ARM: u32 = 0x40000028;
const AUDIT_ARCH_AARCH64: u32 = 0xc00000b7;
const AUDIT_ARCH_RISCV64: u32 = 0xc00000f3;

// ═══════════════════════════════════════════════════════════════════════════════
// BPF PROGRAM BUILDER
// ═══════════════════════════════════════════════════════════════════════════════

/// Builder for BPF filter programs
pub struct BpfProgramBuilder {
    instructions: Vec<BpfInsn>,
    arch: Arch,
    default_action: SeccompAction,
}

impl BpfProgramBuilder {
    /// Create a new builder
    pub fn new(arch: Arch) -> Self {
        BpfProgramBuilder {
            instructions: Vec::new(),
            arch,
            default_action: SeccompAction::KillProcess,
        }
    }
    
    /// Set default action
    pub fn default_action(mut self, action: SeccompAction) -> Self {
        self.default_action = action;
        self
    }
    
    /// Add an instruction
    pub fn insn(mut self, insn: BpfInsn) -> Self {
        self.instructions.push(insn);
        self
    }
    
    /// Add architecture check
    pub fn check_arch(mut self) -> Self {
        // Load arch
        self.instructions.push(BpfInsn::ld_abs(OFF_ARCH));
        // Check against expected arch
        // Jump over kill if matches, otherwise kill
        self.instructions.push(BpfInsn::jeq_k(
            self.arch.audit_arch(),
            1, // skip kill
            0, // proceed to kill
        ));
        self.instructions.push(BpfInsn::ret_k(SeccompAction::KillProcess.to_ret_val()));
        self
    }
    
    /// Add syscall allow rule
    pub fn allow_syscall(mut self, nr: u32) -> Self {
        // Load syscall number
        self.instructions.push(BpfInsn::ld_abs(OFF_NR));
        // Check syscall number
        self.instructions.push(BpfInsn::jeq_k(nr, 0, 1));
        self.instructions.push(BpfInsn::ret_k(SeccompAction::Allow.to_ret_val()));
        self
    }
    
    /// Add syscall deny rule
    pub fn deny_syscall(mut self, nr: u32, action: SeccompAction) -> Self {
        // Load syscall number
        self.instructions.push(BpfInsn::ld_abs(OFF_NR));
        // Check syscall number
        self.instructions.push(BpfInsn::jeq_k(nr, 0, 1));
        self.instructions.push(BpfInsn::ret_k(action.to_ret_val()));
        self
    }
    
    /// Add syscall rule with argument checking
    pub fn syscall_with_args(mut self, nr: u32, filters: &[ArgFilter], action: SeccompAction) -> Self {
        // Load syscall number
        self.instructions.push(BpfInsn::ld_abs(OFF_NR));
        
        // Calculate jump offsets
        let filter_insns = filters.len() * 3; // Each filter needs ~3 instructions
        
        // Check syscall number - if not match, skip all filter checks
        self.instructions.push(BpfInsn::jeq_k(
            nr,
            0, // continue to filters
            (filter_insns + 1) as u8, // skip to next rule
        ));
        
        // Add argument filters
        for filter in filters {
            self = self.add_arg_filter(filter, action);
        }
        
        // If all filters pass, apply action
        self.instructions.push(BpfInsn::ret_k(action.to_ret_val()));
        
        self
    }
    
    fn add_arg_filter(mut self, filter: &ArgFilter, _action: SeccompAction) -> Self {
        let arg_lo = arg_offset_lo(filter.arg_index);
        let arg_hi = arg_offset_hi(filter.arg_index);
        
        // For 32-bit comparisons, load low word
        self.instructions.push(BpfInsn::ld_abs(arg_lo));
        
        match filter.op {
            FilterOp::Equal => {
                self.instructions.push(BpfInsn::jeq_k(
                    filter.value as u32,
                    0, // match - continue
                    1, // no match - skip action
                ));
            }
            FilterOp::NotEqual => {
                self.instructions.push(BpfInsn::jeq_k(
                    filter.value as u32,
                    1, // match - skip action
                    0, // no match - continue
                ));
            }
            FilterOp::LessThan => {
                self.instructions.push(BpfInsn::jge_k(
                    filter.value as u32,
                    1, // >= skip action
                    0, // < continue
                ));
            }
            FilterOp::LessEqual => {
                self.instructions.push(BpfInsn::jgt_k(
                    filter.value as u32,
                    1, // > skip action
                    0, // <= continue
                ));
            }
            FilterOp::GreaterThan => {
                self.instructions.push(BpfInsn::jgt_k(
                    filter.value as u32,
                    0, // > continue
                    1, // <= skip action
                ));
            }
            FilterOp::GreaterEqual => {
                self.instructions.push(BpfInsn::jge_k(
                    filter.value as u32,
                    0, // >= continue
                    1, // < skip action
                ));
            }
            FilterOp::MaskedEqual(mask) => {
                self.instructions.push(BpfInsn::and_k(mask as u32));
                self.instructions.push(BpfInsn::jeq_k(
                    filter.value as u32,
                    0, // match - continue
                    1, // no match - skip action
                ));
            }
        }
        
        self
    }
    
    /// Finalize with default action
    pub fn finish(mut self) -> BpfProgram {
        // Add default return
        self.instructions.push(BpfInsn::ret_k(self.default_action.to_ret_val()));
        
        BpfProgram {
            instructions: self.instructions,
        }
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// BPF PROGRAM
// ═══════════════════════════════════════════════════════════════════════════════

/// Compiled BPF program
pub struct BpfProgram {
    instructions: Vec<BpfInsn>,
}

impl BpfProgram {
    /// Get instruction count
    pub fn len(&self) -> usize {
        self.instructions.len()
    }
    
    /// Check if empty
    pub fn is_empty(&self) -> bool {
        self.instructions.is_empty()
    }
    
    /// Get instructions
    pub fn instructions(&self) -> &[BpfInsn] {
        &self.instructions
    }
    
    /// Convert to sock_fprog for seccomp
    #[cfg(target_os = "linux")]
    pub fn to_sock_fprog(&self) -> SockFprog {
        SockFprog {
            len: self.instructions.len() as u16,
            filter: self.instructions.as_ptr(),
        }
    }
}

/// sock_fprog structure for seccomp
#[cfg(target_os = "linux")]
#[repr(C)]
pub struct SockFprog {
    pub len: u16,
    pub filter: *const BpfInsn,
}

// ═══════════════════════════════════════════════════════════════════════════════
// SECCOMP FILTER
// ═══════════════════════════════════════════════════════════════════════════════

/// Seccomp filter builder from policy
pub struct SeccompFilter {
    program: BpfProgram,
}

impl SeccompFilter {
    /// Create filter from policy
    pub fn from_policy(policy: &SyscallPolicy) -> Self {
        let arch = Arch::current();
        let mut builder = BpfProgramBuilder::new(arch)
            .default_action(policy.default_action.into())
            .check_arch();
        
        // Add per-syscall rules
        for (nr, rule) in &policy.rules {
            if rule.arg_filters.is_empty() {
                // Simple allow/deny
                match rule.action {
                    SyscallAction::Allow => {
                        builder = builder.allow_syscall(*nr);
                    }
                    action => {
                        builder = builder.deny_syscall(*nr, action.into());
                    }
                }
            } else {
                // With argument filters
                builder = builder.syscall_with_args(
                    *nr,
                    &rule.arg_filters,
                    rule.action.into(),
                );
            }
        }
        
        SeccompFilter {
            program: builder.finish(),
        }
    }
    
    /// Install the filter
    #[cfg(target_os = "linux")]
    pub fn install(&self) -> Result<(), SeccompError> {
        use std::os::unix::prelude::*;
        
        // Set NO_NEW_PRIVS
        unsafe {
            if libc::prctl(libc::PR_SET_NO_NEW_PRIVS, 1, 0, 0, 0) != 0 {
                return Err(SeccompError::SetNoNewPrivs(
                    std::io::Error::last_os_error().to_string()
                ));
            }
        }
        
        // Install filter
        let fprog = self.program.to_sock_fprog();
        
        unsafe {
            if libc::prctl(
                libc::PR_SET_SECCOMP,
                libc::SECCOMP_MODE_FILTER,
                &fprog as *const _,
                0,
                0,
            ) != 0 {
                return Err(SeccompError::InstallFilter(
                    std::io::Error::last_os_error().to_string()
                ));
            }
        }
        
        Ok(())
    }
    
    /// Get the BPF program
    pub fn program(&self) -> &BpfProgram {
        &self.program
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// PREDEFINED FILTERS
// ═══════════════════════════════════════════════════════════════════════════════

/// Create a minimal seccomp filter
pub fn minimal_filter() -> SeccompFilter {
    SeccompFilter::from_policy(&SyscallPolicy::minimal())
}

/// Create a standard seccomp filter
pub fn standard_filter() -> SeccompFilter {
    SeccompFilter::from_policy(&SyscallPolicy::standard())
}

/// Create a permissive seccomp filter
pub fn permissive_filter() -> SeccompFilter {
    SeccompFilter::from_policy(&SyscallPolicy::permissive())
}

