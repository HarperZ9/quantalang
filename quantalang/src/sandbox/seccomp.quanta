// ═══════════════════════════════════════════════════════════════════════════════
// ERRORS
// ═══════════════════════════════════════════════════════════════════════════════

/// Seccomp error
#[derive(Debug, Clone)]
pub enum SeccompError {
    SetNoNewPrivs(String),
    InstallFilter(String),
    InvalidFilter(String),
    NotSupported,
}

impl std::fmt::Display for SeccompError {
    fn fmt(&self, f: &mut std::fmt::Formatter<'_>) -> std::fmt::Result {
        match self {
            Self::SetNoNewPrivs(e) => write!(f, "failed to set NO_NEW_PRIVS: {}", e),
            Self::InstallFilter(e) => write!(f, "failed to install filter: {}", e),
            Self::InvalidFilter(e) => write!(f, "invalid filter: {}", e),
            Self::NotSupported => write!(f, "seccomp not supported on this platform"),
        }
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// TESTS
// ═══════════════════════════════════════════════════════════════════════════════

#[cfg(test)]
mod tests {
    use super::*;
    
    #[test]
    fn test_bpf_insn_sizes() {
        assert_eq!(std::mem::size_of::<BpfInsn>(), 8);
    }
    
    #[test]
    fn test_minimal_filter() {
        let filter = minimal_filter();
        assert!(!filter.program().is_empty());
    }
    
    #[test]
    fn test_builder() {
        let arch = Arch::X86_64;
        let program = BpfProgramBuilder::new(arch)
            .default_action(SeccompAction::KillProcess)
            .check_arch()
            .allow_syscall(0) // read
            .allow_syscall(1) // write
            .finish();
        
        // Should have: arch check (3) + 2 syscalls (6) + default (1) = 10
        assert!(program.len() >= 7);
    }
    
    #[test]
    fn test_seccomp_action() {
        assert_eq!(SeccompAction::Allow.to_ret_val(), 0x7fff0000);
        assert_eq!(SeccompAction::KillProcess.to_ret_val(), 0x80000000);
        assert_eq!(SeccompAction::Errno(1).to_ret_val(), 0x00050001);
    }
}
