// ═══════════════════════════════════════════════════════════════════════════════
// SIMD RUNTIME
// ═══════════════════════════════════════════════════════════════════════════════

/// Global SIMD runtime state
static mut SIMD_FEATURES: Option<SimdFeatures> = None;

/// Initialize SIMD runtime (call once at startup)
pub fn init() {
    unsafe {
        if SIMD_FEATURES.is_none() {
            SIMD_FEATURES = Some(SimdFeatures::detect());
        }
    }
}

/// Get detected SIMD features
pub fn features() -> &'static SimdFeatures {
    unsafe {
        SIMD_FEATURES.get_or_insert_with(SimdFeatures::detect)
    }
}

/// Best available SIMD level
pub fn best_level() -> SimdLevel {
    features().best_level()
}

/// Best vector width in bits
pub fn vector_width() -> u32 {
    features().best_vector_width()
}

// ═══════════════════════════════════════════════════════════════════════════════
// PORTABLE VECTOR OPERATIONS
// ═══════════════════════════════════════════════════════════════════════════════

/// Portable SIMD operations (dispatches to best available)
pub mod portable {
    use super::*;
    
    /// Add two f32 slices
    pub fn add_f32(a: &[f32], b: &[f32], out: &mut [f32]) {
        assert_eq!(a.len(), b.len());
        assert_eq!(a.len(), out.len());
        
        let level = best_level();
        let vf = match level {
            SimdLevel::Avx512 => 16,
            SimdLevel::Avx | SimdLevel::Avx2 => 8,
            SimdLevel::Sse2 | SimdLevel::Neon | SimdLevel::Simd128 => 4,
            _ => 1,
        };
        
        let n = a.len();
        let vectorized = (n / vf) * vf;
        
        // Vectorized portion
        for i in (0..vectorized).step_by(vf) {
            for j in 0..vf {
                out[i + j] = a[i + j] + b[i + j];
            }
        }
        
        // Scalar remainder
        for i in vectorized..n {
            out[i] = a[i] + b[i];
        }
    }
    
    /// Multiply two f32 slices
    pub fn mul_f32(a: &[f32], b: &[f32], out: &mut [f32]) {
        assert_eq!(a.len(), b.len());
        assert_eq!(a.len(), out.len());
        
        let n = a.len();
        for i in 0..n {
            out[i] = a[i] * b[i];
        }
    }
    
    /// Dot product of two f32 slices
    pub fn dot_f32(a: &[f32], b: &[f32]) -> f32 {
        assert_eq!(a.len(), b.len());
        
        let mut sum = 0.0f32;
        for i in 0..a.len() {
            sum += a[i] * b[i];
        }
        sum
    }
    
    /// Sum of f32 slice
    pub fn sum_f32(a: &[f32]) -> f32 {
        let mut sum = 0.0f32;
        for &x in a {
            sum += x;
        }
        sum
    }
    
    /// Min of f32 slice
    pub fn min_f32(a: &[f32]) -> f32 {
        let mut min = f32::INFINITY;
        for &x in a {
            if x < min {
                min = x;
            }
        }
        min
    }
    
    /// Max of f32 slice
    pub fn max_f32(a: &[f32]) -> f32 {
        let mut max = f32::NEG_INFINITY;
        for &x in a {
            if x > max {
                max = x;
            }
        }
        max
    }
    
    /// FMA: a * b + c
    pub fn fma_f32(a: &[f32], b: &[f32], c: &[f32], out: &mut [f32]) {
        assert_eq!(a.len(), b.len());
        assert_eq!(a.len(), c.len());
        assert_eq!(a.len(), out.len());
        
        for i in 0..a.len() {
            out[i] = a[i].mul_add(b[i], c[i]);
        }
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// SIMD DISPATCH
// ═══════════════════════════════════════════════════════════════════════════════

/// Runtime SIMD dispatch
pub struct SimdDispatch {
    level: SimdLevel,
}

impl SimdDispatch {
    pub fn new() -> Self {
        SimdDispatch {
            level: best_level(),
        }
    }
    
    pub fn with_level(level: SimdLevel) -> Self {
        SimdDispatch { level }
    }
    
    /// Dispatch vector addition
    pub fn add_f32(&self, a: &[f32], b: &[f32], out: &mut [f32]) {
        match self.level {
            SimdLevel::Avx512 => self.add_f32_avx512(a, b, out),
            SimdLevel::Avx2 | SimdLevel::Avx => self.add_f32_avx(a, b, out),
            SimdLevel::Sse2 | SimdLevel::Sse3 | SimdLevel::Ssse3 |
            SimdLevel::Sse41 | SimdLevel::Sse42 => self.add_f32_sse(a, b, out),
            SimdLevel::Neon => self.add_f32_neon(a, b, out),
            _ => portable::add_f32(a, b, out),
        }
    }
    
    #[cfg(target_arch = "x86_64")]
    fn add_f32_avx512(&self, a: &[f32], b: &[f32], out: &mut [f32]) {
        // AVX-512 implementation would use _mm512_add_ps
        portable::add_f32(a, b, out)
    }
    
    #[cfg(not(target_arch = "x86_64"))]
    fn add_f32_avx512(&self, a: &[f32], b: &[f32], out: &mut [f32]) {
        portable::add_f32(a, b, out)
    }
    
    #[cfg(target_arch = "x86_64")]
    fn add_f32_avx(&self, a: &[f32], b: &[f32], out: &mut [f32]) {
        // AVX implementation would use _mm256_add_ps
        portable::add_f32(a, b, out)
    }
    
    #[cfg(not(target_arch = "x86_64"))]
    fn add_f32_avx(&self, a: &[f32], b: &[f32], out: &mut [f32]) {
        portable::add_f32(a, b, out)
    }
    
    #[cfg(target_arch = "x86_64")]
    fn add_f32_sse(&self, a: &[f32], b: &[f32], out: &mut [f32]) {
        // SSE implementation would use _mm_add_ps
        portable::add_f32(a, b, out)
    }
    
    #[cfg(not(target_arch = "x86_64"))]
    fn add_f32_sse(&self, a: &[f32], b: &[f32], out: &mut [f32]) {
        portable::add_f32(a, b, out)
    }
    
    #[cfg(target_arch = "aarch64")]
    fn add_f32_neon(&self, a: &[f32], b: &[f32], out: &mut [f32]) {
        // NEON implementation would use vaddq_f32
        portable::add_f32(a, b, out)
    }
    
    #[cfg(not(target_arch = "aarch64"))]
    fn add_f32_neon(&self, a: &[f32], b: &[f32], out: &mut [f32]) {
        portable::add_f32(a, b, out)
    }
}

impl Default for SimdDispatch {
    fn default() -> Self {
        Self::new()
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// VECTORIZATION PASS
// ═══════════════════════════════════════════════════════════════════════════════

/// Compiler pass for automatic vectorization
pub struct VectorizationPass {
    vectorizer: Vectorizer,
    stats: VectorizationStats,
}

/// Vectorization statistics
#[derive(Debug, Clone, Default)]
pub struct VectorizationStats {
    pub loops_analyzed: usize,
    pub loops_vectorized: usize,
    pub loops_failed: usize,
    pub total_speedup: f64,
    pub failure_reasons: Vec<(String, VectorizationFailure)>,
}

impl VectorizationPass {
    pub fn new(features: SimdFeatures) -> Self {
        VectorizationPass {
            vectorizer: Vectorizer::new(features),
            stats: VectorizationStats::default(),
        }
    }
    
    /// Run vectorization pass on function
    pub fn run(&mut self, loops: &[Loop]) -> Vec<VectorizationResult> {
        let mut results = Vec::new();
        
        for loop_ in loops {
            self.stats.loops_analyzed += 1;
            
            let result = self.vectorizer.vectorize(loop_);
            
            if result.success {
                self.stats.loops_vectorized += 1;
                self.stats.total_speedup += result.estimated_speedup;
            } else {
                self.stats.loops_failed += 1;
                if let Some(ref reason) = result.failure_reason {
                    self.stats.failure_reasons.push((
                        format!("loop_{}", loop_.id.0),
                        reason.clone(),
                    ));
                }
            }
            
            results.push(result);
        }
        
        results
    }
    
    /// Get statistics
    pub fn stats(&self) -> &VectorizationStats {
        &self.stats
    }
    
    /// Reset statistics
    pub fn reset_stats(&mut self) {
        self.stats = VectorizationStats::default();
    }
}

