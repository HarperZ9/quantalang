// ═══════════════════════════════════════════════════════════════════════════════
// TESTS
// ═══════════════════════════════════════════════════════════════════════════════

#[cfg(test)]
mod tests {
    use super::*;
    
    #[test]
    fn test_init() {
        init();
        let features = features();
        println!("SIMD level: {:?}", features.best_level());
    }
    
    #[test]
    fn test_portable_add() {
        let a = [1.0f32, 2.0, 3.0, 4.0];
        let b = [5.0f32, 6.0, 7.0, 8.0];
        let mut c = [0.0f32; 4];
        
        portable::add_f32(&a, &b, &mut c);
        
        assert_eq!(c, [6.0, 8.0, 10.0, 12.0]);
    }
    
    #[test]
    fn test_portable_dot() {
        let a = [1.0f32, 2.0, 3.0, 4.0];
        let b = [2.0f32, 3.0, 4.0, 5.0];
        
        let dot = portable::dot_f32(&a, &b);
        
        assert_eq!(dot, 40.0); // 2 + 6 + 12 + 20
    }
    
    #[test]
    fn test_simd_dispatch() {
        let dispatch = SimdDispatch::new();
        
        let a = [1.0f32; 16];
        let b = [2.0f32; 16];
        let mut c = [0.0f32; 16];
        
        dispatch.add_f32(&a, &b, &mut c);
        
        for &x in &c {
            assert_eq!(x, 3.0);
        }
    }
}
