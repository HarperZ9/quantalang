        // Tiers
        Tier, TierThresholds,
        
        // Profiles
        FunctionProfile, BranchProfile, TypeProfile, LoopProfile,
        
        // Compiled code
        CompiledCode, InlineCache, DeoptPoint, DeoptReason,
        DeoptState, ValueLocation, StackMap,
        
