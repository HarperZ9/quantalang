    };
}

// ═══════════════════════════════════════════════════════════════════════════════
// TESTS
// ═══════════════════════════════════════════════════════════════════════════════

#[cfg(test)]
mod tests {
    use super::*;
    
    #[test]
    fn test_tier_progression() {
        assert_eq!(Tier::Interpreter.next(), Some(Tier::Baseline));
        assert_eq!(Tier::Baseline.next(), Some(Tier::Optimized));
        assert_eq!(Tier::Optimized.next(), None);
    }
    
    #[test]
    fn test_function_profile() {
        let profile = FunctionProfile::new();
        
        for _ in 0..100 {
            profile.increment_invocations();
        }
        
        let thresholds = TierThresholds::default();
        assert!(profile.should_tier_up(&thresholds));
    }
    
    #[test]
    fn test_branch_profile() {
        let mut profile = BranchProfile::default();
        
        for _ in 0..90 {
            profile.taken += 1;
        }
        for _ in 0..10 {
            profile.not_taken += 1;
        }
        
        assert!((profile.probability() - 0.9).abs() < 0.001);
        assert!(profile.is_biased());
    }
    
    #[test]
    fn test_type_profile() {
        let mut profile = TypeProfile::new();
        
        profile.record(1);
        profile.record(1);
        profile.record(1);
        
        assert!(profile.is_monomorphic());
        
        profile.record(2);
        assert!(profile.is_polymorphic());
    }
    
    #[test]
    fn test_inline_cache() {
        let mut ic = InlineCache::new(0, 0);
        
        ic.add(1, 0x1000);
        ic.add(2, 0x2000);
        
        assert_eq!(ic.lookup(1), Some(0x1000));
        assert_eq!(ic.lookup(2), Some(0x2000));
        assert_eq!(ic.lookup(3), None);
    }
    
    #[test]
    fn test_jit_compiler() {
        let compiler = JitCompiler::new(JitConfig::default());
        
        let profile = compiler.get_profile(1);
        assert_eq!(*profile.tier.read().unwrap(), Tier::Interpreter);
    }
}
