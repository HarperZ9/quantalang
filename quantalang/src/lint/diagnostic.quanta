module quantalang::lint::diagnostic

use alloc::string::String;
use alloc::vec::Vec;
use std::path::{Path, PathBuf};
use std::io::{self, Write};
use crate::lint::config::{OutputFormat, ColorChoice};

// ═══════════════════════════════════════════════════════════════════════════════
// SPAN
// ═══════════════════════════════════════════════════════════════════════════════

/// Source code span
#[derive(Debug, Clone, PartialEq, Eq)]
pub struct Span {
    pub start_line: usize,
    pub start_col: usize,
    pub end_line: usize,
    pub end_col: usize,
}

impl Span {
    pub fn new(start_line: usize, start_col: usize, end_line: usize, end_col: usize) -> Self {
        Span { start_line, start_col, end_line, end_col }
    }
    
    pub fn point(line: usize, col: usize) -> Self {
        Span::new(line, col, line, col)
    }
    
    pub fn line(line: usize) -> Self {
        Span::new(line, 1, line, 1)
    }
    
    pub fn is_multiline(&self) -> bool {
        self.start_line != self.end_line
    }
}

impl Default for Span {
    fn default() -> Self {
        Span::new(1, 1, 1, 1)
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// SEVERITY
// ═══════════════════════════════════════════════════════════════════════════════

#[derive(Debug, Clone, Copy, PartialEq, Eq, PartialOrd, Ord)]
pub enum Severity {
    Note,
    Warning,
    Error,
}

impl Severity {
    pub fn as_str(&self) -> &'static str {
        match self {
            Severity::Note => "note",
            Severity::Warning => "warning",
            Severity::Error => "error",
        }
    }
    
    pub fn color(&self) -> Color {
        match self {
            Severity::Note => Color::Cyan,
            Severity::Warning => Color::Yellow,
            Severity::Error => Color::Red,
        }
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// DIAGNOSTIC
// ═══════════════════════════════════════════════════════════════════════════════

/// A single lint diagnostic
#[derive(Debug, Clone)]
pub struct Diagnostic {
    /// Severity level
    pub severity: Severity,
    
    /// Main message
    pub message: String,
    
    /// Lint rule name
    pub lint_name: Option<String>,
    
    /// Source file
    pub file: Option<PathBuf>,
    
    /// Primary span
    pub span: Option<Span>,
    
    /// Secondary spans with labels
    pub labels: Vec<(Span, String)>,
    
    /// Suggested fix
    pub suggestion: Option<String>,
    
    /// Concrete fix that can be applied
    pub fix: Option<Fix>,
    
    /// Help message
    pub help: Option<String>,
    
    /// Note
    pub note: Option<String>,
    
    /// Source code snippet
    pub snippet: Option<String>,
}

impl Diagnostic {
    pub fn new(severity: Severity, message: &str) -> Self {
        Diagnostic {
            severity,
            message: message.to_string(),
            lint_name: None,
            file: None,
            span: None,
            labels: Vec::new(),
            suggestion: None,
            fix: None,
            help: None,
            note: None,
            snippet: None,
        }
    }
    
    pub fn error(message: &str) -> Self {
        Self::new(Severity::Error, message)
    }
    
    pub fn warning(message: &str) -> Self {
        Self::new(Severity::Warning, message)
    }
    
    pub fn note(message: &str) -> Self {
        Self::new(Severity::Note, message)
    }
    
    pub fn with_file(mut self, file: &Path) -> Self {
        self.file = Some(file.to_path_buf());
        self
    }
    
    pub fn with_span(mut self, span: Span) -> Self {
        self.span = Some(span);
        self
    }
    
    pub fn with_lint(mut self, name: &str) -> Self {
        self.lint_name = Some(name.to_string());
        self
    }
    
    pub fn with_suggestion(mut self, suggestion: &str) -> Self {
        self.suggestion = Some(suggestion.to_string());
        self
    }
    
    pub fn with_fix(mut self, fix: Fix) -> Self {
        self.fix = Some(fix);
        self
    }
    
    pub fn with_help(mut self, help: &str) -> Self {
        self.help = Some(help.to_string());
        self
    }
    
    pub fn is_error(&self) -> bool {
        matches!(self.severity, Severity::Error)
    }
    
    pub fn is_warning(&self) -> bool {
        matches!(self.severity, Severity::Warning)
    }
}

/// A concrete fix that can be applied
#[derive(Debug, Clone)]
pub struct Fix {
    pub description: String,
    pub replacements: Vec<Replacement>,
}

#[derive(Debug, Clone)]
pub struct Replacement {
    pub span: Span,
    pub new_text: String,
}

// ═══════════════════════════════════════════════════════════════════════════════
// DIAGNOSTIC BUILDER
// ═══════════════════════════════════════════════════════════════════════════════

/// Builder for diagnostics
pub struct DiagnosticBuilder {
    diagnostic: Diagnostic,
}

impl DiagnosticBuilder {
    pub fn new(severity: Severity) -> Self {
        DiagnosticBuilder {
            diagnostic: Diagnostic::new(severity, ""),
        }
    }
    
    pub fn message(mut self, msg: &str) -> Self {
        self.diagnostic.message = msg.to_string();
        self
    }
    
    pub fn lint(mut self, name: &str) -> Self {
        self.diagnostic.lint_name = Some(name.to_string());
        self
    }
    
    pub fn file(mut self, path: &Path) -> Self {
        self.diagnostic.file = Some(path.to_path_buf());
        self
    }
    
    pub fn span(mut self, span: Span) -> Self {
        self.diagnostic.span = Some(span);
        self
    }
    
    pub fn label(mut self, span: Span, msg: &str) -> Self {
        self.diagnostic.labels.push((span, msg.to_string()));
        self
    }
    
    pub fn suggestion(mut self, text: &str) -> Self {
        self.diagnostic.suggestion = Some(text.to_string());
        self
    }
    
    pub fn fix(mut self, fix: Fix) -> Self {
        self.diagnostic.fix = Some(fix);
        self
    }
    
    pub fn help(mut self, text: &str) -> Self {
        self.diagnostic.help = Some(text.to_string());
        self
    }
    
    pub fn note(mut self, text: &str) -> Self {
        self.diagnostic.note = Some(text.to_string());
        self
    }
    
    pub fn snippet(mut self, code: &str) -> Self {
        self.diagnostic.snippet = Some(code.to_string());
        self
    }
    
    pub fn build(self) -> Diagnostic {
        self.diagnostic
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// DIAGNOSTIC EMITTER
// ═══════════════════════════════════════════════════════════════════════════════

/// Emits diagnostics in various formats
pub struct DiagnosticEmitter {
    format: OutputFormat,
    color: bool,
    writer: Box<dyn Write>,
}

impl DiagnosticEmitter {
    pub fn new(format: OutputFormat, color: ColorChoice) -> Self {
        let color = match color {
            ColorChoice::Always => true,
            ColorChoice::Never => false,
            ColorChoice::Auto => is_tty(),
        };
        
        DiagnosticEmitter {
            format,
            color,
            writer: Box::new(io::stderr()),
        }
    }
    
    pub fn with_writer<W: Write + 'static>(mut self, writer: W) -> Self {
        self.writer = Box::new(writer);
        self
    }
    
    /// Emit a single diagnostic
    pub fn emit(&mut self, diagnostic: &Diagnostic) {
        match self.format {
            OutputFormat::Human => self.emit_human(diagnostic),
            OutputFormat::Short => self.emit_short(diagnostic),
            OutputFormat::Json => self.emit_json(diagnostic),
            OutputFormat::Sarif => self.emit_sarif(diagnostic),
            OutputFormat::Checkstyle => self.emit_checkstyle(diagnostic),
        }
    }
    
    /// Emit multiple diagnostics
    pub fn emit_all(&mut self, diagnostics: &[Diagnostic]) {
        match self.format {
            OutputFormat::Json => {
                self.emit_json_array(diagnostics);
            }
            OutputFormat::Sarif => {
                self.emit_sarif_report(diagnostics);
            }
            OutputFormat::Checkstyle => {
                self.emit_checkstyle_report(diagnostics);
            }
            _ => {
                for diag in diagnostics {
                    self.emit(diag);
                }
            }
        }
    }
    
    /// Human-readable format
    fn emit_human(&mut self, d: &Diagnostic) {
        // Header: severity[lint]: message
        self.write_colored(&format!("{}", d.severity.as_str()), d.severity.color());
        
        if let Some(ref lint) = d.lint_name {
            self.write_colored(&format!("[{}]", lint), Color::Bold);
        }
        
        let _ = writeln!(self.writer, ": {}", d.message);
        
        // Location
        if let Some(ref file) = d.file {
            let _ = write!(self.writer, "  ");
            self.write_colored("--> ", Color::Blue);
            
            if let Some(ref span) = d.span {
                let _ = writeln!(self.writer, "{}:{}:{}", file.display(), span.start_line, span.start_col);
            } else {
                let _ = writeln!(self.writer, "{}", file.display());
            }
        }
        
        // Code snippet
        if let Some(ref snippet) = d.snippet {
            if let Some(ref span) = d.span {
                self.emit_snippet(snippet, span);
            }
        }
        
        // Labels
        for (span, label) in &d.labels {
            let _ = write!(self.writer, "     ");
            self.write_colored(&format!("{}:{}: ", span.start_line, span.start_col), Color::Blue);
            let _ = writeln!(self.writer, "{}", label);
        }
        
        // Suggestion
        if let Some(ref suggestion) = d.suggestion {
            let _ = write!(self.writer, "  ");
            self.write_colored("help: ", Color::Green);
            let _ = writeln!(self.writer, "{}", suggestion);
        }
        
        // Help
        if let Some(ref help) = d.help {
            let _ = write!(self.writer, "  ");
            self.write_colored("help: ", Color::Cyan);
            let _ = writeln!(self.writer, "{}", help);
        }
        
        // Note
        if let Some(ref note) = d.note {
            let _ = write!(self.writer, "  ");
            self.write_colored("note: ", Color::Cyan);
            let _ = writeln!(self.writer, "{}", note);
        }
        
        let _ = writeln!(self.writer);
    }
    
    fn emit_snippet(&mut self, snippet: &str, span: &Span) {
        let lines: Vec<&str> = snippet.lines().collect();
        
        // Show context around the span
        let start = span.start_line.saturating_sub(2);
        let end = (span.end_line + 1).min(lines.len());
        
        for (idx, line) in lines.iter().enumerate().skip(start).take(end - start) {
            let line_num = idx + 1;
            
            // Line number gutter
            let _ = write!(self.writer, "  ");
            self.write_colored(&format!("{:4} | ", line_num), Color::Blue);
            
            let _ = writeln!(self.writer, "{}", line);
            
            // Underline for span lines
            if line_num >= span.start_line && line_num <= span.end_line {
                let _ = write!(self.writer, "       ");
                self.write_colored("| ", Color::Blue);
                
                let start_col = if line_num == span.start_line { span.start_col } else { 1 };
                let end_col = if line_num == span.end_line { span.end_col } else { line.len() + 1 };
                
                let padding = " ".repeat(start_col.saturating_sub(1));
                let underline = "^".repeat((end_col - start_col).max(1));
                
                let _ = write!(self.writer, "{}", padding);
                self.write_colored(&underline, Color::Red);
                let _ = writeln!(self.writer);
            }
        }
    }
    
    /// Short format (one line per diagnostic)
    fn emit_short(&mut self, d: &Diagnostic) {
        let file = d.file.as_ref()
            .map(|p| p.display().to_string())
            .unwrap_or_else(|| "<unknown>".to_string());
        
        let location = d.span.as_ref()
            .map(|s| format!("{}:{}", s.start_line, s.start_col))
            .unwrap_or_else(|| "1:1".to_string());
        
        let lint = d.lint_name.as_deref().unwrap_or("");
        
        let _ = writeln!(
            self.writer,
            "{}:{}: {} [{}]: {}",
            file, location, d.severity.as_str(), lint, d.message
        );
    }
    
    /// JSON format
    fn emit_json(&mut self, d: &Diagnostic) {
        let _ = writeln!(self.writer, "{}", self.diagnostic_to_json(d));
    }
    
    fn emit_json_array(&mut self, diagnostics: &[Diagnostic]) {
        let _ = writeln!(self.writer, "[");
        
        for (i, d) in diagnostics.iter().enumerate() {
            if i > 0 {
                let _ = writeln!(self.writer, ",");
            }
            let _ = write!(self.writer, "  {}", self.diagnostic_to_json(d));
        }
        
        let _ = writeln!(self.writer, "\n]");
    }
    
    fn diagnostic_to_json(&self, d: &Diagnostic) -> String {
        let mut json = String::from("{");
        
        json.push_str(&format!("\"severity\":\"{}\",", d.severity.as_str()));
        json.push_str(&format!("\"message\":\"{}\",", escape_json(&d.message)));
        
        if let Some(ref lint) = d.lint_name {
            json.push_str(&format!("\"lint\":\"{}\",", lint));
        }
        
        if let Some(ref file) = d.file {
            json.push_str(&format!("\"file\":\"{}\",", escape_json(&file.display().to_string())));
        }
        
        if let Some(ref span) = d.span {
            json.push_str(&format!(
                "\"location\":{{\"line\":{},\"column\":{},\"endLine\":{},\"endColumn\":{}}},",
                span.start_line, span.start_col, span.end_line, span.end_col
            ));
        }
        
        if let Some(ref suggestion) = d.suggestion {
            json.push_str(&format!("\"suggestion\":\"{}\",", escape_json(suggestion)));
        }
        
        // Remove trailing comma and close
        if json.ends_with(',') {
            json.pop();
        }
        json.push('}');
        
        json
    }
    
    /// SARIF format
    fn emit_sarif(&mut self, d: &Diagnostic) {
        // Single result - would need wrapper for proper SARIF
        self.emit_json(d);
    }
    
    fn emit_sarif_report(&mut self, diagnostics: &[Diagnostic]) {
        // Simplified SARIF output
        let _ = writeln!(self.writer, "{{");
        let _ = writeln!(self.writer, "  \"$schema\": \"https://json.schemastore.org/sarif-2.1.0.json\",");
        let _ = writeln!(self.writer, "  \"version\": \"2.1.0\",");
        let _ = writeln!(self.writer, "  \"runs\": [{{");
        let _ = writeln!(self.writer, "    \"tool\": {{\"driver\": {{\"name\": \"quantalint\", \"version\": \"1.0.0\"}}}},");
        let _ = writeln!(self.writer, "    \"results\": [");
        
        for (i, d) in diagnostics.iter().enumerate() {
            if i > 0 {
                let _ = writeln!(self.writer, ",");
            }
            self.emit_sarif_result(d);
        }
        
        let _ = writeln!(self.writer, "\n    ]");
        let _ = writeln!(self.writer, "  }}]");
        let _ = writeln!(self.writer, "}}");
    }
    
    fn emit_sarif_result(&mut self, d: &Diagnostic) {
        let level = match d.severity {
            Severity::Error => "error",
            Severity::Warning => "warning",
            Severity::Note => "note",
        };
        
        let _ = write!(self.writer, "      {{");
        let _ = write!(self.writer, "\"ruleId\":\"{}\",", d.lint_name.as_deref().unwrap_or("unknown"));
        let _ = write!(self.writer, "\"level\":\"{}\",", level);
        let _ = write!(self.writer, "\"message\":{{\"text\":\"{}\"}}", escape_json(&d.message));
        
        if let (Some(ref file), Some(ref span)) = (&d.file, &d.span) {
            let _ = write!(
                self.writer,
                ",\"locations\":[{{\"physicalLocation\":{{\"artifactLocation\":{{\"uri\":\"{}\"}},\"region\":{{\"startLine\":{},\"startColumn\":{}}}}}}}]",
                escape_json(&file.display().to_string()),
                span.start_line,
                span.start_col
            );
        }
        
        let _ = write!(self.writer, "}}");
    }
    
    /// Checkstyle XML format
    fn emit_checkstyle(&mut self, d: &Diagnostic) {
        let file = d.file.as_ref()
            .map(|p| p.display().to_string())
            .unwrap_or_else(|| "unknown".to_string());
        
        let severity = d.severity.as_str();
        let line = d.span.as_ref().map(|s| s.start_line).unwrap_or(1);
        let col = d.span.as_ref().map(|s| s.start_col).unwrap_or(1);
        
        let _ = writeln!(
            self.writer,
            "<error line=\"{}\" column=\"{}\" severity=\"{}\" message=\"{}\" source=\"{}\"/>",
            line, col, severity, escape_xml(&d.message), d.lint_name.as_deref().unwrap_or("")
        );
    }
    
    fn emit_checkstyle_report(&mut self, diagnostics: &[Diagnostic]) {
        let _ = writeln!(self.writer, "<?xml version=\"1.0\" encoding=\"UTF-8\"?>");
        let _ = writeln!(self.writer, "<checkstyle version=\"8.0\">");
        
        // Group by file
        let mut by_file: std::collections::BTreeMap<String, Vec<&Diagnostic>> = std::collections::BTreeMap::new();
        
        for d in diagnostics {
            let file = d.file.as_ref()
                .map(|p| p.display().to_string())
                .unwrap_or_else(|| "unknown".to_string());
            by_file.entry(file).or_default().push(d);
        }
        
        for (file, file_diagnostics) in by_file {
            let _ = writeln!(self.writer, "  <file name=\"{}\">", escape_xml(&file));
            
            for d in file_diagnostics {
                let severity = d.severity.as_str();
                let line = d.span.as_ref().map(|s| s.start_line).unwrap_or(1);
                let col = d.span.as_ref().map(|s| s.start_col).unwrap_or(1);
                
                let _ = writeln!(
                    self.writer,
                    "    <error line=\"{}\" column=\"{}\" severity=\"{}\" message=\"{}\" source=\"{}\"/>",
                    line, col, severity, escape_xml(&d.message), d.lint_name.as_deref().unwrap_or("")
                );
            }
            
            let _ = writeln!(self.writer, "  </file>");
        }
        
        let _ = writeln!(self.writer, "</checkstyle>");
    }
    
    fn write_colored(&mut self, text: &str, color: Color) {
        if self.color {
            let _ = write!(self.writer, "{}{}{}", color.ansi_code(), text, Color::Reset.ansi_code());
        } else {
            let _ = write!(self.writer, "{}", text);
        }
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// COLORS
// ═══════════════════════════════════════════════════════════════════════════════

#[derive(Debug, Clone, Copy)]
enum Color {
    Reset,
    Bold,
    Red,
    Green,
    Yellow,
    Blue,
    Cyan,
}

impl Color {
    fn ansi_code(&self) -> &'static str {
        match self {
            Color::Reset => "\x1b[0m",
            Color::Bold => "\x1b[1m",
            Color::Red => "\x1b[31m",
            Color::Green => "\x1b[32m",
            Color::Yellow => "\x1b[33m",
            Color::Blue => "\x1b[34m",
            Color::Cyan => "\x1b[36m",
        }
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// HELPERS
// ═══════════════════════════════════════════════════════════════════════════════

fn is_tty() -> bool {
    #[cfg(unix)]
    {
        unsafe { libc::isatty(2) != 0 }
    }
    
    #[cfg(not(unix))]
    {
        true
    }
}

fn escape_json(s: &str) -> String {
    s.replace('\\', "\\\\")
        .replace('"', "\\\"")
        .replace('\n', "\\n")
        .replace('\r', "\\r")
        .replace('\t', "\\t")
}

fn escape_xml(s: &str) -> String {
    s.replace('&', "&amp;")
        .replace('<', "&lt;")
        .replace('>', "&gt;")
        .replace('"', "&quot;")
        .replace('\'', "&apos;")
}

// ═══════════════════════════════════════════════════════════════════════════════
// TESTS
// ═══════════════════════════════════════════════════════════════════════════════

#[cfg(test)]
mod tests {
    use super::*;
    
    #[test]
    fn test_span() {
        let span = Span::new(1, 5, 1, 10);
        assert!(!span.is_multiline());
        
        let span = Span::new(1, 1, 3, 5);
        assert!(span.is_multiline());
    }
    
    #[test]
    fn test_diagnostic_builder() {
        let diag = DiagnosticBuilder::new(Severity::Warning)
            .message("test message")
            .lint("test_lint")
            .span(Span::new(1, 1, 1, 10))
            .build();
        
        assert_eq!(diag.message, "test message");
        assert_eq!(diag.lint_name, Some("test_lint".to_string()));
    }
    
    #[test]
    fn test_escape_json() {
        assert_eq!(escape_json("hello\nworld"), "hello\\nworld");
        assert_eq!(escape_json("say \"hi\""), "say \\\"hi\\\"");
    }
}
