// DOCUMENTATION RULES
// ═══════════════════════════════════════════════════════════════════════════════

fn register_documentation_rules(registry: &mut RuleRegistry) {
    registry.register(
        LintRule::new(
            "missing_docs",
            "Public item is missing documentation",
            LintGroup::Documentation,
        )
        .with_level(LintLevel::Warn),
    );
    
    registry.register(
        LintRule::new(
            "missing_doc_examples",
            "Documentation is missing code examples",
            LintGroup::Documentation,
        )
        .with_level(LintLevel::Warn),
    );
    
    registry.register(
        LintRule::new(
            "missing_panics_doc",
            "Function can panic but lacks # Panics section",
            LintGroup::Documentation,
        )
        .with_level(LintLevel::Warn),
    );
    
    registry.register(
        LintRule::new(
            "missing_errors_doc",
            "Function returns Result but lacks # Errors section",
            LintGroup::Documentation,
        )
        .with_level(LintLevel::Warn),
    );
    
    registry.register(
        LintRule::new(
            "missing_safety_doc",
            "Unsafe function lacks # Safety section",
            LintGroup::Documentation,
        )
        .with_level(LintLevel::Warn),
    );
    
    registry.register(
        LintRule::new(
            "broken_intra_doc_links",
            "Documentation contains broken links",
            LintGroup::Documentation,
        )
        .with_level(LintLevel::Warn),
    );
}

// ═══════════════════════════════════════════════════════════════════════════════
// RESTRICTION RULES
// ═══════════════════════════════════════════════════════════════════════════════

fn register_restriction_rules(registry: &mut RuleRegistry) {
    registry.register(
        LintRule::new(
            "panic",
            "Use of panic! macro",
            LintGroup::Restriction,
        )
        .with_level(LintLevel::Allow),
    );
    
    registry.register(
        LintRule::new(
            "unwrap_used",
            "Use of .unwrap()",
            LintGroup::Restriction,
        )
        .with_level(LintLevel::Allow),
    );
    
    registry.register(
        LintRule::new(
            "expect_used",
            "Use of .expect()",
            LintGroup::Restriction,
        )
        .with_level(LintLevel::Allow),
    );
    
    registry.register(
        LintRule::new(
            "print_stdout",
            "Use of print!/println! macros",
            LintGroup::Restriction,
        )
        .with_level(LintLevel::Allow),
    );
    
    registry.register(
        LintRule::new(
            "dbg_macro",
            "Use of dbg! macro",
            LintGroup::Restriction,
        )
        .with_level(LintLevel::Warn),
    );
    
    registry.register(
        LintRule::new(
            "todo",
            "Use of todo! macro",
            LintGroup::Restriction,
        )
        .with_level(LintLevel::Warn),
    );
    
    registry.register(
        LintRule::new(
            "unimplemented",
            "Use of unimplemented! macro",
            LintGroup::Restriction,
        )
        .with_level(LintLevel::Warn),
    );
    
    registry.register(
        LintRule::new(
            "float_arithmetic",
            "Use of floating point arithmetic",
            LintGroup::Restriction,
        )
        .with_level(LintLevel::Allow),
    );
    
    registry.register(
        LintRule::new(
            "integer_arithmetic",
            "Use of integer arithmetic (could overflow)",
            LintGroup::Restriction,
        )
        .with_level(LintLevel::Allow),
    );
    
    registry.register(
        LintRule::new(
            "indexing_slicing",
            "Use of indexing that could panic",
            LintGroup::Restriction,
        )
        .with_level(LintLevel::Allow),
    );
}

// ═══════════════════════════════════════════════════════════════════════════════
// DEPRECATED RULES
// ═══════════════════════════════════════════════════════════════════════════════

fn register_deprecated_rules(registry: &mut RuleRegistry) {
    registry.register(
        LintRule::new(
            "deprecated",
            "Use of deprecated item",
            LintGroup::Deprecated,
        )
        .with_level(LintLevel::Warn),
    );
    
    registry.register(
        LintRule::new(
            "deprecated_since",
            "Use of item deprecated since specific version",
            LintGroup::Deprecated,
        )
        .with_level(LintLevel::Warn),
    );
    
    registry.register(
        LintRule::new(
            "soft_deprecated",
            "Use of soft-deprecated item",
            LintGroup::Deprecated,
        )
        .with_level(LintLevel::Warn),
    );
}

// ═══════════════════════════════════════════════════════════════════════════════
// TESTS
// ═══════════════════════════════════════════════════════════════════════════════

#[cfg(test)]
mod tests {
    use super::*;
    
    #[test]
    fn test_registry() {
        let registry = RuleRegistry::new();
        assert!(registry.len() > 50);
    }
    
    #[test]
    fn test_get_rule() {
        let registry = RuleRegistry::new();
        let rule = registry.get("unused_variable");
        assert!(rule.is_some());
        assert_eq!(rule.unwrap().group, LintGroup::Correctness);
    }
    
    #[test]
    fn test_group_rules() {
        let registry = RuleRegistry::new();
        let rules = registry.group_rules(LintGroup::Style);
        assert!(!rules.is_empty());
    }
    
    #[test]
    fn test_search() {
        let registry = RuleRegistry::new();
        let results = registry.search("unused");
        assert!(results.len() >= 2);
    }
}
