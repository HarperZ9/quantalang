//
// Stage 1: Self-hosted QuantaLang compiler written in QuantaLang
//
// This compiler is compiled by Stage 0 and can compile itself.
// It implements the full language specification (excluding Stage 0 limitations).
//
// Architecture:
// ┌─────────────────────────────────────────────────────────────────────────────┐
// │                        STAGE 1 COMPILER PIPELINE                            │
// ├─────────────────────────────────────────────────────────────────────────────┤
// │                                                                             │
// │  Source Code                                                                │
// │      │                                                                      │
// │      ▼                                                                      │
// │  ┌─────────┐    ┌─────────┐    ┌─────────┐    ┌─────────┐                  │
// │  │  Lexer  │───►│ Parser  │───►│  HIR    │───►│  MIR    │                  │
// │  │         │    │         │    │ Lower   │    │ Build   │                  │
// │  └─────────┘    └─────────┘    └─────────┘    └─────────┘                  │
// │                                                     │                       │
// │                                                     ▼                       │
// │                                              ┌─────────┐                    │
// │                                              │ Codegen │                    │
// │                                              │(LLVM/   │                    │
// │                                              │ Native) │                    │
// │                                              └─────────┘                    │
// │                                                     │                       │
// │                                                     ▼                       │
// │                                               Object Files                  │
// │                                                     │                       │
// │                                                     ▼                       │
// │                                              ┌─────────┐                    │
// │                                              │ Linker  │                    │
// │                                              └─────────┘                    │
// │                                                     │                       │
// │                                                     ▼                       │
// │                                               Executable                    │
// │                                                                             │
// └─────────────────────────────────────────────────────────────────────────────┘
//
// ═══════════════════════════════════════════════════════════════════════════════

module quantalang::bootstrap::stage1::compiler

use alloc::vec::Vec;
use alloc::string::String;
use alloc::boxed::Box;
use alloc::sync::Arc;
use alloc::collections::{BTreeMap, BTreeSet};
use std::path::{Path, PathBuf};
use std::time::{Instant, Duration};
use std::fs;

