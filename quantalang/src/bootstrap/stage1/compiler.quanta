#[cfg(test)]
mod tests {
    use super::*;
    
    #[test]
    fn test_source_map() {
        let mut sm = SourceMap::new();
        // Would test file loading
    }
    
    #[test]
    fn test_interner() {
        let mut interner = Interner::new();
        
        let s1 = interner.intern("hello");
        let s2 = interner.intern("world");
        let s3 = interner.intern("hello");
        
        assert_eq!(s1, s3);
        assert_ne!(s1, s2);
        assert_eq!(interner.get(s1), "hello");
    }
    
    #[test]
    fn test_type_context() {
        let mut ctx = TypeContext::new();
        
        let i32_ty = ctx.mk_int(IntTy::I32);
        let i32_ty2 = ctx.mk_int(IntTy::I32);
        
        assert_eq!(i32_ty, i32_ty2);
    }
    
    #[test]
    fn test_diagnostics() {
        let mut diag = DiagnosticHandler::new();
        
        diag.error("test error", None);
        assert!(diag.has_errors());
        assert_eq!(diag.error_count(), 1);
    }
}
