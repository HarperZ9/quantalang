// QUANTA Standard Library - I/O Module
// Comprehensive I/O primitives: File, Reader, Writer, Buffered I/O, Streams
// Part of Phase 12: Standard Library Implementation

module std::io;

use std::string::String;
use std::vec::Vec;
use std::result::{Result, Ok, Err};
use std::option::{Option, Some, None};

// ============================================================================
// I/O Error Types
// ============================================================================

/// Error kinds for I/O operations
pub enum ErrorKind {
    NotFound,
    PermissionDenied,
    ConnectionRefused,
    ConnectionReset,
    ConnectionAborted,
    NotConnected,
    AddrInUse,
    AddrNotAvailable,
    BrokenPipe,
    AlreadyExists,
    WouldBlock,
    InvalidInput,
    InvalidData,
    TimedOut,
    WriteZero,
    Interrupted,
    UnexpectedEof,
    OutOfMemory,
    Other,
}

/// I/O Error with kind and message
pub struct Error {
    kind: ErrorKind,
    message: String,
    source: Option<Box<Error>>,
}

impl Error {
    /// Create new error
    pub fn new(kind: ErrorKind, message: String) -> Error {
        Error { kind, message, source: None }
    }
    
    /// Create error from kind with default message
    pub fn from_kind(kind: ErrorKind) -> Error {
        let message = match kind {
            ErrorKind::NotFound => "entity not found",
            ErrorKind::PermissionDenied => "permission denied",
            ErrorKind::ConnectionRefused => "connection refused",
            ErrorKind::ConnectionReset => "connection reset",
            ErrorKind::ConnectionAborted => "connection aborted",
            ErrorKind::NotConnected => "not connected",
            ErrorKind::AddrInUse => "address in use",
            ErrorKind::AddrNotAvailable => "address not available",
            ErrorKind::BrokenPipe => "broken pipe",
            ErrorKind::AlreadyExists => "entity already exists",
            ErrorKind::WouldBlock => "operation would block",
            ErrorKind::InvalidInput => "invalid input",
            ErrorKind::InvalidData => "invalid data",
            ErrorKind::TimedOut => "operation timed out",
            ErrorKind::WriteZero => "write zero bytes",
            ErrorKind::Interrupted => "operation interrupted",
            ErrorKind::UnexpectedEof => "unexpected end of file",
            ErrorKind::OutOfMemory => "out of memory",
            ErrorKind::Other => "other error",
        };
        Error::new(kind, String::from(message))
    }
    
    /// Get error kind
    pub fn kind(&self) -> ErrorKind {
        self.kind
    }
    
    /// Get error message
    pub fn message(&self) -> &str {
        self.message.as_str()
    }
    
    /// Chain error with source
    pub fn with_source(mut self, source: Error) -> Error {
        self.source = Some(Box::new(source));
        self
    }
    
    /// Get source error
    pub fn source(&self) -> Option<&Error> {
        self.source.as_ref().map(|b| b.as_ref())
    }
}

impl Debug for Error {
    fn fmt(&self, f: &mut Formatter) -> Result<(), FormatError> {
        write!(f, "Error {{ kind: {:?}, message: {} }}", self.kind, self.message)
    }
}

impl Display for Error {
    fn fmt(&self, f: &mut Formatter) -> Result<(), FormatError> {
        write!(f, "{}", self.message)
    }
}

/// Result type alias for I/O operations
pub type Result<T> = std::result::Result<T, Error>;

// ============================================================================
// Seek Trait
// ============================================================================

/// Position for seeking within a stream
pub enum SeekFrom {
    Start(u64),
    End(i64),
    Current(i64),
}

/// Trait for seeking within a stream
pub trait Seek {
    /// Seek to position, returns new position
    fn seek(&mut self, pos: SeekFrom) -> Result<u64>;
    
    /// Rewind to beginning
    fn rewind(&mut self) -> Result<()> {
        self.seek(SeekFrom::Start(0))?;
        Ok(())
    }
    
    /// Get current stream position
    fn stream_position(&mut self) -> Result<u64> {
        self.seek(SeekFrom::Current(0))
    }
    
    /// Get stream length
    fn stream_len(&mut self) -> Result<u64> {
        let current = self.stream_position()?;
        let end = self.seek(SeekFrom::End(0))?;
        self.seek(SeekFrom::Start(current))?;
        Ok(end)
    }
}

// ============================================================================
// Read Trait
// ============================================================================

/// Trait for reading bytes from a source
pub trait Read {
    /// Read bytes into buffer, returns number of bytes read
    fn read(&mut self, buf: &mut [u8]) -> Result<usize>;
    
    /// Read exact number of bytes, error if not enough
    fn read_exact(&mut self, buf: &mut [u8]) -> Result<()> {
        let mut offset = 0;
        while offset < buf.len() {
            match self.read(&mut buf[offset..]) {
                Ok(0) => return Err(Error::from_kind(ErrorKind::UnexpectedEof)),
                Ok(n) => offset += n,
                Err(e) if e.kind() == ErrorKind::Interrupted => continue,
                Err(e) => return Err(e),
            }
        }
        Ok(())
    }
    
    /// Read all bytes to end into vector
    fn read_to_end(&mut self, buf: &mut Vec<u8>) -> Result<usize> {
        let mut total = 0;
        let mut chunk = [0u8; 8192];
        loop {
            match self.read(&mut chunk) {
                Ok(0) => return Ok(total),
                Ok(n) => {
                    buf.extend_from_slice(&chunk[..n]);
                    total += n;
                }
                Err(e) if e.kind() == ErrorKind::Interrupted => continue,
                Err(e) => return Err(e),
            }
        }
    }
    
    /// Read all bytes to string
    fn read_to_string(&mut self, buf: &mut String) -> Result<usize> {
        let mut bytes = Vec::new();
        let len = self.read_to_end(&mut bytes)?;
        match String::from_utf8(bytes) {
            Ok(s) => {
                buf.push_str(&s);
                Ok(len)
            }
            Err(_) => Err(Error::new(ErrorKind::InvalidData, String::from("stream did not contain valid UTF-8"))),
        }
    }
    
    /// Read single byte
    fn read_byte(&mut self) -> Result<Option<u8>> {
        let mut buf = [0u8; 1];
        match self.read(&mut buf) {
            Ok(0) => Ok(None),
            Ok(_) => Ok(Some(buf[0])),
            Err(e) => Err(e),
        }
    }
    
    /// Create iterator over bytes
    fn bytes(self) -> Bytes<Self> where Self: Sized {
        Bytes { inner: self }
    }
    
    /// Chain with another reader
    fn chain<R: Read>(self, other: R) -> Chain<Self, R> where Self: Sized {
        Chain { first: self, second: other, first_done: false }
    }
    
    /// Take at most n bytes
    fn take(self, limit: u64) -> Take<Self> where Self: Sized {
        Take { inner: self, limit }
    }
}

/// Iterator over bytes in a reader
pub struct Bytes<R: Read> {
    inner: R,
}

impl<R: Read> Iterator for Bytes<R> {
    type Item = Result<u8>;
    
    fn next(&mut self) -> Option<Self::Item> {
        match self.inner.read_byte() {
            Ok(Some(b)) => Some(Ok(b)),
            Ok(None) => None,
            Err(e) => Some(Err(e)),
        }
    }
}

/// Chained reader
pub struct Chain<R1: Read, R2: Read> {
    first: R1,
    second: R2,
    first_done: bool,
}

impl<R1: Read, R2: Read> Read for Chain<R1, R2> {
    fn read(&mut self, buf: &mut [u8]) -> Result<usize> {
        if !self.first_done {
            match self.first.read(buf) {
                Ok(0) => self.first_done = true,
                other => return other,
            }
        }
        self.second.read(buf)
    }
}

/// Limited reader
pub struct Take<R: Read> {
    inner: R,
    limit: u64,
}

impl<R: Read> Read for Take<R> {
    fn read(&mut self, buf: &mut [u8]) -> Result<usize> {
        if self.limit == 0 {
            return Ok(0);
        }
        let max = std::cmp::min(buf.len() as u64, self.limit) as usize;
        let n = self.inner.read(&mut buf[..max])?;
        self.limit -= n as u64;
        Ok(n)
    }
}

impl<R: Read> Take<R> {
    /// Get remaining limit
    pub fn limit(&self) -> u64 {
        self.limit
    }
    
    /// Set new limit
    pub fn set_limit(&mut self, limit: u64) {
        self.limit = limit;
    }
    
    /// Get inner reader reference
    pub fn get_ref(&self) -> &R {
        &self.inner
    }
    
    /// Get inner reader mutable reference
    pub fn get_mut(&mut self) -> &mut R {
        &mut self.inner
    }
    
    /// Consume and return inner reader
    pub fn into_inner(self) -> R {
        self.inner
    }
}

// ============================================================================
// Write Trait
// ============================================================================

/// Trait for writing bytes to a destination
pub trait Write {
    /// Write bytes from buffer, returns number of bytes written
    fn write(&mut self, buf: &[u8]) -> Result<usize>;
    
    /// Flush buffered data
    fn flush(&mut self) -> Result<()>;
    
    /// Write all bytes from buffer
    fn write_all(&mut self, buf: &[u8]) -> Result<()> {
        let mut offset = 0;
        while offset < buf.len() {
            match self.write(&buf[offset..]) {
                Ok(0) => return Err(Error::from_kind(ErrorKind::WriteZero)),
                Ok(n) => offset += n,
                Err(e) if e.kind() == ErrorKind::Interrupted => continue,
                Err(e) => return Err(e),
            }
        }
        Ok(())
    }
    
    /// Write formatted string
    fn write_fmt(&mut self, fmt: Arguments) -> Result<()> {
        let s = format!("{}", fmt);
        self.write_all(s.as_bytes())
    }
    
    /// Create adapter for &mut Write
    fn by_ref(&mut self) -> &mut Self {
        self
    }
}

// ============================================================================
// BufRead Trait
// ============================================================================

/// Trait for buffered reading
pub trait BufRead: Read {
    /// Return internal buffer contents
    fn fill_buf(&mut self) -> Result<&[u8]>;
    
    /// Mark bytes as consumed
    fn consume(&mut self, amt: usize);
    
    /// Check if buffer has data
    fn has_data_left(&mut self) -> Result<bool> {
        Ok(!self.fill_buf()?.is_empty())
    }
    
    /// Read until delimiter, appending to buf
    fn read_until(&mut self, byte: u8, buf: &mut Vec<u8>) -> Result<usize> {
        let mut total = 0;
        loop {
            let (done, used) = {
                let available = self.fill_buf()?;
                match available.iter().position(|&b| b == byte) {
                    Some(i) => {
                        buf.extend_from_slice(&available[..=i]);
                        (true, i + 1)
                    }
                    None => {
                        buf.extend_from_slice(available);
                        (available.is_empty(), available.len())
                    }
                }
            };
            self.consume(used);
            total += used;
            if done {
                return Ok(total);
            }
        }
    }
    
    /// Read line, appending to string (includes newline)
    fn read_line(&mut self, buf: &mut String) -> Result<usize> {
        let mut bytes = Vec::new();
        let len = self.read_until(b'\n', &mut bytes)?;
        match String::from_utf8(bytes) {
            Ok(s) => {
                buf.push_str(&s);
                Ok(len)
            }
            Err(_) => Err(Error::new(ErrorKind::InvalidData, String::from("stream did not contain valid UTF-8"))),
        }
    }
    
    /// Iterator over lines
    fn lines(self) -> Lines<Self> where Self: Sized {
        Lines { buf: self }
    }
    
    /// Split by byte delimiter
    fn split(self, byte: u8) -> Split<Self> where Self: Sized {
        Split { buf: self, delim: byte }
    }
}

/// Iterator over lines
pub struct Lines<B: BufRead> {
    buf: B,
}

impl<B: BufRead> Iterator for Lines<B> {
    type Item = Result<String>;
    
    fn next(&mut self) -> Option<Self::Item> {
        let mut line = String::new();
        match self.buf.read_line(&mut line) {
            Ok(0) => None,
            Ok(_) => {
                // Remove trailing newline
                if line.ends_with('\n') {
                    line.pop();
                    if line.ends_with('\r') {
                        line.pop();
                    }
                }
                Some(Ok(line))
            }
            Err(e) => Some(Err(e)),
        }
    }
}

/// Iterator over splits
pub struct Split<B: BufRead> {
    buf: B,
    delim: u8,
}

impl<B: BufRead> Iterator for Split<B> {
    type Item = Result<Vec<u8>>;
    
    fn next(&mut self) -> Option<Self::Item> {
        let mut chunk = Vec::new();
        match self.buf.read_until(self.delim, &mut chunk) {
            Ok(0) => None,
            Ok(_) => {
                // Remove trailing delimiter
                if chunk.last() == Some(&self.delim) {
                    chunk.pop();
                }
                Some(Ok(chunk))
            }
            Err(e) => Some(Err(e)),
        }
    }
}

// ============================================================================
// BufReader - Buffered Reader Wrapper
// ============================================================================

const DEFAULT_BUF_SIZE: usize = 8192;

/// Buffered reader wrapper
pub struct BufReader<R: Read> {
    inner: R,
    buf: Vec<u8>,
    pos: usize,
    cap: usize,
}

impl<R: Read> BufReader<R> {
    /// Create new buffered reader with default capacity
    pub fn new(inner: R) -> BufReader<R> {
        BufReader::with_capacity(DEFAULT_BUF_SIZE, inner)
    }
    
    /// Create buffered reader with specific capacity
    pub fn with_capacity(capacity: usize, inner: R) -> BufReader<R> {
        let mut buf = Vec::with_capacity(capacity);
        buf.resize(capacity, 0);
        BufReader {
            inner,
            buf,
            pos: 0,
            cap: 0,
        }
    }
    
    /// Get reference to inner reader
    pub fn get_ref(&self) -> &R {
        &self.inner
    }
    
    /// Get mutable reference to inner reader
    pub fn get_mut(&mut self) -> &mut R {
        &mut self.inner
    }
    
    /// Consume and return inner reader
    pub fn into_inner(self) -> R {
        self.inner
    }
    
    /// Get buffer contents
    pub fn buffer(&self) -> &[u8] {
        &self.buf[self.pos..self.cap]
    }
    
    /// Get buffer capacity
    pub fn capacity(&self) -> usize {
        self.buf.len()
    }
    
    /// Discard buffer contents
    fn discard_buffer(&mut self) {
        self.pos = 0;
        self.cap = 0;
    }
}

impl<R: Read> Read for BufReader<R> {
    fn read(&mut self, buf: &mut [u8]) -> Result<usize> {
        // If requesting more than buffer and buffer is empty, read directly
        if self.pos == self.cap && buf.len() >= self.buf.len() {
            self.discard_buffer();
            return self.inner.read(buf);
        }
        
        let nread = {
            let buffered = self.fill_buf()?;
            let nread = std::cmp::min(buffered.len(), buf.len());
            buf[..nread].copy_from_slice(&buffered[..nread]);
            nread
        };
        self.consume(nread);
        Ok(nread)
    }
}

impl<R: Read> BufRead for BufReader<R> {
    fn fill_buf(&mut self) -> Result<&[u8]> {
        if self.pos >= self.cap {
            self.cap = self.inner.read(&mut self.buf)?;
            self.pos = 0;
        }
        Ok(&self.buf[self.pos..self.cap])
    }
    
    fn consume(&mut self, amt: usize) {
        self.pos = std::cmp::min(self.pos + amt, self.cap);
    }
}

impl<R: Read + Seek> Seek for BufReader<R> {
    fn seek(&mut self, pos: SeekFrom) -> Result<u64> {
        let result = match pos {
            SeekFrom::Current(n) => {
                // Adjust for buffered data
                let remainder = (self.cap - self.pos) as i64;
                let adjusted = n.checked_sub(remainder)
                    .ok_or_else(|| Error::new(ErrorKind::InvalidInput, String::from("seek underflow")))?;
                self.inner.seek(SeekFrom::Current(adjusted))?
            }
            _ => self.inner.seek(pos)?,
        };
        self.discard_buffer();
        Ok(result)
    }
}

// ============================================================================
// BufWriter - Buffered Writer Wrapper
// ============================================================================

/// Buffered writer wrapper
pub struct BufWriter<W: Write> {
    inner: W,
    buf: Vec<u8>,
    panicked: bool,
}

impl<W: Write> BufWriter<W> {
    /// Create new buffered writer with default capacity
    pub fn new(inner: W) -> BufWriter<W> {
        BufWriter::with_capacity(DEFAULT_BUF_SIZE, inner)
    }
    
    /// Create buffered writer with specific capacity
    pub fn with_capacity(capacity: usize, inner: W) -> BufWriter<W> {
        BufWriter {
            inner,
            buf: Vec::with_capacity(capacity),
            panicked: false,
        }
    }
    
    /// Get reference to inner writer
    pub fn get_ref(&self) -> &W {
        &self.inner
    }
    
    /// Get mutable reference to inner writer
    pub fn get_mut(&mut self) -> &mut W {
        &mut self.inner
    }
    
    /// Get buffer contents
    pub fn buffer(&self) -> &[u8] {
        &self.buf
    }
    
    /// Get buffer capacity
    pub fn capacity(&self) -> usize {
        self.buf.capacity()
    }
    
    /// Consume and return inner writer, flushing first
    pub fn into_inner(mut self) -> Result<W> {
        self.flush_buf()?;
        Ok(self.inner)
    }
    
    /// Flush buffer to inner writer
    fn flush_buf(&mut self) -> Result<()> {
        let mut written = 0;
        let len = self.buf.len();
        
        while written < len {
            self.panicked = true;
            let r = self.inner.write(&self.buf[written..]);
            self.panicked = false;
            
            match r {
                Ok(0) => return Err(Error::from_kind(ErrorKind::WriteZero)),
                Ok(n) => written += n,
                Err(e) if e.kind() == ErrorKind::Interrupted => continue,
                Err(e) => {
                    // Remove written bytes from buffer
                    if written > 0 {
                        self.buf.drain(..written);
                    }
                    return Err(e);
                }
            }
        }
        
        self.buf.clear();
        Ok(())
    }
    
    /// Write to buffer, flushing if needed
    fn write_to_buf(&mut self, buf: &[u8]) -> usize {
        let available = self.buf.capacity() - self.buf.len();
        let amt = std::cmp::min(buf.len(), available);
        self.buf.extend_from_slice(&buf[..amt]);
        amt
    }
}

impl<W: Write> Write for BufWriter<W> {
    fn write(&mut self, buf: &[u8]) -> Result<usize> {
        // If buffer is full, flush it
        if self.buf.len() >= self.buf.capacity() {
            self.flush_buf()?;
        }
        
        // If input is larger than buffer capacity, write directly
        if buf.len() >= self.buf.capacity() {
            self.inner.write(buf)
        } else {
            Ok(self.write_to_buf(buf))
        }
    }
    
    fn flush(&mut self) -> Result<()> {
        self.flush_buf()?;
        self.inner.flush()
    }
    
    fn write_all(&mut self, buf: &[u8]) -> Result<()> {
        // If buffer is full, flush it
        if self.buf.len() >= self.buf.capacity() {
            self.flush_buf()?;
        }
        
        // If larger than capacity, write directly
        if buf.len() > self.buf.capacity() - self.buf.len() {
            self.flush_buf()?;
            self.inner.write_all(buf)
        } else {
            self.buf.extend_from_slice(buf);
            Ok(())
        }
    }
}

impl<W: Write + Seek> Seek for BufWriter<W> {
    fn seek(&mut self, pos: SeekFrom) -> Result<u64> {
        self.flush_buf()?;
        self.inner.seek(pos)
    }
}

impl<W: Write> Drop for BufWriter<W> {
    fn drop(&mut self) {
        if !self.panicked {
            let _ = self.flush_buf();
        }
    }
}

// ============================================================================
// LineWriter - Line-buffered Writer
// ============================================================================

/// Line-buffered writer - flushes on newlines
pub struct LineWriter<W: Write> {
    inner: BufWriter<W>,
    need_flush: bool,
}

impl<W: Write> LineWriter<W> {
    /// Create new line writer with default capacity
    pub fn new(inner: W) -> LineWriter<W> {
        LineWriter::with_capacity(1024, inner)
    }
    
    /// Create line writer with specific capacity
    pub fn with_capacity(capacity: usize, inner: W) -> LineWriter<W> {
        LineWriter {
            inner: BufWriter::with_capacity(capacity, inner),
            need_flush: false,
        }
    }
    
    /// Get reference to inner writer
    pub fn get_ref(&self) -> &W {
        self.inner.get_ref()
    }
    
    /// Get mutable reference to inner writer
    pub fn get_mut(&mut self) -> &mut W {
        self.inner.get_mut()
    }
    
    /// Consume and return inner writer
    pub fn into_inner(self) -> Result<W> {
        self.inner.into_inner()
    }
}

impl<W: Write> Write for LineWriter<W> {
    fn write(&mut self, buf: &[u8]) -> Result<usize> {
        // Find last newline
        if let Some(i) = buf.iter().rposition(|&b| b == b'\n') {
            // Write up to and including newline
            let n = self.inner.write(&buf[..=i])?;
            self.need_flush = true;
            
            // Flush after newline
            if self.need_flush {
                self.inner.flush()?;
                self.need_flush = false;
            }
            
            // Write remainder
            if n > i {
                Ok(n)
            } else {
                Ok(i + 1)
            }
        } else {
            self.inner.write(buf)
        }
    }
    
    fn flush(&mut self) -> Result<()> {
        self.inner.flush()
    }
}

// ============================================================================
// Cursor - In-memory I/O
// ============================================================================

/// Cursor wraps an in-memory buffer for Read/Write/Seek
pub struct Cursor<T> {
    inner: T,
    pos: u64,
}

impl<T> Cursor<T> {
    /// Create new cursor at position 0
    pub fn new(inner: T) -> Cursor<T> {
        Cursor { inner, pos: 0 }
    }
    
    /// Get reference to inner value
    pub fn get_ref(&self) -> &T {
        &self.inner
    }
    
    /// Get mutable reference to inner value
    pub fn get_mut(&mut self) -> &mut T {
        &mut self.inner
    }
    
    /// Consume and return inner value
    pub fn into_inner(self) -> T {
        self.inner
    }
    
    /// Get current position
    pub fn position(&self) -> u64 {
        self.pos
    }
    
    /// Set position
    pub fn set_position(&mut self, pos: u64) {
        self.pos = pos;
    }
}

impl<T: AsRef<[u8]>> Read for Cursor<T> {
    fn read(&mut self, buf: &mut [u8]) -> Result<usize> {
        let slice = self.inner.as_ref();
        let pos = self.pos as usize;
        
        if pos >= slice.len() {
            return Ok(0);
        }
        
        let amt = std::cmp::min(buf.len(), slice.len() - pos);
        buf[..amt].copy_from_slice(&slice[pos..pos + amt]);
        self.pos += amt as u64;
        Ok(amt)
    }
}

impl<T: AsRef<[u8]>> BufRead for Cursor<T> {
    fn fill_buf(&mut self) -> Result<&[u8]> {
        let slice = self.inner.as_ref();
        let pos = self.pos as usize;
        Ok(&slice[std::cmp::min(pos, slice.len())..])
    }
    
    fn consume(&mut self, amt: usize) {
        self.pos += amt as u64;
    }
}

impl Write for Cursor<Vec<u8>> {
    fn write(&mut self, buf: &[u8]) -> Result<usize> {
        let pos = self.pos as usize;
        
        // Extend if needed
        if pos + buf.len() > self.inner.len() {
            self.inner.resize(pos + buf.len(), 0);
        }
        
        self.inner[pos..pos + buf.len()].copy_from_slice(buf);
        self.pos += buf.len() as u64;
        Ok(buf.len())
    }
    
    fn flush(&mut self) -> Result<()> {
        Ok(())
    }
}

impl Write for Cursor<&mut Vec<u8>> {
    fn write(&mut self, buf: &[u8]) -> Result<usize> {
        let pos = self.pos as usize;
        
        if pos + buf.len() > self.inner.len() {
            self.inner.resize(pos + buf.len(), 0);
        }
        
        self.inner[pos..pos + buf.len()].copy_from_slice(buf);
        self.pos += buf.len() as u64;
        Ok(buf.len())
    }
    
    fn flush(&mut self) -> Result<()> {
        Ok(())
    }
}

impl Write for Cursor<&mut [u8]> {
    fn write(&mut self, buf: &[u8]) -> Result<usize> {
        let pos = self.pos as usize;
        
        if pos >= self.inner.len() {
            return Ok(0);
        }
        
        let amt = std::cmp::min(buf.len(), self.inner.len() - pos);
        self.inner[pos..pos + amt].copy_from_slice(&buf[..amt]);
        self.pos += amt as u64;
        Ok(amt)
    }
    
    fn flush(&mut self) -> Result<()> {
        Ok(())
    }
}

impl<T: AsRef<[u8]>> Seek for Cursor<T> {
    fn seek(&mut self, style: SeekFrom) -> Result<u64> {
        let (base, offset) = match style {
            SeekFrom::Start(n) => {
                self.pos = n;
                return Ok(n);
            }
            SeekFrom::End(n) => (self.inner.as_ref().len() as u64, n),
            SeekFrom::Current(n) => (self.pos, n),
        };
        
        let new_pos = if offset >= 0 {
            base.checked_add(offset as u64)
        } else {
            base.checked_sub((-offset) as u64)
        };
        
        match new_pos {
            Some(n) => {
                self.pos = n;
                Ok(n)
            }
            None => Err(Error::new(ErrorKind::InvalidInput, String::from("seek to negative position"))),
        }
    }
}

// ============================================================================
// File - Filesystem File Handle
// ============================================================================

/// File open options
pub struct OpenOptions {
    read: bool,
    write: bool,
    append: bool,
    truncate: bool,
    create: bool,
    create_new: bool,
    mode: u32,
}

impl OpenOptions {
    /// Create new options with defaults
    pub fn new() -> OpenOptions {
        OpenOptions {
            read: false,
            write: false,
            append: false,
            truncate: false,
            create: false,
            create_new: false,
            mode: 0o666,
        }
    }
    
    /// Open for reading
    pub fn read(mut self, read: bool) -> OpenOptions {
        self.read = read;
        self
    }
    
    /// Open for writing
    pub fn write(mut self, write: bool) -> OpenOptions {
        self.write = write;
        self
    }
    
    /// Append to file
    pub fn append(mut self, append: bool) -> OpenOptions {
        self.append = append;
        self
    }
    
    /// Truncate file on open
    pub fn truncate(mut self, truncate: bool) -> OpenOptions {
        self.truncate = truncate;
        self
    }
    
    /// Create file if it doesn't exist
    pub fn create(mut self, create: bool) -> OpenOptions {
        self.create = create;
        self
    }
    
    /// Create new file, error if exists
    pub fn create_new(mut self, create_new: bool) -> OpenOptions {
        self.create_new = create_new;
        self
    }
    
    /// Set file permissions (Unix)
    pub fn mode(mut self, mode: u32) -> OpenOptions {
        self.mode = mode;
        self
    }
    
    /// Open file with these options
    pub fn open(&self, path: &str) -> Result<File> {
        // Build flags
        let mut flags = 0i32;
        
        match (self.read, self.write, self.append) {
            (true, false, false) => flags |= O_RDONLY,
            (false, true, false) => flags |= O_WRONLY,
            (true, true, false) => flags |= O_RDWR,
            (false, _, true) => flags |= O_WRONLY | O_APPEND,
            (true, _, true) => flags |= O_RDWR | O_APPEND,
            (false, false, false) => return Err(Error::new(ErrorKind::InvalidInput, String::from("no access mode specified"))),
        }
        
        if self.create {
            flags |= O_CREAT;
        }
        if self.create_new {
            flags |= O_CREAT | O_EXCL;
        }
        if self.truncate {
            flags |= O_TRUNC;
        }
        
        File::open_with_flags(path, flags, self.mode)
    }
}

impl Default for OpenOptions {
    fn default() -> OpenOptions {
        OpenOptions::new()
    }
}

// File flag constants (POSIX)
const O_RDONLY: i32 = 0;
const O_WRONLY: i32 = 1;
const O_RDWR: i32 = 2;
const O_CREAT: i32 = 64;
const O_EXCL: i32 = 128;
const O_TRUNC: i32 = 512;
const O_APPEND: i32 = 1024;

/// File handle
pub struct File {
    fd: i32,
    path: String,
}

impl File {
    /// Open file for reading
    pub fn open(path: &str) -> Result<File> {
        OpenOptions::new().read(true).open(path)
    }
    
    /// Create or truncate file for writing
    pub fn create(path: &str) -> Result<File> {
        OpenOptions::new()
            .write(true)
            .create(true)
            .truncate(true)
            .open(path)
    }
    
    /// Open file with specific flags
    fn open_with_flags(path: &str, flags: i32, mode: u32) -> Result<File> {
        let fd = unsafe { syscall_open(path.as_ptr(), path.len(), flags, mode) };
        
        if fd < 0 {
            return Err(File::error_from_errno(-fd));
        }
        
        Ok(File {
            fd,
            path: String::from(path),
        })
    }
    
    /// Convert errno to Error
    fn error_from_errno(errno: i32) -> Error {
        let kind = match errno {
            2 => ErrorKind::NotFound,           // ENOENT
            13 => ErrorKind::PermissionDenied,  // EACCES
            17 => ErrorKind::AlreadyExists,     // EEXIST
            22 => ErrorKind::InvalidInput,      // EINVAL
            28 => ErrorKind::OutOfMemory,       // ENOSPC
            _ => ErrorKind::Other,
        };
        Error::from_kind(kind)
    }
    
    /// Sync all data and metadata to disk
    pub fn sync_all(&self) -> Result<()> {
        let ret = unsafe { syscall_fsync(self.fd) };
        if ret < 0 {
            Err(File::error_from_errno(-ret))
        } else {
            Ok(())
        }
    }
    
    /// Sync data to disk (not metadata)
    pub fn sync_data(&self) -> Result<()> {
        let ret = unsafe { syscall_fdatasync(self.fd) };
        if ret < 0 {
            Err(File::error_from_errno(-ret))
        } else {
            Ok(())
        }
    }
    
    /// Set file length
    pub fn set_len(&self, size: u64) -> Result<()> {
        let ret = unsafe { syscall_ftruncate(self.fd, size) };
        if ret < 0 {
            Err(File::error_from_errno(-ret))
        } else {
            Ok(())
        }
    }
    
    /// Get file metadata
    pub fn metadata(&self) -> Result<Metadata> {
        let mut stat = StatBuf::default();
        let ret = unsafe { syscall_fstat(self.fd, &mut stat) };
        if ret < 0 {
            Err(File::error_from_errno(-ret))
        } else {
            Ok(Metadata::from_stat(stat))
        }
    }
    
    /// Try to clone file handle
    pub fn try_clone(&self) -> Result<File> {
        let new_fd = unsafe { syscall_dup(self.fd) };
        if new_fd < 0 {
            Err(File::error_from_errno(-new_fd))
        } else {
            Ok(File {
                fd: new_fd,
                path: self.path.clone(),
            })
        }
    }
    
    /// Set permissions
    pub fn set_permissions(&self, mode: u32) -> Result<()> {
        let ret = unsafe { syscall_fchmod(self.fd, mode) };
        if ret < 0 {
            Err(File::error_from_errno(-ret))
        } else {
            Ok(())
        }
    }
}

impl Read for File {
    fn read(&mut self, buf: &mut [u8]) -> Result<usize> {
        let ret = unsafe { syscall_read(self.fd, buf.as_mut_ptr(), buf.len()) };
        if ret < 0 {
            Err(File::error_from_errno(-ret))
        } else {
            Ok(ret as usize)
        }
    }
}

impl Write for File {
    fn write(&mut self, buf: &[u8]) -> Result<usize> {
        let ret = unsafe { syscall_write(self.fd, buf.as_ptr(), buf.len()) };
        if ret < 0 {
            Err(File::error_from_errno(-ret))
        } else {
            Ok(ret as usize)
        }
    }
    
    fn flush(&mut self) -> Result<()> {
        Ok(())
    }
}

impl Seek for File {
    fn seek(&mut self, pos: SeekFrom) -> Result<u64> {
        let (offset, whence) = match pos {
            SeekFrom::Start(n) => (n as i64, 0),    // SEEK_SET
            SeekFrom::Current(n) => (n, 1),          // SEEK_CUR
            SeekFrom::End(n) => (n, 2),              // SEEK_END
        };
        
        let ret = unsafe { syscall_lseek(self.fd, offset, whence) };
        if ret < 0 {
            Err(File::error_from_errno(-ret as i32))
        } else {
            Ok(ret as u64)
        }
    }
}

impl Drop for File {
    fn drop(&mut self) {
        unsafe { syscall_close(self.fd) };
    }
}

// System call declarations (platform-specific implementations)
extern "C" {
    fn syscall_open(path: *const u8, path_len: usize, flags: i32, mode: u32) -> i32;
    fn syscall_close(fd: i32) -> i32;
    fn syscall_read(fd: i32, buf: *mut u8, count: usize) -> isize;
    fn syscall_write(fd: i32, buf: *const u8, count: usize) -> isize;
    fn syscall_lseek(fd: i32, offset: i64, whence: i32) -> i64;
    fn syscall_fsync(fd: i32) -> i32;
    fn syscall_fdatasync(fd: i32) -> i32;
    fn syscall_ftruncate(fd: i32, length: u64) -> i32;
    fn syscall_fstat(fd: i32, stat: *mut StatBuf) -> i32;
    fn syscall_dup(fd: i32) -> i32;
    fn syscall_fchmod(fd: i32, mode: u32) -> i32;
}

// ============================================================================
// File Metadata
// ============================================================================

/// Raw stat buffer from syscall
#[repr(C)]
struct StatBuf {
    st_dev: u64,
    st_ino: u64,
    st_mode: u32,
    st_nlink: u32,
    st_uid: u32,
    st_gid: u32,
    st_rdev: u64,
    st_size: i64,
    st_blksize: i64,
    st_blocks: i64,
    st_atime: i64,
    st_atime_nsec: i64,
    st_mtime: i64,
    st_mtime_nsec: i64,
    st_ctime: i64,
    st_ctime_nsec: i64,
}

impl Default for StatBuf {
    fn default() -> StatBuf {
        StatBuf {
            st_dev: 0,
            st_ino: 0,
            st_mode: 0,
            st_nlink: 0,
            st_uid: 0,
            st_gid: 0,
            st_rdev: 0,
            st_size: 0,
            st_blksize: 0,
            st_blocks: 0,
            st_atime: 0,
            st_atime_nsec: 0,
            st_mtime: 0,
            st_mtime_nsec: 0,
            st_ctime: 0,
            st_ctime_nsec: 0,
        }
    }
}

/// File type
pub enum FileType {
    File,
    Directory,
    Symlink,
    BlockDevice,
    CharDevice,
    Fifo,
    Socket,
    Unknown,
}

impl FileType {
    fn from_mode(mode: u32) -> FileType {
        match mode & 0o170000 {
            0o100000 => FileType::File,
            0o040000 => FileType::Directory,
            0o120000 => FileType::Symlink,
            0o060000 => FileType::BlockDevice,
            0o020000 => FileType::CharDevice,
            0o010000 => FileType::Fifo,
            0o140000 => FileType::Socket,
            _ => FileType::Unknown,
        }
    }
    
    pub fn is_file(&self) -> bool {
        matches!(self, FileType::File)
    }
    
    pub fn is_dir(&self) -> bool {
        matches!(self, FileType::Directory)
    }
    
    pub fn is_symlink(&self) -> bool {
        matches!(self, FileType::Symlink)
    }
}

/// File permissions
pub struct Permissions {
    mode: u32,
}

impl Permissions {
    pub fn readonly(&self) -> bool {
        (self.mode & 0o222) == 0
    }
    
    pub fn set_readonly(&mut self, readonly: bool) {
        if readonly {
            self.mode &= !0o222;
        } else {
            self.mode |= 0o644;
        }
    }
    
    pub fn mode(&self) -> u32 {
        self.mode & 0o777
    }
}

/// File metadata
pub struct Metadata {
    file_type: FileType,
    size: u64,
    permissions: Permissions,
    modified: u64,
    accessed: u64,
    created: u64,
    inode: u64,
    nlink: u32,
    uid: u32,
    gid: u32,
}

impl Metadata {
    fn from_stat(stat: StatBuf) -> Metadata {
        Metadata {
            file_type: FileType::from_mode(stat.st_mode),
            size: stat.st_size as u64,
            permissions: Permissions { mode: stat.st_mode },
            modified: stat.st_mtime as u64,
            accessed: stat.st_atime as u64,
            created: stat.st_ctime as u64,
            inode: stat.st_ino,
            nlink: stat.st_nlink,
            uid: stat.st_uid,
            gid: stat.st_gid,
        }
    }
    
    pub fn file_type(&self) -> &FileType {
        &self.file_type
    }
    
    pub fn is_file(&self) -> bool {
        self.file_type.is_file()
    }
    
    pub fn is_dir(&self) -> bool {
        self.file_type.is_dir()
    }
    
    pub fn is_symlink(&self) -> bool {
        self.file_type.is_symlink()
    }
    
    pub fn len(&self) -> u64 {
        self.size
    }
    
    pub fn is_empty(&self) -> bool {
        self.size == 0
    }
    
    pub fn permissions(&self) -> &Permissions {
        &self.permissions
    }
    
    pub fn modified(&self) -> u64 {
        self.modified
    }
    
    pub fn accessed(&self) -> u64 {
        self.accessed
    }
    
    pub fn created(&self) -> u64 {
        self.created
    }
}

// ============================================================================
// Standard I/O Streams
// ============================================================================

/// Standard input
pub struct Stdin {
    _private: (),
}

/// Standard input lock
pub struct StdinLock<'a> {
    inner: BufReader<StdinRaw>,
    _marker: std::marker::PhantomData<&'a ()>,
}

struct StdinRaw;

impl Read for StdinRaw {
    fn read(&mut self, buf: &mut [u8]) -> Result<usize> {
        let ret = unsafe { syscall_read(0, buf.as_mut_ptr(), buf.len()) };
        if ret < 0 {
            Err(File::error_from_errno(-ret as i32))
        } else {
            Ok(ret as usize)
        }
    }
}

impl Stdin {
    /// Get a reference to stdin
    pub fn new() -> Stdin {
        Stdin { _private: () }
    }
    
    /// Lock stdin for exclusive access
    pub fn lock(&self) -> StdinLock<'_> {
        StdinLock {
            inner: BufReader::new(StdinRaw),
            _marker: std::marker::PhantomData,
        }
    }
    
    /// Read line from stdin
    pub fn read_line(&self, buf: &mut String) -> Result<usize> {
        self.lock().read_line(buf)
    }
}

impl Read for Stdin {
    fn read(&mut self, buf: &mut [u8]) -> Result<usize> {
        self.lock().read(buf)
    }
}

impl<'a> Read for StdinLock<'a> {
    fn read(&mut self, buf: &mut [u8]) -> Result<usize> {
        self.inner.read(buf)
    }
}

impl<'a> BufRead for StdinLock<'a> {
    fn fill_buf(&mut self) -> Result<&[u8]> {
        self.inner.fill_buf()
    }
    
    fn consume(&mut self, amt: usize) {
        self.inner.consume(amt)
    }
}

/// Standard output
pub struct Stdout {
    _private: (),
}

/// Standard output lock
pub struct StdoutLock<'a> {
    inner: LineWriter<StdoutRaw>,
    _marker: std::marker::PhantomData<&'a ()>,
}

struct StdoutRaw;

impl Write for StdoutRaw {
    fn write(&mut self, buf: &[u8]) -> Result<usize> {
        let ret = unsafe { syscall_write(1, buf.as_ptr(), buf.len()) };
        if ret < 0 {
            Err(File::error_from_errno(-ret as i32))
        } else {
            Ok(ret as usize)
        }
    }
    
    fn flush(&mut self) -> Result<()> {
        Ok(())
    }
}

impl Stdout {
    /// Get a reference to stdout
    pub fn new() -> Stdout {
        Stdout { _private: () }
    }
    
    /// Lock stdout for exclusive access
    pub fn lock(&self) -> StdoutLock<'_> {
        StdoutLock {
            inner: LineWriter::new(StdoutRaw),
            _marker: std::marker::PhantomData,
        }
    }
}

impl Write for Stdout {
    fn write(&mut self, buf: &[u8]) -> Result<usize> {
        self.lock().write(buf)
    }
    
    fn flush(&mut self) -> Result<()> {
        self.lock().flush()
    }
}

impl<'a> Write for StdoutLock<'a> {
    fn write(&mut self, buf: &[u8]) -> Result<usize> {
        self.inner.write(buf)
    }
    
    fn flush(&mut self) -> Result<()> {
        self.inner.flush()
    }
}

/// Standard error
pub struct Stderr {
    _private: (),
}

/// Standard error lock
pub struct StderrLock<'a> {
    _marker: std::marker::PhantomData<&'a ()>,
}

struct StderrRaw;

impl Write for StderrRaw {
    fn write(&mut self, buf: &[u8]) -> Result<usize> {
        let ret = unsafe { syscall_write(2, buf.as_ptr(), buf.len()) };
        if ret < 0 {
            Err(File::error_from_errno(-ret as i32))
        } else {
            Ok(ret as usize)
        }
    }
    
    fn flush(&mut self) -> Result<()> {
        Ok(())
    }
}

impl Stderr {
    /// Get a reference to stderr
    pub fn new() -> Stderr {
        Stderr { _private: () }
    }
    
    /// Lock stderr for exclusive access
    pub fn lock(&self) -> StderrLock<'_> {
        StderrLock {
            _marker: std::marker::PhantomData,
        }
    }
}

impl Write for Stderr {
    fn write(&mut self, buf: &[u8]) -> Result<usize> {
        StderrRaw.write(buf)
    }
    
    fn flush(&mut self) -> Result<()> {
        Ok(())
    }
}

impl<'a> Write for StderrLock<'a> {
    fn write(&mut self, buf: &[u8]) -> Result<usize> {
        StderrRaw.write(buf)
    }
    
    fn flush(&mut self) -> Result<()> {
        Ok(())
    }
}

/// Get stdin handle
pub fn stdin() -> Stdin {
    Stdin::new()
}

/// Get stdout handle
pub fn stdout() -> Stdout {
    Stdout::new()
}

/// Get stderr handle
pub fn stderr() -> Stderr {
    Stderr::new()
}

// ============================================================================
// Copy Utilities
// ============================================================================

/// Copy all bytes from reader to writer
pub fn copy<R: Read, W: Write>(reader: &mut R, writer: &mut W) -> Result<u64> {
    let mut buf = [0u8; 8192];
    let mut written = 0u64;
    
    loop {
        let len = match reader.read(&mut buf) {
            Ok(0) => return Ok(written),
            Ok(len) => len,
            Err(e) if e.kind() == ErrorKind::Interrupted => continue,
            Err(e) => return Err(e),
        };
        
        writer.write_all(&buf[..len])?;
        written += len as u64;
    }
}

// ============================================================================
// Empty/Sink/Repeat
// ============================================================================

/// Reader that always returns empty
pub struct Empty;

impl Read for Empty {
    fn read(&mut self, _buf: &mut [u8]) -> Result<usize> {
        Ok(0)
    }
}

impl BufRead for Empty {
    fn fill_buf(&mut self) -> Result<&[u8]> {
        Ok(&[])
    }
    
    fn consume(&mut self, _amt: usize) {}
}

/// Get empty reader
pub fn empty() -> Empty {
    Empty
}

/// Writer that discards all data
pub struct Sink;

impl Write for Sink {
    fn write(&mut self, buf: &[u8]) -> Result<usize> {
        Ok(buf.len())
    }
    
    fn flush(&mut self) -> Result<()> {
        Ok(())
    }
}

/// Get sink writer
pub fn sink() -> Sink {
    Sink
}

/// Reader that repeats a byte infinitely
pub struct Repeat {
    byte: u8,
}

impl Read for Repeat {
    fn read(&mut self, buf: &mut [u8]) -> Result<usize> {
        for b in buf.iter_mut() {
            *b = self.byte;
        }
        Ok(buf.len())
    }
}

/// Get repeat reader
pub fn repeat(byte: u8) -> Repeat {
    Repeat { byte }
}

// ============================================================================
// Print Macros
// ============================================================================

/// Print to stdout
#[macro_export]
macro_rules! print {
    ($($arg:tt)*) => {{
        use $crate::io::{Write, stdout};
        let _ = write!(stdout(), $($arg)*);
    }};
}

/// Print line to stdout
#[macro_export]
macro_rules! println {
    () => {{
        use $crate::io::{Write, stdout};
        let _ = stdout().write_all(b"\n");
    }};
    ($($arg:tt)*) => {{
        use $crate::io::{Write, stdout};
        let _ = write!(stdout(), $($arg)*);
        let _ = stdout().write_all(b"\n");
    }};
}

/// Print to stderr
#[macro_export]
macro_rules! eprint {
    ($($arg:tt)*) => {{
        use $crate::io::{Write, stderr};
        let _ = write!(stderr(), $($arg)*);
    }};
}

/// Print line to stderr
#[macro_export]
macro_rules! eprintln {
    () => {{
        use $crate::io::{Write, stderr};
        let _ = stderr().write_all(b"\n");
    }};
    ($($arg:tt)*) => {{
        use $crate::io::{Write, stderr};
        let _ = write!(stderr(), $($arg)*);
        let _ = stderr().write_all(b"\n");
    }};
}

// ============================================================================
// Tests
// ============================================================================

#[cfg(test)]
mod tests {
    use super::*;
    
    #[test]
    fn test_cursor_read_write() {
        let mut cursor = Cursor::new(vec![0u8; 10]);
        
        cursor.write_all(b"hello").unwrap();
        assert_eq!(cursor.position(), 5);
        
        cursor.set_position(0);
        let mut buf = [0u8; 5];
        cursor.read_exact(&mut buf).unwrap();
        assert_eq!(&buf, b"hello");
    }
    
    #[test]
    fn test_cursor_seek() {
        let data = vec![0u8, 1, 2, 3, 4, 5, 6, 7, 8, 9];
        let mut cursor = Cursor::new(data);
        
        assert_eq!(cursor.seek(SeekFrom::Start(5)).unwrap(), 5);
        assert_eq!(cursor.seek(SeekFrom::Current(2)).unwrap(), 7);
        assert_eq!(cursor.seek(SeekFrom::End(-2)).unwrap(), 8);
    }
    
    #[test]
    fn test_buf_reader() {
        let data = b"hello\nworld\n";
        let cursor = Cursor::new(data.to_vec());
        let mut reader = BufReader::new(cursor);
        
        let mut line = String::new();
        reader.read_line(&mut line).unwrap();
        assert_eq!(line, "hello\n");
        
        line.clear();
        reader.read_line(&mut line).unwrap();
        assert_eq!(line, "world\n");
    }
    
    #[test]
    fn test_buf_writer() {
        let mut buf = Vec::new();
        {
            let mut writer = BufWriter::new(Cursor::new(&mut buf));
            writer.write_all(b"hello world").unwrap();
            writer.flush().unwrap();
        }
        assert_eq!(buf, b"hello world");
    }
    
    #[test]
    fn test_chain_reader() {
        let r1 = Cursor::new(b"hello ".to_vec());
        let r2 = Cursor::new(b"world".to_vec());
        let mut chain = r1.chain(r2);
        
        let mut buf = String::new();
        chain.read_to_string(&mut buf).unwrap();
        assert_eq!(buf, "hello world");
    }
    
    #[test]
    fn test_take_reader() {
        let cursor = Cursor::new(b"hello world".to_vec());
        let mut take = cursor.take(5);
        
        let mut buf = String::new();
        take.read_to_string(&mut buf).unwrap();
        assert_eq!(buf, "hello");
    }
    
    #[test]
    fn test_copy() {
        let mut reader = Cursor::new(b"test data".to_vec());
        let mut writer = Cursor::new(Vec::new());
        
        let n = copy(&mut reader, &mut writer).unwrap();
        assert_eq!(n, 9);
        assert_eq!(writer.into_inner(), b"test data");
    }
    
    #[test]
    fn test_lines_iterator() {
        let data = b"line1\nline2\r\nline3";
        let cursor = Cursor::new(data.to_vec());
        let reader = BufReader::new(cursor);
        
        let lines: Vec<String> = reader.lines().map(|r| r.unwrap()).collect();
        assert_eq!(lines, vec!["line1", "line2", "line3"]);
    }
    
    #[test]
    fn test_empty_sink_repeat() {
        // Empty always returns 0 bytes
        let mut buf = [0u8; 10];
        assert_eq!(empty().read(&mut buf).unwrap(), 0);
        
        // Sink discards everything
        assert_eq!(sink().write(b"test").unwrap(), 4);
        
        // Repeat fills with byte
        let mut r = repeat(0xAB);
        r.read(&mut buf).unwrap();
        assert!(buf.iter().all(|&b| b == 0xAB));
    }
    
    #[test]
    fn test_error_kinds() {
        let err = Error::from_kind(ErrorKind::NotFound);
        assert!(matches!(err.kind(), ErrorKind::NotFound));
        
        let err2 = Error::new(ErrorKind::InvalidData, String::from("test"));
        let chained = err.with_source(err2);
        assert!(chained.source().is_some());
    }
}
