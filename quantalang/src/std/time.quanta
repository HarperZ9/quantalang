/// QuantaLang Standard Library - Time and Date
/// Duration, Instant, SystemTime, DateTime, formatting and parsing
module std::time;

use std::cmp::{Ord, Ordering, PartialOrd};
use std::ops::{Add, AddAssign, Sub, SubAssign, Mul, MulAssign, Div, DivAssign};
use std::fmt::{Debug, Display, Formatter, Result as FmtResult};
use std::option::Option;
use std::result::Result;
use std::string::String;

// ============================================================================
// Duration - Time span
// ============================================================================

/// Represents a span of time with nanosecond precision
#[derive(Clone, Copy, PartialEq, Eq, PartialOrd, Ord, Hash)]
pub struct Duration {
    secs: u64,
    nanos: u32,  // Always 0..999_999_999
}

impl Duration {
    /// Zero duration
    pub const ZERO: Duration = Duration { secs: 0, nanos: 0 };
    
    /// Maximum duration
    pub const MAX: Duration = Duration { secs: u64::MAX, nanos: 999_999_999 };
    
    /// One nanosecond
    pub const NANOSECOND: Duration = Duration { secs: 0, nanos: 1 };
    
    /// One microsecond
    pub const MICROSECOND: Duration = Duration { secs: 0, nanos: 1_000 };
    
    /// One millisecond
    pub const MILLISECOND: Duration = Duration { secs: 0, nanos: 1_000_000 };
    
    /// One second
    pub const SECOND: Duration = Duration { secs: 1, nanos: 0 };
    
    /// One minute
    pub const MINUTE: Duration = Duration { secs: 60, nanos: 0 };
    
    /// One hour
    pub const HOUR: Duration = Duration { secs: 3600, nanos: 0 };
    
    /// One day
    pub const DAY: Duration = Duration { secs: 86400, nanos: 0 };
    
    /// One week
    pub const WEEK: Duration = Duration { secs: 604800, nanos: 0 };
    
    const NANOS_PER_SEC: u32 = 1_000_000_000;
    const NANOS_PER_MILLI: u32 = 1_000_000;
    const NANOS_PER_MICRO: u32 = 1_000;
    const MILLIS_PER_SEC: u64 = 1_000;
    const MICROS_PER_SEC: u64 = 1_000_000;
    
    /// Create duration from seconds and nanoseconds
    pub const fn new(secs: u64, nanos: u32) -> Self {
        let extra_secs = (nanos / Self::NANOS_PER_SEC) as u64;
        let nanos = nanos % Self::NANOS_PER_SEC;
        Self {
            secs: secs.saturating_add(extra_secs),
            nanos,
        }
    }
    
    /// Create from seconds
    pub const fn from_secs(secs: u64) -> Self {
        Self { secs, nanos: 0 }
    }
    
    /// Create from milliseconds
    pub const fn from_millis(millis: u64) -> Self {
        Self {
            secs: millis / Self::MILLIS_PER_SEC,
            nanos: ((millis % Self::MILLIS_PER_SEC) * Self::NANOS_PER_MILLI as u64) as u32,
        }
    }
    
    /// Create from microseconds
    pub const fn from_micros(micros: u64) -> Self {
        Self {
            secs: micros / Self::MICROS_PER_SEC,
            nanos: ((micros % Self::MICROS_PER_SEC) * Self::NANOS_PER_MICRO as u64) as u32,
        }
    }
    
    /// Create from nanoseconds
    pub const fn from_nanos(nanos: u64) -> Self {
        Self {
            secs: nanos / Self::NANOS_PER_SEC as u64,
            nanos: (nanos % Self::NANOS_PER_SEC as u64) as u32,
        }
    }
    
    /// Create from floating-point seconds
    pub fn from_secs_f64(secs: f64) -> Self {
        if secs < 0.0 || secs.is_nan() {
            panic!("Duration::from_secs_f64: invalid value");
        }
        
        let whole_secs = secs.trunc() as u64;
        let nanos = ((secs.fract()) * Self::NANOS_PER_SEC as f64) as u32;
        Self { secs: whole_secs, nanos }
    }
    
    /// Create from floating-point seconds (32-bit)
    pub fn from_secs_f32(secs: f32) -> Self {
        Self::from_secs_f64(secs as f64)
    }
    
    /// Check if duration is zero
    pub const fn is_zero(&self) -> bool {
        self.secs == 0 && self.nanos == 0
    }
    
    /// Get total seconds (truncated)
    pub const fn as_secs(&self) -> u64 {
        self.secs
    }
    
    /// Get subsecond nanoseconds
    pub const fn subsec_nanos(&self) -> u32 {
        self.nanos
    }
    
    /// Get subsecond microseconds
    pub const fn subsec_micros(&self) -> u32 {
        self.nanos / Self::NANOS_PER_MICRO
    }
    
    /// Get subsecond milliseconds
    pub const fn subsec_millis(&self) -> u32 {
        self.nanos / Self::NANOS_PER_MILLI
    }
    
    /// Get total milliseconds
    pub const fn as_millis(&self) -> u128 {
        self.secs as u128 * Self::MILLIS_PER_SEC as u128 + 
            self.nanos as u128 / Self::NANOS_PER_MILLI as u128
    }
    
    /// Get total microseconds
    pub const fn as_micros(&self) -> u128 {
        self.secs as u128 * Self::MICROS_PER_SEC as u128 + 
            self.nanos as u128 / Self::NANOS_PER_MICRO as u128
    }
    
    /// Get total nanoseconds
    pub const fn as_nanos(&self) -> u128 {
        self.secs as u128 * Self::NANOS_PER_SEC as u128 + self.nanos as u128
    }
    
    /// Convert to floating-point seconds
    pub fn as_secs_f64(&self) -> f64 {
        self.secs as f64 + self.nanos as f64 / Self::NANOS_PER_SEC as f64
    }
    
    /// Convert to floating-point seconds (32-bit)
    pub fn as_secs_f32(&self) -> f32 {
        self.as_secs_f64() as f32
    }
    
    /// Checked addition
    pub fn checked_add(self, rhs: Duration) -> Option<Duration> {
        let mut secs = self.secs.checked_add(rhs.secs)?;
        let mut nanos = self.nanos + rhs.nanos;
        
        if nanos >= Self::NANOS_PER_SEC {
            nanos -= Self::NANOS_PER_SEC;
            secs = secs.checked_add(1)?;
        }
        
        Some(Duration { secs, nanos })
    }
    
    /// Saturating addition
    pub fn saturating_add(self, rhs: Duration) -> Duration {
        self.checked_add(rhs).unwrap_or(Duration::MAX)
    }
    
    /// Checked subtraction
    pub fn checked_sub(self, rhs: Duration) -> Option<Duration> {
        let mut secs = self.secs.checked_sub(rhs.secs)?;
        let nanos = if self.nanos >= rhs.nanos {
            self.nanos - rhs.nanos
        } else {
            secs = secs.checked_sub(1)?;
            self.nanos + Self::NANOS_PER_SEC - rhs.nanos
        };
        
        Some(Duration { secs, nanos })
    }
    
    /// Saturating subtraction
    pub fn saturating_sub(self, rhs: Duration) -> Duration {
        self.checked_sub(rhs).unwrap_or(Duration::ZERO)
    }
    
    /// Checked multiplication
    pub fn checked_mul(self, rhs: u32) -> Option<Duration> {
        let total_nanos = self.nanos as u64 * rhs as u64;
        let extra_secs = total_nanos / Self::NANOS_PER_SEC as u64;
        let nanos = (total_nanos % Self::NANOS_PER_SEC as u64) as u32;
        
        let secs = self.secs
            .checked_mul(rhs as u64)?
            .checked_add(extra_secs)?;
        
        Some(Duration { secs, nanos })
    }
    
    /// Saturating multiplication
    pub fn saturating_mul(self, rhs: u32) -> Duration {
        self.checked_mul(rhs).unwrap_or(Duration::MAX)
    }
    
    /// Checked division
    pub fn checked_div(self, rhs: u32) -> Option<Duration> {
        if rhs == 0 {
            return None;
        }
        
        let secs = self.secs / rhs as u64;
        let carry = self.secs % rhs as u64;
        let extra_nanos = carry * Self::NANOS_PER_SEC as u64 / rhs as u64;
        let nanos = (self.nanos as u64 / rhs as u64 + extra_nanos) as u32;
        
        Some(Duration { secs, nanos })
    }
    
    /// Multiply by floating-point
    pub fn mul_f64(self, rhs: f64) -> Duration {
        Duration::from_secs_f64(self.as_secs_f64() * rhs)
    }
    
    /// Multiply by floating-point (32-bit)
    pub fn mul_f32(self, rhs: f32) -> Duration {
        Duration::from_secs_f64(self.as_secs_f64() * rhs as f64)
    }
    
    /// Divide by floating-point
    pub fn div_f64(self, rhs: f64) -> Duration {
        Duration::from_secs_f64(self.as_secs_f64() / rhs)
    }
    
    /// Divide by floating-point (32-bit)
    pub fn div_f32(self, rhs: f32) -> Duration {
        Duration::from_secs_f64(self.as_secs_f64() / rhs as f64)
    }
    
    /// Divide durations, returning ratio
    pub fn div_duration_f64(self, rhs: Duration) -> f64 {
        self.as_secs_f64() / rhs.as_secs_f64()
    }
}

impl Add for Duration {
    type Output = Duration;
    
    fn add(self, rhs: Duration) -> Duration {
        self.checked_add(rhs).expect("Duration overflow")
    }
}

impl AddAssign for Duration {
    fn add_assign(&mut self, rhs: Duration) {
        *self = *self + rhs;
    }
}

impl Sub for Duration {
    type Output = Duration;
    
    fn sub(self, rhs: Duration) -> Duration {
        self.checked_sub(rhs).expect("Duration underflow")
    }
}

impl SubAssign for Duration {
    fn sub_assign(&mut self, rhs: Duration) {
        *self = *self - rhs;
    }
}

impl Mul<u32> for Duration {
    type Output = Duration;
    
    fn mul(self, rhs: u32) -> Duration {
        self.checked_mul(rhs).expect("Duration overflow")
    }
}

impl MulAssign<u32> for Duration {
    fn mul_assign(&mut self, rhs: u32) {
        *self = *self * rhs;
    }
}

impl Div<u32> for Duration {
    type Output = Duration;
    
    fn div(self, rhs: u32) -> Duration {
        self.checked_div(rhs).expect("Division by zero")
    }
}

impl DivAssign<u32> for Duration {
    fn div_assign(&mut self, rhs: u32) {
        *self = *self / rhs;
    }
}

impl Default for Duration {
    fn default() -> Self {
        Duration::ZERO
    }
}

impl Debug for Duration {
    fn fmt(&self, f: &mut Formatter<'_>) -> FmtResult {
        write!(f, "Duration {{ secs: {}, nanos: {} }}", self.secs, self.nanos)
    }
}

impl Display for Duration {
    fn fmt(&self, f: &mut Formatter<'_>) -> FmtResult {
        if self.secs >= 86400 {
            let days = self.secs / 86400;
            let hours = (self.secs % 86400) / 3600;
            write!(f, "{}d {}h", days, hours)
        } else if self.secs >= 3600 {
            let hours = self.secs / 3600;
            let mins = (self.secs % 3600) / 60;
            write!(f, "{}h {}m", hours, mins)
        } else if self.secs >= 60 {
            let mins = self.secs / 60;
            let secs = self.secs % 60;
            write!(f, "{}m {}s", mins, secs)
        } else if self.secs > 0 {
            write!(f, "{}.{:03}s", self.secs, self.subsec_millis())
        } else if self.nanos >= 1_000_000 {
            write!(f, "{}ms", self.nanos / 1_000_000)
        } else if self.nanos >= 1_000 {
            write!(f, "{}µs", self.nanos / 1_000)
        } else {
            write!(f, "{}ns", self.nanos)
        }
    }
}

// ============================================================================
// Instant - Monotonic clock
// ============================================================================

/// Monotonic time for measuring elapsed time
#[derive(Clone, Copy, PartialEq, Eq, PartialOrd, Ord, Hash)]
pub struct Instant {
    nanos: u128,
}

impl Instant {
    /// Capture current instant
    pub fn now() -> Self {
        let nanos = unsafe { __clock_monotonic_nanos() };
        Self { nanos }
    }
    
    /// Duration since this instant
    pub fn elapsed(&self) -> Duration {
        Self::now().duration_since(*self)
    }
    
    /// Duration from earlier instant to this one
    pub fn duration_since(&self, earlier: Instant) -> Duration {
        Duration::from_nanos((self.nanos.saturating_sub(earlier.nanos)) as u64)
    }
    
    /// Checked duration since earlier instant
    pub fn checked_duration_since(&self, earlier: Instant) -> Option<Duration> {
        if self.nanos >= earlier.nanos {
            Some(Duration::from_nanos((self.nanos - earlier.nanos) as u64))
        } else {
            None
        }
    }
    
    /// Saturating duration since
    pub fn saturating_duration_since(&self, earlier: Instant) -> Duration {
        self.checked_duration_since(earlier).unwrap_or(Duration::ZERO)
    }
    
    /// Add duration, returning None on overflow
    pub fn checked_add(&self, duration: Duration) -> Option<Instant> {
        let nanos = self.nanos.checked_add(duration.as_nanos())?;
        Some(Instant { nanos })
    }
    
    /// Subtract duration, returning None on underflow
    pub fn checked_sub(&self, duration: Duration) -> Option<Instant> {
        let nanos = self.nanos.checked_sub(duration.as_nanos())?;
        Some(Instant { nanos })
    }
}

impl Add<Duration> for Instant {
    type Output = Instant;
    
    fn add(self, rhs: Duration) -> Instant {
        self.checked_add(rhs).expect("Instant overflow")
    }
}

impl AddAssign<Duration> for Instant {
    fn add_assign(&mut self, rhs: Duration) {
        *self = *self + rhs;
    }
}

impl Sub<Duration> for Instant {
    type Output = Instant;
    
    fn sub(self, rhs: Duration) -> Instant {
        self.checked_sub(rhs).expect("Instant underflow")
    }
}

impl SubAssign<Duration> for Instant {
    fn sub_assign(&mut self, rhs: Duration) {
        *self = *self - rhs;
    }
}

impl Sub<Instant> for Instant {
    type Output = Duration;
    
    fn sub(self, rhs: Instant) -> Duration {
        self.duration_since(rhs)
    }
}

impl Debug for Instant {
    fn fmt(&self, f: &mut Formatter<'_>) -> FmtResult {
        write!(f, "Instant({}ns)", self.nanos)
    }
}

// ============================================================================
// SystemTime - Wall clock time
// ============================================================================

/// Error when converting system time
pub struct SystemTimeError {
    duration: Duration,
}

impl SystemTimeError {
    pub fn duration(&self) -> Duration {
        self.duration
    }
}

/// Wall clock time (may not be monotonic)
#[derive(Clone, Copy, PartialEq, Eq, PartialOrd, Ord, Hash)]
pub struct SystemTime {
    /// Seconds since Unix epoch
    secs: i64,
    /// Nanoseconds 0..999_999_999
    nanos: u32,
}

impl SystemTime {
    /// Unix epoch (1970-01-01 00:00:00 UTC)
    pub const UNIX_EPOCH: SystemTime = SystemTime { secs: 0, nanos: 0 };
    
    /// Get current system time
    pub fn now() -> Self {
        let (secs, nanos) = unsafe { __clock_realtime() };
        Self { secs, nanos }
    }
    
    /// Duration since Unix epoch
    pub fn duration_since_epoch(&self) -> Result<Duration, SystemTimeError> {
        if self.secs >= 0 {
            Ok(Duration::new(self.secs as u64, self.nanos))
        } else {
            Err(SystemTimeError {
                duration: Duration::new((-self.secs) as u64, self.nanos),
            })
        }
    }
    
    /// Duration since earlier time
    pub fn duration_since(&self, earlier: SystemTime) -> Result<Duration, SystemTimeError> {
        let diff_secs = self.secs - earlier.secs;
        let diff_nanos = self.nanos as i64 - earlier.nanos as i64;
        
        let total_nanos = diff_secs * 1_000_000_000 + diff_nanos;
        
        if total_nanos >= 0 {
            Ok(Duration::from_nanos(total_nanos as u64))
        } else {
            Err(SystemTimeError {
                duration: Duration::from_nanos((-total_nanos) as u64),
            })
        }
    }
    
    /// Time elapsed since this SystemTime
    pub fn elapsed(&self) -> Result<Duration, SystemTimeError> {
        SystemTime::now().duration_since(*self)
    }
    
    /// Add duration
    pub fn checked_add(&self, duration: Duration) -> Option<SystemTime> {
        let extra_secs = (self.nanos as u64 + duration.subsec_nanos() as u64) / 1_000_000_000;
        let nanos = ((self.nanos as u64 + duration.subsec_nanos() as u64) % 1_000_000_000) as u32;
        let secs = self.secs
            .checked_add(duration.as_secs() as i64)?
            .checked_add(extra_secs as i64)?;
        
        Some(SystemTime { secs, nanos })
    }
    
    /// Subtract duration
    pub fn checked_sub(&self, duration: Duration) -> Option<SystemTime> {
        let nanos = if self.nanos >= duration.subsec_nanos() {
            self.nanos - duration.subsec_nanos()
        } else {
            return self.checked_sub_with_borrow(duration);
        };
        
        let secs = self.secs.checked_sub(duration.as_secs() as i64)?;
        Some(SystemTime { secs, nanos })
    }
    
    fn checked_sub_with_borrow(&self, duration: Duration) -> Option<SystemTime> {
        let nanos = 1_000_000_000 + self.nanos - duration.subsec_nanos();
        let secs = self.secs
            .checked_sub(duration.as_secs() as i64)?
            .checked_sub(1)?;
        Some(SystemTime { secs, nanos })
    }
}

impl Add<Duration> for SystemTime {
    type Output = SystemTime;
    
    fn add(self, rhs: Duration) -> SystemTime {
        self.checked_add(rhs).expect("SystemTime overflow")
    }
}

impl AddAssign<Duration> for SystemTime {
    fn add_assign(&mut self, rhs: Duration) {
        *self = *self + rhs;
    }
}

impl Sub<Duration> for SystemTime {
    type Output = SystemTime;
    
    fn sub(self, rhs: Duration) -> SystemTime {
        self.checked_sub(rhs).expect("SystemTime underflow")
    }
}

impl SubAssign<Duration> for SystemTime {
    fn sub_assign(&mut self, rhs: Duration) {
        *self = *self - rhs;
    }
}

impl Debug for SystemTime {
    fn fmt(&self, f: &mut Formatter<'_>) -> FmtResult {
        write!(f, "SystemTime {{ secs: {}, nanos: {} }}", self.secs, self.nanos)
    }
}

// ============================================================================
// DateTime - Calendar date and time
// ============================================================================

/// Month of the year
#[derive(Clone, Copy, PartialEq, Eq, PartialOrd, Ord, Hash, Debug)]
pub enum Month {
    January = 1,
    February = 2,
    March = 3,
    April = 4,
    May = 5,
    June = 6,
    July = 7,
    August = 8,
    September = 9,
    October = 10,
    November = 11,
    December = 12,
}

impl Month {
    pub fn from_number(n: u8) -> Option<Month> {
        match n {
            1 => Some(Month::January),
            2 => Some(Month::February),
            3 => Some(Month::March),
            4 => Some(Month::April),
            5 => Some(Month::May),
            6 => Some(Month::June),
            7 => Some(Month::July),
            8 => Some(Month::August),
            9 => Some(Month::September),
            10 => Some(Month::October),
            11 => Some(Month::November),
            12 => Some(Month::December),
            _ => None,
        }
    }
    
    pub fn number(&self) -> u8 {
        *self as u8
    }
    
    pub fn name(&self) -> &'static str {
        match self {
            Month::January => "January",
            Month::February => "February",
            Month::March => "March",
            Month::April => "April",
            Month::May => "May",
            Month::June => "June",
            Month::July => "July",
            Month::August => "August",
            Month::September => "September",
            Month::October => "October",
            Month::November => "November",
            Month::December => "December",
        }
    }
    
    pub fn short_name(&self) -> &'static str {
        match self {
            Month::January => "Jan",
            Month::February => "Feb",
            Month::March => "Mar",
            Month::April => "Apr",
            Month::May => "May",
            Month::June => "Jun",
            Month::July => "Jul",
            Month::August => "Aug",
            Month::September => "Sep",
            Month::October => "Oct",
            Month::November => "Nov",
            Month::December => "Dec",
        }
    }
}

/// Day of the week
#[derive(Clone, Copy, PartialEq, Eq, PartialOrd, Ord, Hash, Debug)]
pub enum Weekday {
    Monday = 1,
    Tuesday = 2,
    Wednesday = 3,
    Thursday = 4,
    Friday = 5,
    Saturday = 6,
    Sunday = 7,
}

impl Weekday {
    pub fn from_number(n: u8) -> Option<Weekday> {
        match n {
            1 => Some(Weekday::Monday),
            2 => Some(Weekday::Tuesday),
            3 => Some(Weekday::Wednesday),
            4 => Some(Weekday::Thursday),
            5 => Some(Weekday::Friday),
            6 => Some(Weekday::Saturday),
            7 => Some(Weekday::Sunday),
            _ => None,
        }
    }
    
    pub fn number(&self) -> u8 {
        *self as u8
    }
    
    pub fn number_from_sunday(&self) -> u8 {
        match self {
            Weekday::Sunday => 0,
            _ => *self as u8,
        }
    }
    
    pub fn name(&self) -> &'static str {
        match self {
            Weekday::Monday => "Monday",
            Weekday::Tuesday => "Tuesday",
            Weekday::Wednesday => "Wednesday",
            Weekday::Thursday => "Thursday",
            Weekday::Friday => "Friday",
            Weekday::Saturday => "Saturday",
            Weekday::Sunday => "Sunday",
        }
    }
    
    pub fn short_name(&self) -> &'static str {
        match self {
            Weekday::Monday => "Mon",
            Weekday::Tuesday => "Tue",
            Weekday::Wednesday => "Wed",
            Weekday::Thursday => "Thu",
            Weekday::Friday => "Fri",
            Weekday::Saturday => "Sat",
            Weekday::Sunday => "Sun",
        }
    }
    
    pub fn next(self) -> Weekday {
        match self {
            Weekday::Monday => Weekday::Tuesday,
            Weekday::Tuesday => Weekday::Wednesday,
            Weekday::Wednesday => Weekday::Thursday,
            Weekday::Thursday => Weekday::Friday,
            Weekday::Friday => Weekday::Saturday,
            Weekday::Saturday => Weekday::Sunday,
            Weekday::Sunday => Weekday::Monday,
        }
    }
    
    pub fn prev(self) -> Weekday {
        match self {
            Weekday::Monday => Weekday::Sunday,
            Weekday::Tuesday => Weekday::Monday,
            Weekday::Wednesday => Weekday::Tuesday,
            Weekday::Thursday => Weekday::Wednesday,
            Weekday::Friday => Weekday::Thursday,
            Weekday::Saturday => Weekday::Friday,
            Weekday::Sunday => Weekday::Saturday,
        }
    }
}

/// Calendar date (year, month, day)
#[derive(Clone, Copy, PartialEq, Eq, PartialOrd, Ord, Hash)]
pub struct Date {
    year: i32,
    month: u8,   // 1..12
    day: u8,     // 1..31
}

impl Date {
    /// Create a new date
    pub fn new(year: i32, month: u8, day: u8) -> Option<Self> {
        if month < 1 || month > 12 {
            return None;
        }
        
        let max_day = days_in_month(year, month);
        if day < 1 || day > max_day {
            return None;
        }
        
        Some(Self { year, month, day })
    }
    
    /// Current date (UTC)
    pub fn today() -> Self {
        DateTime::now().date()
    }
    
    pub fn year(&self) -> i32 {
        self.year
    }
    
    pub fn month(&self) -> Month {
        Month::from_number(self.month).unwrap()
    }
    
    pub fn month_number(&self) -> u8 {
        self.month
    }
    
    pub fn day(&self) -> u8 {
        self.day
    }
    
    /// Day of the year (1-366)
    pub fn ordinal(&self) -> u16 {
        let mut day = self.day as u16;
        for m in 1..self.month {
            day += days_in_month(self.year, m) as u16;
        }
        day
    }
    
    /// Day of week
    pub fn weekday(&self) -> Weekday {
        // Zeller's congruence
        let mut y = self.year;
        let mut m = self.month as i32;
        
        if m < 3 {
            m += 12;
            y -= 1;
        }
        
        let q = self.day as i32;
        let k = y % 100;
        let j = y / 100;
        
        let h = (q + (13 * (m + 1)) / 5 + k + k / 4 + j / 4 - 2 * j) % 7;
        let h = ((h + 7) % 7) as u8;
        
        // Convert to Monday=1
        match h {
            0 => Weekday::Saturday,
            1 => Weekday::Sunday,
            2 => Weekday::Monday,
            3 => Weekday::Tuesday,
            4 => Weekday::Wednesday,
            5 => Weekday::Thursday,
            6 => Weekday::Friday,
            _ => unreachable!(),
        }
    }
    
    /// ISO week number (1-53)
    pub fn iso_week(&self) -> u8 {
        let ordinal = self.ordinal() as i32;
        let weekday = self.weekday().number() as i32;
        
        let week = (ordinal - weekday + 10) / 7;
        
        if week < 1 {
            // Belongs to previous year's last week
            53
        } else if week > 52 {
            // Check if it's actually week 1 of next year
            let dec31 = Date::new(self.year, 12, 31).unwrap();
            if dec31.weekday().number() < 4 {
                1
            } else {
                week as u8
            }
        } else {
            week as u8
        }
    }
    
    /// Check if leap year
    pub fn is_leap_year(&self) -> bool {
        is_leap_year(self.year)
    }
    
    /// Add days
    pub fn add_days(&self, days: i32) -> Date {
        let mut total_days = self.to_days() + days;
        Date::from_days(total_days)
    }
    
    /// Subtract days
    pub fn sub_days(&self, days: i32) -> Date {
        self.add_days(-days)
    }
    
    /// Days between dates
    pub fn days_until(&self, other: Date) -> i32 {
        other.to_days() - self.to_days()
    }
    
    /// Convert to days since epoch (year 1, day 1)
    fn to_days(&self) -> i32 {
        let mut days = 0i32;
        
        // Add years
        if self.year > 0 {
            for y in 1..self.year {
                days += if is_leap_year(y) { 366 } else { 365 };
            }
        } else {
            for y in (self.year..0).rev() {
                days -= if is_leap_year(y) { 366 } else { 365 };
            }
        }
        
        // Add months
        for m in 1..self.month {
            days += days_in_month(self.year, m) as i32;
        }
        
        // Add days
        days + self.day as i32
    }
    
    /// Convert from days since epoch
    fn from_days(mut days: i32) -> Date {
        let mut year = 1i32;
        
        // Find year
        while days > 365 {
            let year_days = if is_leap_year(year) { 366 } else { 365 };
            if days > year_days {
                days -= year_days;
                year += 1;
            } else {
                break;
            }
        }
        
        while days <= 0 {
            year -= 1;
            days += if is_leap_year(year) { 366 } else { 365 };
        }
        
        // Find month
        let mut month = 1u8;
        while month <= 12 {
            let month_days = days_in_month(year, month) as i32;
            if days > month_days {
                days -= month_days;
                month += 1;
            } else {
                break;
            }
        }
        
        Date {
            year,
            month,
            day: days as u8,
        }
    }
}

impl Debug for Date {
    fn fmt(&self, f: &mut Formatter<'_>) -> FmtResult {
        write!(f, "{:04}-{:02}-{:02}", self.year, self.month, self.day)
    }
}

impl Display for Date {
    fn fmt(&self, f: &mut Formatter<'_>) -> FmtResult {
        write!(f, "{:04}-{:02}-{:02}", self.year, self.month, self.day)
    }
}

/// Time of day (hour, minute, second, nanosecond)
#[derive(Clone, Copy, PartialEq, Eq, PartialOrd, Ord, Hash)]
pub struct Time {
    hour: u8,     // 0..23
    minute: u8,   // 0..59
    second: u8,   // 0..59 (60 for leap second)
    nanos: u32,   // 0..999_999_999
}

impl Time {
    pub fn new(hour: u8, minute: u8, second: u8, nanos: u32) -> Option<Self> {
        if hour > 23 || minute > 59 || second > 60 || nanos > 999_999_999 {
            return None;
        }
        Some(Self { hour, minute, second, nanos })
    }
    
    pub fn from_hms(hour: u8, minute: u8, second: u8) -> Option<Self> {
        Self::new(hour, minute, second, 0)
    }
    
    pub fn midnight() -> Self {
        Self { hour: 0, minute: 0, second: 0, nanos: 0 }
    }
    
    pub fn noon() -> Self {
        Self { hour: 12, minute: 0, second: 0, nanos: 0 }
    }
    
    pub fn hour(&self) -> u8 {
        self.hour
    }
    
    pub fn minute(&self) -> u8 {
        self.minute
    }
    
    pub fn second(&self) -> u8 {
        self.second
    }
    
    pub fn nanosecond(&self) -> u32 {
        self.nanos
    }
    
    pub fn millisecond(&self) -> u16 {
        (self.nanos / 1_000_000) as u16
    }
    
    /// Seconds since midnight
    pub fn seconds_since_midnight(&self) -> u32 {
        self.hour as u32 * 3600 + self.minute as u32 * 60 + self.second as u32
    }
}

impl Debug for Time {
    fn fmt(&self, f: &mut Formatter<'_>) -> FmtResult {
        write!(f, "{:02}:{:02}:{:02}.{:09}", self.hour, self.minute, self.second, self.nanos)
    }
}

impl Display for Time {
    fn fmt(&self, f: &mut Formatter<'_>) -> FmtResult {
        if self.nanos == 0 {
            write!(f, "{:02}:{:02}:{:02}", self.hour, self.minute, self.second)
        } else if self.nanos % 1_000_000 == 0 {
            write!(f, "{:02}:{:02}:{:02}.{:03}", self.hour, self.minute, self.second, self.nanos / 1_000_000)
        } else if self.nanos % 1_000 == 0 {
            write!(f, "{:02}:{:02}:{:02}.{:06}", self.hour, self.minute, self.second, self.nanos / 1_000)
        } else {
            write!(f, "{:02}:{:02}:{:02}.{:09}", self.hour, self.minute, self.second, self.nanos)
        }
    }
}

/// Combined date and time (UTC)
#[derive(Clone, Copy, PartialEq, Eq, PartialOrd, Ord, Hash)]
pub struct DateTime {
    date: Date,
    time: Time,
}

impl DateTime {
    pub fn new(date: Date, time: Time) -> Self {
        Self { date, time }
    }
    
    /// Current UTC date and time
    pub fn now() -> Self {
        let st = SystemTime::now();
        Self::from_system_time(st)
    }
    
    pub fn from_system_time(st: SystemTime) -> Self {
        let secs = st.secs;
        let nanos = st.nanos;
        
        // Days since Unix epoch
        let days = (secs / 86400) as i32;
        let secs_of_day = (secs % 86400) as u32;
        
        // Date from days since 1970-01-01
        let epoch = Date::new(1970, 1, 1).unwrap();
        let date = epoch.add_days(days);
        
        // Time from seconds of day
        let hour = (secs_of_day / 3600) as u8;
        let minute = ((secs_of_day % 3600) / 60) as u8;
        let second = (secs_of_day % 60) as u8;
        let time = Time::new(hour, minute, second, nanos).unwrap();
        
        Self { date, time }
    }
    
    pub fn to_system_time(&self) -> SystemTime {
        let epoch = Date::new(1970, 1, 1).unwrap();
        let days = epoch.days_until(self.date);
        let secs_of_day = self.time.seconds_since_midnight();
        
        let secs = days as i64 * 86400 + secs_of_day as i64;
        SystemTime { secs, nanos: self.time.nanos }
    }
    
    pub fn date(&self) -> Date {
        self.date
    }
    
    pub fn time(&self) -> Time {
        self.time
    }
    
    pub fn year(&self) -> i32 {
        self.date.year()
    }
    
    pub fn month(&self) -> Month {
        self.date.month()
    }
    
    pub fn day(&self) -> u8 {
        self.date.day()
    }
    
    pub fn hour(&self) -> u8 {
        self.time.hour()
    }
    
    pub fn minute(&self) -> u8 {
        self.time.minute()
    }
    
    pub fn second(&self) -> u8 {
        self.time.second()
    }
    
    pub fn weekday(&self) -> Weekday {
        self.date.weekday()
    }
    
    /// Unix timestamp (seconds since 1970-01-01)
    pub fn timestamp(&self) -> i64 {
        self.to_system_time().secs
    }
    
    /// Unix timestamp with milliseconds
    pub fn timestamp_millis(&self) -> i64 {
        self.timestamp() * 1000 + self.time.millisecond() as i64
    }
    
    /// Create from Unix timestamp
    pub fn from_timestamp(secs: i64) -> Self {
        Self::from_system_time(SystemTime { secs, nanos: 0 })
    }
    
    /// Create from Unix timestamp with nanoseconds
    pub fn from_timestamp_nanos(secs: i64, nanos: u32) -> Self {
        Self::from_system_time(SystemTime { secs, nanos })
    }
    
    /// Format to ISO 8601 string
    pub fn to_rfc3339(&self) -> String {
        format![
            "{:04}-{:02}-{:02}T{:02}:{:02}:{:02}Z",
            self.date.year,
            self.date.month,
            self.date.day,
            self.time.hour,
            self.time.minute,
            self.time.second
        ]
    }
    
    /// Parse from ISO 8601 string
    pub fn from_rfc3339(s: &str) -> Option<Self> {
        // Basic format: YYYY-MM-DDTHH:MM:SSZ
        if s.len() < 20 {
            return None;
        }
        
        let year = s[0..4].parse::<i32>().ok()?;
        let month = s[5..7].parse::<u8>().ok()?;
        let day = s[8..10].parse::<u8>().ok()?;
        let hour = s[11..13].parse::<u8>().ok()?;
        let minute = s[14..16].parse::<u8>().ok()?;
        let second = s[17..19].parse::<u8>().ok()?;
        
        let date = Date::new(year, month, day)?;
        let time = Time::from_hms(hour, minute, second)?;
        
        Some(Self::new(date, time))
    }
}

impl Debug for DateTime {
    fn fmt(&self, f: &mut Formatter<'_>) -> FmtResult {
        write!(f, "{} {}", self.date, self.time)
    }
}

impl Display for DateTime {
    fn fmt(&self, f: &mut Formatter<'_>) -> FmtResult {
        write!(f, "{}T{}Z", self.date, self.time)
    }
}

// ============================================================================
// Timezone
// ============================================================================

/// Timezone offset from UTC
#[derive(Clone, Copy, PartialEq, Eq, Hash)]
pub struct UtcOffset {
    /// Offset in seconds (-86400 to 86400)
    seconds: i32,
}

impl UtcOffset {
    pub const UTC: UtcOffset = UtcOffset { seconds: 0 };
    
    pub fn from_hms(hours: i8, minutes: i8, seconds: i8) -> Option<Self> {
        let total = hours as i32 * 3600 + minutes as i32 * 60 + seconds as i32;
        if total.abs() > 86400 {
            return None;
        }
        Some(Self { seconds: total })
    }
    
    pub fn from_hours(hours: i8) -> Option<Self> {
        Self::from_hms(hours, 0, 0)
    }
    
    pub fn as_seconds(&self) -> i32 {
        self.seconds
    }
    
    pub fn hours(&self) -> i8 {
        (self.seconds / 3600) as i8
    }
    
    pub fn minutes(&self) -> i8 {
        ((self.seconds % 3600) / 60) as i8
    }
    
    pub fn is_utc(&self) -> bool {
        self.seconds == 0
    }
}

impl Display for UtcOffset {
    fn fmt(&self, f: &mut Formatter<'_>) -> FmtResult {
        let sign = if self.seconds < 0 { '-' } else { '+' };
        let abs_hours = self.hours().abs();
        let abs_mins = self.minutes().abs();
        
        if abs_mins == 0 {
            write!(f, "{}{:02}:00", sign, abs_hours)
        } else {
            write!(f, "{}{:02}:{:02}", sign, abs_hours, abs_mins)
        }
    }
}

// ============================================================================
// Helper functions
// ============================================================================

fn is_leap_year(year: i32) -> bool {
    (year % 4 == 0 && year % 100 != 0) || year % 400 == 0
}

fn days_in_month(year: i32, month: u8) -> u8 {
    match month {
        1 | 3 | 5 | 7 | 8 | 10 | 12 => 31,
        4 | 6 | 9 | 11 => 30,
        2 => if is_leap_year(year) { 29 } else { 28 },
        _ => 0,
    }
}

// ============================================================================
// Timer utilities
// ============================================================================

/// Sleep for a duration
pub fn sleep(duration: Duration) {
    unsafe { __sleep_nanos(duration.as_nanos() as u64); }
}

/// Sleep until an instant
pub fn sleep_until(deadline: Instant) {
    let now = Instant::now();
    if let Some(duration) = deadline.checked_duration_since(now) {
        sleep(duration);
    }
}

/// Simple timer for profiling
pub struct Timer {
    start: Instant,
    label: &'static str,
}

impl Timer {
    pub fn new(label: &'static str) -> Self {
        Self {
            start: Instant::now(),
            label,
        }
    }
    
    pub fn elapsed(&self) -> Duration {
        self.start.elapsed()
    }
    
    pub fn reset(&mut self) {
        self.start = Instant::now();
    }
}

impl Drop for Timer {
    fn drop(&mut self) {
        println!("{}: {:?}", self.label, self.elapsed());
    }
}

/// Execute a closure and return (result, duration)
pub fn timed<F, R>(f: F) -> (R, Duration)
where
    F: FnOnce() -> R,
{
    let start = Instant::now();
    let result = f();
    (result, start.elapsed())
}

// ============================================================================
// External declarations
// ============================================================================

extern "C" {
    fn __clock_monotonic_nanos() -> u128;
    fn __clock_realtime() -> (i64, u32);
    fn __sleep_nanos(nanos: u64);
}

// ============================================================================
// Tests
// ============================================================================

#[cfg(test)]
mod tests {
    use super::*;
    
    #[test]
    fn test_duration_basic() {
        let d = Duration::from_secs(5);
        assert_eq!(d.as_secs(), 5);
        assert_eq!(d.as_millis(), 5000);
        
        let d = Duration::from_millis(1500);
        assert_eq!(d.as_secs(), 1);
        assert_eq!(d.subsec_millis(), 500);
    }
    
    #[test]
    fn test_duration_arithmetic() {
        let a = Duration::from_secs(2);
        let b = Duration::from_millis(500);
        
        let c = a + b;
        assert_eq!(c.as_secs(), 2);
        assert_eq!(c.subsec_millis(), 500);
        
        let d = a - b;
        assert_eq!(d.as_millis(), 1500);
    }
    
    #[test]
    fn test_duration_mul_div() {
        let d = Duration::from_secs(10);
        assert_eq!((d * 3).as_secs(), 30);
        assert_eq!((d / 2).as_secs(), 5);
    }
    
    #[test]
    fn test_date_creation() {
        let d = Date::new(2024, 2, 29).unwrap(); // Leap year
        assert_eq!(d.year(), 2024);
        assert_eq!(d.month_number(), 2);
        assert_eq!(d.day(), 29);
        
        assert!(Date::new(2023, 2, 29).is_none()); // Not leap year
        assert!(Date::new(2024, 13, 1).is_none()); // Invalid month
    }
    
    #[test]
    fn test_date_weekday() {
        // 2024-01-01 is a Monday
        let d = Date::new(2024, 1, 1).unwrap();
        assert_eq!(d.weekday(), Weekday::Monday);
        
        // 2024-01-07 is a Sunday
        let d = Date::new(2024, 1, 7).unwrap();
        assert_eq!(d.weekday(), Weekday::Sunday);
    }
    
    #[test]
    fn test_date_arithmetic() {
        let d = Date::new(2024, 1, 15).unwrap();
        let d2 = d.add_days(20);
        assert_eq!(d2, Date::new(2024, 2, 4).unwrap());
        
        let d3 = d.sub_days(15);
        assert_eq!(d3, Date::new(2023, 12, 31).unwrap());
    }
    
    #[test]
    fn test_time_creation() {
        let t = Time::from_hms(14, 30, 45).unwrap();
        assert_eq!(t.hour(), 14);
        assert_eq!(t.minute(), 30);
        assert_eq!(t.second(), 45);
        
        assert!(Time::from_hms(24, 0, 0).is_none());
        assert!(Time::from_hms(0, 60, 0).is_none());
    }
    
    #[test]
    fn test_datetime_rfc3339() {
        let dt = DateTime::from_rfc3339("2024-06-15T14:30:00Z").unwrap();
        assert_eq!(dt.year(), 2024);
        assert_eq!(dt.month(), Month::June);
        assert_eq!(dt.day(), 15);
        assert_eq!(dt.hour(), 14);
        assert_eq!(dt.minute(), 30);
        
        let s = dt.to_rfc3339();
        assert_eq!(s, "2024-06-15T14:30:00Z");
    }
    
    #[test]
    fn test_leap_year() {
        assert!(is_leap_year(2000));
        assert!(is_leap_year(2024));
        assert!(!is_leap_year(1900));
        assert!(!is_leap_year(2023));
    }
    
    #[test]
    fn test_utc_offset() {
        let offset = UtcOffset::from_hms(-5, 0, 0).unwrap();
        assert_eq!(offset.as_seconds(), -18000);
        assert_eq!(offset.hours(), -5);
    }
}
