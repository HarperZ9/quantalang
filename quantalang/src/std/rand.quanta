#[cfg(test)]
mod tests {
    use super::*;
    
    #[test]
    fn test_xoshiro_basic() {
        let mut rng = Xoshiro256StarStar::new(42);
        let a = rng.next_u64();
        let b = rng.next_u64();
        assert_ne!(a, b);
    }
    
    #[test]
    fn test_xoshiro_reproducible() {
        let mut rng1 = Xoshiro256StarStar::new(12345);
        let mut rng2 = Xoshiro256StarStar::new(12345);
        
        for _ in 0..100 {
            assert_eq!(rng1.next_u64(), rng2.next_u64());
        }
    }
    
    #[test]
    fn test_gen_range() {
        let mut rng = Xoshiro256StarStar::new(42);
        
        for _ in 0..1000 {
            let n = rng.gen_range_u64(10, 20);
            assert!(n >= 10 && n < 20);
        }
    }
    
    #[test]
    fn test_gen_f64_range() {
        let mut rng = Xoshiro256StarStar::new(42);
        
        for _ in 0..1000 {
            let f = rng.gen_f64();
            assert!(f >= 0.0 && f < 1.0);
        }
    }
    
    #[test]
    fn test_shuffle() {
        let mut rng = Xoshiro256StarStar::new(42);
        let mut arr = [1, 2, 3, 4, 5];
        let original = arr;
        
        rng.shuffle(&mut arr);
        
        // Should contain same elements
        arr.sort();
        assert_eq!(arr, [1, 2, 3, 4, 5]);
    }
    
    #[test]
    fn test_choose() {
        let mut rng = Xoshiro256StarStar::new(42);
        let arr = [1, 2, 3, 4, 5];
        
        for _ in 0..100 {
            let choice = rng.choose(&arr).unwrap();
            assert!(arr.contains(choice));
        }
    }
    
    #[test]
    fn test_fill_bytes() {
        let mut rng = Xoshiro256StarStar::new(42);
        let mut buf1 = [0u8; 32];
        let mut buf2 = [0u8; 32];
        
        rng.fill_bytes(&mut buf1);
        rng.fill_bytes(&mut buf2);
        
        assert_ne!(buf1, buf2);
        assert_ne!(buf1, [0u8; 32]);
    }
    
    #[test]
    fn test_pcg() {
        let mut rng = Pcg64::new(42, 1);
        let a = rng.next_u64();
        let b = rng.next_u64();
        assert_ne!(a, b);
    }
    
    #[test]
    fn test_chacha() {
        let key = [0u8; 32];
        let mut rng = ChaCha20Rng::new(key);
        
        let a = rng.next_u64();
        let b = rng.next_u64();
        assert_ne!(a, b);
    }
    
    #[test]
    fn test_normal_distribution() {
        let mut rng = Xoshiro256StarStar::new(42);
        let normal = Normal::new(0.0, 1.0);
        
        let mut sum = 0.0;
        let n = 10000;
        
        for _ in 0..n {
            sum += normal.sample(&mut rng);
        }
        
        let mean = sum / n as f64;
        // Should be close to 0
        assert!(mean.abs() < 0.1);
    }
    
    #[test]
    fn test_weighted_index() {
        let mut rng = Xoshiro256StarStar::new(42);
        let weights = WeightedIndex::new(&[1.0, 2.0, 7.0]).unwrap();
        
        let mut counts = [0; 3];
        let n = 10000;
        
        for _ in 0..n {
            let idx = weights.sample(&mut rng);
            counts[idx] += 1;
        }
        
        // Index 2 should be picked ~70% of time
        let ratio = counts[2] as f64 / n as f64;
        assert!(ratio > 0.6 && ratio < 0.8);
    }
    
    #[test]
    fn test_jump() {
        let mut rng1 = Xoshiro256StarStar::new(42);
        let mut rng2 = Xoshiro256StarStar::new(42);
        
        rng1.jump();
        
        // After jump, sequences should differ
        assert_ne!(rng1.next_u64(), rng2.next_u64());
    }
}
