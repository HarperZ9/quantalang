/// QuantaLang Standard Library
/// 
/// The standard library provides essential functionality for QuantaLang programs,
/// including collections, I/O, networking, concurrency, and more.
/// 
/// # Organization
/// 
/// The standard library is organized into the following modules:
/// 
/// ## Core Types
/// - [`prelude`] - Automatically imported essentials
/// - [`vec`] - Dynamic arrays (`Vec<T>`)
/// - [`string`] - UTF-8 strings (`String`)
/// - [`hashmap`] - Hash-based maps (`HashMap<K, V>`)
/// - [`btree`] - B-tree ordered maps (`BTreeMap<K, V>`)
/// 
/// ## I/O and Filesystem
/// - [`io`] - Input/output traits and utilities
/// - [`path`] - Filesystem path manipulation
/// - [`process`] - Process spawning and management
/// - [`env`] - Environment variables and arguments
/// 
/// ## Networking
/// - [`net`] - TCP, UDP, and HTTP networking
/// 
/// ## Concurrency
/// - [`sync`] - Synchronization primitives (Mutex, RwLock, Channel)
/// - [`time`] - Time measurement and duration
/// 
/// ## Text Processing
/// - [`regex`] - Regular expression matching
/// - [`json`] - JSON parsing and serialization
/// - [`base64`] - Base64 encoding/decoding
/// 
/// ## Security
/// - [`crypto`] - Cryptographic hashing and HMAC
/// - [`rand`] - Random number generation
/// - [`uuid`] - UUID generation
/// 
/// ## Compression
/// - [`compress`] - Gzip, zlib, and deflate compression
/// 
/// # Example
/// 
/// ```quanta
/// use std::vec::Vec;
/// use std::io::{File, Read};
/// use std::json;
/// 
/// fn main() -> Result<(), std::io::Error> {
///     // Read a JSON file
///     let mut file = File::open("config.json")?;
///     let mut contents = String::new();
///     file.read_to_string(&mut contents)?;
///     
///     // Parse JSON
///     let config = json::from_str(&contents)?;
///     println!("Loaded config: {}", config);
///     
///     Ok(())
/// }
/// ```
module std;

// ============================================================================
// Core Modules
// ============================================================================

/// The prelude - automatically imported in every module
pub mod prelude;

/// Dynamic array type
pub mod vec;

/// String type and utilities  
pub mod string;

/// Hash map collection
pub mod hashmap;

/// B-tree ordered map
pub mod btree;

// ============================================================================
// I/O Modules
// ============================================================================

/// Input/output operations
pub mod io;

/// Filesystem paths
pub mod path;

/// Process management
pub mod process;

/// Environment interaction
pub mod env;

// ============================================================================
// Networking
// ============================================================================

/// Network protocols (TCP, UDP, HTTP)
pub mod net;

// ============================================================================
// Concurrency
// ============================================================================

/// Synchronization primitives
pub mod sync;

/// Time and duration
pub mod time;

// ============================================================================
// Text Processing
// ============================================================================

/// Regular expressions
pub mod regex;

/// JSON serialization
pub mod json;

/// Base64 encoding
pub mod base64;

// ============================================================================
// Security & Randomness
// ============================================================================

/// Cryptographic primitives
pub mod crypto;

/// Random number generation
pub mod rand;

/// UUID generation
pub mod uuid;

// ============================================================================
// Compression
// ============================================================================

/// Compression algorithms
pub mod compress;

// ============================================================================
// Re-exports for Convenience
// ============================================================================

/// Common collection types
pub mod collections {
    pub use super::vec::Vec;
    pub use super::hashmap::HashMap;
    pub use super::btree::BTreeMap;
    pub use super::string::String;
}

/// I/O prelude for common I/O operations
pub mod io_prelude {
    pub use super::io::{Read, Write, BufRead, Seek};
    pub use super::io::{stdin, stdout, stderr};
    pub use super::io::{File, BufReader, BufWriter};
}

/// Networking prelude
pub mod net_prelude {
    pub use super::net::{TcpListener, TcpStream};
    pub use super::net::{UdpSocket};
    pub use super::net::{SocketAddr, IpAddr, Ipv4Addr, Ipv6Addr};
}

/// Concurrency prelude
pub mod sync_prelude {
    pub use super::sync::{Mutex, RwLock, Arc, Channel};
    pub use super::sync::atomic::{AtomicBool, AtomicU64, Ordering};
}

// ============================================================================
// Version Information
// ============================================================================

/// Standard library version
pub const VERSION: &str = "1.0.0";

/// Minimum supported language version
pub const MIN_LANG_VERSION: &str = "1.0.0";

/// Get version information
pub fn version() -> &'static str {
    VERSION
}

/// Get full version string
pub fn version_string() -> String {
    format!("QuantaLang Standard Library v{}", VERSION)
}

// ============================================================================
// Feature Detection
// ============================================================================

/// Check if a feature is available
pub fn has_feature(feature: &str) -> bool {
    match feature {
        "vec" | "string" | "hashmap" | "btree" => true,
        "io" | "path" | "process" | "env" => true,
        "net" | "tcp" | "udp" | "http" => true,
        "sync" | "mutex" | "rwlock" | "channel" => true,
        "time" | "duration" | "instant" => true,
        "regex" | "json" | "base64" => true,
        "crypto" | "sha256" | "sha512" | "blake3" | "hmac" => true,
        "rand" | "random" => true,
        "uuid" => true,
        "compress" | "gzip" | "zlib" | "deflate" => true,
        _ => false,
    }
}

/// List all available features
pub fn available_features() -> Vec<&'static str> {
    vec![
        // Collections
        "vec", "string", "hashmap", "btree",
        // I/O
        "io", "path", "process", "env",
        // Networking
        "net", "tcp", "udp", "http",
        // Concurrency
        "sync", "mutex", "rwlock", "channel", "atomic",
        // Time
        "time", "duration", "instant", "datetime",
        // Text
        "regex", "json", "base64",
        // Security
        "crypto", "sha256", "sha512", "blake3", "hmac",
        "rand", "random",
        "uuid",
        // Compression
        "compress", "gzip", "zlib", "deflate",
    ]
}
