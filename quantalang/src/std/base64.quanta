/// QuantaLang Standard Library - Base64 Encoding
/// RFC 4648 compliant Base64 and Base64URL encoding/decoding
module std::base64;

use std::vec::Vec;
use std::string::String;
use std::result::Result;
use std::fmt::{Debug, Display};

// ============================================================================
// Error Type
// ============================================================================

/// Base64 decoding error
#[derive(Clone, Debug, PartialEq, Eq)]
pub struct DecodeError {
    kind: DecodeErrorKind,
    position: usize,
}

#[derive(Clone, Copy, Debug, PartialEq, Eq)]
pub enum DecodeErrorKind {
    /// Invalid character in input
    InvalidCharacter,
    /// Invalid input length
    InvalidLength,
    /// Invalid padding
    InvalidPadding,
}

impl DecodeError {
    pub fn kind(&self) -> DecodeErrorKind {
        self.kind
    }
    
    pub fn position(&self) -> usize {
        self.position
    }
}

impl Display for DecodeError {
    fn fmt(&self, f: &mut std::fmt::Formatter<'_>) -> std::fmt::Result {
        match self.kind {
            DecodeErrorKind::InvalidCharacter => {
                write!(f, "invalid character at position {}", self.position)
            }
            DecodeErrorKind::InvalidLength => {
                write!(f, "invalid input length")
            }
            DecodeErrorKind::InvalidPadding => {
                write!(f, "invalid padding at position {}", self.position)
            }
        }
    }
}

impl std::error::Error for DecodeError {}

// ============================================================================
// Encoding Tables
// ============================================================================

/// Standard Base64 alphabet (RFC 4648 Section 4)
const STANDARD_ALPHABET: &[u8; 64] = 
    b"ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789+/";

/// URL-safe Base64 alphabet (RFC 4648 Section 5)
const URL_SAFE_ALPHABET: &[u8; 64] = 
    b"ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789-_";

/// Decoding table for standard Base64
const STANDARD_DECODE: [i8; 256] = {
    let mut table = [-1i8; 256];
    let mut i = 0;
    while i < 64 {
        table[STANDARD_ALPHABET[i] as usize] = i as i8;
        i += 1;
    }
    table
};

/// Decoding table for URL-safe Base64
const URL_SAFE_DECODE: [i8; 256] = {
    let mut table = [-1i8; 256];
    let mut i = 0;
    while i < 64 {
        table[URL_SAFE_ALPHABET[i] as usize] = i as i8;
        i += 1;
    }
    table
};

// ============================================================================
// Configuration
// ============================================================================

/// Base64 encoding configuration
#[derive(Clone, Copy, Debug)]
pub struct Config {
    /// Alphabet to use
    alphabet: Alphabet,
    /// Whether to add padding
    pad: bool,
}

/// Base64 alphabet variant
#[derive(Clone, Copy, Debug, PartialEq, Eq)]
pub enum Alphabet {
    /// Standard Base64 (+/)
    Standard,
    /// URL-safe Base64 (-_)
    UrlSafe,
}

impl Config {
    /// Standard Base64 with padding
    pub const STANDARD: Config = Config {
        alphabet: Alphabet::Standard,
        pad: true,
    };
    
    /// Standard Base64 without padding
    pub const STANDARD_NO_PAD: Config = Config {
        alphabet: Alphabet::Standard,
        pad: false,
    };
    
    /// URL-safe Base64 with padding
    pub const URL_SAFE: Config = Config {
        alphabet: Alphabet::UrlSafe,
        pad: true,
    };
    
    /// URL-safe Base64 without padding
    pub const URL_SAFE_NO_PAD: Config = Config {
        alphabet: Alphabet::UrlSafe,
        pad: false,
    };
    
    /// Create custom config
    pub fn new(alphabet: Alphabet, pad: bool) -> Self {
        Config { alphabet, pad }
    }
    
    fn encode_table(&self) -> &'static [u8; 64] {
        match self.alphabet {
            Alphabet::Standard => STANDARD_ALPHABET,
            Alphabet::UrlSafe => URL_SAFE_ALPHABET,
        }
    }
    
    fn decode_table(&self) -> &'static [i8; 256] {
        match self.alphabet {
            Alphabet::Standard => &STANDARD_DECODE,
            Alphabet::UrlSafe => &URL_SAFE_DECODE,
        }
    }
}

impl Default for Config {
    fn default() -> Self {
        Config::STANDARD
    }
}

// ============================================================================
// Encoding
// ============================================================================

/// Encode bytes to Base64 string using specified config
pub fn encode_config(data: &[u8], config: Config) -> String {
    let table = config.encode_table();
    
    // Calculate output size
    let full_chunks = data.len() / 3;
    let remainder = data.len() % 3;
    let mut output_len = full_chunks * 4;
    if remainder > 0 {
        output_len += if config.pad { 4 } else { remainder + 1 };
    }
    
    let mut output = String::with_capacity(output_len);
    
    // Process 3-byte chunks
    let mut i = 0;
    while i + 3 <= data.len() {
        let b0 = data[i] as usize;
        let b1 = data[i + 1] as usize;
        let b2 = data[i + 2] as usize;
        
        output.push(table[b0 >> 2] as char);
        output.push(table[((b0 & 0x03) << 4) | (b1 >> 4)] as char);
        output.push(table[((b1 & 0x0f) << 2) | (b2 >> 6)] as char);
        output.push(table[b2 & 0x3f] as char);
        
        i += 3;
    }
    
    // Handle remainder
    match data.len() - i {
        1 => {
            let b0 = data[i] as usize;
            output.push(table[b0 >> 2] as char);
            output.push(table[(b0 & 0x03) << 4] as char);
            if config.pad {
                output.push('=');
                output.push('=');
            }
        }
        2 => {
            let b0 = data[i] as usize;
            let b1 = data[i + 1] as usize;
            output.push(table[b0 >> 2] as char);
            output.push(table[((b0 & 0x03) << 4) | (b1 >> 4)] as char);
            output.push(table[(b1 & 0x0f) << 2] as char);
            if config.pad {
                output.push('=');
            }
        }
        _ => {}
    }
    
    output
}

/// Encode bytes to standard Base64 string
pub fn encode(data: &[u8]) -> String {
    encode_config(data, Config::STANDARD)
}

/// Encode bytes to URL-safe Base64 string
pub fn encode_url_safe(data: &[u8]) -> String {
    encode_config(data, Config::URL_SAFE_NO_PAD)
}

// ============================================================================
// Decoding
// ============================================================================

/// Decode Base64 string using specified config
pub fn decode_config(input: &str, config: Config) -> Result<Vec<u8>, DecodeError> {
    let table = config.decode_table();
    let bytes = input.as_bytes();
    
    // Remove padding and validate
    let mut len = bytes.len();
    let mut padding = 0;
    
    while len > 0 && bytes[len - 1] == b'=' {
        padding += 1;
        len -= 1;
    }
    
    if padding > 2 {
        return Err(DecodeError {
            kind: DecodeErrorKind::InvalidPadding,
            position: len,
        });
    }
    
    // Validate length
    let total_len = len + padding;
    if config.pad && total_len % 4 != 0 {
        return Err(DecodeError {
            kind: DecodeErrorKind::InvalidLength,
            position: 0,
        });
    }
    
    // Calculate output size
    let output_len = (len * 6) / 8;
    let mut output = Vec::with_capacity(output_len);
    
    // Decode 4-character chunks
    let mut i = 0;
    while i + 4 <= len {
        let c0 = decode_char(table, bytes[i], i)?;
        let c1 = decode_char(table, bytes[i + 1], i + 1)?;
        let c2 = decode_char(table, bytes[i + 2], i + 2)?;
        let c3 = decode_char(table, bytes[i + 3], i + 3)?;
        
        output.push((c0 << 2) | (c1 >> 4));
        output.push(((c1 & 0x0f) << 4) | (c2 >> 2));
        output.push(((c2 & 0x03) << 6) | c3);
        
        i += 4;
    }
    
    // Handle remainder
    match len - i {
        2 => {
            let c0 = decode_char(table, bytes[i], i)?;
            let c1 = decode_char(table, bytes[i + 1], i + 1)?;
            output.push((c0 << 2) | (c1 >> 4));
        }
        3 => {
            let c0 = decode_char(table, bytes[i], i)?;
            let c1 = decode_char(table, bytes[i + 1], i + 1)?;
            let c2 = decode_char(table, bytes[i + 2], i + 2)?;
            output.push((c0 << 2) | (c1 >> 4));
            output.push(((c1 & 0x0f) << 4) | (c2 >> 2));
        }
        1 => {
            return Err(DecodeError {
                kind: DecodeErrorKind::InvalidLength,
                position: i,
            });
        }
        _ => {}
    }
    
    Ok(output)
}

fn decode_char(table: &[i8; 256], byte: u8, pos: usize) -> Result<u8, DecodeError> {
    let value = table[byte as usize];
    if value < 0 {
        Err(DecodeError {
            kind: DecodeErrorKind::InvalidCharacter,
            position: pos,
        })
    } else {
        Ok(value as u8)
    }
}

/// Decode standard Base64 string
pub fn decode(input: &str) -> Result<Vec<u8>, DecodeError> {
    // Try with padding first, then without
    decode_config(input, Config::STANDARD)
        .or_else(|_| decode_config(input, Config::STANDARD_NO_PAD))
}

/// Decode URL-safe Base64 string
pub fn decode_url_safe(input: &str) -> Result<Vec<u8>, DecodeError> {
    decode_config(input, Config::URL_SAFE)
        .or_else(|_| decode_config(input, Config::URL_SAFE_NO_PAD))
}

// ============================================================================
// Streaming Encoder/Decoder
// ============================================================================

/// Streaming Base64 encoder
pub struct Encoder {
    config: Config,
    buffer: Vec<u8>,
    output: String,
}

impl Encoder {
    /// Create new encoder
    pub fn new(config: Config) -> Self {
        Encoder {
            config,
            buffer: Vec::new(),
            output: String::new(),
        }
    }
    
    /// Write data to encode
    pub fn write(&mut self, data: &[u8]) {
        self.buffer.extend_from_slice(data);
        
        // Encode complete 3-byte chunks
        let complete = (self.buffer.len() / 3) * 3;
        if complete > 0 {
            self.output.push_str(&encode_config(&self.buffer[..complete], self.config));
            self.buffer.drain(..complete);
        }
    }
    
    /// Finish encoding and return result
    pub fn finish(mut self) -> String {
        if !self.buffer.is_empty() {
            self.output.push_str(&encode_config(&self.buffer, self.config));
        }
        self.output
    }
}

/// Streaming Base64 decoder
pub struct Decoder {
    config: Config,
    buffer: String,
    output: Vec<u8>,
}

impl Decoder {
    /// Create new decoder
    pub fn new(config: Config) -> Self {
        Decoder {
            config,
            buffer: String::new(),
            output: Vec::new(),
        }
    }
    
    /// Write data to decode
    pub fn write(&mut self, data: &str) -> Result<(), DecodeError> {
        self.buffer.push_str(data);
        
        // Decode complete 4-character chunks
        let complete = (self.buffer.len() / 4) * 4;
        if complete > 0 {
            let decoded = decode_config(&self.buffer[..complete], self.config)?;
            self.output.extend_from_slice(&decoded);
            self.buffer.drain(..complete);
        }
        
        Ok(())
    }
    
    /// Finish decoding and return result
    pub fn finish(mut self) -> Result<Vec<u8>, DecodeError> {
        if !self.buffer.is_empty() {
            let decoded = decode_config(&self.buffer, self.config)?;
            self.output.extend_from_slice(&decoded);
        }
        Ok(self.output)
    }
}

// ============================================================================
// Utility Functions
// ============================================================================

/// Calculate encoded length for given input length
pub fn encoded_len(input_len: usize, pad: bool) -> usize {
    if pad {
        (input_len + 2) / 3 * 4
    } else {
        let full_chunks = input_len / 3;
        let remainder = input_len % 3;
        full_chunks * 4 + if remainder > 0 { remainder + 1 } else { 0 }
    }
}

/// Calculate maximum decoded length for given input length
pub fn decoded_len_estimate(input_len: usize) -> usize {
    input_len / 4 * 3 + 3
}

/// Check if string is valid Base64
pub fn is_valid(input: &str) -> bool {
    decode(input).is_ok()
}

/// Check if string is valid URL-safe Base64
pub fn is_valid_url_safe(input: &str) -> bool {
    decode_url_safe(input).is_ok()
}

// ============================================================================
// Display Utilities
// ============================================================================

/// Encode and display with line wrapping
pub fn encode_display(data: &[u8], line_length: usize) -> String {
    let encoded = encode(data);
    
    if line_length == 0 || encoded.len() <= line_length {
        return encoded;
    }
    
    let mut result = String::with_capacity(encoded.len() + encoded.len() / line_length);
    
    for (i, chunk) in encoded.as_bytes().chunks(line_length).enumerate() {
        if i > 0 {
            result.push('\n');
        }
        result.push_str(std::str::from_utf8(chunk).unwrap());
    }
    
    result
}

/// Decode string with whitespace (MIME style)
pub fn decode_mime(input: &str) -> Result<Vec<u8>, DecodeError> {
    // Remove whitespace
    let clean: String = input.chars()
        .filter(|c| !c.is_whitespace())
        .collect();
    decode(&clean)
}

// ============================================================================
// Tests
// ============================================================================

#[cfg(test)]
mod tests {
    use super::*;
    
    #[test]
    fn test_encode_empty() {
        assert_eq!(encode(b""), "");
    }
    
    #[test]
    fn test_encode_basic() {
        assert_eq!(encode(b"f"), "Zg==");
        assert_eq!(encode(b"fo"), "Zm8=");
        assert_eq!(encode(b"foo"), "Zm9v");
        assert_eq!(encode(b"foob"), "Zm9vYg==");
        assert_eq!(encode(b"fooba"), "Zm9vYmE=");
        assert_eq!(encode(b"foobar"), "Zm9vYmFy");
    }
    
    #[test]
    fn test_decode_basic() {
        assert_eq!(decode("").unwrap(), b"");
        assert_eq!(decode("Zg==").unwrap(), b"f");
        assert_eq!(decode("Zm8=").unwrap(), b"fo");
        assert_eq!(decode("Zm9v").unwrap(), b"foo");
        assert_eq!(decode("Zm9vYg==").unwrap(), b"foob");
        assert_eq!(decode("Zm9vYmE=").unwrap(), b"fooba");
        assert_eq!(decode("Zm9vYmFy").unwrap(), b"foobar");
    }
    
    #[test]
    fn test_decode_no_padding() {
        assert_eq!(decode("Zg").unwrap(), b"f");
        assert_eq!(decode("Zm8").unwrap(), b"fo");
    }
    
    #[test]
    fn test_roundtrip() {
        let test_cases = [
            b"".as_slice(),
            b"a",
            b"ab",
            b"abc",
            b"Hello, World!",
            b"\x00\x01\x02\x03\xff\xfe\xfd",
        ];
        
        for data in test_cases {
            let encoded = encode(data);
            let decoded = decode(&encoded).unwrap();
            assert_eq!(decoded, data);
        }
    }
    
    #[test]
    fn test_url_safe() {
        // Standard uses + and /
        let data = &[0xfb, 0xef, 0xbe];
        let standard = encode(data);
        assert!(standard.contains('+') || standard.contains('/'));
        
        // URL-safe uses - and _
        let url_safe = encode_url_safe(data);
        assert!(!url_safe.contains('+'));
        assert!(!url_safe.contains('/'));
        
        // Both should decode to same data
        assert_eq!(decode(&standard).unwrap(), data);
        assert_eq!(decode_url_safe(&url_safe).unwrap(), data);
    }
    
    #[test]
    fn test_no_padding() {
        let data = b"test";
        
        let with_pad = encode_config(data, Config::STANDARD);
        let without_pad = encode_config(data, Config::STANDARD_NO_PAD);
        
        assert!(with_pad.ends_with('='));
        assert!(!without_pad.contains('='));
        
        assert_eq!(decode(&with_pad).unwrap(), data);
        assert_eq!(decode(&without_pad).unwrap(), data);
    }
    
    #[test]
    fn test_invalid_character() {
        let err = decode("Zm9v!bar").unwrap_err();
        assert_eq!(err.kind(), DecodeErrorKind::InvalidCharacter);
    }
    
    #[test]
    fn test_invalid_length() {
        let err = decode_config("Z", Config::STANDARD).unwrap_err();
        assert_eq!(err.kind(), DecodeErrorKind::InvalidLength);
    }
    
    #[test]
    fn test_streaming_encoder() {
        let mut encoder = Encoder::new(Config::STANDARD);
        encoder.write(b"foo");
        encoder.write(b"bar");
        let result = encoder.finish();
        
        assert_eq!(result, encode(b"foobar"));
    }
    
    #[test]
    fn test_streaming_decoder() {
        let mut decoder = Decoder::new(Config::STANDARD);
        decoder.write("Zm9v").unwrap();
        decoder.write("YmFy").unwrap();
        let result = decoder.finish().unwrap();
        
        assert_eq!(result, b"foobar");
    }
    
    #[test]
    fn test_encode_display() {
        let data = b"Hello, World! This is a longer message.";
        let wrapped = encode_display(data, 20);
        
        assert!(wrapped.contains('\n'));
        for line in wrapped.lines() {
            assert!(line.len() <= 20);
        }
    }
    
    #[test]
    fn test_decode_mime() {
        let input = "Zm9v\nYmFy";
        assert_eq!(decode_mime(input).unwrap(), b"foobar");
    }
    
    #[test]
    fn test_encoded_len() {
        assert_eq!(encoded_len(0, true), 0);
        assert_eq!(encoded_len(1, true), 4);
        assert_eq!(encoded_len(2, true), 4);
        assert_eq!(encoded_len(3, true), 4);
        assert_eq!(encoded_len(4, true), 8);
        
        assert_eq!(encoded_len(1, false), 2);
        assert_eq!(encoded_len(2, false), 3);
        assert_eq!(encoded_len(3, false), 4);
    }
    
    #[test]
    fn test_binary_data() {
        let data: Vec<u8> = (0..=255).collect();
        let encoded = encode(&data);
        let decoded = decode(&encoded).unwrap();
        assert_eq!(decoded, data);
    }
}
