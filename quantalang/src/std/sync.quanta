/// QuantaLang Standard Library - Synchronization Primitives
/// Mutex, RwLock, Channel, Condvar, Barrier, Once, atomic operations
module std::sync;

use std::mem::{size_of, align_of, transmute};
use std::ptr::{null, null_mut, NonNull};
use std::option::Option;
use std::result::Result;
use std::vec::Vec;
use std::collections::VecDeque;
use std::time::Duration;

// ============================================================================
// Atomic Operations
// ============================================================================

/// Memory ordering for atomic operations
pub enum Ordering {
    /// No ordering constraints
    Relaxed,
    /// Acquire semantics - loads before this cannot move after
    Acquire,
    /// Release semantics - stores after this cannot move before
    Release,
    /// Both acquire and release
    AcqRel,
    /// Sequential consistency - total ordering
    SeqCst,
}

/// Atomic boolean
pub struct AtomicBool {
    value: u8,  // 0 = false, 1 = true
}

impl AtomicBool {
    pub const fn new(value: bool) -> Self {
        Self { value: if value { 1 } else { 0 } }
    }
    
    /// Load with specified ordering
    #[intrinsic("atomic_load")]
    pub fn load(&self, order: Ordering) -> bool {
        // Intrinsic: atomic load
        unsafe { __atomic_load(&self.value, order) != 0 }
    }
    
    /// Store with specified ordering
    #[intrinsic("atomic_store")]
    pub fn store(&self, value: bool, order: Ordering) {
        let v = if value { 1u8 } else { 0u8 };
        unsafe { __atomic_store(&self.value, v, order); }
    }
    
    /// Swap and return old value
    #[intrinsic("atomic_swap")]
    pub fn swap(&self, value: bool, order: Ordering) -> bool {
        let v = if value { 1u8 } else { 0u8 };
        unsafe { __atomic_swap(&self.value, v, order) != 0 }
    }
    
    /// Compare and swap - returns (success, previous_value)
    #[intrinsic("atomic_cmpxchg")]
    pub fn compare_exchange(
        &self,
        current: bool,
        new: bool,
        success: Ordering,
        failure: Ordering,
    ) -> Result<bool, bool> {
        let c = if current { 1u8 } else { 0u8 };
        let n = if new { 1u8 } else { 0u8 };
        let (ok, prev) = unsafe { __atomic_cmpxchg(&self.value, c, n, success, failure) };
        if ok { Ok(prev != 0) } else { Err(prev != 0) }
    }
    
    /// Weak compare-exchange (may fail spuriously)
    pub fn compare_exchange_weak(
        &self,
        current: bool,
        new: bool,
        success: Ordering,
        failure: Ordering,
    ) -> Result<bool, bool> {
        let c = if current { 1u8 } else { 0u8 };
        let n = if new { 1u8 } else { 0u8 };
        let (ok, prev) = unsafe { __atomic_cmpxchg_weak(&self.value, c, n, success, failure) };
        if ok { Ok(prev != 0) } else { Err(prev != 0) }
    }
    
    /// Fetch and apply bitwise AND
    pub fn fetch_and(&self, value: bool, order: Ordering) -> bool {
        let v = if value { 1u8 } else { 0u8 };
        unsafe { __atomic_fetch_and(&self.value, v, order) != 0 }
    }
    
    /// Fetch and apply bitwise OR
    pub fn fetch_or(&self, value: bool, order: Ordering) -> bool {
        let v = if value { 1u8 } else { 0u8 };
        unsafe { __atomic_fetch_or(&self.value, v, order) != 0 }
    }
    
    /// Fetch and apply bitwise XOR
    pub fn fetch_xor(&self, value: bool, order: Ordering) -> bool {
        let v = if value { 1u8 } else { 0u8 };
        unsafe { __atomic_fetch_xor(&self.value, v, order) != 0 }
    }
}

/// Atomic usize
pub struct AtomicUsize {
    value: usize,
}

impl AtomicUsize {
    pub const fn new(value: usize) -> Self {
        Self { value }
    }
    
    pub fn load(&self, order: Ordering) -> usize {
        unsafe { __atomic_load(&self.value, order) }
    }
    
    pub fn store(&self, value: usize, order: Ordering) {
        unsafe { __atomic_store(&self.value, value, order); }
    }
    
    pub fn swap(&self, value: usize, order: Ordering) -> usize {
        unsafe { __atomic_swap(&self.value, value, order) }
    }
    
    pub fn compare_exchange(
        &self,
        current: usize,
        new: usize,
        success: Ordering,
        failure: Ordering,
    ) -> Result<usize, usize> {
        let (ok, prev) = unsafe { __atomic_cmpxchg(&self.value, current, new, success, failure) };
        if ok { Ok(prev) } else { Err(prev) }
    }
    
    pub fn compare_exchange_weak(
        &self,
        current: usize,
        new: usize,
        success: Ordering,
        failure: Ordering,
    ) -> Result<usize, usize> {
        let (ok, prev) = unsafe { __atomic_cmpxchg_weak(&self.value, current, new, success, failure) };
        if ok { Ok(prev) } else { Err(prev) }
    }
    
    pub fn fetch_add(&self, value: usize, order: Ordering) -> usize {
        unsafe { __atomic_fetch_add(&self.value, value, order) }
    }
    
    pub fn fetch_sub(&self, value: usize, order: Ordering) -> usize {
        unsafe { __atomic_fetch_sub(&self.value, value, order) }
    }
    
    pub fn fetch_and(&self, value: usize, order: Ordering) -> usize {
        unsafe { __atomic_fetch_and(&self.value, value, order) }
    }
    
    pub fn fetch_or(&self, value: usize, order: Ordering) -> usize {
        unsafe { __atomic_fetch_or(&self.value, value, order) }
    }
    
    pub fn fetch_xor(&self, value: usize, order: Ordering) -> usize {
        unsafe { __atomic_fetch_xor(&self.value, value, order) }
    }
    
    pub fn fetch_max(&self, value: usize, order: Ordering) -> usize {
        unsafe { __atomic_fetch_max(&self.value, value, order) }
    }
    
    pub fn fetch_min(&self, value: usize, order: Ordering) -> usize {
        unsafe { __atomic_fetch_min(&self.value, value, order) }
    }
    
    pub fn fetch_update<F>(
        &self,
        set_order: Ordering,
        fetch_order: Ordering,
        mut f: F,
    ) -> Result<usize, usize>
    where
        F: FnMut(usize) -> Option<usize>,
    {
        let mut prev = self.load(fetch_order);
        loop {
            match f(prev) {
                Some(next) => {
                    match self.compare_exchange_weak(prev, next, set_order, fetch_order) {
                        Ok(_) => return Ok(prev),
                        Err(next_prev) => prev = next_prev,
                    }
                }
                None => return Err(prev),
            }
        }
    }
}

/// Atomic isize
pub struct AtomicIsize {
    value: isize,
}

impl AtomicIsize {
    pub const fn new(value: isize) -> Self {
        Self { value }
    }
    
    pub fn load(&self, order: Ordering) -> isize {
        unsafe { __atomic_load(&self.value, order) }
    }
    
    pub fn store(&self, value: isize, order: Ordering) {
        unsafe { __atomic_store(&self.value, value, order); }
    }
    
    pub fn swap(&self, value: isize, order: Ordering) -> isize {
        unsafe { __atomic_swap(&self.value, value, order) }
    }
    
    pub fn compare_exchange(
        &self,
        current: isize,
        new: isize,
        success: Ordering,
        failure: Ordering,
    ) -> Result<isize, isize> {
        let (ok, prev) = unsafe { __atomic_cmpxchg(&self.value, current, new, success, failure) };
        if ok { Ok(prev) } else { Err(prev) }
    }
    
    pub fn fetch_add(&self, value: isize, order: Ordering) -> isize {
        unsafe { __atomic_fetch_add(&self.value, value, order) }
    }
    
    pub fn fetch_sub(&self, value: isize, order: Ordering) -> isize {
        unsafe { __atomic_fetch_sub(&self.value, value, order) }
    }
}

/// Atomic pointer
pub struct AtomicPtr<T> {
    ptr: *mut T,
}

impl<T> AtomicPtr<T> {
    pub const fn new(ptr: *mut T) -> Self {
        Self { ptr }
    }
    
    pub fn load(&self, order: Ordering) -> *mut T {
        unsafe { __atomic_load(&self.ptr, order) }
    }
    
    pub fn store(&self, ptr: *mut T, order: Ordering) {
        unsafe { __atomic_store(&self.ptr, ptr, order); }
    }
    
    pub fn swap(&self, ptr: *mut T, order: Ordering) -> *mut T {
        unsafe { __atomic_swap(&self.ptr, ptr, order) }
    }
    
    pub fn compare_exchange(
        &self,
        current: *mut T,
        new: *mut T,
        success: Ordering,
        failure: Ordering,
    ) -> Result<*mut T, *mut T> {
        let (ok, prev) = unsafe { __atomic_cmpxchg(&self.ptr, current, new, success, failure) };
        if ok { Ok(prev) } else { Err(prev) }
    }
}

/// Memory fence
#[intrinsic("atomic_fence")]
pub fn fence(order: Ordering) {
    unsafe { __atomic_fence(order); }
}

/// Compiler fence (no CPU barrier)
#[intrinsic("compiler_fence")]
pub fn compiler_fence(order: Ordering) {
    unsafe { __compiler_fence(order); }
}

/// Spin-loop hint for busy waiting
#[intrinsic("spin_loop_hint")]
pub fn spin_loop_hint() {
    unsafe { __spin_loop_hint(); }
}

// ============================================================================
// Mutex - Mutual Exclusion Lock
// ============================================================================

/// Mutex state
const UNLOCKED: usize = 0;
const LOCKED: usize = 1;
const LOCKED_CONTENDED: usize = 2;

/// Poison error when a thread panicked while holding the lock
pub struct PoisonError<T> {
    guard: T,
}

impl<T> PoisonError<T> {
    pub fn new(guard: T) -> Self {
        Self { guard }
    }
    
    pub fn into_inner(self) -> T {
        self.guard
    }
    
    pub fn get_ref(&self) -> &T {
        &self.guard
    }
    
    pub fn get_mut(&mut self) -> &mut T {
        &mut self.guard
    }
}

/// Result type for lock operations
pub type LockResult<Guard> = Result<Guard, PoisonError<Guard>>;

/// Result type for try_lock operations
pub type TryLockResult<Guard> = Result<Guard, TryLockError<Guard>>;

pub enum TryLockError<T> {
    /// Lock was poisoned
    Poisoned(PoisonError<T>),
    /// Lock would block
    WouldBlock,
}

/// Mutual exclusion primitive
pub struct Mutex<T> {
    /// Lock state
    state: AtomicUsize,
    /// Poisoned flag
    poisoned: AtomicBool,
    /// Protected data
    data: UnsafeCell<T>,
}

// Safety: Mutex provides synchronized access
unsafe impl<T: Send> Send for Mutex<T> {}
unsafe impl<T: Send> Sync for Mutex<T> {}

impl<T> Mutex<T> {
    /// Create a new unlocked mutex
    pub const fn new(value: T) -> Self {
        Self {
            state: AtomicUsize::new(UNLOCKED),
            poisoned: AtomicBool::new(false),
            data: UnsafeCell::new(value),
        }
    }
    
    /// Acquire the lock, blocking until available
    pub fn lock(&self) -> LockResult<MutexGuard<'_, T>> {
        // Fast path: try to acquire uncontended
        if self.state.compare_exchange(
            UNLOCKED,
            LOCKED,
            Ordering::Acquire,
            Ordering::Relaxed,
        ).is_ok() {
            return self.make_guard();
        }
        
        // Slow path: contended lock
        self.lock_contended()
    }
    
    #[cold]
    fn lock_contended(&self) -> LockResult<MutexGuard<'_, T>> {
        let mut spin_count = 0;
        const MAX_SPINS: usize = 100;
        
        loop {
            // Spin phase
            if spin_count < MAX_SPINS {
                let state = self.state.load(Ordering::Relaxed);
                if state == UNLOCKED {
                    if self.state.compare_exchange(
                        UNLOCKED,
                        LOCKED,
                        Ordering::Acquire,
                        Ordering::Relaxed,
                    ).is_ok() {
                        return self.make_guard();
                    }
                }
                spin_loop_hint();
                spin_count += 1;
                continue;
            }
            
            // Mark as contended and wait
            if self.state.swap(LOCKED_CONTENDED, Ordering::Acquire) == UNLOCKED {
                return self.make_guard();
            }
            
            // Futex wait
            unsafe {
                __futex_wait(&self.state as *const _ as *const u32, LOCKED_CONTENDED as u32);
            }
        }
    }
    
    /// Try to acquire the lock without blocking
    pub fn try_lock(&self) -> TryLockResult<MutexGuard<'_, T>> {
        if self.state.compare_exchange(
            UNLOCKED,
            LOCKED,
            Ordering::Acquire,
            Ordering::Relaxed,
        ).is_ok() {
            match self.make_guard() {
                Ok(guard) => Ok(guard),
                Err(e) => Err(TryLockError::Poisoned(e)),
            }
        } else {
            Err(TryLockError::WouldBlock)
        }
    }
    
    /// Check if the mutex is poisoned
    pub fn is_poisoned(&self) -> bool {
        self.poisoned.load(Ordering::Relaxed)
    }
    
    /// Get mutable reference (only valid if we have exclusive access)
    pub fn get_mut(&mut self) -> LockResult<&mut T> {
        let data = self.data.get_mut();
        if self.poisoned.load(Ordering::Relaxed) {
            Err(PoisonError::new(data))
        } else {
            Ok(data)
        }
    }
    
    /// Consume mutex and return inner value
    pub fn into_inner(self) -> LockResult<T> {
        let data = self.data.into_inner();
        if self.poisoned.load(Ordering::Relaxed) {
            Err(PoisonError::new(data))
        } else {
            Ok(data)
        }
    }
    
    fn make_guard(&self) -> LockResult<MutexGuard<'_, T>> {
        let guard = MutexGuard { mutex: self };
        if self.poisoned.load(Ordering::Relaxed) {
            Err(PoisonError::new(guard))
        } else {
            Ok(guard)
        }
    }
    
    fn unlock(&self) {
        if self.state.swap(UNLOCKED, Ordering::Release) == LOCKED_CONTENDED {
            // Wake one waiter
            unsafe {
                __futex_wake(&self.state as *const _ as *const u32, 1);
            }
        }
    }
}

/// RAII guard for Mutex
pub struct MutexGuard<'a, T> {
    mutex: &'a Mutex<T>,
}

impl<'a, T> MutexGuard<'a, T> {
    /// Get reference to mutex
    pub fn mutex(&self) -> &'a Mutex<T> {
        self.mutex
    }
}

impl<T> Deref for MutexGuard<'_, T> {
    type Target = T;
    
    fn deref(&self) -> &T {
        unsafe { &*self.mutex.data.get() }
    }
}

impl<T> DerefMut for MutexGuard<'_, T> {
    fn deref_mut(&mut self) -> &mut T {
        unsafe { &mut *self.mutex.data.get() }
    }
}

impl<T> Drop for MutexGuard<'_, T> {
    fn drop(&mut self) {
        self.mutex.unlock();
    }
}

// ============================================================================
// RwLock - Reader-Writer Lock
// ============================================================================

/// Reader-writer lock state encoding:
/// - Bits 0-29: reader count (max ~1 billion readers)
/// - Bit 30: writer waiting flag
/// - Bit 31: writer active flag
const READER_MASK: usize = 0x3FFFFFFF;
const WRITER_WAITING: usize = 0x40000000;
const WRITER_ACTIVE: usize = 0x80000000;

/// Reader-writer lock allowing multiple readers or single writer
pub struct RwLock<T> {
    state: AtomicUsize,
    poisoned: AtomicBool,
    /// Number of writers waiting (for fair scheduling)
    writer_queue: AtomicUsize,
    data: UnsafeCell<T>,
}

unsafe impl<T: Send> Send for RwLock<T> {}
unsafe impl<T: Send + Sync> Sync for RwLock<T> {}

impl<T> RwLock<T> {
    pub const fn new(value: T) -> Self {
        Self {
            state: AtomicUsize::new(0),
            poisoned: AtomicBool::new(false),
            writer_queue: AtomicUsize::new(0),
            data: UnsafeCell::new(value),
        }
    }
    
    /// Acquire read lock
    pub fn read(&self) -> LockResult<RwLockReadGuard<'_, T>> {
        loop {
            let state = self.state.load(Ordering::Relaxed);
            
            // Cannot acquire if writer active or writers waiting (to prevent starvation)
            if (state & (WRITER_ACTIVE | WRITER_WAITING)) != 0 {
                self.wait_for_readers();
                continue;
            }
            
            // Try to increment reader count
            let readers = state & READER_MASK;
            if readers == READER_MASK {
                panic!("RwLock reader count overflow");
            }
            
            if self.state.compare_exchange_weak(
                state,
                state + 1,
                Ordering::Acquire,
                Ordering::Relaxed,
            ).is_ok() {
                return self.make_read_guard();
            }
        }
    }
    
    /// Try to acquire read lock without blocking
    pub fn try_read(&self) -> TryLockResult<RwLockReadGuard<'_, T>> {
        let state = self.state.load(Ordering::Relaxed);
        
        if (state & (WRITER_ACTIVE | WRITER_WAITING)) != 0 {
            return Err(TryLockError::WouldBlock);
        }
        
        let readers = state & READER_MASK;
        if readers == READER_MASK {
            return Err(TryLockError::WouldBlock);
        }
        
        if self.state.compare_exchange(
            state,
            state + 1,
            Ordering::Acquire,
            Ordering::Relaxed,
        ).is_ok() {
            match self.make_read_guard() {
                Ok(guard) => Ok(guard),
                Err(e) => Err(TryLockError::Poisoned(e)),
            }
        } else {
            Err(TryLockError::WouldBlock)
        }
    }
    
    /// Acquire write lock
    pub fn write(&self) -> LockResult<RwLockWriteGuard<'_, T>> {
        // Signal that a writer is waiting
        self.writer_queue.fetch_add(1, Ordering::Relaxed);
        
        loop {
            let state = self.state.load(Ordering::Relaxed);
            
            // Set writer waiting flag
            if (state & WRITER_WAITING) == 0 {
                self.state.fetch_or(WRITER_WAITING, Ordering::Relaxed);
            }
            
            // Can only acquire if no readers and no active writer
            if (state & (READER_MASK | WRITER_ACTIVE)) != 0 {
                self.wait_for_writer();
                continue;
            }
            
            // Try to acquire
            if self.state.compare_exchange_weak(
                state | WRITER_WAITING,
                WRITER_ACTIVE,
                Ordering::Acquire,
                Ordering::Relaxed,
            ).is_ok() {
                self.writer_queue.fetch_sub(1, Ordering::Relaxed);
                
                // Clear waiting flag if no more writers
                if self.writer_queue.load(Ordering::Relaxed) == 0 {
                    self.state.fetch_and(!WRITER_WAITING, Ordering::Relaxed);
                }
                
                return self.make_write_guard();
            }
        }
    }
    
    /// Try to acquire write lock without blocking
    pub fn try_write(&self) -> TryLockResult<RwLockWriteGuard<'_, T>> {
        let state = self.state.load(Ordering::Relaxed);
        
        if (state & (READER_MASK | WRITER_ACTIVE)) != 0 {
            return Err(TryLockError::WouldBlock);
        }
        
        if self.state.compare_exchange(
            state,
            WRITER_ACTIVE,
            Ordering::Acquire,
            Ordering::Relaxed,
        ).is_ok() {
            match self.make_write_guard() {
                Ok(guard) => Ok(guard),
                Err(e) => Err(TryLockError::Poisoned(e)),
            }
        } else {
            Err(TryLockError::WouldBlock)
        }
    }
    
    pub fn is_poisoned(&self) -> bool {
        self.poisoned.load(Ordering::Relaxed)
    }
    
    pub fn get_mut(&mut self) -> LockResult<&mut T> {
        let data = self.data.get_mut();
        if self.poisoned.load(Ordering::Relaxed) {
            Err(PoisonError::new(data))
        } else {
            Ok(data)
        }
    }
    
    pub fn into_inner(self) -> LockResult<T> {
        let data = self.data.into_inner();
        if self.poisoned.load(Ordering::Relaxed) {
            Err(PoisonError::new(data))
        } else {
            Ok(data)
        }
    }
    
    fn wait_for_readers(&self) {
        // Spin briefly then yield
        for _ in 0..100 {
            spin_loop_hint();
            let state = self.state.load(Ordering::Relaxed);
            if (state & (WRITER_ACTIVE | WRITER_WAITING)) == 0 {
                return;
            }
        }
        unsafe { __thread_yield(); }
    }
    
    fn wait_for_writer(&self) {
        for _ in 0..100 {
            spin_loop_hint();
            let state = self.state.load(Ordering::Relaxed);
            if (state & (READER_MASK | WRITER_ACTIVE)) == 0 {
                return;
            }
        }
        unsafe { __thread_yield(); }
    }
    
    fn make_read_guard(&self) -> LockResult<RwLockReadGuard<'_, T>> {
        let guard = RwLockReadGuard { lock: self };
        if self.poisoned.load(Ordering::Relaxed) {
            Err(PoisonError::new(guard))
        } else {
            Ok(guard)
        }
    }
    
    fn make_write_guard(&self) -> LockResult<RwLockWriteGuard<'_, T>> {
        let guard = RwLockWriteGuard { lock: self };
        if self.poisoned.load(Ordering::Relaxed) {
            Err(PoisonError::new(guard))
        } else {
            Ok(guard)
        }
    }
    
    fn read_unlock(&self) {
        let prev = self.state.fetch_sub(1, Ordering::Release);
        // Wake writer if this was the last reader
        if (prev & READER_MASK) == 1 && (prev & WRITER_WAITING) != 0 {
            unsafe { __futex_wake(&self.state as *const _ as *const u32, 1); }
        }
    }
    
    fn write_unlock(&self) {
        self.state.fetch_and(!WRITER_ACTIVE, Ordering::Release);
        // Wake all waiters
        unsafe { __futex_wake(&self.state as *const _ as *const u32, u32::MAX); }
    }
}

/// RAII read guard
pub struct RwLockReadGuard<'a, T> {
    lock: &'a RwLock<T>,
}

impl<T> Deref for RwLockReadGuard<'_, T> {
    type Target = T;
    
    fn deref(&self) -> &T {
        unsafe { &*self.lock.data.get() }
    }
}

impl<T> Drop for RwLockReadGuard<'_, T> {
    fn drop(&mut self) {
        self.lock.read_unlock();
    }
}

/// RAII write guard
pub struct RwLockWriteGuard<'a, T> {
    lock: &'a RwLock<T>,
}

impl<T> Deref for RwLockWriteGuard<'_, T> {
    type Target = T;
    
    fn deref(&self) -> &T {
        unsafe { &*self.lock.data.get() }
    }
}

impl<T> DerefMut for RwLockWriteGuard<'_, T> {
    fn deref_mut(&mut self) -> &mut T {
        unsafe { &mut *self.lock.data.get() }
    }
}

impl<T> Drop for RwLockWriteGuard<'_, T> {
    fn drop(&mut self) {
        self.lock.write_unlock();
    }
}

// ============================================================================
// Condition Variable
// ============================================================================

/// Condition variable for signaling between threads
pub struct Condvar {
    /// Futex word for waiting
    futex: AtomicUsize,
}

impl Condvar {
    pub const fn new() -> Self {
        Self {
            futex: AtomicUsize::new(0),
        }
    }
    
    /// Wait for notification, releasing the mutex while waiting
    pub fn wait<'a, T>(&self, guard: MutexGuard<'a, T>) -> LockResult<MutexGuard<'a, T>> {
        let mutex = guard.mutex();
        
        // Get current futex value
        let key = self.futex.load(Ordering::Relaxed);
        
        // Release the mutex
        drop(guard);
        
        // Wait on futex
        unsafe {
            __futex_wait(&self.futex as *const _ as *const u32, key as u32);
        }
        
        // Re-acquire mutex
        mutex.lock()
    }
    
    /// Wait with timeout
    pub fn wait_timeout<'a, T>(
        &self,
        guard: MutexGuard<'a, T>,
        duration: Duration,
    ) -> LockResult<(MutexGuard<'a, T>, WaitTimeoutResult)> {
        let mutex = guard.mutex();
        let key = self.futex.load(Ordering::Relaxed);
        
        drop(guard);
        
        let timed_out = unsafe {
            __futex_wait_timeout(
                &self.futex as *const _ as *const u32,
                key as u32,
                duration.as_nanos() as u64,
            )
        };
        
        let result = WaitTimeoutResult { timed_out };
        
        match mutex.lock() {
            Ok(guard) => Ok((guard, result)),
            Err(e) => Err(PoisonError::new((e.into_inner(), result))),
        }
    }
    
    /// Wake one waiting thread
    pub fn notify_one(&self) {
        self.futex.fetch_add(1, Ordering::SeqCst);
        unsafe {
            __futex_wake(&self.futex as *const _ as *const u32, 1);
        }
    }
    
    /// Wake all waiting threads
    pub fn notify_all(&self) {
        self.futex.fetch_add(1, Ordering::SeqCst);
        unsafe {
            __futex_wake(&self.futex as *const _ as *const u32, u32::MAX);
        }
    }
}

pub struct WaitTimeoutResult {
    timed_out: bool,
}

impl WaitTimeoutResult {
    pub fn timed_out(&self) -> bool {
        self.timed_out
    }
}

// ============================================================================
// Barrier
// ============================================================================

/// Synchronization barrier for multiple threads
pub struct Barrier {
    /// Number of threads required
    num_threads: usize,
    /// State: count in lower bits, generation in upper bits
    state: Mutex<BarrierState>,
    cvar: Condvar,
}

struct BarrierState {
    count: usize,
    generation: usize,
}

/// Result returned from barrier wait
pub struct BarrierWaitResult {
    is_leader: bool,
}

impl BarrierWaitResult {
    pub fn is_leader(&self) -> bool {
        self.is_leader
    }
}

impl Barrier {
    pub fn new(n: usize) -> Self {
        assert!(n > 0, "Barrier requires at least 1 thread");
        Self {
            num_threads: n,
            state: Mutex::new(BarrierState {
                count: 0,
                generation: 0,
            }),
            cvar: Condvar::new(),
        }
    }
    
    /// Wait at the barrier until all threads arrive
    pub fn wait(&self) -> BarrierWaitResult {
        let mut state = self.state.lock().unwrap_or_else(|e| e.into_inner());
        
        let generation = state.generation;
        state.count += 1;
        
        if state.count == self.num_threads {
            // Last thread to arrive - release all
            state.count = 0;
            state.generation = state.generation.wrapping_add(1);
            self.cvar.notify_all();
            BarrierWaitResult { is_leader: true }
        } else {
            // Wait for others
            while state.generation == generation {
                state = self.cvar.wait(state).unwrap_or_else(|e| e.into_inner());
            }
            BarrierWaitResult { is_leader: false }
        }
    }
}

// ============================================================================
// Once - One-time initialization
// ============================================================================

const ONCE_INCOMPLETE: usize = 0;
const ONCE_RUNNING: usize = 1;
const ONCE_COMPLETE: usize = 2;
const ONCE_POISONED: usize = 3;

/// Synchronization primitive for one-time initialization
pub struct Once {
    state: AtomicUsize,
}

impl Once {
    pub const fn new() -> Self {
        Self {
            state: AtomicUsize::new(ONCE_INCOMPLETE),
        }
    }
    
    /// Run the initialization function exactly once
    pub fn call_once<F: FnOnce()>(&self, f: F) {
        if self.is_completed() {
            return;
        }
        self.call_once_slow(f);
    }
    
    #[cold]
    fn call_once_slow<F: FnOnce()>(&self, f: F) {
        loop {
            match self.state.compare_exchange(
                ONCE_INCOMPLETE,
                ONCE_RUNNING,
                Ordering::Acquire,
                Ordering::Relaxed,
            ) {
                Ok(_) => {
                    // We won the race, run the closure
                    let result = std::panic::catch_unwind(std::panic::AssertUnwindSafe(f));
                    
                    match result {
                        Ok(()) => {
                            self.state.store(ONCE_COMPLETE, Ordering::Release);
                        }
                        Err(_) => {
                            self.state.store(ONCE_POISONED, Ordering::Release);
                        }
                    }
                    
                    // Wake all waiters
                    unsafe {
                        __futex_wake(&self.state as *const _ as *const u32, u32::MAX);
                    }
                    return;
                }
                Err(ONCE_RUNNING) => {
                    // Someone else is running, wait
                    unsafe {
                        __futex_wait(&self.state as *const _ as *const u32, ONCE_RUNNING as u32);
                    }
                }
                Err(ONCE_COMPLETE) => return,
                Err(ONCE_POISONED) => panic!("Once instance has been poisoned"),
                Err(_) => unreachable!(),
            }
        }
    }
    
    pub fn is_completed(&self) -> bool {
        self.state.load(Ordering::Acquire) == ONCE_COMPLETE
    }
}

/// Lazy initialization wrapper
pub struct Lazy<T, F = fn() -> T> {
    cell: OnceLock<T>,
    init: Cell<Option<F>>,
}

impl<T, F: FnOnce() -> T> Lazy<T, F> {
    pub const fn new(f: F) -> Self {
        Self {
            cell: OnceLock::new(),
            init: Cell::new(Some(f)),
        }
    }
    
    pub fn force(this: &Self) -> &T {
        this.cell.get_or_init(|| {
            let f = this.init.take().expect("Lazy already initialized");
            f()
        })
    }
}

impl<T, F: FnOnce() -> T> Deref for Lazy<T, F> {
    type Target = T;
    
    fn deref(&self) -> &T {
        Lazy::force(self)
    }
}

/// Thread-safe lazy cell
pub struct OnceLock<T> {
    once: Once,
    value: UnsafeCell<Option<T>>,
}

unsafe impl<T: Send> Send for OnceLock<T> {}
unsafe impl<T: Send + Sync> Sync for OnceLock<T> {}

impl<T> OnceLock<T> {
    pub const fn new() -> Self {
        Self {
            once: Once::new(),
            value: UnsafeCell::new(None),
        }
    }
    
    pub fn get(&self) -> Option<&T> {
        if self.once.is_completed() {
            unsafe { (*self.value.get()).as_ref() }
        } else {
            None
        }
    }
    
    pub fn get_mut(&mut self) -> Option<&mut T> {
        self.value.get_mut().as_mut()
    }
    
    pub fn set(&self, value: T) -> Result<(), T> {
        let mut value = Some(value);
        self.once.call_once(|| {
            unsafe {
                *self.value.get() = value.take();
            }
        });
        match value {
            Some(v) => Err(v),
            None => Ok(()),
        }
    }
    
    pub fn get_or_init<F: FnOnce() -> T>(&self, f: F) -> &T {
        self.once.call_once(|| {
            unsafe {
                *self.value.get() = Some(f());
            }
        });
        unsafe { (*self.value.get()).as_ref().unwrap() }
    }
    
    pub fn into_inner(self) -> Option<T> {
        self.value.into_inner()
    }
}

// ============================================================================
// Channel - Multi-producer, multi-consumer channel
// ============================================================================

/// Error when sending on a disconnected channel
pub struct SendError<T>(pub T);

/// Error when receiving on an empty or disconnected channel
pub enum TryRecvError {
    /// No message available
    Empty,
    /// Channel disconnected
    Disconnected,
}

/// Error from recv on disconnected channel
pub struct RecvError;

/// Error when sending on a full or disconnected channel
pub enum TrySendError<T> {
    Full(T),
    Disconnected(T),
}

/// Create an unbounded channel
pub fn channel<T>() -> (Sender<T>, Receiver<T>) {
    let inner = Arc::new(ChannelInner::new(None));
    (
        Sender { inner: inner.clone() },
        Receiver { inner },
    )
}

/// Create a bounded channel with given capacity
pub fn sync_channel<T>(bound: usize) -> (SyncSender<T>, Receiver<T>) {
    let inner = Arc::new(ChannelInner::new(Some(bound)));
    (
        SyncSender { inner: inner.clone() },
        Receiver { inner },
    )
}

struct ChannelInner<T> {
    /// Message queue
    queue: Mutex<VecDeque<T>>,
    /// Capacity (None for unbounded)
    capacity: Option<usize>,
    /// Number of senders
    senders: AtomicUsize,
    /// Number of receivers  
    receivers: AtomicUsize,
    /// Condvar for receivers waiting for messages
    not_empty: Condvar,
    /// Condvar for senders waiting for space
    not_full: Condvar,
}

impl<T> ChannelInner<T> {
    fn new(capacity: Option<usize>) -> Self {
        Self {
            queue: Mutex::new(VecDeque::new()),
            capacity,
            senders: AtomicUsize::new(1),
            receivers: AtomicUsize::new(1),
            not_empty: Condvar::new(),
            not_full: Condvar::new(),
        }
    }
    
    fn is_disconnected(&self) -> bool {
        self.senders.load(Ordering::Relaxed) == 0 ||
        self.receivers.load(Ordering::Relaxed) == 0
    }
}

/// Sending half of a channel
pub struct Sender<T> {
    inner: Arc<ChannelInner<T>>,
}

impl<T> Sender<T> {
    pub fn send(&self, value: T) -> Result<(), SendError<T>> {
        if self.inner.receivers.load(Ordering::Relaxed) == 0 {
            return Err(SendError(value));
        }
        
        let mut queue = self.inner.queue.lock().unwrap_or_else(|e| e.into_inner());
        queue.push_back(value);
        drop(queue);
        
        self.inner.not_empty.notify_one();
        Ok(())
    }
}

impl<T> Clone for Sender<T> {
    fn clone(&self) -> Self {
        self.inner.senders.fetch_add(1, Ordering::Relaxed);
        Self { inner: self.inner.clone() }
    }
}

impl<T> Drop for Sender<T> {
    fn drop(&mut self) {
        if self.inner.senders.fetch_sub(1, Ordering::AcqRel) == 1 {
            // Last sender dropped, wake all receivers
            self.inner.not_empty.notify_all();
        }
    }
}

/// Synchronous sending half with backpressure
pub struct SyncSender<T> {
    inner: Arc<ChannelInner<T>>,
}

impl<T> SyncSender<T> {
    pub fn send(&self, value: T) -> Result<(), SendError<T>> {
        let mut value = Some(value);
        
        loop {
            if self.inner.receivers.load(Ordering::Relaxed) == 0 {
                return Err(SendError(value.take().unwrap()));
            }
            
            let mut queue = self.inner.queue.lock().unwrap_or_else(|e| e.into_inner());
            
            if let Some(cap) = self.inner.capacity {
                if queue.len() >= cap {
                    // Wait for space
                    queue = self.inner.not_full.wait(queue).unwrap_or_else(|e| e.into_inner());
                    continue;
                }
            }
            
            queue.push_back(value.take().unwrap());
            drop(queue);
            
            self.inner.not_empty.notify_one();
            return Ok(());
        }
    }
    
    pub fn try_send(&self, value: T) -> Result<(), TrySendError<T>> {
        if self.inner.receivers.load(Ordering::Relaxed) == 0 {
            return Err(TrySendError::Disconnected(value));
        }
        
        let mut queue = self.inner.queue.lock().unwrap_or_else(|e| e.into_inner());
        
        if let Some(cap) = self.inner.capacity {
            if queue.len() >= cap {
                return Err(TrySendError::Full(value));
            }
        }
        
        queue.push_back(value);
        drop(queue);
        
        self.inner.not_empty.notify_one();
        Ok(())
    }
}

impl<T> Clone for SyncSender<T> {
    fn clone(&self) -> Self {
        self.inner.senders.fetch_add(1, Ordering::Relaxed);
        Self { inner: self.inner.clone() }
    }
}

impl<T> Drop for SyncSender<T> {
    fn drop(&mut self) {
        if self.inner.senders.fetch_sub(1, Ordering::AcqRel) == 1 {
            self.inner.not_empty.notify_all();
        }
    }
}

/// Receiving half of a channel
pub struct Receiver<T> {
    inner: Arc<ChannelInner<T>>,
}

impl<T> Receiver<T> {
    pub fn recv(&self) -> Result<T, RecvError> {
        loop {
            let mut queue = self.inner.queue.lock().unwrap_or_else(|e| e.into_inner());
            
            if let Some(value) = queue.pop_front() {
                let had_capacity = self.inner.capacity.is_some();
                drop(queue);
                
                if had_capacity {
                    self.inner.not_full.notify_one();
                }
                return Ok(value);
            }
            
            // Check if all senders are gone
            if self.inner.senders.load(Ordering::Relaxed) == 0 {
                return Err(RecvError);
            }
            
            // Wait for message
            queue = self.inner.not_empty.wait(queue).unwrap_or_else(|e| e.into_inner());
        }
    }
    
    pub fn try_recv(&self) -> Result<T, TryRecvError> {
        let mut queue = self.inner.queue.lock().unwrap_or_else(|e| e.into_inner());
        
        if let Some(value) = queue.pop_front() {
            let had_capacity = self.inner.capacity.is_some();
            drop(queue);
            
            if had_capacity {
                self.inner.not_full.notify_one();
            }
            return Ok(value);
        }
        
        if self.inner.senders.load(Ordering::Relaxed) == 0 {
            Err(TryRecvError::Disconnected)
        } else {
            Err(TryRecvError::Empty)
        }
    }
    
    pub fn recv_timeout(&self, timeout: Duration) -> Result<T, RecvTimeoutError> {
        let deadline = Instant::now() + timeout;
        
        loop {
            let mut queue = self.inner.queue.lock().unwrap_or_else(|e| e.into_inner());
            
            if let Some(value) = queue.pop_front() {
                let had_capacity = self.inner.capacity.is_some();
                drop(queue);
                
                if had_capacity {
                    self.inner.not_full.notify_one();
                }
                return Ok(value);
            }
            
            if self.inner.senders.load(Ordering::Relaxed) == 0 {
                return Err(RecvTimeoutError::Disconnected);
            }
            
            let remaining = deadline.saturating_duration_since(Instant::now());
            if remaining.is_zero() {
                return Err(RecvTimeoutError::Timeout);
            }
            
            let (new_queue, _) = self.inner.not_empty
                .wait_timeout(queue, remaining)
                .unwrap_or_else(|e| e.into_inner());
            queue = new_queue;
        }
    }
    
    /// Create an iterator that receives values until disconnected
    pub fn iter(&self) -> Iter<'_, T> {
        Iter { rx: self }
    }
    
    /// Create an iterator that tries to receive without blocking
    pub fn try_iter(&self) -> TryIter<'_, T> {
        TryIter { rx: self }
    }
}

impl<T> Drop for Receiver<T> {
    fn drop(&mut self) {
        if self.inner.receivers.fetch_sub(1, Ordering::AcqRel) == 1 {
            // Last receiver dropped, wake all senders
            self.inner.not_full.notify_all();
        }
    }
}

pub enum RecvTimeoutError {
    Timeout,
    Disconnected,
}

/// Blocking iterator over channel
pub struct Iter<'a, T> {
    rx: &'a Receiver<T>,
}

impl<T> Iterator for Iter<'_, T> {
    type Item = T;
    
    fn next(&mut self) -> Option<T> {
        self.rx.recv().ok()
    }
}

/// Non-blocking iterator over channel
pub struct TryIter<'a, T> {
    rx: &'a Receiver<T>,
}

impl<T> Iterator for TryIter<'_, T> {
    type Item = T;
    
    fn next(&mut self) -> Option<T> {
        self.rx.try_recv().ok()
    }
}

// ============================================================================
// Arc - Atomically Reference Counted pointer
// ============================================================================

struct ArcInner<T> {
    strong: AtomicUsize,
    weak: AtomicUsize,
    data: T,
}

/// Thread-safe reference counting pointer
pub struct Arc<T> {
    ptr: NonNull<ArcInner<T>>,
}

unsafe impl<T: Send + Sync> Send for Arc<T> {}
unsafe impl<T: Send + Sync> Sync for Arc<T> {}

impl<T> Arc<T> {
    pub fn new(value: T) -> Self {
        let inner = Box::new(ArcInner {
            strong: AtomicUsize::new(1),
            weak: AtomicUsize::new(1), // One weak ref to prevent dealloc while strong > 0
            data: value,
        });
        
        Self {
            ptr: NonNull::from(Box::leak(inner)),
        }
    }
    
    fn inner(&self) -> &ArcInner<T> {
        unsafe { self.ptr.as_ref() }
    }
    
    /// Get the strong reference count
    pub fn strong_count(this: &Self) -> usize {
        this.inner().strong.load(Ordering::Relaxed)
    }
    
    /// Get the weak reference count
    pub fn weak_count(this: &Self) -> usize {
        this.inner().weak.load(Ordering::Relaxed) - 1
    }
    
    /// Create a weak reference
    pub fn downgrade(this: &Self) -> Weak<T> {
        this.inner().weak.fetch_add(1, Ordering::Relaxed);
        Weak { ptr: this.ptr }
    }
    
    /// Get mutable reference if this is the only strong reference
    pub fn get_mut(this: &mut Self) -> Option<&mut T> {
        if Arc::strong_count(this) == 1 {
            fence(Ordering::Acquire);
            Some(unsafe { &mut (*this.ptr.as_ptr()).data })
        } else {
            None
        }
    }
    
    /// Try to unwrap the Arc if this is the only reference
    pub fn try_unwrap(this: Self) -> Result<T, Self> {
        if this.inner().strong.compare_exchange(
            1,
            0,
            Ordering::Release,
            Ordering::Relaxed,
        ).is_ok() {
            fence(Ordering::Acquire);
            
            let data = unsafe { std::ptr::read(&(*this.ptr.as_ptr()).data) };
            
            // Drop weak count
            if this.inner().weak.fetch_sub(1, Ordering::Release) == 1 {
                fence(Ordering::Acquire);
                unsafe { drop(Box::from_raw(this.ptr.as_ptr())); }
            }
            
            std::mem::forget(this);
            Ok(data)
        } else {
            Err(this)
        }
    }
    
    /// Make a mutable reference, cloning if necessary
    pub fn make_mut(this: &mut Self) -> &mut T
    where
        T: Clone,
    {
        if Arc::strong_count(this) != 1 {
            // Clone the data
            *this = Arc::new((**this).clone());
        }
        
        fence(Ordering::Acquire);
        unsafe { &mut (*this.ptr.as_ptr()).data }
    }
}

impl<T> Clone for Arc<T> {
    fn clone(&self) -> Self {
        let old_count = self.inner().strong.fetch_add(1, Ordering::Relaxed);
        
        if old_count > isize::MAX as usize {
            panic!("Arc strong count overflow");
        }
        
        Self { ptr: self.ptr }
    }
}

impl<T> Deref for Arc<T> {
    type Target = T;
    
    fn deref(&self) -> &T {
        &self.inner().data
    }
}

impl<T> Drop for Arc<T> {
    fn drop(&mut self) {
        if self.inner().strong.fetch_sub(1, Ordering::Release) != 1 {
            return;
        }
        
        fence(Ordering::Acquire);
        
        // Drop the data
        unsafe { std::ptr::drop_in_place(&mut (*self.ptr.as_ptr()).data); }
        
        // Drop weak count
        if self.inner().weak.fetch_sub(1, Ordering::Release) == 1 {
            fence(Ordering::Acquire);
            unsafe { drop(Box::from_raw(self.ptr.as_ptr())); }
        }
    }
}

impl<T: Default> Default for Arc<T> {
    fn default() -> Self {
        Arc::new(T::default())
    }
}

impl<T: PartialEq> PartialEq for Arc<T> {
    fn eq(&self, other: &Self) -> bool {
        **self == **other
    }
}

impl<T: Eq> Eq for Arc<T> {}

impl<T: Hash> Hash for Arc<T> {
    fn hash<H: Hasher>(&self, state: &mut H) {
        (**self).hash(state);
    }
}

impl<T: Debug> Debug for Arc<T> {
    fn fmt(&self, f: &mut Formatter<'_>) -> fmt::Result {
        Debug::fmt(&**self, f)
    }
}

/// Weak reference to an Arc
pub struct Weak<T> {
    ptr: NonNull<ArcInner<T>>,
}

unsafe impl<T: Send + Sync> Send for Weak<T> {}
unsafe impl<T: Send + Sync> Sync for Weak<T> {}

impl<T> Weak<T> {
    /// Create a new weak pointer that doesn't point to anything
    pub fn new() -> Self {
        Self {
            ptr: NonNull::dangling(),
        }
    }
    
    /// Try to upgrade to a strong reference
    pub fn upgrade(&self) -> Option<Arc<T>> {
        let inner = unsafe { self.ptr.as_ref() };
        
        loop {
            let count = inner.strong.load(Ordering::Relaxed);
            
            if count == 0 {
                return None;
            }
            
            if inner.strong.compare_exchange_weak(
                count,
                count + 1,
                Ordering::Acquire,
                Ordering::Relaxed,
            ).is_ok() {
                return Some(Arc { ptr: self.ptr });
            }
        }
    }
    
    pub fn strong_count(&self) -> usize {
        unsafe { self.ptr.as_ref() }.strong.load(Ordering::Relaxed)
    }
    
    pub fn weak_count(&self) -> usize {
        unsafe { self.ptr.as_ref() }.weak.load(Ordering::Relaxed)
    }
}

impl<T> Clone for Weak<T> {
    fn clone(&self) -> Self {
        unsafe { self.ptr.as_ref() }.weak.fetch_add(1, Ordering::Relaxed);
        Self { ptr: self.ptr }
    }
}

impl<T> Drop for Weak<T> {
    fn drop(&mut self) {
        let inner = unsafe { self.ptr.as_ref() };
        
        if inner.weak.fetch_sub(1, Ordering::Release) == 1 {
            fence(Ordering::Acquire);
            unsafe { drop(Box::from_raw(self.ptr.as_ptr())); }
        }
    }
}

// ============================================================================
// Scoped Threads
// ============================================================================

/// Spawn a scoped thread that borrows from the enclosing scope
pub fn scope<'env, F, T>(f: F) -> T
where
    F: for<'scope> FnOnce(&'scope Scope<'scope, 'env>) -> T,
{
    let scope = Scope {
        handles: Mutex::new(Vec::new()),
        _marker: PhantomData,
    };
    
    let result = f(&scope);
    
    // Join all threads
    let handles = scope.handles.into_inner().unwrap_or_else(|e| e.into_inner());
    for handle in handles {
        let _ = handle.join();
    }
    
    result
}

pub struct Scope<'scope, 'env: 'scope> {
    handles: Mutex<Vec<JoinHandle<()>>>,
    _marker: PhantomData<&'scope &'env ()>,
}

impl<'scope, 'env> Scope<'scope, 'env> {
    pub fn spawn<F, T>(&'scope self, f: F) -> ScopedJoinHandle<'scope, T>
    where
        F: FnOnce() -> T + Send + 'scope,
        T: Send + 'scope,
    {
        let result = Arc::new(Mutex::new(None));
        let result_clone = result.clone();
        
        let handle = std::thread::spawn(move || {
            let value = f();
            *result_clone.lock().unwrap_or_else(|e| e.into_inner()) = Some(value);
        });
        
        self.handles.lock().unwrap_or_else(|e| e.into_inner()).push(handle);
        
        ScopedJoinHandle {
            result,
            _marker: PhantomData,
        }
    }
}

pub struct ScopedJoinHandle<'scope, T> {
    result: Arc<Mutex<Option<T>>>,
    _marker: PhantomData<&'scope ()>,
}

impl<T> ScopedJoinHandle<'_, T> {
    pub fn join(self) -> T {
        loop {
            let mut guard = self.result.lock().unwrap_or_else(|e| e.into_inner());
            if let Some(value) = guard.take() {
                return value;
            }
            drop(guard);
            std::thread::yield_now();
        }
    }
}

// ============================================================================
// Thread-local storage
// ============================================================================

/// Thread-local storage key
pub struct LocalKey<T: 'static> {
    init: fn() -> T,
    // Platform-specific TLS implementation
}

impl<T: 'static> LocalKey<T> {
    pub const fn new(init: fn() -> T) -> Self {
        Self { init }
    }
    
    pub fn with<F, R>(&'static self, f: F) -> R
    where
        F: FnOnce(&T) -> R,
    {
        // Platform-specific TLS access
        unsafe {
            let ptr = __tls_get(self as *const _ as usize);
            if ptr.is_null() {
                let value = (self.init)();
                let boxed = Box::new(value);
                let ptr = Box::into_raw(boxed);
                __tls_set(self as *const _ as usize, ptr as *mut u8);
                f(&*ptr)
            } else {
                f(&*(ptr as *const T))
            }
        }
    }
}

/// Macro for declaring thread-local variables
#[macro_export]
macro_rules! thread_local {
    ($(static $name:ident: $t:ty = $init:expr;)*) => {
        $(
            static $name: $crate::sync::LocalKey<$t> = $crate::sync::LocalKey::new(|| $init);
        )*
    };
}

// ============================================================================
// External declarations (platform-specific)
// ============================================================================

extern "C" {
    fn __atomic_load<T>(ptr: *const T, order: Ordering) -> T;
    fn __atomic_store<T>(ptr: *const T, value: T, order: Ordering);
    fn __atomic_swap<T>(ptr: *const T, value: T, order: Ordering) -> T;
    fn __atomic_cmpxchg<T>(ptr: *const T, current: T, new: T, success: Ordering, failure: Ordering) -> (bool, T);
    fn __atomic_cmpxchg_weak<T>(ptr: *const T, current: T, new: T, success: Ordering, failure: Ordering) -> (bool, T);
    fn __atomic_fetch_add<T>(ptr: *const T, value: T, order: Ordering) -> T;
    fn __atomic_fetch_sub<T>(ptr: *const T, value: T, order: Ordering) -> T;
    fn __atomic_fetch_and<T>(ptr: *const T, value: T, order: Ordering) -> T;
    fn __atomic_fetch_or<T>(ptr: *const T, value: T, order: Ordering) -> T;
    fn __atomic_fetch_xor<T>(ptr: *const T, value: T, order: Ordering) -> T;
    fn __atomic_fetch_max<T>(ptr: *const T, value: T, order: Ordering) -> T;
    fn __atomic_fetch_min<T>(ptr: *const T, value: T, order: Ordering) -> T;
    fn __atomic_fence(order: Ordering);
    fn __compiler_fence(order: Ordering);
    fn __spin_loop_hint();
    fn __futex_wait(addr: *const u32, expected: u32) -> i32;
    fn __futex_wait_timeout(addr: *const u32, expected: u32, timeout_ns: u64) -> bool;
    fn __futex_wake(addr: *const u32, count: u32) -> i32;
    fn __thread_yield();
    fn __tls_get(key: usize) -> *mut u8;
    fn __tls_set(key: usize, value: *mut u8);
}

// ============================================================================
// Tests
// ============================================================================

#[cfg(test)]
mod tests {
    use super::*;
    
    #[test]
    fn test_atomic_bool() {
        let b = AtomicBool::new(false);
        assert_eq!(b.load(Ordering::Relaxed), false);
        b.store(true, Ordering::Relaxed);
        assert_eq!(b.load(Ordering::Relaxed), true);
        assert_eq!(b.swap(false, Ordering::Relaxed), true);
        assert_eq!(b.load(Ordering::Relaxed), false);
    }
    
    #[test]
    fn test_atomic_usize() {
        let u = AtomicUsize::new(0);
        assert_eq!(u.fetch_add(5, Ordering::Relaxed), 0);
        assert_eq!(u.load(Ordering::Relaxed), 5);
        assert_eq!(u.fetch_sub(2, Ordering::Relaxed), 5);
        assert_eq!(u.load(Ordering::Relaxed), 3);
    }
    
    #[test]
    fn test_mutex_basic() {
        let m = Mutex::new(0);
        {
            let mut guard = m.lock().unwrap();
            *guard = 42;
        }
        assert_eq!(*m.lock().unwrap(), 42);
    }
    
    #[test]
    fn test_rwlock_basic() {
        let lock = RwLock::new(0);
        
        // Multiple readers
        {
            let r1 = lock.read().unwrap();
            let r2 = lock.read().unwrap();
            assert_eq!(*r1, 0);
            assert_eq!(*r2, 0);
        }
        
        // Single writer
        {
            let mut w = lock.write().unwrap();
            *w = 42;
        }
        
        assert_eq!(*lock.read().unwrap(), 42);
    }
    
    #[test]
    fn test_channel_basic() {
        let (tx, rx) = channel();
        tx.send(42).unwrap();
        assert_eq!(rx.recv().unwrap(), 42);
    }
    
    #[test]
    fn test_sync_channel() {
        let (tx, rx) = sync_channel(2);
        tx.send(1).unwrap();
        tx.send(2).unwrap();
        assert_eq!(rx.recv().unwrap(), 1);
        assert_eq!(rx.recv().unwrap(), 2);
    }
    
    #[test]
    fn test_arc_basic() {
        let a = Arc::new(42);
        let b = a.clone();
        assert_eq!(*a, 42);
        assert_eq!(*b, 42);
        assert_eq!(Arc::strong_count(&a), 2);
    }
    
    #[test]
    fn test_arc_weak() {
        let a = Arc::new(42);
        let w = Arc::downgrade(&a);
        assert_eq!(*w.upgrade().unwrap(), 42);
        drop(a);
        assert!(w.upgrade().is_none());
    }
    
    #[test]
    fn test_once() {
        static ONCE: Once = Once::new();
        static mut VALUE: usize = 0;
        
        ONCE.call_once(|| unsafe { VALUE = 42; });
        ONCE.call_once(|| unsafe { VALUE = 100; }); // Should not run
        
        assert_eq!(unsafe { VALUE }, 42);
    }
    
    #[test]
    fn test_barrier() {
        let barrier = Arc::new(Barrier::new(2));
        let b2 = barrier.clone();
        
        let handle = std::thread::spawn(move || {
            b2.wait();
            42
        });
        
        barrier.wait();
        assert_eq!(handle.join().unwrap(), 42);
    }
}
