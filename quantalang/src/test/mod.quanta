// ═══════════════════════════════════════════════════════════════════════════════
// TESTS
// ═══════════════════════════════════════════════════════════════════════════════

#[cfg(test)]
mod tests {
    use super::*;
    
    #[test]
    fn test_builder() {
        let builder = TestBuilder::new()
            .filter("test_foo")
            .threads(4)
            .verbose(true);
        
        assert_eq!(builder.config().filter, Some("test_foo".to_string()));
        assert_eq!(builder.config().test_threads, 4);
        assert!(builder.config().verbose);
    }
    
    #[test]
    fn test_config_defaults() {
        let config = TestConfig::default();
        assert_eq!(config.test_threads, 0);
        assert!(!config.no_fail_fast);
    }
}
