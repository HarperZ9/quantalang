//
// The QuantaLang Test Runner (quantatest) provides integrated test execution
// for QuantaLang projects.
//
// Features:
// - Automatic test discovery (#[test] attribute)
// - Parallel test execution
// - Output capture and reporting
// - Multiple output formats (pretty, JSON, JUnit)
// - Test filtering and skip patterns
// - Timeout support
// - Doc test execution
// - Benchmark support
//
// ═══════════════════════════════════════════════════════════════════════════════

//! # QuantaLang Test Runner
//!
//! Integrated test framework for QuantaLang.
//!
//! ## Quick Start
//!
//! ```bash
//! # Run all tests
//! quantatest
//!
//! # Run specific test
//! quantatest test_foo
//!
//! # Run ignored tests
//! quantatest --ignored
//!
//! # Show verbose output
//! quantatest -v
//!
//! # Generate JUnit report
//! quantatest --report results.xml --report-format junit
//! ```
//!
//! ## Writing Tests
//!
//! ```quanta
//! #[test]
//! fn test_simple() {
//!     assert!(true);
//! }
//!
//! #[test]
//! #[ignore = "not ready"]
//! fn test_ignored() {
//!     todo!()
//! }
//!
//! #[test]
//! #[should_panic(expected = "oops")]
//! fn test_panic() {
//!     panic!("oops");
//! }
//!
//! #[test]
//! #[timeout(5s)]
//! fn test_with_timeout() {
//!     // Must complete within 5 seconds
//! }
//! ```
//!
//! ## Modules
//!
//! - [`config`] - Test configuration and types
//! - [`discovery`] - Test discovery from source files
//! - [`executor`] - Test execution engine
//! - [`reporter`] - Output formatters
//! - [`cli`] - Command-line interface

module quantalang::test

