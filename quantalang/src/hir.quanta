    pub span: Span,
}

#[derive(Debug)]
pub struct HirStateDef {
    pub def_id: DefId,
    pub name: String,
    pub data: Vec<HirFieldDef>,
    pub span: Span,
}

#[derive(Debug)]
pub struct HirTransition {
    pub from_state: DefId,
    pub to_state: DefId,
    pub trigger: String,
    pub span: Span,
}

#[derive(Debug)]
pub struct HirEffectDef {
    pub def_id: DefId,
    pub name: String,
    pub operations: Vec<HirEffectOp>,
    pub span: Span,
}

#[derive(Debug)]
pub struct HirEffectOp {
    pub name: String,
    pub sig: HirFnSig,
    pub span: Span,
}

// ═══════════════════════════════════════════════════════════════════════════════
// TRAITS AND IMPLS
// ═══════════════════════════════════════════════════════════════════════════════

#[derive(Debug)]
pub struct HirTraitDef {
    pub def_id: DefId,
    pub name: String,
    pub generics: HirGenerics,
    pub supertraits: Vec<HirTraitRef>,
    pub items: Vec<HirTraitItem>,
    pub is_auto: bool,
    pub is_unsafe: bool,
    pub span: Span,
}

#[derive(Debug)]
pub struct HirTraitItem {
    pub def_id: DefId,
    pub name: String,
    pub kind: HirTraitItemKind,
    pub span: Span,
}

#[derive(Debug)]
pub enum HirTraitItemKind {
    Const { ty: Ty, default: Option<BodyId> },
    Type { bounds: Vec<HirTraitBound>, default: Option<Ty> },
    Fn { sig: HirFnSig, default: Option<BodyId> },
}

#[derive(Debug)]
pub struct HirImplDef {
    pub def_id: DefId,
    pub generics: HirGenerics,
    pub trait_ref: Option<HirTraitRef>,
    pub self_ty: Ty,
    pub items: Vec<HirImplItem>,
    pub is_unsafe: bool,
    pub is_negative: bool,
    pub span: Span,
}

#[derive(Debug)]
pub struct HirImplItem {
    pub def_id: DefId,
    pub name: String,
    pub kind: HirImplItemKind,
    pub vis: HirVisibility,
    pub span: Span,
}

#[derive(Debug)]
pub enum HirImplItemKind {
    Const { ty: Ty, body: BodyId },
    Type { ty: Ty },
    Fn { sig: HirFnSig, body: BodyId },
}

