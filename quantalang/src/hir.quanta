// ═══════════════════════════════════════════════════════════════════════════════
//
// HIR is the first IR after parsing. It performs:
// 1. Name resolution (all identifiers resolved to definitions)
// 2. Desugaring (for loops → loop + iterators, ? → match, etc.)
// 3. Type annotation propagation
// 4. Lifetime elision resolution
// 5. Method resolution (UFCS normalization)
//
// HIR preserves high-level structure for:
// - Type inference
// - Trait resolution
// - Macro hygiene verification
//
// ═══════════════════════════════════════════════════════════════════════════════

module quantalang::hir

use std::collections::HashMap
use crate::ast::{Span, Mutability, BinaryOp, UnaryOp}
use crate::types::{Ty, TypeVar, AdtId, TraitId, Lifetime, EffectSet, FnSig, IntTy, FloatTy}

// ═══════════════════════════════════════════════════════════════════════════════
// DEFINITION IDS (Unique identifiers for all definitions)
// ═══════════════════════════════════════════════════════════════════════════════

/// Unique ID for any definition in the program
#[derive(Debug, Clone, Copy, PartialEq, Eq, Hash)]
pub struct DefId {
    pub crate_id: u32,
    pub local_id: u32,
}

impl DefId {
    pub fn new(crate_id: u32, local_id: u32) -> Self {
        DefId { crate_id, local_id }
    }
    
    pub fn local(id: u32) -> Self {
        DefId { crate_id: 0, local_id: id }
    }
}

/// Local variable ID (unique within a function body)
#[derive(Debug, Clone, Copy, PartialEq, Eq, Hash)]
pub struct LocalId(pub u32);

/// Body ID (unique identifier for a function/closure body)
#[derive(Debug, Clone, Copy, PartialEq, Eq, Hash)]
pub struct BodyId(pub DefId);

// ═══════════════════════════════════════════════════════════════════════════════
// HIR CRATE (Top-level compilation unit)
// ═══════════════════════════════════════════════════════════════════════════════

#[derive(Debug)]
pub struct HirCrate {
    pub name: String,
    pub items: HashMap<DefId, HirItem>,
    pub bodies: HashMap<BodyId, HirBody>,
    pub trait_impls: Vec<HirImplDef>,
    pub exported_items: Vec<DefId>,
}

// ═══════════════════════════════════════════════════════════════════════════════
// HIR ITEMS (Top-level definitions)
// ═══════════════════════════════════════════════════════════════════════════════

#[derive(Debug)]
pub struct HirItem {
    pub def_id: DefId,
    pub name: String,
    pub kind: HirItemKind,
    pub vis: HirVisibility,
    pub span: Span,
}

#[derive(Debug)]
pub enum HirItemKind {
    Function(HirFnDef),
    Struct(HirStructDef),
    Enum(HirEnumDef),
    Union(HirUnionDef),
    Trait(HirTraitDef),
    TypeAlias(HirTypeAlias),
    Const(HirConstDef),
    Static(HirStaticDef),
    Mod(HirModDef),
    
    // QuantaLang extensions
    Bitfield(HirBitfieldDef),
    StateMachine(HirStateMachineDef),
    Effect(HirEffectDef),
}

#[derive(Debug, Clone, Copy, PartialEq, Eq)]
pub enum HirVisibility {
    Public,
    Crate,
    Restricted(DefId),  // pub(in path)
    Private,
}

// ═══════════════════════════════════════════════════════════════════════════════
// FUNCTION DEFINITIONS
// ═══════════════════════════════════════════════════════════════════════════════

#[derive(Debug)]
pub struct HirFnDef {
    pub def_id: DefId,
    pub name: String,
    pub generics: HirGenerics,
    pub sig: HirFnSig,
    pub body_id: Option<BodyId>,
    pub qualifiers: HirFnQualifiers,
    pub span: Span,
}

#[derive(Debug)]
pub struct HirFnSig {
    pub inputs: Vec<(LocalId, Ty)>,
    pub output: Ty,
    pub c_variadic: bool,
    pub effects: EffectSet,
}

#[derive(Debug, Default)]
pub struct HirFnQualifiers {
    pub is_async: bool,
    pub is_unsafe: bool,
    pub is_const: bool,
    pub is_extern: bool,
    pub abi: HirAbi,
    // QuantaLang extensions
    pub is_kernel: bool,
    pub is_pure: bool,
}

#[derive(Debug, Clone, Copy, PartialEq, Eq, Default)]
pub enum HirAbi {
    #[default]
    Quanta,
    C,
    System,
    Stdcall,
    Fastcall,
    Vectorcall,
    SysV64,
    Win64,
}

// ═══════════════════════════════════════════════════════════════════════════════
// GENERICS
// ═══════════════════════════════════════════════════════════════════════════════

#[derive(Debug, Default)]
pub struct HirGenerics {
    pub params: Vec<HirGenericParam>,
    pub where_clause: Vec<HirWherePredicate>,
    pub span: Span,
}

#[derive(Debug)]
pub struct HirGenericParam {
    pub def_id: DefId,
    pub name: String,
    pub kind: HirGenericParamKind,
    pub span: Span,
}

#[derive(Debug)]
pub enum HirGenericParamKind {
    Lifetime { bounds: Vec<Lifetime> },
    Type { default: Option<Ty>, bounds: Vec<HirTraitBound> },
    Const { ty: Ty, default: Option<HirConstArg> },
}

#[derive(Debug)]
pub struct HirTraitBound {
    pub trait_ref: HirTraitRef,
    pub modifier: HirBoundModifier,
    pub span: Span,
}

#[derive(Debug, Clone, Copy, PartialEq, Eq)]
pub enum HirBoundModifier {
    None,
    Maybe,    // ?Trait
    Negative, // !Trait
}

#[derive(Debug)]
pub struct HirTraitRef {
    pub trait_def: DefId,
    pub generic_args: Vec<HirGenericArg>,
    pub span: Span,
}

#[derive(Debug)]
pub enum HirGenericArg {
    Lifetime(Lifetime),
    Type(Ty),
    Const(HirConstArg),
}

#[derive(Debug)]
pub struct HirConstArg {
    pub value: HirConstValue,
    pub ty: Ty,
    pub span: Span,
}

#[derive(Debug)]
pub enum HirConstValue {
    Scalar(u128),
    Bool(bool),
    Char(char),
    // ... other const values
}

#[derive(Debug)]
pub struct HirWherePredicate {
    pub kind: HirWherePredicateKind,
    pub span: Span,
}

#[derive(Debug)]
pub enum HirWherePredicateKind {
    BoundPredicate { ty: Ty, bounds: Vec<HirTraitBound> },
    RegionPredicate { lifetime: Lifetime, bounds: Vec<Lifetime> },
    EqPredicate { lhs: Ty, rhs: Ty },
}

// ═══════════════════════════════════════════════════════════════════════════════
// TYPE DEFINITIONS
// ═══════════════════════════════════════════════════════════════════════════════

#[derive(Debug)]
pub struct HirStructDef {
    pub def_id: DefId,
    pub name: String,
    pub generics: HirGenerics,
    pub kind: HirStructKind,
    pub is_linear: bool,
    pub span: Span,
}

#[derive(Debug)]
pub enum HirStructKind {
    Struct(Vec<HirFieldDef>),
    Tuple(Vec<HirFieldDef>),
    Unit,
}

#[derive(Debug)]
pub struct HirFieldDef {
    pub def_id: DefId,
    pub name: String,
    pub ty: Ty,
    pub vis: HirVisibility,
    pub is_volatile: bool,
    pub volatile_access: Option<crate::types::VolatileAccess>,
    pub offset: Option<u64>,  // For @offset attribute
    pub span: Span,
}

#[derive(Debug)]
pub struct HirEnumDef {
    pub def_id: DefId,
    pub name: String,
    pub generics: HirGenerics,
    pub variants: Vec<HirVariantDef>,
    pub repr: Option<HirRepr>,
    pub span: Span,
}

#[derive(Debug)]
pub struct HirVariantDef {
    pub def_id: DefId,
    pub name: String,
    pub fields: Vec<HirFieldDef>,
    pub discriminant: Option<i128>,
    pub span: Span,
}

#[derive(Debug)]
pub struct HirUnionDef {
    pub def_id: DefId,
    pub name: String,
    pub generics: HirGenerics,
    pub fields: Vec<HirFieldDef>,
    pub span: Span,
}

#[derive(Debug)]
pub enum HirRepr {
    C,
    Transparent,
    Int(IntTy),
    Align(u64),
    Packed,
}

