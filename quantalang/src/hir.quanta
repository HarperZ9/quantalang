// ═══════════════════════════════════════════════════════════════════════════════
// HIR BODY (Function/closure bodies)
// ═══════════════════════════════════════════════════════════════════════════════

#[derive(Debug)]
pub struct HirBody {
    pub id: BodyId,
    pub params: Vec<HirParam>,
    pub locals: Vec<HirLocal>,
    pub expr: HirExpr,
    pub generator_kind: Option<HirGeneratorKind>,
}

#[derive(Debug)]
pub struct HirParam {
    pub local_id: LocalId,
    pub pat: HirPat,
    pub ty: Ty,
    pub span: Span,
}

#[derive(Debug)]
pub struct HirLocal {
    pub id: LocalId,
    pub name: String,
    pub ty: Ty,
    pub mutability: Mutability,
    pub init: Option<Box<HirExpr>>,
    pub span: Span,
}

#[derive(Debug, Clone, Copy, PartialEq, Eq)]
pub enum HirGeneratorKind {
    Gen,    // Generator (yield)
    Async,  // Async block/fn
}

// ═══════════════════════════════════════════════════════════════════════════════
// HIR EXPRESSIONS (Desugared, resolved)
// ═══════════════════════════════════════════════════════════════════════════════

#[derive(Debug)]
pub struct HirExpr {
    pub id: HirExprId,
    pub kind: HirExprKind,
    pub ty: Ty,
    pub span: Span,
}

#[derive(Debug, Clone, Copy, PartialEq, Eq, Hash)]
pub struct HirExprId(pub u32);

#[derive(Debug)]
pub enum HirExprKind {
    // ─────────────────────────────────────────────────────────────────────────
    // Literals
    // ─────────────────────────────────────────────────────────────────────────
    Literal(HirLiteral),
    
    // ─────────────────────────────────────────────────────────────────────────
    // Paths (fully resolved)
    // ─────────────────────────────────────────────────────────────────────────
    Path(HirPath),
    
    // ─────────────────────────────────────────────────────────────────────────
    // Operations
    // ─────────────────────────────────────────────────────────────────────────
    Unary(UnaryOp, Box<HirExpr>),
    Binary(BinaryOp, Box<HirExpr>, Box<HirExpr>),
    
    // ─────────────────────────────────────────────────────────────────────────
    // Compound literals
    // ─────────────────────────────────────────────────────────────────────────
    Tuple(Vec<HirExpr>),
    Array(Vec<HirExpr>),
    Repeat(Box<HirExpr>, HirConstArg),  // [expr; N]
    Struct {
        path: HirPath,
        fields: Vec<HirFieldExpr>,
        base: Option<Box<HirExpr>>,
    },
    
    // ─────────────────────────────────────────────────────────────────────────
    // Access
    // ─────────────────────────────────────────────────────────────────────────
    Field(Box<HirExpr>, String),
    TupleField(Box<HirExpr>, u32),
    Index(Box<HirExpr>, Box<HirExpr>),
    
    // ─────────────────────────────────────────────────────────────────────────
    // Calls (UFCS normalized: all method calls become function calls)
    // ─────────────────────────────────────────────────────────────────────────
    Call {
        func: Box<HirExpr>,
        args: Vec<HirExpr>,
    },
    MethodCall {
        receiver: Box<HirExpr>,
        method: DefId,
        generic_args: Vec<HirGenericArg>,
        args: Vec<HirExpr>,
    },
    
    // ─────────────────────────────────────────────────────────────────────────
    // Control flow (desugared)
    // ─────────────────────────────────────────────────────────────────────────
    If {
        condition: Box<HirExpr>,
        then_branch: Box<HirExpr>,
        else_branch: Option<Box<HirExpr>>,
    },
    Match {
        scrutinee: Box<HirExpr>,
        arms: Vec<HirMatchArm>,
    },
    Loop {
        body: Box<HirExpr>,
        label: Option<String>,
    },
    // Note: for, while desugared to Loop + Match
    
    // ─────────────────────────────────────────────────────────────────────────
    // Jumps
    // ─────────────────────────────────────────────────────────────────────────
    Break { label: Option<String>, value: Option<Box<HirExpr>> },
    Continue { label: Option<String> },
    Return(Option<Box<HirExpr>>),
    
    // ─────────────────────────────────────────────────────────────────────────
    // Blocks
    // ─────────────────────────────────────────────────────────────────────────
    Block(HirBlock),
    Unsafe(Box<HirExpr>),
    
    // ─────────────────────────────────────────────────────────────────────────
    // References
    // ─────────────────────────────────────────────────────────────────────────
    Ref(Mutability, Box<HirExpr>),
    Deref(Box<HirExpr>),
    
    // ─────────────────────────────────────────────────────────────────────────
    // Type operations
    // ─────────────────────────────────────────────────────────────────────────
    Cast(Box<HirExpr>, Ty),
    
    // ─────────────────────────────────────────────────────────────────────────
    // Closures
    // ─────────────────────────────────────────────────────────────────────────
    Closure {
        capture: HirCaptureMode,
        body: BodyId,
        captures: Vec<HirCapture>,
    },
    
    // ─────────────────────────────────────────────────────────────────────────
    // Async/Await
    // ─────────────────────────────────────────────────────────────────────────
    Await(Box<HirExpr>),
    Yield(Option<Box<HirExpr>>),
    
    // ─────────────────────────────────────────────────────────────────────────
    // Assignment
    // ─────────────────────────────────────────────────────────────────────────
    Assign(Box<HirExpr>, Box<HirExpr>),
    AssignOp(BinaryOp, Box<HirExpr>, Box<HirExpr>),
    
    // ─────────────────────────────────────────────────────────────────────────
    // Let (in expression position)
    // ─────────────────────────────────────────────────────────────────────────
    Let { pat: HirPat, init: Box<HirExpr> },
    
    // ─────────────────────────────────────────────────────────────────────────
    // QuantaLang extensions
    // ─────────────────────────────────────────────────────────────────────────
    Asm(HirAsmExpr),
    Consume(Box<HirExpr>),  // Explicit linear resource consumption
    StateTransition {
        expr: Box<HirExpr>,
        from_state: DefId,
        to_state: DefId,
        trigger: String,
    },
    
    // ─────────────────────────────────────────────────────────────────────────
    // Error recovery
    // ─────────────────────────────────────────────────────────────────────────
    Err,
}

#[derive(Debug)]
pub struct HirLiteral {
    pub kind: HirLiteralKind,
    pub span: Span,
}

#[derive(Debug)]
pub enum HirLiteralKind {
    Bool(bool),
    Char(char),
    Byte(u8),
    Int(u128, IntTy),
    Float(f64, FloatTy),
    Str(String),
    ByteStr(Vec<u8>),
}

#[derive(Debug)]
pub struct HirPath {
    pub res: HirRes,
    pub segments: Vec<HirPathSegment>,
    pub span: Span,
}

#[derive(Debug)]
pub enum HirRes {
    Def(DefKind, DefId),
    Local(LocalId),
    PrimTy(HirPrimTy),
    SelfTy(Option<DefId>, Option<DefId>),  // trait def, impl def
    Err,
}

#[derive(Debug, Clone, Copy, PartialEq, Eq)]
pub enum DefKind {
    Mod,
    Struct,
    Union,
    Enum,
    Variant,
    Trait,
    TypeAlias,
    Fn,
    Const,
    Static,
    Ctor,
    AssocFn,
    AssocTy,
    AssocConst,
    Field,
    // QuantaLang
    Bitfield,
    StateMachine,
    State,
    Effect,
}

#[derive(Debug, Clone, Copy, PartialEq, Eq)]
pub enum HirPrimTy {
    Bool,
    Char,
    Int(IntTy),
    Float(FloatTy),
    Str,
    Never,
}

#[derive(Debug)]
pub struct HirPathSegment {
    pub name: String,
    pub args: Option<Vec<HirGenericArg>>,
    pub span: Span,
}

#[derive(Debug)]
pub struct HirFieldExpr {
    pub name: String,
    pub expr: HirExpr,
    pub span: Span,
}

#[derive(Debug)]
pub struct HirMatchArm {
    pub pat: HirPat,
    pub guard: Option<Box<HirExpr>>,
    pub body: Box<HirExpr>,
    pub span: Span,
}

#[derive(Debug)]
pub struct HirBlock {
    pub stmts: Vec<HirStmt>,
    pub expr: Option<Box<HirExpr>>,
    pub span: Span,
}

#[derive(Debug)]
pub struct HirStmt {
    pub kind: HirStmtKind,
    pub span: Span,
}

#[derive(Debug)]
pub enum HirStmtKind {
    Local(HirLocal),
    Expr(HirExpr),
    Semi(HirExpr),
}

#[derive(Debug, Clone, Copy, PartialEq, Eq)]
pub enum HirCaptureMode {
    ByRef,
    ByValue,
}

#[derive(Debug)]
pub struct HirCapture {
    pub local: LocalId,
    pub mode: HirCaptureMode,
    pub mutability: Mutability,
}

#[derive(Debug)]
pub struct HirAsmExpr {
    pub template: Vec<HirAsmTemplatePiece>,
    pub operands: Vec<HirAsmOperand>,
    pub options: HirAsmOptions,
    pub span: Span,
}

#[derive(Debug)]
pub enum HirAsmTemplatePiece {
    String(String),
    Placeholder { idx: usize, modifier: Option<char> },
}

#[derive(Debug)]
pub struct HirAsmOperand {
    pub kind: HirAsmOperandKind,
    pub span: Span,
}

#[derive(Debug)]
pub enum HirAsmOperandKind {
    In { reg: String, expr: HirExpr },
    Out { reg: String, expr: Option<HirExpr>, late: bool },
    InOut { reg: String, in_expr: HirExpr, out_expr: Option<HirExpr> },
    Const(HirConstArg),
    Sym(HirPath),
}

#[derive(Debug, Default)]
pub struct HirAsmOptions {
    pub pure_: bool,
    pub nomem: bool,
    pub readonly: bool,
    pub preserves_flags: bool,
    pub noreturn: bool,
    pub nostack: bool,
}

// ═══════════════════════════════════════════════════════════════════════════════
// HIR PATTERNS
// ═══════════════════════════════════════════════════════════════════════════════

#[derive(Debug)]
pub struct HirPat {
    pub id: HirPatId,
    pub kind: HirPatKind,
    pub ty: Ty,
    pub span: Span,
}

#[derive(Debug, Clone, Copy, PartialEq, Eq, Hash)]
pub struct HirPatId(pub u32);

#[derive(Debug)]
pub enum HirPatKind {
    Wild,
    Binding {
        name: String,
        local_id: LocalId,
        mutability: Mutability,
        subpat: Option<Box<HirPat>>,
    },
    Struct {
        path: HirPath,
        fields: Vec<HirPatField>,
        rest: bool,
    },
    TupleStruct {
        path: HirPath,
        pats: Vec<HirPat>,
    },
    Path(HirPath),
    Tuple(Vec<HirPat>),
    Ref {
        mutability: Mutability,
        pat: Box<HirPat>,
    },
    Lit(HirLiteral),
    Range {
        start: Option<Box<HirPat>>,
        end: Option<Box<HirPat>>,
        inclusive: bool,
    },
    Slice {
        before: Vec<HirPat>,
        middle: Option<Box<HirPat>>,
        after: Vec<HirPat>,
    },
    Or(Vec<HirPat>),
}

#[derive(Debug)]
pub struct HirPatField {
    pub name: String,
    pub pat: HirPat,
    pub shorthand: bool,
    pub span: Span,
}

// ═══════════════════════════════════════════════════════════════════════════════
// HIR LOWERING CONTEXT
// ═══════════════════════════════════════════════════════════════════════════════

pub struct HirLowering {
    next_def_id: u32,
    next_local_id: u32,
    next_expr_id: u32,
    next_pat_id: u32,
    
    /// Definition table
    defs: HashMap<DefId, DefInfo>,
    
    /// Current scope for name resolution
    scopes: Vec<Scope>,
    
    /// Errors collected during lowering
    errors: Vec<HirError>,
}

#[derive(Debug)]
struct DefInfo {
    name: String,
    kind: DefKind,
    parent: Option<DefId>,
}

#[derive(Debug, Default)]
struct Scope {
    bindings: HashMap<String, HirRes>,
    kind: ScopeKind,
}

#[derive(Debug, Default, Clone, Copy, PartialEq, Eq)]
enum ScopeKind {
    #[default]
    Block,
    Function,
    Module,
    Loop(Option<String>),  // Label
}

#[derive(Debug)]
pub enum HirError {
    UnresolvedName { name: String, span: Span },
    DuplicateDefinition { name: String, span: Span },
    InvalidBreak { span: Span },
    InvalidContinue { span: Span },
    MismatchedTypes { expected: Ty, found: Ty, span: Span },
}

impl HirLowering {
    pub fn new() -> Self {
        HirLowering {
            next_def_id: 0,
            next_local_id: 0,
            next_expr_id: 0,
            next_pat_id: 0,
            defs: HashMap::new(),
            scopes: vec![Scope::default()],
            errors: Vec::new(),
        }
    }
    
    pub fn fresh_def_id(&mut self) -> DefId {
        let id = DefId::local(self.next_def_id);
        self.next_def_id += 1;
        id
    }
    
    pub fn fresh_local_id(&mut self) -> LocalId {
        let id = LocalId(self.next_local_id);
        self.next_local_id += 1;
        id
    }
    
    pub fn fresh_expr_id(&mut self) -> HirExprId {
        let id = HirExprId(self.next_expr_id);
        self.next_expr_id += 1;
        id
    }
    
    pub fn fresh_pat_id(&mut self) -> HirPatId {
        let id = HirPatId(self.next_pat_id);
        self.next_pat_id += 1;
        id
    }
    
    pub fn push_scope(&mut self, kind: ScopeKind) {
        self.scopes.push(Scope { bindings: HashMap::new(), kind });
    }
    
    pub fn pop_scope(&mut self) {
        self.scopes.pop();
    }
    
    pub fn define(&mut self, name: String, res: HirRes) {
        if let Some(scope) = self.scopes.last_mut() {
            scope.bindings.insert(name, res);
        }
    }
    
    pub fn resolve(&self, name: &str) -> Option<HirRes> {
        for scope in self.scopes.iter().rev() {
            if let Some(res) = scope.bindings.get(name) {
                return Some(res.clone());
            }
        }
        None
    }
    
    pub fn current_loop_label(&self) -> Option<String> {
        for scope in self.scopes.iter().rev() {
            if let ScopeKind::Loop(label) = &scope.kind {
                return label.clone();
            }
        }
        None
    }
    
    pub fn errors(&self) -> &[HirError] {
        &self.errors
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// TESTS
// ═══════════════════════════════════════════════════════════════════════════════

#[cfg(test)]
mod tests {
    use super::*;
    
    #[test]
    fn test_def_id() {
        let id = DefId::local(42);
        assert_eq!(id.crate_id, 0);
        assert_eq!(id.local_id, 42);
    }
    
    #[test]
    fn test_scope_resolution() {
        let mut ctx = HirLowering::new();
        
        let local = LocalId(0);
        ctx.define("x".to_string(), HirRes::Local(local));
        
        assert!(matches!(ctx.resolve("x"), Some(HirRes::Local(_))));
        assert!(ctx.resolve("y").is_none());
        
        ctx.push_scope(ScopeKind::Block);
        let local2 = LocalId(1);
        ctx.define("x".to_string(), HirRes::Local(local2));
        
        // Inner scope shadows outer
        if let Some(HirRes::Local(l)) = ctx.resolve("x") {
            assert_eq!(l.0, 1);
        }
        
        ctx.pop_scope();
        
        // Outer scope restored
        if let Some(HirRes::Local(l)) = ctx.resolve("x") {
            assert_eq!(l.0, 0);
        }
    }
}
