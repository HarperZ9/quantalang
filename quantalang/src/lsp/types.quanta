module quantalang::lsp::types

use std::collections::HashMap;
use crate::lsp::protocol::JsonValue;

// ═══════════════════════════════════════════════════════════════════════════════
// DOCUMENT IDENTIFIERS
// ═══════════════════════════════════════════════════════════════════════════════

/// URI representing a document
pub type DocumentUri = String;

/// Identifies a text document
#[derive(Debug, Clone)]
pub struct TextDocumentIdentifier {
    pub uri: DocumentUri,
}

/// Identifies a versioned text document
#[derive(Debug, Clone)]
pub struct VersionedTextDocumentIdentifier {
    pub uri: DocumentUri,
    pub version: i32,
}

/// Item to transfer a text document from client to server
#[derive(Debug, Clone)]
pub struct TextDocumentItem {
    pub uri: DocumentUri,
    pub language_id: String,
    pub version: i32,
    pub text: String,
}

// ═══════════════════════════════════════════════════════════════════════════════
// POSITIONS AND RANGES
// ═══════════════════════════════════════════════════════════════════════════════

/// Position in a text document (0-based line and character)
#[derive(Debug, Clone, Copy, PartialEq, Eq, Default)]
pub struct Position {
    /// Line position (0-based)
    pub line: u32,
    /// Character offset on the line (0-based, UTF-16 code units)
    pub character: u32,
}

impl Position {
    pub fn new(line: u32, character: u32) -> Self {
        Position { line, character }
    }
    
    pub fn to_json(&self) -> JsonValue {
        let mut obj = HashMap::new();
        obj.insert("line".to_string(), JsonValue::Number(self.line as f64));
        obj.insert("character".to_string(), JsonValue::Number(self.character as f64));
        JsonValue::Object(obj)
    }
    
    pub fn from_json(json: &JsonValue) -> Option<Self> {
        Some(Position {
            line: json.get_i64("line")? as u32,
            character: json.get_i64("character")? as u32,
        })
    }
}

/// Range in a text document
#[derive(Debug, Clone, Copy, PartialEq, Eq, Default)]
pub struct Range {
    /// Start position (inclusive)
    pub start: Position,
    /// End position (exclusive)
    pub end: Position,
}

impl Range {
    pub fn new(start: Position, end: Position) -> Self {
        Range { start, end }
    }
    
    pub fn point(pos: Position) -> Self {
        Range { start: pos, end: pos }
    }
    
    pub fn to_json(&self) -> JsonValue {
        let mut obj = HashMap::new();
        obj.insert("start".to_string(), self.start.to_json());
        obj.insert("end".to_string(), self.end.to_json());
        JsonValue::Object(obj)
    }
    
    pub fn from_json(json: &JsonValue) -> Option<Self> {
        Some(Range {
            start: Position::from_json(json.get("start")?)?,
            end: Position::from_json(json.get("end")?)?,
        })
    }
    
    pub fn contains(&self, pos: Position) -> bool {
        (self.start.line < pos.line || 
            (self.start.line == pos.line && self.start.character <= pos.character))
        && (pos.line < self.end.line ||
            (pos.line == self.end.line && pos.character <= self.end.character))
    }
}

/// Location in a document
#[derive(Debug, Clone)]
pub struct Location {
    pub uri: DocumentUri,
    pub range: Range,
}

impl Location {
    pub fn new(uri: DocumentUri, range: Range) -> Self {
        Location { uri, range }
    }
    
    pub fn to_json(&self) -> JsonValue {
        let mut obj = HashMap::new();
        obj.insert("uri".to_string(), JsonValue::String(self.uri.clone()));
        obj.insert("range".to_string(), self.range.to_json());
        JsonValue::Object(obj)
    }
}

/// Link to a location with origin selection range
#[derive(Debug, Clone)]
pub struct LocationLink {
    /// Range in the origin document
    pub origin_selection_range: Option<Range>,
    /// Target URI
    pub target_uri: DocumentUri,
    /// Full range of the target
    pub target_range: Range,
    /// Selection range within target (for highlighting)
    pub target_selection_range: Range,
}

// ═══════════════════════════════════════════════════════════════════════════════
// TEXT EDITS
// ═══════════════════════════════════════════════════════════════════════════════

/// Text edit in a document
#[derive(Debug, Clone)]
pub struct TextEdit {
    /// Range to replace
    pub range: Range,
    /// New text
    pub new_text: String,
}

impl TextEdit {
    pub fn new(range: Range, new_text: String) -> Self {
        TextEdit { range, new_text }
    }
    
    pub fn insert(pos: Position, text: String) -> Self {
        TextEdit {
            range: Range::point(pos),
            new_text: text,
        }
    }
    
    pub fn delete(range: Range) -> Self {
        TextEdit {
            range,
            new_text: String::new(),
        }
    }
    
    pub fn to_json(&self) -> JsonValue {
        let mut obj = HashMap::new();
        obj.insert("range".to_string(), self.range.to_json());
        obj.insert("newText".to_string(), JsonValue::String(self.new_text.clone()));
        JsonValue::Object(obj)
    }
}

/// Document changes for a workspace edit
#[derive(Debug, Clone)]
pub struct TextDocumentEdit {
    pub text_document: VersionedTextDocumentIdentifier,
    pub edits: Vec<TextEdit>,
}

/// Workspace edit
#[derive(Debug, Clone, Default)]
pub struct WorkspaceEdit {
    /// Map of URI to text edits
    pub changes: HashMap<DocumentUri, Vec<TextEdit>>,
    /// Document changes (for versioned edits)
    pub document_changes: Vec<TextDocumentEdit>,
}

impl WorkspaceEdit {
    pub fn new() -> Self {
        WorkspaceEdit::default()
    }
    
    pub fn add_edit(&mut self, uri: DocumentUri, edit: TextEdit) {
        self.changes.entry(uri).or_default().push(edit);
    }
    
    pub fn to_json(&self) -> JsonValue {
        let mut obj = HashMap::new();
        
        if !self.changes.is_empty() {
            let mut changes = HashMap::new();
            for (uri, edits) in &self.changes {
                let edits_json: Vec<JsonValue> = edits.iter().map(|e| e.to_json()).collect();
                changes.insert(uri.clone(), JsonValue::Array(edits_json));
            }
            obj.insert("changes".to_string(), JsonValue::Object(changes));
        }
        
        JsonValue::Object(obj)
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// DIAGNOSTICS
// ═══════════════════════════════════════════════════════════════════════════════

/// Diagnostic severity
#[derive(Debug, Clone, Copy, PartialEq, Eq)]
#[repr(u8)]
pub enum DiagnosticSeverity {
    Error = 1,
    Warning = 2,
    Information = 3,
    Hint = 4,
}

/// Diagnostic tag
#[derive(Debug, Clone, Copy, PartialEq, Eq)]
#[repr(u8)]
pub enum DiagnosticTag {
    Unnecessary = 1,
    Deprecated = 2,
}

/// Related diagnostic information
#[derive(Debug, Clone)]
pub struct DiagnosticRelatedInformation {
    pub location: Location,
    pub message: String,
}

/// A diagnostic (error, warning, etc.)
#[derive(Debug, Clone)]
pub struct Diagnostic {
    /// Range of the diagnostic
    pub range: Range,
    /// Severity
    pub severity: Option<DiagnosticSeverity>,
    /// Diagnostic code
    pub code: Option<String>,
    /// Code description URL
    pub code_description: Option<String>,
    /// Source of the diagnostic (e.g., "quantalang")
    pub source: Option<String>,
    /// Human-readable message
    pub message: String,
    /// Tags
    pub tags: Vec<DiagnosticTag>,
    /// Related information
    pub related_information: Vec<DiagnosticRelatedInformation>,
}

impl Diagnostic {
    pub fn error(range: Range, message: String) -> Self {
        Diagnostic {
            range,
            severity: Some(DiagnosticSeverity::Error),
            code: None,
            code_description: None,
            source: Some("quantalang".to_string()),
            message,
            tags: Vec::new(),
            related_information: Vec::new(),
        }
    }
    
    pub fn warning(range: Range, message: String) -> Self {
        Diagnostic {
            range,
            severity: Some(DiagnosticSeverity::Warning),
            code: None,
            code_description: None,
            source: Some("quantalang".to_string()),
            message,
            tags: Vec::new(),
            related_information: Vec::new(),
        }
    }
    
    pub fn hint(range: Range, message: String) -> Self {
        Diagnostic {
            range,
            severity: Some(DiagnosticSeverity::Hint),
            code: None,
            code_description: None,
            source: Some("quantalang".to_string()),
            message,
            tags: Vec::new(),
            related_information: Vec::new(),
        }
    }
    
    pub fn with_code(mut self, code: &str) -> Self {
        self.code = Some(code.to_string());
        self
    }
    
    pub fn with_tag(mut self, tag: DiagnosticTag) -> Self {
        self.tags.push(tag);
        self
    }
    
    pub fn with_related(mut self, location: Location, message: String) -> Self {
        self.related_information.push(DiagnosticRelatedInformation {
            location,
            message,
        });
        self
    }
    
    pub fn to_json(&self) -> JsonValue {
        let mut obj = HashMap::new();
        
        obj.insert("range".to_string(), self.range.to_json());
        
        if let Some(severity) = self.severity {
            obj.insert("severity".to_string(), JsonValue::Number(severity as u8 as f64));
        }
        
        if let Some(ref code) = self.code {
            obj.insert("code".to_string(), JsonValue::String(code.clone()));
        }
        
        if let Some(ref source) = self.source {
            obj.insert("source".to_string(), JsonValue::String(source.clone()));
        }
        
        obj.insert("message".to_string(), JsonValue::String(self.message.clone()));
        
        if !self.tags.is_empty() {
            let tags: Vec<JsonValue> = self.tags.iter()
                .map(|t| JsonValue::Number(*t as u8 as f64))
                .collect();
            obj.insert("tags".to_string(), JsonValue::Array(tags));
        }
        
        if !self.related_information.is_empty() {
            let related: Vec<JsonValue> = self.related_information.iter()
                .map(|r| {
                    let mut rel = HashMap::new();
                    rel.insert("location".to_string(), r.location.to_json());
                    rel.insert("message".to_string(), JsonValue::String(r.message.clone()));
                    JsonValue::Object(rel)
                })
                .collect();
            obj.insert("relatedInformation".to_string(), JsonValue::Array(related));
        }
        
        JsonValue::Object(obj)
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// COMPLETION
// ═══════════════════════════════════════════════════════════════════════════════

/// Completion item kind
#[derive(Debug, Clone, Copy, PartialEq, Eq)]
#[repr(u8)]
pub enum CompletionItemKind {
    Text = 1,
    Method = 2,
    Function = 3,
    Constructor = 4,
    Field = 5,
    Variable = 6,
    Class = 7,
    Interface = 8,
    Module = 9,
    Property = 10,
    Unit = 11,
    Value = 12,
    Enum = 13,
    Keyword = 14,
    Snippet = 15,
    Color = 16,
    File = 17,
    Reference = 18,
    Folder = 19,
    EnumMember = 20,
    Constant = 21,
    Struct = 22,
    Event = 23,
    Operator = 24,
    TypeParameter = 25,
}

/// Insert text format
#[derive(Debug, Clone, Copy, PartialEq, Eq)]
#[repr(u8)]
pub enum InsertTextFormat {
    PlainText = 1,
    Snippet = 2,
}

/// Completion item
#[derive(Debug, Clone)]
pub struct CompletionItem {
    /// Display label
    pub label: String,
    /// Label details (type info, etc.)
    pub label_detail: Option<String>,
    /// Kind of completion
    pub kind: Option<CompletionItemKind>,
    /// Tags (deprecated, etc.)
    pub tags: Vec<DiagnosticTag>,
    /// Detailed human-readable string
    pub detail: Option<String>,
    /// Documentation
    pub documentation: Option<String>,
    /// Deprecated flag
    pub deprecated: bool,
    /// If true, this item should be selected
    pub preselect: bool,
    /// String used for sorting
    pub sort_text: Option<String>,
    /// String used for filtering
    pub filter_text: Option<String>,
    /// Text to insert
    pub insert_text: Option<String>,
    /// Insert text format
    pub insert_text_format: Option<InsertTextFormat>,
    /// Text edit to apply
    pub text_edit: Option<TextEdit>,
    /// Additional text edits
    pub additional_text_edits: Vec<TextEdit>,
    /// Commit characters
    pub commit_characters: Vec<char>,
}

impl CompletionItem {
    pub fn new(label: String) -> Self {
        CompletionItem {
            label,
            label_detail: None,
            kind: None,
            tags: Vec::new(),
            detail: None,
            documentation: None,
            deprecated: false,
            preselect: false,
            sort_text: None,
            filter_text: None,
            insert_text: None,
            insert_text_format: None,
            text_edit: None,
            additional_text_edits: Vec::new(),
            commit_characters: Vec::new(),
        }
    }
    
    pub fn keyword(label: &str) -> Self {
        CompletionItem::new(label.to_string())
            .with_kind(CompletionItemKind::Keyword)
    }
    
    pub fn function(name: &str, signature: &str) -> Self {
        CompletionItem::new(name.to_string())
            .with_kind(CompletionItemKind::Function)
            .with_detail(signature.to_string())
    }
    
    pub fn variable(name: &str, ty: &str) -> Self {
        CompletionItem::new(name.to_string())
            .with_kind(CompletionItemKind::Variable)
            .with_detail(ty.to_string())
    }
    
    pub fn field(name: &str, ty: &str) -> Self {
        CompletionItem::new(name.to_string())
            .with_kind(CompletionItemKind::Field)
            .with_detail(ty.to_string())
    }
    
    pub fn method(name: &str, signature: &str) -> Self {
        CompletionItem::new(name.to_string())
            .with_kind(CompletionItemKind::Method)
            .with_detail(signature.to_string())
    }
    
    pub fn struct_item(name: &str) -> Self {
        CompletionItem::new(name.to_string())
            .with_kind(CompletionItemKind::Struct)
    }
    
    pub fn enum_item(name: &str) -> Self {
        CompletionItem::new(name.to_string())
            .with_kind(CompletionItemKind::Enum)
    }
    
    pub fn snippet(label: &str, snippet: &str, detail: &str) -> Self {
        CompletionItem::new(label.to_string())
            .with_kind(CompletionItemKind::Snippet)
            .with_insert_text(snippet.to_string())
            .with_insert_text_format(InsertTextFormat::Snippet)
            .with_detail(detail.to_string())
    }
    
    pub fn with_kind(mut self, kind: CompletionItemKind) -> Self {
        self.kind = Some(kind);
        self
    }
    
    pub fn with_detail(mut self, detail: String) -> Self {
        self.detail = Some(detail);
        self
    }
    
    pub fn with_documentation(mut self, doc: String) -> Self {
        self.documentation = Some(doc);
        self
    }
    
    pub fn with_insert_text(mut self, text: String) -> Self {
        self.insert_text = Some(text);
        self
    }
    
    pub fn with_insert_text_format(mut self, format: InsertTextFormat) -> Self {
        self.insert_text_format = Some(format);
        self
    }
    
    pub fn with_sort_text(mut self, text: String) -> Self {
        self.sort_text = Some(text);
        self
    }
    
    pub fn deprecated(mut self) -> Self {
        self.deprecated = true;
        self.tags.push(DiagnosticTag::Deprecated);
        self
    }
    
    pub fn preselected(mut self) -> Self {
        self.preselect = true;
        self
    }
    
    pub fn to_json(&self) -> JsonValue {
        let mut obj = HashMap::new();
        
        obj.insert("label".to_string(), JsonValue::String(self.label.clone()));
        
        if let Some(kind) = self.kind {
            obj.insert("kind".to_string(), JsonValue::Number(kind as u8 as f64));
        }
        
        if let Some(ref detail) = self.detail {
            obj.insert("detail".to_string(), JsonValue::String(detail.clone()));
        }
        
        if let Some(ref doc) = self.documentation {
            obj.insert("documentation".to_string(), JsonValue::String(doc.clone()));
        }
        
        if self.deprecated {
            obj.insert("deprecated".to_string(), JsonValue::Bool(true));
        }
        
        if self.preselect {
            obj.insert("preselect".to_string(), JsonValue::Bool(true));
        }
        
        if let Some(ref sort_text) = self.sort_text {
            obj.insert("sortText".to_string(), JsonValue::String(sort_text.clone()));
        }
        
        if let Some(ref filter_text) = self.filter_text {
            obj.insert("filterText".to_string(), JsonValue::String(filter_text.clone()));
        }
        
        if let Some(ref insert_text) = self.insert_text {
            obj.insert("insertText".to_string(), JsonValue::String(insert_text.clone()));
        }
        
        if let Some(format) = self.insert_text_format {
            obj.insert("insertTextFormat".to_string(), JsonValue::Number(format as u8 as f64));
        }
        
        if let Some(ref edit) = self.text_edit {
            obj.insert("textEdit".to_string(), edit.to_json());
        }
        
        if !self.tags.is_empty() {
            let tags: Vec<JsonValue> = self.tags.iter()
                .map(|t| JsonValue::Number(*t as u8 as f64))
                .collect();
            obj.insert("tags".to_string(), JsonValue::Array(tags));
        }
        
        JsonValue::Object(obj)
    }
}

/// Completion list
#[derive(Debug, Clone)]
pub struct CompletionList {
    /// Is this list incomplete?
    pub is_incomplete: bool,
    /// Completion items
    pub items: Vec<CompletionItem>,
}

impl CompletionList {
    pub fn new(items: Vec<CompletionItem>) -> Self {
        CompletionList {
            is_incomplete: false,
            items,
        }
    }
    
    pub fn incomplete(items: Vec<CompletionItem>) -> Self {
        CompletionList {
            is_incomplete: true,
            items,
        }
    }
    
    pub fn to_json(&self) -> JsonValue {
        let mut obj = HashMap::new();
        obj.insert("isIncomplete".to_string(), JsonValue::Bool(self.is_incomplete));
        let items: Vec<JsonValue> = self.items.iter().map(|i| i.to_json()).collect();
        obj.insert("items".to_string(), JsonValue::Array(items));
        JsonValue::Object(obj)
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// HOVER
// ═══════════════════════════════════════════════════════════════════════════════

/// Hover result
#[derive(Debug, Clone)]
pub struct Hover {
    /// Hover contents (markdown)
    pub contents: String,
    /// Range to highlight
    pub range: Option<Range>,
}

impl Hover {
    pub fn new(contents: String) -> Self {
        Hover { contents, range: None }
    }
    
    pub fn with_range(mut self, range: Range) -> Self {
        self.range = Some(range);
        self
    }
    
    pub fn to_json(&self) -> JsonValue {
        let mut obj = HashMap::new();
        
        // Use MarkupContent for markdown
        let mut content = HashMap::new();
        content.insert("kind".to_string(), JsonValue::String("markdown".to_string()));
        content.insert("value".to_string(), JsonValue::String(self.contents.clone()));
        obj.insert("contents".to_string(), JsonValue::Object(content));
        
        if let Some(ref range) = self.range {
            obj.insert("range".to_string(), range.to_json());
        }
        
        JsonValue::Object(obj)
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// SIGNATURE HELP
// ═══════════════════════════════════════════════════════════════════════════════

/// Parameter information
#[derive(Debug, Clone)]
pub struct ParameterInformation {
    /// Label (name or [start, end])
    pub label: String,
    /// Documentation
    pub documentation: Option<String>,
}

/// Signature information
#[derive(Debug, Clone)]
pub struct SignatureInformation {
    /// Label (full signature)
    pub label: String,
    /// Documentation
    pub documentation: Option<String>,
    /// Parameters
    pub parameters: Vec<ParameterInformation>,
    /// Active parameter
    pub active_parameter: Option<u32>,
}

/// Signature help result
#[derive(Debug, Clone)]
pub struct SignatureHelp {
    /// Signatures
    pub signatures: Vec<SignatureInformation>,
    /// Active signature
    pub active_signature: Option<u32>,
    /// Active parameter
    pub active_parameter: Option<u32>,
}

impl SignatureHelp {
    pub fn to_json(&self) -> JsonValue {
        let mut obj = HashMap::new();
        
        let sigs: Vec<JsonValue> = self.signatures.iter().map(|sig| {
            let mut s = HashMap::new();
            s.insert("label".to_string(), JsonValue::String(sig.label.clone()));
            
            if let Some(ref doc) = sig.documentation {
                s.insert("documentation".to_string(), JsonValue::String(doc.clone()));
            }
            
            let params: Vec<JsonValue> = sig.parameters.iter().map(|p| {
                let mut param = HashMap::new();
                param.insert("label".to_string(), JsonValue::String(p.label.clone()));
                if let Some(ref doc) = p.documentation {
                    param.insert("documentation".to_string(), JsonValue::String(doc.clone()));
                }
                JsonValue::Object(param)
            }).collect();
            s.insert("parameters".to_string(), JsonValue::Array(params));
            
            JsonValue::Object(s)
        }).collect();
        
        obj.insert("signatures".to_string(), JsonValue::Array(sigs));
        
        if let Some(active) = self.active_signature {
            obj.insert("activeSignature".to_string(), JsonValue::Number(active as f64));
        }
        
        if let Some(active) = self.active_parameter {
            obj.insert("activeParameter".to_string(), JsonValue::Number(active as f64));
        }
        
        JsonValue::Object(obj)
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// SYMBOLS
// ═══════════════════════════════════════════════════════════════════════════════

/// Symbol kind
#[derive(Debug, Clone, Copy, PartialEq, Eq)]
#[repr(u8)]
pub enum SymbolKind {
    File = 1,
    Module = 2,
    Namespace = 3,
    Package = 4,
    Class = 5,
    Method = 6,
    Property = 7,
    Field = 8,
    Constructor = 9,
    Enum = 10,
    Interface = 11,
    Function = 12,
    Variable = 13,
    Constant = 14,
    String = 15,
    Number = 16,
    Boolean = 17,
    Array = 18,
    Object = 19,
    Key = 20,
    Null = 21,
    EnumMember = 22,
    Struct = 23,
    Event = 24,
    Operator = 25,
    TypeParameter = 26,
}

/// Document symbol (hierarchical)
#[derive(Debug, Clone)]
pub struct DocumentSymbol {
    /// Symbol name
    pub name: String,
    /// Detail (type info)
    pub detail: Option<String>,
    /// Symbol kind
    pub kind: SymbolKind,
    /// Tags
    pub tags: Vec<DiagnosticTag>,
    /// Deprecated
    pub deprecated: bool,
    /// Full range of the symbol
    pub range: Range,
    /// Range of the symbol's name
    pub selection_range: Range,
    /// Children
    pub children: Vec<DocumentSymbol>,
}

impl DocumentSymbol {
    pub fn new(name: String, kind: SymbolKind, range: Range, selection_range: Range) -> Self {
        DocumentSymbol {
            name,
            detail: None,
            kind,
            tags: Vec::new(),
            deprecated: false,
            range,
            selection_range,
            children: Vec::new(),
        }
    }
    
    pub fn with_detail(mut self, detail: String) -> Self {
        self.detail = Some(detail);
        self
    }
    
    pub fn with_children(mut self, children: Vec<DocumentSymbol>) -> Self {
        self.children = children;
        self
    }
    
    pub fn to_json(&self) -> JsonValue {
        let mut obj = HashMap::new();
        
        obj.insert("name".to_string(), JsonValue::String(self.name.clone()));
        obj.insert("kind".to_string(), JsonValue::Number(self.kind as u8 as f64));
        obj.insert("range".to_string(), self.range.to_json());
        obj.insert("selectionRange".to_string(), self.selection_range.to_json());
        
        if let Some(ref detail) = self.detail {
            obj.insert("detail".to_string(), JsonValue::String(detail.clone()));
        }
        
        if self.deprecated {
            obj.insert("deprecated".to_string(), JsonValue::Bool(true));
        }
        
        if !self.children.is_empty() {
            let children: Vec<JsonValue> = self.children.iter().map(|c| c.to_json()).collect();
            obj.insert("children".to_string(), JsonValue::Array(children));
        }
        
        JsonValue::Object(obj)
    }
}

/// Workspace symbol
#[derive(Debug, Clone)]
pub struct SymbolInformation {
    pub name: String,
    pub kind: SymbolKind,
    pub tags: Vec<DiagnosticTag>,
    pub deprecated: bool,
    pub location: Location,
    pub container_name: Option<String>,
}

// ═══════════════════════════════════════════════════════════════════════════════
// CODE ACTIONS
// ═══════════════════════════════════════════════════════════════════════════════

/// Code action kind
#[derive(Debug, Clone, PartialEq, Eq)]
pub struct CodeActionKind(pub String);

impl CodeActionKind {
    pub const QUICK_FIX: &'static str = "quickfix";
    pub const REFACTOR: &'static str = "refactor";
    pub const REFACTOR_EXTRACT: &'static str = "refactor.extract";
    pub const REFACTOR_INLINE: &'static str = "refactor.inline";
    pub const REFACTOR_REWRITE: &'static str = "refactor.rewrite";
    pub const SOURCE: &'static str = "source";
    pub const SOURCE_ORGANIZE_IMPORTS: &'static str = "source.organizeImports";
    pub const SOURCE_FIX_ALL: &'static str = "source.fixAll";
    
    pub fn quick_fix() -> Self { CodeActionKind(Self::QUICK_FIX.to_string()) }
    pub fn refactor() -> Self { CodeActionKind(Self::REFACTOR.to_string()) }
}

/// Code action
#[derive(Debug, Clone)]
pub struct CodeAction {
    /// Title
    pub title: String,
    /// Kind
    pub kind: Option<CodeActionKind>,
    /// Diagnostics this action resolves
    pub diagnostics: Vec<Diagnostic>,
    /// Is preferred action
    pub is_preferred: bool,
    /// Edit to apply
    pub edit: Option<WorkspaceEdit>,
}

impl CodeAction {
    pub fn new(title: String) -> Self {
        CodeAction {
            title,
            kind: None,
            diagnostics: Vec::new(),
            is_preferred: false,
            edit: None,
        }
    }
    
    pub fn quick_fix(title: String, edit: WorkspaceEdit) -> Self {
        CodeAction {
            title,
            kind: Some(CodeActionKind::quick_fix()),
            diagnostics: Vec::new(),
            is_preferred: true,
            edit: Some(edit),
        }
    }
    
    pub fn to_json(&self) -> JsonValue {
        let mut obj = HashMap::new();
        
        obj.insert("title".to_string(), JsonValue::String(self.title.clone()));
        
        if let Some(ref kind) = self.kind {
            obj.insert("kind".to_string(), JsonValue::String(kind.0.clone()));
        }
        
        if self.is_preferred {
            obj.insert("isPreferred".to_string(), JsonValue::Bool(true));
        }
        
        if let Some(ref edit) = self.edit {
            obj.insert("edit".to_string(), edit.to_json());
        }
        
        JsonValue::Object(obj)
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// SEMANTIC TOKENS
// ═══════════════════════════════════════════════════════════════════════════════

/// Semantic token types
#[derive(Debug, Clone, Copy, PartialEq, Eq)]
#[repr(u8)]
pub enum SemanticTokenType {
    Namespace = 0,
    Type = 1,
    Class = 2,
    Enum = 3,
    Interface = 4,
    Struct = 5,
    TypeParameter = 6,
    Parameter = 7,
    Variable = 8,
    Property = 9,
    EnumMember = 10,
    Event = 11,
    Function = 12,
    Method = 13,
    Macro = 14,
    Keyword = 15,
    Modifier = 16,
    Comment = 17,
    String = 18,
    Number = 19,
    Regexp = 20,
    Operator = 21,
}

/// Semantic token modifiers
#[derive(Debug, Clone, Copy, PartialEq, Eq)]
#[repr(u8)]
pub enum SemanticTokenModifier {
    Declaration = 0,
    Definition = 1,
    Readonly = 2,
    Static = 3,
    Deprecated = 4,
    Abstract = 5,
    Async = 6,
    Modification = 7,
    Documentation = 8,
    DefaultLibrary = 9,
}

/// Semantic tokens data
#[derive(Debug, Clone, Default)]
pub struct SemanticTokens {
    /// Encoded tokens (delta line, delta char, length, type, modifiers)
    pub data: Vec<u32>,
}

impl SemanticTokens {
    pub fn new() -> Self {
        SemanticTokens { data: Vec::new() }
    }
    
    /// Add a token relative to the previous one
    pub fn push(&mut self, delta_line: u32, delta_char: u32, length: u32, 
                token_type: SemanticTokenType, modifiers: u32) {
        self.data.push(delta_line);
        self.data.push(delta_char);
        self.data.push(length);
        self.data.push(token_type as u32);
        self.data.push(modifiers);
    }
    
    pub fn to_json(&self) -> JsonValue {
        let mut obj = HashMap::new();
        let data: Vec<JsonValue> = self.data.iter().map(|&n| JsonValue::Number(n as f64)).collect();
        obj.insert("data".to_string(), JsonValue::Array(data));
        JsonValue::Object(obj)
    }
}
