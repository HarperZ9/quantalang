//
// DAP-compatible debug adapter for QuantaLang programs.
//
// Features:
// - Full Debug Adapter Protocol support
// - Breakpoints (source, function, conditional)
// - Step execution (in, over, out)
// - Variable inspection
// - Expression evaluation
// - Stack trace navigation
// - Multi-thread debugging
//
// ═══════════════════════════════════════════════════════════════════════════════

//! # QuantaLang Debugger
//!
//! Debug Adapter Protocol (DAP) server for IDE integration.
//!
//! ## Quick Start
//!
//! ```bash
//! # Start debug adapter (communicates via stdin/stdout)
//! quanta-debug
//!
//! # Debug a program directly
//! quanta-debug run program.quanta
//!
//! # Attach to running process
//! quanta-debug attach --pid 12345
//! ```
//!
//! ## VS Code Integration
//!
//! Add to `.vscode/launch.json`:
//!
//! ```json
//! {
//!   "type": "quantalang",
//!   "request": "launch",
//!   "name": "Debug Program",
//!   "program": "${workspaceFolder}/src/main.quanta",
//!   "stopOnEntry": true
//! }
//! ```
//!
//! ## Modules
//!
//! - [`protocol`] - DAP message types
//! - [`state`] - Debug session state management
//! - [`server`] - DAP server implementation

module quantalang::debug

// Submodules
pub mod protocol;
pub mod state;
pub mod server;

// Re-exports
pub use protocol::*;
pub use state::{
    DebugSession, SessionState, ThreadState, ThreadExecutionState,
    StepType, FrameInfo, DebuggedProcess, BreakpointManager,
    VariableStore, VariableContainer, SourceManager, SourceContent,
    DebugConfig,
};
pub use server::DebugAdapter;

