// FRAME INFO
// ═══════════════════════════════════════════════════════════════════════════════

#[derive(Debug, Clone)]
pub struct FrameInfo {
    pub id: i64,
    pub thread_id: i64,
    pub name: String,
    pub source_path: Option<PathBuf>,
    pub line: i64,
    pub column: i64,
    pub instruction_pointer: u64,
    pub frame_pointer: u64,
    pub stack_pointer: u64,
}

// ═══════════════════════════════════════════════════════════════════════════════
// DEBUGGED PROCESS
// ═══════════════════════════════════════════════════════════════════════════════

pub struct DebuggedProcess {
    pid: u32,
    program: PathBuf,
    #[cfg(unix)]
    child: Option<std::process::Child>,
}

impl DebuggedProcess {
    pub fn launch(
        program: &str,
        args: &[String],
        cwd: Option<&str>,
        env: &BTreeMap<String, String>,
    ) -> Result<Self, String> {
        let mut cmd = std::process::Command::new(program);
        cmd.args(args);
        
        if let Some(cwd) = cwd {
            cmd.current_dir(cwd);
        }
        
        for (k, v) in env {
            cmd.env(k, v);
        }
        
        let child = cmd.spawn()
            .map_err(|e| format!("failed to launch: {}", e))?;
        
        let pid = child.id();
        
        Ok(DebuggedProcess {
            pid,
            program: PathBuf::from(program),
            #[cfg(unix)]
            child: Some(child),
        })
    }
    
    pub fn attach(pid: u32) -> Result<Self, String> {
        #[cfg(unix)]
        unsafe {
            if libc::ptrace(libc::PTRACE_ATTACH, pid as i32, 0, 0) == -1 {
                return Err(format!("failed to attach to process {}", pid));
            }
        }
        
        Ok(DebuggedProcess {
            pid,
            program: PathBuf::new(),
            #[cfg(unix)]
            child: None,
        })
    }
    
    pub fn connect(host: &str, port: u16) -> Result<Self, String> {
        // Remote debugging - connect to debug server
        Err("remote debugging not yet implemented".to_string())
    }
    
    pub fn pid(&self) -> u32 {
        self.pid
    }
    
    pub fn terminate(&mut self) -> Result<(), String> {
        #[cfg(unix)]
        {
            if let Some(ref mut child) = self.child {
                child.kill().map_err(|e| format!("failed to terminate: {}", e))?;
            } else {
                unsafe {
                    libc::kill(self.pid as i32, libc::SIGTERM);
                }
            }
        }
        Ok(())
    }
    
    pub fn read_memory(&self, address: u64, size: usize) -> Result<Vec<u8>, String> {
        // In real implementation, use ptrace or /proc/pid/mem
        Err("memory reading not yet implemented".to_string())
    }
    
    pub fn write_memory(&self, address: u64, data: &[u8]) -> Result<(), String> {
        // In real implementation, use ptrace
        Err("memory writing not yet implemented".to_string())
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// BREAKPOINT MANAGER
// ═══════════════════════════════════════════════════════════════════════════════

pub struct BreakpointManager {
    next_id: i64,
    source_breakpoints: BTreeMap<String, Vec<BreakpointInfo>>,
    function_breakpoints: Vec<BreakpointInfo>,
    data_breakpoints: Vec<BreakpointInfo>,
}

impl BreakpointManager {
    pub fn new() -> Self {
        BreakpointManager {
            next_id: 1,
            source_breakpoints: BTreeMap::new(),
            function_breakpoints: Vec::new(),
            data_breakpoints: Vec::new(),
        }
    }
    
    pub fn set_source_breakpoints(&mut self, source: &Source, breakpoints: &[SourceBreakpoint]) -> Vec<Breakpoint> {
        let path = source.path.clone().unwrap_or_default();
        
        let infos: Vec<BreakpointInfo> = breakpoints.iter().map(|bp| {
            let id = self.next_id;
            self.next_id += 1;
            
            BreakpointInfo {
                id,
                verified: true,
                line: bp.line,
                column: bp.column,
                condition: bp.condition.clone(),
                hit_condition: bp.hit_condition.clone(),
                log_message: bp.log_message.clone(),
                hit_count: 0,
                enabled: true,
            }
        }).collect();
        
        let result: Vec<Breakpoint> = infos.iter().map(|info| {
            Breakpoint {
                id: Some(info.id),
                verified: info.verified,
                message: None,
                source: Some(source.clone()),
                line: Some(info.line),
                column: info.column,
                end_line: None,
                end_column: None,
                instruction_reference: None,
                offset: None,
            }
        }).collect();
        
        self.source_breakpoints.insert(path, infos);
        
        result
    }
    
    pub fn set_function_breakpoints(&mut self, breakpoints: &[FunctionBreakpoint]) -> Vec<Breakpoint> {
        self.function_breakpoints.clear();
        
        breakpoints.iter().map(|bp| {
            let id = self.next_id;
            self.next_id += 1;
            
            self.function_breakpoints.push(BreakpointInfo {
                id,
                verified: true,
                line: 0,
                column: None,
                condition: bp.condition.clone(),
                hit_condition: bp.hit_condition.clone(),
                log_message: None,
                hit_count: 0,
                enabled: true,
            });
            
            Breakpoint {
                id: Some(id),
                verified: true,
                message: None,
                source: None,
                line: None,
                column: None,
                end_line: None,
                end_column: None,
                instruction_reference: None,
                offset: None,
            }
        }).collect()
    }
    
    pub fn get_at(&self, file: &str, line: i64) -> Option<i64> {
        self.source_breakpoints.get(file)
            .and_then(|bps| bps.iter().find(|bp| bp.line == line && bp.enabled))
            .map(|bp| bp.id)
    }
}

#[derive(Debug, Clone)]
struct BreakpointInfo {
    id: i64,
    verified: bool,
    line: i64,
    column: Option<i64>,
    condition: Option<String>,
    hit_condition: Option<String>,
    log_message: Option<String>,
    hit_count: i64,
    enabled: bool,
}

// ═══════════════════════════════════════════════════════════════════════════════
// VARIABLE STORE
// ═══════════════════════════════════════════════════════════════════════════════

pub struct VariableStore {
    next_reference: i64,
    references: BTreeMap<i64, VariableContainer>,
}

impl VariableStore {
    pub fn new() -> Self {
        VariableStore {
            next_reference: 1,
            references: BTreeMap::new(),
        }
    }
    
    pub fn allocate_reference(&mut self) -> i64 {
        let ref_id = self.next_reference;
        self.next_reference += 1;
        ref_id
    }
    
    pub fn store(&mut self, reference: i64, container: VariableContainer) {
        self.references.insert(reference, container);
    }
    
    pub fn get(&self, reference: i64) -> Option<&VariableContainer> {
        self.references.get(&reference)
    }
    
    pub fn clear(&mut self) {
        self.references.clear();
        self.next_reference = 1;
    }
}

#[derive(Debug, Clone)]
pub enum VariableContainer {
    Scope { frame_id: i64, scope_type: ScopePresentationHint },
    Struct { fields: Vec<(String, String, String)> },
    Array { elements: Vec<String> },
}

// ═══════════════════════════════════════════════════════════════════════════════
// SOURCE MANAGER
// ═══════════════════════════════════════════════════════════════════════════════

pub struct SourceManager {
    sources: BTreeMap<i64, SourceContent>,
    next_reference: i64,
    path_to_reference: BTreeMap<PathBuf, i64>,
}

impl SourceManager {
    pub fn new() -> Self {
        SourceManager {
            sources: BTreeMap::new(),
            next_reference: 1,
            path_to_reference: BTreeMap::new(),
        }
    }
    
    pub fn get_source(&self, reference: i64) -> Option<&SourceContent> {
        self.sources.get(&reference)
    }
    
    pub fn load_file(&mut self, path: &std::path::Path) -> Result<i64, String> {
        if let Some(&ref_id) = self.path_to_reference.get(path) {
            return Ok(ref_id);
        }
        
        let content = std::fs::read_to_string(path)
            .map_err(|e| format!("failed to read source: {}", e))?;
        
        let ref_id = self.next_reference;
        self.next_reference += 1;
        
        self.sources.insert(ref_id, SourceContent {
            path: path.to_path_buf(),
            content,
        });
        
        self.path_to_reference.insert(path.to_path_buf(), ref_id);
        
        Ok(ref_id)
    }
}

#[derive(Debug, Clone)]
pub struct SourceContent {
    pub path: PathBuf,
    pub content: String,
}

// ═══════════════════════════════════════════════════════════════════════════════
// DEBUG CONFIG
// ═══════════════════════════════════════════════════════════════════════════════

#[derive(Debug, Clone)]
pub struct DebugConfig {
    pub lines_start_at_1: bool,
    pub columns_start_at_1: bool,
    pub path_format: PathFormat,
    pub supports_variable_type: bool,
    pub supports_memory_references: bool,
}

impl Default for DebugConfig {
    fn default() -> Self {
        DebugConfig {
            lines_start_at_1: true,
            columns_start_at_1: true,
            path_format: PathFormat::Path,
            supports_variable_type: true,
            supports_memory_references: true,
        }
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// TESTS
// ═══════════════════════════════════════════════════════════════════════════════

#[cfg(test)]
mod tests {
    use super::*;
    
    #[test]
    fn test_session_state() {
        let session = DebugSession::new(1);
        assert_eq!(session.state(), SessionState::Uninitialized);
        
        session.set_state(SessionState::Initialized);
        assert!(session.is_initialized());
    }
    
    #[test]
    fn test_breakpoint_manager() {
        let mut mgr = BreakpointManager::new();
        
        let source = Source {
            name: Some("test.quanta".to_string()),
            path: Some("/test.quanta".to_string()),
            source_reference: None,
            presentation_hint: None,
            origin: None,
            sources: Vec::new(),
            adapter_data: None,
            checksums: Vec::new(),
        };
        
        let bps = mgr.set_source_breakpoints(&source, &[
            SourceBreakpoint { line: 10, column: None, condition: None, hit_condition: None, log_message: None },
        ]);
        
        assert_eq!(bps.len(), 1);
        assert!(bps[0].verified);
    }
}
