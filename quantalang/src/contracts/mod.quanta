// ═══════════════════════════════════════════════════════════════════════════════
// TESTS
// ═══════════════════════════════════════════════════════════════════════════════

#[cfg(test)]
mod tests {
    use super::*;
    
    #[test]
    fn test_contract_checker_modes() {
        let checker = ContractChecker::new(ContractMode::Full);
        assert_eq!(checker.mode(), ContractMode::Full);
        
        checker.set_mode(ContractMode::Disabled);
        assert_eq!(checker.mode(), ContractMode::Disabled);
    }
    
    #[test]
    fn test_precondition_check() {
        let checker = ContractChecker::new(ContractMode::Full);
        
        // Should pass
        let result = checker.check_precondition(
            true,
            "x > 0",
            Some("x must be positive"),
            SourceLocation::default(),
            BTreeMap::new(),
        );
        assert!(result.is_ok());
        
        // Set handler to avoid panic
        checker.set_handler(Box::new(|_| {}));
        
        // Should fail
        let result = checker.check_precondition(
            false,
            "x > 0",
            Some("x must be positive"),
            SourceLocation::default(),
            BTreeMap::new(),
        );
        assert!(result.is_err());
    }
    
    #[test]
    fn test_static_verifier() {
        let mut verifier = StaticVerifier::new(VerifierConfig::default());
        
        let contract = FunctionContract {
            name: "test".to_string(),
            requires: vec![],
            ensures: vec![],
            modifies: vec![],
            pure: true,
            decreases: None,
            frame: None,
        };
        
        let body = FunctionBody {
            statements: vec![],
        };
        
        let results = verifier.verify_function(&contract, &body);
        // Empty function should have no VCs
        assert!(results.is_empty());
    }
    
    #[test]
    fn test_verification_summary() {
        let summary = VerificationSummary {
            total: 10,
            verified: 8,
            failed: 1,
            unknown: 1,
            timeout: 0,
            errors: 0,
            total_time_ms: 1000,
        };
        
        assert!((summary.success_rate() - 0.8).abs() < 0.001);
        assert!(!summary.all_verified());
    }
}
