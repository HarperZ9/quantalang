    // SMT interface
    SmtSolver, SmtFormula, SmtDecl, SmtSort, SmtExpr, SmtLiteral,
    SmtResult, SmtModel, SmtValue,
    vc_to_smt,
    
    // Results
    VerificationResult, VerificationOutcome,
    Counterexample, TraceStep, SourceLocation,
};

