// ═══════════════════════════════════════════════════════════════════════════════
// RUNTIME CONTRACT CHECKING
// ═══════════════════════════════════════════════════════════════════════════════

/// Contract checking mode
#[derive(Debug, Clone, Copy, PartialEq, Eq)]
pub enum ContractMode {
    /// No runtime checking
    Disabled,
    /// Check preconditions only
    Preconditions,
    /// Check pre/postconditions
    Full,
    /// Check everything including invariants
    Paranoid,
}

/// Contract violation
#[derive(Debug, Clone)]
pub struct ContractViolation {
    /// Kind of contract violated
    pub kind: ContractKind,
    
    /// Contract expression (as string)
    pub contract: String,
    
    /// Description
    pub description: Option<String>,
    
    /// Location in source
    pub location: SourceLocation,
    
    /// Variable values at violation
    pub context: BTreeMap<String, String>,
}

#[derive(Debug, Clone, Copy, PartialEq, Eq)]
pub enum ContractKind {
    Precondition,
    Postcondition,
    Assertion,
    Invariant,
    LoopInvariant,
    LoopVariant,
}

impl std::fmt::Display for ContractViolation {
    fn fmt(&self, f: &mut std::fmt::Formatter<'_>) -> std::fmt::Result {
        write!(f, "{:?} violated: {}", self.kind, self.contract)?;
        if let Some(desc) = &self.description {
            write!(f, " ({})", desc)?;
        }
        write!(f, " at {}:{}:{}", 
            self.location.file, self.location.line, self.location.column)
    }
}

/// Contract violation handler
pub type ViolationHandler = Box<dyn Fn(&ContractViolation) + Send + Sync>;

/// Runtime contract checker
pub struct ContractChecker {
    /// Checking mode
    mode: RwLock<ContractMode>,
    
    /// Violation handler
    handler: RwLock<Option<ViolationHandler>>,
    
    /// Statistics
    stats: RwLock<CheckerStats>,
}

/// Checker statistics
#[derive(Debug, Clone, Default)]
pub struct CheckerStats {
    pub preconditions_checked: u64,
    pub postconditions_checked: u64,
    pub assertions_checked: u64,
    pub invariants_checked: u64,
    pub violations: u64,
}

impl ContractChecker {
    pub fn new(mode: ContractMode) -> Self {
        ContractChecker {
            mode: RwLock::new(mode),
            handler: RwLock::new(None),
            stats: RwLock::new(CheckerStats::default()),
        }
    }
    
    /// Set checking mode
    pub fn set_mode(&self, mode: ContractMode) {
        *self.mode.write().unwrap() = mode;
    }
    
    /// Get current mode
    pub fn mode(&self) -> ContractMode {
        *self.mode.read().unwrap()
    }
    
    /// Set violation handler
    pub fn set_handler(&self, handler: ViolationHandler) {
        *self.handler.write().unwrap() = Some(handler);
    }
    
    /// Check precondition
    pub fn check_precondition(
        &self,
        condition: bool,
        contract: &str,
        description: Option<&str>,
        location: SourceLocation,
        context: BTreeMap<String, String>,
    ) -> Result<(), ContractViolation> {
        let mode = *self.mode.read().unwrap();
        
        if mode == ContractMode::Disabled {
            return Ok(());
        }
        
        {
            let mut stats = self.stats.write().unwrap();
            stats.preconditions_checked += 1;
        }
        
        if !condition {
            let violation = ContractViolation {
                kind: ContractKind::Precondition,
                contract: contract.to_string(),
                description: description.map(String::from),
                location,
                context,
            };
            
            self.handle_violation(&violation);
            return Err(violation);
        }
        
        Ok(())
    }
    
    /// Check postcondition
    pub fn check_postcondition(
        &self,
        condition: bool,
        contract: &str,
        description: Option<&str>,
        location: SourceLocation,
        context: BTreeMap<String, String>,
    ) -> Result<(), ContractViolation> {
        let mode = *self.mode.read().unwrap();
        
        if mode == ContractMode::Disabled || mode == ContractMode::Preconditions {
            return Ok(());
        }
        
        {
            let mut stats = self.stats.write().unwrap();
            stats.postconditions_checked += 1;
        }
        
        if !condition {
            let violation = ContractViolation {
                kind: ContractKind::Postcondition,
                contract: contract.to_string(),
                description: description.map(String::from),
                location,
                context,
            };
            
            self.handle_violation(&violation);
            return Err(violation);
        }
        
        Ok(())
    }
    
    /// Check assertion
    pub fn check_assertion(
        &self,
        condition: bool,
        contract: &str,
        description: Option<&str>,
        location: SourceLocation,
        context: BTreeMap<String, String>,
    ) -> Result<(), ContractViolation> {
        let mode = *self.mode.read().unwrap();
        
        if mode == ContractMode::Disabled {
            return Ok(());
        }
        
        {
            let mut stats = self.stats.write().unwrap();
            stats.assertions_checked += 1;
        }
        
        if !condition {
            let violation = ContractViolation {
                kind: ContractKind::Assertion,
                contract: contract.to_string(),
                description: description.map(String::from),
                location,
                context,
            };
            
            self.handle_violation(&violation);
            return Err(violation);
        }
        
        Ok(())
    }
    
    /// Check type invariant
    pub fn check_invariant(
        &self,
        condition: bool,
        contract: &str,
        type_name: &str,
        location: SourceLocation,
        context: BTreeMap<String, String>,
    ) -> Result<(), ContractViolation> {
        let mode = *self.mode.read().unwrap();
        
        if mode != ContractMode::Paranoid {
            return Ok(());
        }
        
        {
            let mut stats = self.stats.write().unwrap();
            stats.invariants_checked += 1;
        }
        
        if !condition {
            let violation = ContractViolation {
                kind: ContractKind::Invariant,
                contract: contract.to_string(),
                description: Some(format!("invariant of type {}", type_name)),
                location,
                context,
            };
            
            self.handle_violation(&violation);
            return Err(violation);
        }
        
        Ok(())
    }
    
    fn handle_violation(&self, violation: &ContractViolation) {
        {
            let mut stats = self.stats.write().unwrap();
            stats.violations += 1;
        }
        
        if let Some(handler) = &*self.handler.read().unwrap() {
            handler(violation);
        } else {
            // Default: panic
            panic!("Contract violation: {}", violation);
        }
    }
    
    /// Get statistics
    pub fn stats(&self) -> CheckerStats {
        self.stats.read().unwrap().clone()
    }
    
    /// Reset statistics
    pub fn reset_stats(&self) {
        *self.stats.write().unwrap() = CheckerStats::default();
    }
}

impl Default for ContractChecker {
    fn default() -> Self {
        Self::new(ContractMode::Full)
    }
}

// Global contract checker
static mut GLOBAL_CHECKER: Option<ContractChecker> = None;

/// Get global contract checker
pub fn checker() -> &'static ContractChecker {
    unsafe {
        if GLOBAL_CHECKER.is_none() {
            GLOBAL_CHECKER = Some(ContractChecker::default());
        }
        GLOBAL_CHECKER.as_ref().unwrap()
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// STATIC VERIFIER
// ═══════════════════════════════════════════════════════════════════════════════

/// Static contract verifier
pub struct StaticVerifier {
    /// VC generator
    vc_gen: VcGenerator,
    
    /// SMT solver (would be Z3, CVC5, etc.)
    solver: Box<dyn SmtSolver + Send + Sync>,
    
    /// Configuration
    config: VerifierConfig,
    
    /// Results
    results: Vec<VerificationResult>,
}

/// Verifier configuration
#[derive(Debug, Clone)]
pub struct VerifierConfig {
    /// Timeout per VC (milliseconds)
    pub timeout_ms: u64,
    
    /// Maximum VCs to check
    pub max_vcs: usize,
    
    /// Generate counterexamples
    pub counterexamples: bool,
    
    /// Use incremental solving
    pub incremental: bool,
    
    /// Parallelism
    pub parallel: bool,
}

impl Default for VerifierConfig {
    fn default() -> Self {
        VerifierConfig {
            timeout_ms: 10_000,
            max_vcs: 1000,
            counterexamples: true,
            incremental: true,
            parallel: true,
        }
    }
}

/// Dummy SMT solver for testing
pub struct DummySolver;

impl SmtSolver for DummySolver {
    fn check_sat(&mut self, _formula: &SmtFormula) -> SmtResult {
        SmtResult::Unsat // Assume everything verifies
    }
    
    fn get_model(&self) -> Option<SmtModel> {
        None
    }
    
    fn get_unsat_core(&self) -> Option<Vec<String>> {
        None
    }
    
    fn push(&mut self) {}
    fn pop(&mut self) {}
    fn set_timeout(&mut self, _millis: u64) {}
}

impl StaticVerifier {
    pub fn new(config: VerifierConfig) -> Self {
        StaticVerifier {
            vc_gen: VcGenerator::new(),
            solver: Box::new(DummySolver),
            config,
            results: Vec::new(),
        }
    }
    
    /// Verify function contract
    pub fn verify_function(
        &mut self,
        contract: &FunctionContract,
        body: &FunctionBody,
    ) -> Vec<VerificationResult> {
        let vcs = self.vc_gen.generate_function_vcs(contract, body);
        self.verify_vcs(&vcs)
    }
    
    /// Verify VCs
    pub fn verify_vcs(&mut self, vcs: &[VerificationCondition]) -> Vec<VerificationResult> {
        let mut results = Vec::new();
        
        for vc in vcs.iter().take(self.config.max_vcs) {
            let result = self.verify_vc(vc);
            results.push(result);
        }
        
        self.results.extend(results.clone());
        results
    }
    
    fn verify_vc(&mut self, vc: &VerificationCondition) -> VerificationResult {
        let start = Instant::now();
        
        self.solver.set_timeout(self.config.timeout_ms);
        
        let formula = vc_to_smt(vc);
        let smt_result = self.solver.check_sat(&formula);
        
        let time_ms = start.elapsed().as_millis() as u64;
        
        let (outcome, counterexample) = match smt_result {
            SmtResult::Unsat => (VerificationOutcome::Verified, None),
            SmtResult::Sat => {
                let ce = if self.config.counterexamples {
                    self.solver.get_model().map(|model| {
                        Counterexample {
                            variable_values: model.assignments.iter()
                                .map(|(k, v)| (k.clone(), format!("{:?}", v)))
                                .collect(),
                            trace: vec![],
                        }
                    })
                } else {
                    None
                };
                (VerificationOutcome::Failed, ce)
            }
            SmtResult::Unknown => (VerificationOutcome::Unknown, None),
            SmtResult::Timeout => (VerificationOutcome::Timeout, None),
            SmtResult::Error(_) => (VerificationOutcome::Error, None),
        };
        
        VerificationResult {
            vc_id: vc.id,
            outcome,
            counterexample,
            time_ms,
        }
    }
    
    /// Get all results
    pub fn results(&self) -> &[VerificationResult] {
        &self.results
    }
    
    /// Get summary
    pub fn summary(&self) -> VerificationSummary {
        let mut summary = VerificationSummary::default();
        
        for result in &self.results {
            summary.total += 1;
            match result.outcome {
                VerificationOutcome::Verified => summary.verified += 1,
                VerificationOutcome::Failed => summary.failed += 1,
                VerificationOutcome::Unknown => summary.unknown += 1,
                VerificationOutcome::Timeout => summary.timeout += 1,
                VerificationOutcome::Error => summary.errors += 1,
            }
            summary.total_time_ms += result.time_ms;
        }
        
        summary
    }
}

/// Verification summary
#[derive(Debug, Clone, Default)]
pub struct VerificationSummary {
    pub total: usize,
    pub verified: usize,
    pub failed: usize,
    pub unknown: usize,
    pub timeout: usize,
    pub errors: usize,
    pub total_time_ms: u64,
}

impl VerificationSummary {
    pub fn success_rate(&self) -> f64 {
        if self.total > 0 {
            self.verified as f64 / self.total as f64
        } else {
            0.0
        }
    }
    
    pub fn all_verified(&self) -> bool {
        self.verified == self.total
    }
}

