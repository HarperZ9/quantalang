/// Main entry point
pub fn main() -> Result<i32, String> {
    let args: Vec<String> = std::env::args().skip(1).collect();
    let cli = parse_args(&args)?;
    run(&cli)
}

// ═══════════════════════════════════════════════════════════════════════════════
// TESTS
// ═══════════════════════════════════════════════════════════════════════════════

#[cfg(test)]
mod tests {
    use super::*;
    
    #[test]
    fn test_profiler_new() {
        let profiler = Profiler::new();
        assert!(!profiler.is_profiling());
        assert_eq!(profiler.sample_count(), 0);
    }
    
    #[test]
    fn test_profiler_config() {
        let mut config = ProfilerConfig::default();
        config.sample_frequency = 1000;
        config.memory_profiling = true;
        
        let profiler = Profiler::with_config(config);
        assert_eq!(profiler.config().sample_frequency, 1000);
        assert!(profiler.config().memory_profiling);
    }
    
    #[test]
    fn test_parse_args_run() {
        let args = vec!["run".to_string(), "program.quanta".to_string()];
        let cli = parse_args(&args).unwrap();
        
        match cli.command {
            ProfileCommand::Run { program, .. } => {
                assert_eq!(program, "program.quanta");
            }
            _ => panic!("expected Run command"),
        }
    }
    
    #[test]
    fn test_parse_args_format() {
        let args = vec![
            "--format".to_string(),
            "flamegraph".to_string(),
            "run".to_string(),
            "prog.quanta".to_string(),
        ];
        let cli = parse_args(&args).unwrap();
        assert_eq!(cli.config.output_format, OutputFormat::Flamegraph);
    }
}
