//
// CPU and memory profiler with sampling and instrumentation modes.
//
// Features:
// - CPU sampling profiler (configurable frequency)
// - Instrumentation-based precise timing
// - Memory allocation tracking
// - Call graph generation
// - Flamegraph output
// - Multiple output formats (text, JSON, callgrind, pprof)
//
// ═══════════════════════════════════════════════════════════════════════════════

//! # QuantaLang Profiler
//!
//! Performance profiling toolkit for QuantaLang programs.
//!
//! ## Quick Start
//!
//! ```bash
//! # Profile a program
//! quanta-profile run program.quanta
//!
//! # Attach to running process
//! quanta-profile attach --pid 12345
//!
//! # Generate flamegraph
//! quanta-profile run --format flamegraph program.quanta > profile.svg
//! ```
//!
//! ## Programmatic API
//!
//! ```quanta
//! use quantalang::profile::{Profiler, ProfilerConfig};
//!
//! // Start profiling
//! let profiler = Profiler::new();
//! profiler.start()?;
//!
//! // ... run code ...
//!
//! // Stop and analyze
//! let report = profiler.stop_and_report()?;
//! println!("{}", report);
//! ```
//!
//! ## Instrumentation
//!
//! ```quanta
//! use quantalang::profile::instrument;
//!
//! #[instrument]
//! fn expensive_function() {
//!     // Automatically timed
//! }
//! ```

module quantalang::profile

