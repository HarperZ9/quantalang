//
// The QuantaLang Formatter (quantafmt) provides automatic code formatting
// for QuantaLang source files.
//
// Features:
// - Wadler-Lindig pretty printing algorithm
// - Configurable style options (.quantafmt.toml)
// - AST-preserving transformations
// - IDE integration support
// - Check mode for CI/CD
// - Diff output for review
//
// ═══════════════════════════════════════════════════════════════════════════════

//! # QuantaLang Formatter
//!
//! Code formatter for QuantaLang source files.
//!
//! ## Quick Start
//!
//! ```bash
//! # Format a file (output to stdout)
//! quantafmt src/main.quanta
//!
//! # Format and write back
//! quantafmt -w src/main.quanta
//!
//! # Check formatting (CI mode)
//! quantafmt --check src/
//!
//! # Show diff
//! quantafmt --diff src/main.quanta
//! ```
//!
//! ## Configuration
//!
//! Create `.quantafmt.toml` in your project root:
//!
//! ```toml
//! max_width = 100
//! hard_tabs = false
//! tab_spaces = 4
//! edition = "2025"
//!
//! # Imports
//! reorder_imports = true
//! merge_imports = true
//! group_imports = "StdExternalCrate"
//!
//! # Functions
//! fn_args_layout = "Tall"
//! fn_single_line = true
//!
//! # Trailing commas
//! trailing_comma = "Vertical"
//!
//! # Comments
//! wrap_comments = false
//! format_code_in_doc_comments = false
//! ```
//!
//! ## Programmatic API
//!
//! ```quanta
//! use quantalang::fmt::{format_string, Config};
//!
//! let source = "fn   main(  ) {  }";
//! let config = Config::default();
//! let formatted = format_string(source, &config)?;
//! assert_eq!(formatted, "fn main() {}\n");
//! ```
//!
//! ## Modules
//!
//! - [`config`] - Configuration options and parsing
//! - [`printer`] - Wadler-Lindig pretty printer
//! - [`visitor`] - AST to document visitor
//! - [`cli`] - Command-line interface

module quantalang::fmt

