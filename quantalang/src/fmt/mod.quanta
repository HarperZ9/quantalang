// ═══════════════════════════════════════════════════════════════════════════════
// TESTS
// ═══════════════════════════════════════════════════════════════════════════════

#[cfg(test)]
mod tests {
    use super::*;
    
    #[test]
    fn test_formatter_builder() {
        let formatter = Formatter::new()
            .max_width(120)
            .hard_tabs(false)
            .tab_spaces(4);
        
        assert_eq!(formatter.config().max_width, 120);
        assert!(!formatter.config().hard_tabs);
        assert_eq!(formatter.config().tab_spaces, 4);
    }
    
    #[test]
    fn test_presets() {
        let default = presets::default_style();
        assert_eq!(default.max_width, 100);
        
        let compact = presets::compact();
        assert_eq!(compact.max_width, 120);
        
        let expanded = presets::expanded();
        assert_eq!(expanded.max_width, 80);
    }
    
    #[test]
    fn test_ide_formatting_options() {
        let config = Config::default();
        let opts = ide::formatting_options(&config);
        
        assert_eq!(opts.tab_size, 4);
        assert!(opts.insert_spaces);
        assert!(opts.trim_trailing_whitespace);
        assert!(opts.insert_final_newline);
    }
}
