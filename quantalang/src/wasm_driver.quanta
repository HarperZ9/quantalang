// TESTS
// ═══════════════════════════════════════════════════════════════════════════════

#[cfg(test)]
mod tests {
    use super::*;
    
    #[test]
    fn test_target_from_str() {
        assert_eq!(WasmTarget::from_str("wasm32-wasi"), Some(WasmTarget::Wasm32Wasi));
        assert_eq!(WasmTarget::from_str("wasm32-unknown-unknown"), Some(WasmTarget::Wasm32Unknown));
        assert_eq!(WasmTarget::from_str("invalid"), None);
    }
    
    #[test]
    fn test_compile_hello_world() {
        let source = r#"
            fn main() {
                println("Hello, World!");
            }
        "#;
        
        let driver = WasmDriver::new(WasmOptions::default());
        let binary = driver.compile_source(source).unwrap();
        
        assert_eq!(&binary[0..4], &WASM_MAGIC);
    }
    
    #[test]
    fn test_binary_to_wat() {
        let driver = WasmDriver::new(WasmOptions::default());
        let binary = driver.compile_source("fn main() {}").unwrap();
        let wat = driver.binary_to_wat(&binary).unwrap();
        
        assert!(wat.contains("(module"));
        assert!(wat.contains("export"));
    }
}
