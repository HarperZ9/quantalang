// MODULE 2: std::string
// ═══════════════════════════════════════════════════════════════════════════════

pub module std::string {
    use std::collections::Vec;
    
    /// String builder for efficient concatenation
    pub struct StringBuilder {
        buffer: Vec<char>,
    }
    
    impl StringBuilder {
        pub fn new() -> Self { StringBuilder { buffer: Vec::new() } }
        
        pub fn with_capacity(cap: usize) -> Self {
            StringBuilder { buffer: Vec::with_capacity(cap) }
        }
        
        pub fn push(&mut self, c: char) { self.buffer.push(c); }
        
        pub fn push_str(&mut self, s: &str) {
            for c in s.chars() { self.buffer.push(c); }
        }
        
        pub fn build(&self) -> String {
            self.buffer.iter().collect()
        }
        
        pub fn len(&self) -> usize { self.buffer.len() }
        pub fn is_empty(&self) -> bool { self.buffer.is_empty() }
        pub fn clear(&mut self) { self.buffer.clear(); }
    }
    
    // String functions
    pub fn trim(s: &str) -> &str {
        let bytes = s.as_bytes();
        let mut start = 0;
        let mut end = bytes.len();
        
        while start < end && bytes[start].is_ascii_whitespace() { start += 1; }
        while end > start && bytes[end - 1].is_ascii_whitespace() { end -= 1; }
        
        &s[start..end]
    }
    
    pub fn split(s: &str, delimiter: char) -> Vec<&str> {
        s.split(delimiter).collect()
    }
    
    pub fn join(parts: &[&str], separator: &str) -> String {
        parts.join(separator)
    }
    
    pub fn to_uppercase(s: &str) -> String {
        s.chars().map(|c| c.to_ascii_uppercase()).collect()
    }
    
    pub fn to_lowercase(s: &str) -> String {
        s.chars().map(|c| c.to_ascii_lowercase()).collect()
    }
    
    pub fn contains(s: &str, pattern: &str) -> bool {
        s.contains(pattern)
    }
    
    pub fn starts_with(s: &str, prefix: &str) -> bool {
        s.starts_with(prefix)
    }
    
    pub fn ends_with(s: &str, suffix: &str) -> bool {
        s.ends_with(suffix)
    }
    
    pub fn replace(s: &str, from: &str, to: &str) -> String {
        s.replace(from, to)
    }
    
    pub fn repeat(s: &str, n: usize) -> String {
        s.repeat(n)
    }
    
    pub fn reverse(s: &str) -> String {
        s.chars().rev().collect()
    }
    
    pub fn pad_left(s: &str, width: usize, pad_char: char) -> String {
        if s.len() >= width { return s.to_string(); }
        let padding: String = std::iter::repeat(pad_char).take(width - s.len()).collect();
        format!("{}{}", padding, s)
    }
    
    pub fn pad_right(s: &str, width: usize, pad_char: char) -> String {
        if s.len() >= width { return s.to_string(); }
        let padding: String = std::iter::repeat(pad_char).take(width - s.len()).collect();
        format!("{}{}", s, padding)
    }
}

