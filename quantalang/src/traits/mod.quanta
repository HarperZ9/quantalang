//! # Trait System
//!
//! Comprehensive trait-based polymorphism with advanced features:
//!
//! - **Coherence**: Orphan rules ensure global uniqueness of implementations
//! - **Specialization**: More specific impls override generic ones
//! - **Associated Items**: Types, constants, and functions bound to traits
//! - **Object Safety**: Runtime trait object dispatch support
//!
//! ## Trait Declaration
//!
//! ```quanta
//! trait Iterator {
//!     type Item;
//!     
//!     fn next(&mut self) -> Option<Self::Item>;
//!     
//!     // Provided method with default implementation
//!     fn count(self) -> usize {
//!         let mut count = 0;
//!         while let Some(_) = self.next() {
//!             count += 1;
//!         }
//!         count
//!     }
//! }
//! ```
//!
//! ## Implementation
//!
//! ```quanta
//! impl<T> Iterator for Vec<T> {
//!     type Item = T;
//!     
//!     fn next(&mut self) -> Option<T> {
//!         self.pop()
//!     }
//! }
//! ```
//!
//! ## Specialization
//!
//! ```quanta
//! impl<T: Clone> ToString for T {
//!     default fn to_string(&self) -> String {
//!         // Generic implementation
//!     }
//! }
//!
//! impl ToString for str {
//!     fn to_string(&self) -> String {
//!         // Specialized for str
//!         String::from(self)
//!     }
//! }
//! ```

module quantalang::traits

pub mod system;

pub use system::{
    // Identifiers
    TraitId, CrateId, ImplId,
    
    // Trait definition
    TraitDef, TypeParam, TypeBound, TraitRef, GenericArg,
    AssocType, AssocConst, TraitMethod, Receiver, Param,
    WhereClause, WherePredicate, Lifetime,
    
    // Types
    Type, IntTy, UIntTy, FloatTy, Mutability, Abi, ClosureKind,
    TypePath, InferVar, ConstValue,
    
    // Implementations
    TraitImpl, MethodImpl, SpecializationInfo,
    
    // Coherence
    CoherenceChecker, CoherenceError,
    
    // Resolution
    TraitResolver, Resolution, ResolutionError,
};

use alloc::vec::Vec;
use alloc::string::String;
use alloc::collections::BTreeMap;
use std::sync::Arc;

// ═══════════════════════════════════════════════════════════════════════════════
// BUILT-IN TRAITS
// ═══════════════════════════════════════════════════════════════════════════════

/// Built-in trait registry
pub struct BuiltinTraits {
    traits: BTreeMap<TraitId, TraitDef>,
}

impl BuiltinTraits {
    pub fn new() -> Self {
        let mut traits = BTreeMap::new();
        
        // Sized
        traits.insert(
            TraitId::builtin("Sized"),
            TraitDef {
                id: TraitId::builtin("Sized"),
                type_params: vec![],
                supertraits: vec![],
                assoc_types: vec![],
                assoc_consts: vec![],
                methods: vec![],
                is_marker: true,
                is_auto: true,
                is_unsafe: false,
                object_safe: Some(false),
                doc: Some("Types with known size at compile time".to_string()),
            },
        );
        
        // Copy
        traits.insert(
            TraitId::builtin("Copy"),
            TraitDef {
                id: TraitId::builtin("Copy"),
                type_params: vec![],
                supertraits: vec![TraitRef {
                    trait_id: TraitId::builtin("Clone"),
                    args: vec![],
                }],
                assoc_types: vec![],
                assoc_consts: vec![],
                methods: vec![],
                is_marker: true,
                is_auto: false,
                is_unsafe: false,
                object_safe: Some(true),
                doc: Some("Types that can be copied by simple bit-copy".to_string()),
            },
        );
        
        // Clone
        traits.insert(
            TraitId::builtin("Clone"),
            TraitDef {
                id: TraitId::builtin("Clone"),
                type_params: vec![],
                supertraits: vec![],
                assoc_types: vec![],
                assoc_consts: vec![],
                methods: vec![
                    TraitMethod {
                        name: "clone".to_string(),
                        type_params: vec![],
                        receiver: Some(Receiver::ByRef(Lifetime::Anonymous)),
                        params: vec![],
                        return_type: Type::Named {
                            path: TypePath::simple("Self"),
                            args: vec![],
                        },
                        where_clause: None,
                        has_default: false,
                        is_unsafe: false,
                    },
                ],
                is_marker: false,
                is_auto: false,
                is_unsafe: false,
                object_safe: Some(true),
                doc: Some("Types that can be explicitly duplicated".to_string()),
            },
        );
        
        // Drop
        traits.insert(
            TraitId::builtin("Drop"),
            TraitDef {
                id: TraitId::builtin("Drop"),
                type_params: vec![],
                supertraits: vec![],
                assoc_types: vec![],
                assoc_consts: vec![],
                methods: vec![
                    TraitMethod {
                        name: "drop".to_string(),
                        type_params: vec![],
                        receiver: Some(Receiver::ByRefMut(Lifetime::Anonymous)),
                        params: vec![],
                        return_type: Type::Unit,
                        where_clause: None,
                        has_default: false,
                        is_unsafe: false,
                    },
                ],
                is_marker: false,
                is_auto: false,
                is_unsafe: false,
                object_safe: Some(true),
                doc: Some("Custom destructor logic".to_string()),
            },
        );
        
        // Send
        traits.insert(
            TraitId::builtin("Send"),
            TraitDef {
                id: TraitId::builtin("Send"),
                type_params: vec![],
                supertraits: vec![],
                assoc_types: vec![],
                assoc_consts: vec![],
                methods: vec![],
                is_marker: true,
                is_auto: true,
                is_unsafe: true,
                object_safe: Some(true),
                doc: Some("Types safe to send between threads".to_string()),
            },
        );
        
        // Sync
        traits.insert(
            TraitId::builtin("Sync"),
            TraitDef {
                id: TraitId::builtin("Sync"),
                type_params: vec![],
                supertraits: vec![],
                assoc_types: vec![],
                assoc_consts: vec![],
                methods: vec![],
                is_marker: true,
                is_auto: true,
                is_unsafe: true,
                object_safe: Some(true),
                doc: Some("Types safe to share between threads".to_string()),
            },
        );
        
        // Default
        traits.insert(
            TraitId::builtin("Default"),
            TraitDef {
                id: TraitId::builtin("Default"),
                type_params: vec![],
                supertraits: vec![],
                assoc_types: vec![],
                assoc_consts: vec![],
                methods: vec![
                    TraitMethod {
                        name: "default".to_string(),
                        type_params: vec![],
                        receiver: None,
                        params: vec![],
                        return_type: Type::Named {
                            path: TypePath::simple("Self"),
                            args: vec![],
                        },
                        where_clause: None,
                        has_default: false,
                        is_unsafe: false,
                    },
                ],
                is_marker: false,
                is_auto: false,
                is_unsafe: false,
                object_safe: Some(false), // Returns Self
                doc: Some("Types with default value".to_string()),
            },
        );
        
        // Eq, PartialEq, Ord, PartialOrd, Hash
        Self::add_comparison_traits(&mut traits);
        
        // Fn, FnMut, FnOnce
        Self::add_fn_traits(&mut traits);
        
        // Iterator
        Self::add_iterator_trait(&mut traits);
        
        BuiltinTraits { traits }
    }
    
    fn add_comparison_traits(traits: &mut BTreeMap<TraitId, TraitDef>) {
        // PartialEq
        traits.insert(
            TraitId::builtin("PartialEq"),
            TraitDef {
                id: TraitId::builtin("PartialEq"),
                type_params: vec![TypeParam {
                    name: "Rhs".to_string(),
                    bounds: vec![],
                    default: Some(Type::Named {
                        path: TypePath::simple("Self"),
                        args: vec![],
                    }),
                }],
                supertraits: vec![],
                assoc_types: vec![],
                assoc_consts: vec![],
                methods: vec![
                    TraitMethod {
                        name: "eq".to_string(),
                        type_params: vec![],
                        receiver: Some(Receiver::ByRef(Lifetime::Anonymous)),
                        params: vec![Param {
                            name: "other".to_string(),
                            ty: Type::Ref {
                                lifetime: Lifetime::Anonymous,
                                mutability: Mutability::Shared,
                                ty: Box::new(Type::Param("Rhs".to_string())),
                            },
                            is_variadic: false,
                        }],
                        return_type: Type::Bool,
                        where_clause: None,
                        has_default: false,
                        is_unsafe: false,
                    },
                ],
                is_marker: false,
                is_auto: false,
                is_unsafe: false,
                object_safe: Some(true),
                doc: Some("Partial equality comparison".to_string()),
            },
        );
        
        // Eq
        traits.insert(
            TraitId::builtin("Eq"),
            TraitDef {
                id: TraitId::builtin("Eq"),
                type_params: vec![],
                supertraits: vec![TraitRef {
                    trait_id: TraitId::builtin("PartialEq"),
                    args: vec![],
                }],
                assoc_types: vec![],
                assoc_consts: vec![],
                methods: vec![],
                is_marker: true,
                is_auto: false,
                is_unsafe: false,
                object_safe: Some(true),
                doc: Some("Full equality (reflexive)".to_string()),
            },
        );
    }
    
    fn add_fn_traits(traits: &mut BTreeMap<TraitId, TraitDef>) {
        // FnOnce
        traits.insert(
            TraitId::builtin("FnOnce"),
            TraitDef {
                id: TraitId::builtin("FnOnce"),
                type_params: vec![TypeParam {
                    name: "Args".to_string(),
                    bounds: vec![],
                    default: None,
                }],
                supertraits: vec![],
                assoc_types: vec![AssocType {
                    name: "Output".to_string(),
                    bounds: vec![],
                    default: None,
                }],
                assoc_consts: vec![],
                methods: vec![
                    TraitMethod {
                        name: "call_once".to_string(),
                        type_params: vec![],
                        receiver: Some(Receiver::ByValue),
                        params: vec![Param {
                            name: "args".to_string(),
                            ty: Type::Param("Args".to_string()),
                            is_variadic: false,
                        }],
                        return_type: Type::Projection {
                            base: Box::new(Type::Named {
                                path: TypePath::simple("Self"),
                                args: vec![],
                            }),
                            trait_ref: TraitRef {
                                trait_id: TraitId::builtin("FnOnce"),
                                args: vec![GenericArg::Type(Type::Param("Args".to_string()))],
                            },
                            item: "Output".to_string(),
                        },
                        where_clause: None,
                        has_default: false,
                        is_unsafe: false,
                    },
                ],
                is_marker: false,
                is_auto: false,
                is_unsafe: false,
                object_safe: Some(false),
                doc: Some("Callable that consumes self".to_string()),
            },
        );
        
        // FnMut
        traits.insert(
            TraitId::builtin("FnMut"),
            TraitDef {
                id: TraitId::builtin("FnMut"),
                type_params: vec![TypeParam {
                    name: "Args".to_string(),
                    bounds: vec![],
                    default: None,
                }],
                supertraits: vec![TraitRef {
                    trait_id: TraitId::builtin("FnOnce"),
                    args: vec![GenericArg::Type(Type::Param("Args".to_string()))],
                }],
                assoc_types: vec![],
                assoc_consts: vec![],
                methods: vec![
                    TraitMethod {
                        name: "call_mut".to_string(),
                        type_params: vec![],
                        receiver: Some(Receiver::ByRefMut(Lifetime::Anonymous)),
                        params: vec![Param {
                            name: "args".to_string(),
                            ty: Type::Param("Args".to_string()),
                            is_variadic: false,
                        }],
                        return_type: Type::Projection {
                            base: Box::new(Type::Named {
                                path: TypePath::simple("Self"),
                                args: vec![],
                            }),
                            trait_ref: TraitRef {
                                trait_id: TraitId::builtin("FnOnce"),
                                args: vec![GenericArg::Type(Type::Param("Args".to_string()))],
                            },
                            item: "Output".to_string(),
                        },
                        where_clause: None,
                        has_default: false,
                        is_unsafe: false,
                    },
                ],
                is_marker: false,
                is_auto: false,
                is_unsafe: false,
                object_safe: Some(false),
                doc: Some("Callable that borrows self mutably".to_string()),
            },
        );
        
        // Fn
        traits.insert(
            TraitId::builtin("Fn"),
            TraitDef {
                id: TraitId::builtin("Fn"),
                type_params: vec![TypeParam {
                    name: "Args".to_string(),
                    bounds: vec![],
                    default: None,
                }],
                supertraits: vec![TraitRef {
                    trait_id: TraitId::builtin("FnMut"),
                    args: vec![GenericArg::Type(Type::Param("Args".to_string()))],
                }],
                assoc_types: vec![],
                assoc_consts: vec![],
                methods: vec![
                    TraitMethod {
                        name: "call".to_string(),
                        type_params: vec![],
                        receiver: Some(Receiver::ByRef(Lifetime::Anonymous)),
                        params: vec![Param {
                            name: "args".to_string(),
                            ty: Type::Param("Args".to_string()),
                            is_variadic: false,
                        }],
                        return_type: Type::Projection {
                            base: Box::new(Type::Named {
                                path: TypePath::simple("Self"),
                                args: vec![],
                            }),
                            trait_ref: TraitRef {
                                trait_id: TraitId::builtin("FnOnce"),
                                args: vec![GenericArg::Type(Type::Param("Args".to_string()))],
                            },
                            item: "Output".to_string(),
                        },
                        where_clause: None,
                        has_default: false,
                        is_unsafe: false,
                    },
                ],
                is_marker: false,
                is_auto: false,
                is_unsafe: false,
                object_safe: Some(false),
                doc: Some("Callable that borrows self immutably".to_string()),
            },
        );
    }
    
    fn add_iterator_trait(traits: &mut BTreeMap<TraitId, TraitDef>) {
        traits.insert(
            TraitId::builtin("Iterator"),
            TraitDef {
                id: TraitId::builtin("Iterator"),
                type_params: vec![],
                supertraits: vec![],
                assoc_types: vec![AssocType {
                    name: "Item".to_string(),
                    bounds: vec![],
                    default: None,
                }],
                assoc_consts: vec![],
                methods: vec![
                    TraitMethod {
                        name: "next".to_string(),
                        type_params: vec![],
                        receiver: Some(Receiver::ByRefMut(Lifetime::Anonymous)),
                        params: vec![],
                        return_type: Type::Named {
                            path: TypePath::simple("Option"),
                            args: vec![GenericArg::Type(Type::Projection {
                                base: Box::new(Type::Named {
                                    path: TypePath::simple("Self"),
                                    args: vec![],
                                }),
                                trait_ref: TraitRef {
                                    trait_id: TraitId::builtin("Iterator"),
                                    args: vec![],
                                },
                                item: "Item".to_string(),
                            })],
                        },
                        where_clause: None,
                        has_default: false,
                        is_unsafe: false,
                    },
                ],
                is_marker: false,
                is_auto: false,
                is_unsafe: false,
                object_safe: Some(true),
                doc: Some("Trait for iterating over collections".to_string()),
            },
        );
    }
    
    /// Get trait by ID
    pub fn get(&self, id: &TraitId) -> Option<&TraitDef> {
        self.traits.get(id)
    }
    
    /// Get all built-in traits
    pub fn all(&self) -> impl Iterator<Item = &TraitDef> {
        self.traits.values()
    }
}

impl Default for BuiltinTraits {
    fn default() -> Self {
        Self::new()
    }
}

