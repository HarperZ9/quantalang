pub mod prelude {
    pub use super::{
        // Identifiers
        TraitId, ImplId,
        
        // Definitions
        TraitDef, TraitImpl, TraitMethod,
        TypeParam, TypeBound, TraitRef,
        AssocType, AssocConst,
        
        // Types
        Type, Lifetime,
        
        // Resolution
        TraitResolver, Resolution, ResolutionError,
        
        // Coherence
        CoherenceChecker, CoherenceError,
        
        // Built-ins
        BuiltinTraits,
    };
}

// ═══════════════════════════════════════════════════════════════════════════════
// TESTS
// ═══════════════════════════════════════════════════════════════════════════════

#[cfg(test)]
mod tests {
    use super::*;
    
    #[test]
    fn test_builtin_traits() {
        let builtins = BuiltinTraits::new();
        
        assert!(builtins.get(&TraitId::builtin("Clone")).is_some());
        assert!(builtins.get(&TraitId::builtin("Copy")).is_some());
        assert!(builtins.get(&TraitId::builtin("Send")).is_some());
        assert!(builtins.get(&TraitId::builtin("Sync")).is_some());
        assert!(builtins.get(&TraitId::builtin("Iterator")).is_some());
    }
    
    #[test]
    fn test_copy_requires_clone() {
        let builtins = BuiltinTraits::new();
        let copy = builtins.get(&TraitId::builtin("Copy")).unwrap();
        
        assert!(!copy.supertraits.is_empty());
        assert_eq!(copy.supertraits[0].trait_id, TraitId::builtin("Clone"));
    }
    
    #[test]
    fn test_fn_trait_hierarchy() {
        let builtins = BuiltinTraits::new();
        
        let fn_trait = builtins.get(&TraitId::builtin("Fn")).unwrap();
        assert_eq!(fn_trait.supertraits[0].trait_id, TraitId::builtin("FnMut"));
        
        let fn_mut = builtins.get(&TraitId::builtin("FnMut")).unwrap();
        assert_eq!(fn_mut.supertraits[0].trait_id, TraitId::builtin("FnOnce"));
    }
}
