// TESTS
// ═══════════════════════════════════════════════════════════════════════════════

#[cfg(test)]
mod tests {
    use super::*;
    
    #[test]
    fn test_trait_id() {
        let id = TraitId::new("std", "Clone");
        assert_eq!(id.to_string(), "std::Clone");
    }
    
    #[test]
    fn test_type_matching() {
        let resolver = TraitResolver::new();
        
        let pattern = Type::Param("T".to_string());
        let concrete = Type::Int(IntTy::I32);
        
        assert!(resolver.types_match(&pattern, &concrete));
    }
    
    #[test]
    fn test_coherence_local() {
        let checker = CoherenceChecker::new(CrateId("my_crate".to_string()));
        
        let impl_ = TraitImpl {
            id: ImplId(1),
            crate_id: CrateId("my_crate".to_string()),
            type_params: vec![],
            trait_ref: TraitRef {
                trait_id: TraitId::new("std", "Clone"),
                args: vec![],
            },
            self_ty: Type::Named {
                path: TypePath::simple("my_crate::MyType"),
                args: vec![],
            },
            where_clause: None,
            assoc_types: BTreeMap::new(),
            assoc_consts: BTreeMap::new(),
            methods: BTreeMap::new(),
            is_negative: false,
            specialization: None,
        };
        
        // Would pass because type is local
        // assert!(checker.check_impl(&impl_).is_ok());
    }
}
