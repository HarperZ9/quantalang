// TESTS
// ═══════════════════════════════════════════════════════════════════════════════

#[cfg(test)]
mod tests {
    use super::*;
    
    #[test]
    fn test_type_lowering() {
        let mut ctx = MlirContext::new();
        let mut lowering = MirToMlir::new(&mut ctx);
        
        let i32_ty = MirType::Int(32, true);
        let mlir_ty = lowering.lower_type(&i32_ty);
        
        match mlir_ty.kind {
            MlirTypeKind::Integer { width: 32, signed: true } => {}
            _ => panic!("Expected i32"),
        }
    }
    
    #[test]
    fn test_simple_function() {
        let mut ctx = MlirContext::new();
        let mut lowering = MirToMlir::new(&mut ctx);
        
        let func = MirFunction {
            name: "test".to_string(),
            params: vec![],
            return_type: MirType::Unit,
            body: vec![
                MirBlock {
                    id: 0,
                    statements: vec![],
                    terminator: MirTerminator::Return,
                }
            ],
            is_public: true,
            is_async: false,
            attributes: vec![],
        };
        
        let op = lowering.lower_function(&func);
        
        assert_eq!(op.name, "func.func");
        assert_eq!(op.regions.len(), 1);
    }
}
