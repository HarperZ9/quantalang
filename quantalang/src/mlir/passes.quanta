// TESTS
// ═══════════════════════════════════════════════════════════════════════════════

#[cfg(test)]
mod tests {
    use super::*;
    
    #[test]
    fn test_pass_manager() {
        let mut pm = PassManager::new();
        pm.add_pass(Box::new(CanonicalizationPass::new()));
        pm.add_pass(Box::new(DeadCodeElimination::new()));
        
        assert_eq!(pm.passes.len(), 2);
    }
    
    #[test]
    fn test_lowering_pipeline() {
        let pm = PassManager::create_lowering_pipeline();
        
        // Should have multiple passes
        assert!(pm.passes.len() >= 4);
    }
    
    #[test]
    fn test_optimization_pipeline() {
        let pm = PassManager::create_optimization_pipeline(OptLevel::O2);
        
        // O2 should have several passes
        assert!(pm.passes.len() >= 3);
    }
    
    #[test]
    fn test_canonicalization() {
        let pass = CanonicalizationPass::new();
        assert_eq!(pass.name(), "canonicalize");
    }
    
    #[test]
    fn test_dce() {
        let pass = DeadCodeElimination::new();
        assert_eq!(pass.name(), "dce");
    }
}
