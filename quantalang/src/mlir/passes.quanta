// LOWERING PASSES
// ═══════════════════════════════════════════════════════════════════════════════

/// Lower Quanta dialect to standard dialects
pub struct LowerQuantaToStandard;

impl LowerQuantaToStandard {
    pub fn new() -> Self { LowerQuantaToStandard }
}

impl Pass for LowerQuantaToStandard {
    fn name(&self) -> &str { "lower-quanta-to-std" }
    
    fn description(&self) -> &str {
        "Lower Quanta dialect operations to standard dialects"
    }
    
    fn run_on_module(&self, module: &mut Module, ctx: &mut MlirContext) -> PassResult {
        for block in &mut module.body.blocks {
            for op in &mut block.operations {
                self.lower_operation(op);
            }
        }
        
        PassResult::Success
    }
    
    fn clone_pass(&self) -> Box<dyn Pass> {
        Box::new(LowerQuantaToStandard)
    }
}

impl LowerQuantaToStandard {
    fn lower_operation(&self, op: &mut Operation) {
        match op.name.as_str() {
            "quanta.box.alloc" => {
                // Lower to memref.alloc
                op.name = "memref.alloc".to_string();
            }
            
            "quanta.box.dealloc" => {
                op.name = "memref.dealloc".to_string();
            }
            
            "quanta.struct.get" => {
                // Lower to llvm.extractvalue
                op.name = "llvm.extractvalue".to_string();
            }
            
            "quanta.match" => {
                // Lower to scf.if / switch
                // This would be a complex lowering
            }
            
            _ => {}
        }
    }
}

