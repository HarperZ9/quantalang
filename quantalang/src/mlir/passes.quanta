        PassResult::Success
    }
    
    fn clone_pass(&self) -> Box<dyn Pass> {
        Box::new(LowerScfToCf)
    }
}

/// Convert to LLVM dialect
pub struct ConvertToLlvm;

impl ConvertToLlvm {
    pub fn new() -> Self { ConvertToLlvm }
}

impl Pass for ConvertToLlvm {
    fn name(&self) -> &str { "convert-to-llvm" }
    
    fn description(&self) -> &str {
        "Convert all operations to LLVM dialect"
    }
    
    fn run_on_module(&self, module: &mut Module, ctx: &mut MlirContext) -> PassResult {
        for block in &mut module.body.blocks {
            for op in &mut block.operations {
                self.convert_operation(op);
            }
        }
        
        PassResult::Success
    }
    
    fn clone_pass(&self) -> Box<dyn Pass> {
        Box::new(ConvertToLlvm)
    }
}

impl ConvertToLlvm {
    fn convert_operation(&self, op: &mut Operation) {
        match op.name.as_str() {
            "func.func" => {
                op.name = "llvm.func".to_string();
            }
            
            "func.return" => {
                op.name = "llvm.return".to_string();
            }
            
            "func.call" => {
                op.name = "llvm.call".to_string();
            }
            
            "memref.alloc" => {
                op.name = "llvm.alloca".to_string();
            }
            
            "memref.load" => {
                op.name = "llvm.load".to_string();
            }
            
            "memref.store" => {
                op.name = "llvm.store".to_string();
            }
            
            "arith.addi" => {
                op.name = "llvm.add".to_string();
            }
            
            "arith.subi" => {
                op.name = "llvm.sub".to_string();
            }
            
            "arith.muli" => {
                op.name = "llvm.mul".to_string();
            }
            
            "arith.divsi" => {
                op.name = "llvm.sdiv".to_string();
            }
            
            "arith.cmpi" => {
                op.name = "llvm.icmp".to_string();
            }
            
            "cf.br" => {
                op.name = "llvm.br".to_string();
            }
            
            "cf.cond_br" => {
                op.name = "llvm.cond_br".to_string();
            }
            
            _ => {}
        }
    }
}

/// Reconcile unrealized casts
pub struct ReconcileUnrealizedCasts;

impl ReconcileUnrealizedCasts {
    pub fn new() -> Self { ReconcileUnrealizedCasts }
}

impl Pass for ReconcileUnrealizedCasts {
    fn name(&self) -> &str { "reconcile-unrealized-casts" }
    
    fn description(&self) -> &str {
        "Remove unrealized conversion casts"
    }
    
    fn run_on_module(&self, module: &mut Module, ctx: &mut MlirContext) -> PassResult {
        for block in &mut module.body.blocks {
            block.operations.retain(|op| {
                op.name != "builtin.unrealized_conversion_cast"
            });
        }
        
        PassResult::Success
    }
    
    fn clone_pass(&self) -> Box<dyn Pass> {
        Box::new(ReconcileUnrealizedCasts)
    }
}

