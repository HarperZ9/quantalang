// ═══════════════════════════════════════════════════════════════════════════════
// PASS INFRASTRUCTURE
// ═══════════════════════════════════════════════════════════════════════════════

/// Pass result
#[derive(Debug, Clone, Copy, PartialEq, Eq)]
pub enum PassResult {
    Success,
    Failure,
}

/// Pass trait
pub trait Pass: Send + Sync {
    /// Pass name
    fn name(&self) -> &str;
    
    /// Pass description
    fn description(&self) -> &str { "" }
    
    /// Run the pass on a module
    fn run_on_module(&self, module: &mut Module, ctx: &mut MlirContext) -> PassResult;
    
    /// Run the pass on a single operation
    fn run_on_operation(&self, op: &mut Operation, ctx: &mut MlirContext) -> PassResult {
        PassResult::Success
    }
    
    /// Clone the pass
    fn clone_pass(&self) -> Box<dyn Pass>;
}

/// Pass manager
pub struct PassManager {
    passes: Vec<Box<dyn Pass>>,
    options: PassManagerOptions,
}

#[derive(Debug, Clone)]
pub struct PassManagerOptions {
    /// Print IR after each pass
    pub print_after_all: bool,
    /// Print IR before and after passes that modify it
    pub print_before_after: bool,
    /// Verify IR after each pass
    pub verify_after_all: bool,
    /// Enable timing
    pub enable_timing: bool,
    /// Enable statistics
    pub enable_statistics: bool,
}

impl Default for PassManagerOptions {
    fn default() -> Self {
        PassManagerOptions {
            print_after_all: false,
            print_before_after: false,
            verify_after_all: true,
            enable_timing: false,
            enable_statistics: false,
        }
    }
}

impl PassManager {
    pub fn new() -> Self {
        PassManager {
            passes: Vec::new(),
            options: PassManagerOptions::default(),
        }
    }
    
    pub fn with_options(options: PassManagerOptions) -> Self {
        PassManager {
            passes: Vec::new(),
            options,
        }
    }
    
    /// Add a pass to the pipeline
    pub fn add_pass(&mut self, pass: Box<dyn Pass>) {
        self.passes.push(pass);
    }
    
    /// Run all passes on the module
    pub fn run(&self, module: &mut Module, ctx: &mut MlirContext) -> PassResult {
        let mut printer = IrPrinter::new();
        
        for pass in &self.passes {
            if self.options.print_before_after {
                println!("// ===== Before {} =====", pass.name());
                println!("{}", printer.print_module(module));
            }
            
            let start = std::time::Instant::now();
            let result = pass.run_on_module(module, ctx);
            let duration = start.elapsed();
            
            if self.options.enable_timing {
                println!("// Pass {}: {:?}", pass.name(), duration);
            }
            
            if result == PassResult::Failure {
                eprintln!("Pass {} failed", pass.name());
                return PassResult::Failure;
            }
            
            if self.options.print_after_all || self.options.print_before_after {
                println!("// ===== After {} =====", pass.name());
                println!("{}", printer.print_module(module));
            }
            
            if self.options.verify_after_all {
                // TODO: Run verifier
            }
        }
        
        PassResult::Success
    }
    
    /// Create a standard lowering pipeline
    pub fn create_lowering_pipeline() -> Self {
        let mut pm = PassManager::new();
        
        // Canonicalization
        pm.add_pass(Box::new(CanonicalizationPass::new()));
        
        // CSE
        pm.add_pass(Box::new(CommonSubexpressionElimination::new()));
        
        // Lower Quanta dialect to standard dialects
        pm.add_pass(Box::new(LowerQuantaToStandard::new()));
        
        // Lower SCF to CF
        pm.add_pass(Box::new(LowerScfToCf::new()));
        
        // Convert to LLVM dialect
        pm.add_pass(Box::new(ConvertToLlvm::new()));
        
        // Reconcile unrealized casts
        pm.add_pass(Box::new(ReconcileUnrealizedCasts::new()));
        
        pm
    }
    
    /// Create an optimization pipeline
    pub fn create_optimization_pipeline(opt_level: OptLevel) -> Self {
        let mut pm = PassManager::new();
        
        // Always run canonicalization
        pm.add_pass(Box::new(CanonicalizationPass::new()));
        
        if opt_level >= OptLevel::O1 {
            pm.add_pass(Box::new(CommonSubexpressionElimination::new()));
            pm.add_pass(Box::new(DeadCodeElimination::new()));
        }
        
        if opt_level >= OptLevel::O2 {
            pm.add_pass(Box::new(LoopInvariantCodeMotion::new()));
            pm.add_pass(Box::new(InliningPass::new(InliningConfig::default())));
            pm.add_pass(Box::new(CanonicalizationPass::new()));
        }
        
        if opt_level >= OptLevel::O3 {
            pm.add_pass(Box::new(LoopUnrolling::new(LoopUnrollingConfig::default())));
            pm.add_pass(Box::new(Vectorization::new()));
        }
        
        pm
    }
}

impl Default for PassManager {
    fn default() -> Self {
        Self::new()
    }
}

#[derive(Debug, Clone, Copy, PartialEq, Eq, PartialOrd, Ord)]
pub enum OptLevel {
    O0,
    O1,
    O2,
    O3,
    Os,
    Oz,
}

