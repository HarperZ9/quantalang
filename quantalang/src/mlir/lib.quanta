//
// MLIR Backend Integration for QuantaLang
//
// Version: 1.0.0
// Status: Production Ready
//
// This module provides a complete MLIR-based compilation pipeline:
//
//   ┌─────────────────────────────────────────────────────────────────────────┐
//   │                        MLIR COMPILATION PIPELINE                        │
//   └─────────────────────────────────────────────────────────────────────────┘
//
//   QuantaLang Source
//         │
//         ▼
//   ┌─────────────┐
//   │    AST      │    Parsing & Semantic Analysis
//   └─────────────┘
//         │
//         ▼
//   ┌─────────────┐
//   │    HIR      │    High-level IR (type-checked)
//   └─────────────┘
//         │
//         ▼
//   ┌─────────────┐
//   │    MIR      │    Mid-level IR (CFG, SSA)
//   └─────────────┘
//         │
//         ▼  ← lowering.quanta
//   ┌─────────────┐
//   │ MLIR Quanta │    QuantaLang MLIR Dialect
//   │  Dialect    │    (box, rc, match, effect, async)
//   └─────────────┘
//         │
//         ▼  ← passes.quanta (LowerQuantaToStandard)
//   ┌─────────────┐
//   │   MLIR      │    Standard Dialects
//   │  Standard   │    (arith, func, scf, memref)
//   └─────────────┘
//         │
//         ▼  ← passes.quanta (ConvertToLlvm)
//   ┌─────────────┐
//   │ MLIR LLVM   │    LLVM Dialect
//   │  Dialect    │
//   └─────────────┘
//         │
//         ▼  ← codegen.quanta
//   ┌─────────────┐
//   │  LLVM IR    │    LLVM IR Text
//   └─────────────┘
//         │
//         ▼  ← External: llc/clang
//   ┌─────────────┐
//   │   Native    │    x86_64, AArch64, RISC-V, WASM
//   │    Code     │
//   └─────────────┘
//
// ═══════════════════════════════════════════════════════════════════════════════
//
// MODULES:
//
//   dialect   - MLIR dialect definitions (Quanta, Arith, Func, SCF, LLVM)
//   ir        - IR builder, operations, blocks, regions, modules
//   lowering  - MIR to MLIR lowering pass
//   passes    - Pass infrastructure and transformation passes
//   codegen   - MLIR LLVM dialect to LLVM IR text generation
//   target    - Target triple, data layout, CPU features
//   optimizer - Pattern rewriting, analysis, cost modeling
//
// ═══════════════════════════════════════════════════════════════════════════════

module quantalang::mlir::lib

