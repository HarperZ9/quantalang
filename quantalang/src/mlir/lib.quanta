pub fn print_help() {
    println!("═══════════════════════════════════════════════════════════════════════════════");
    println!("                    QUANTALANG™ MLIR BACKEND v{}", VERSION);
    println!("═══════════════════════════════════════════════════════════════════════════════");
    println!();
    println!("MLIR-based compilation infrastructure for QuantaLang.");
    println!();
    println!("MODULES:");
    println!("  dialect   - MLIR dialect definitions");
    println!("  ir        - IR builder and representation");
    println!("  lowering  - MIR → MLIR translation");
    println!("  passes    - Transformation passes");
    println!("  codegen   - MLIR → LLVM IR generation");
    println!("  target    - Target machine configuration");
    println!("  optimizer - Pattern rewriting & analysis");
    println!();
    println!("DIALECTS:");
    println!("  quanta    - QuantaLang-specific operations");
    println!("              box, rc, match, effect, async");
    println!("  arith     - Arithmetic operations");
    println!("  func      - Function definitions and calls");
    println!("  scf       - Structured control flow");
    println!("  memref    - Memory reference operations");
    println!("  llvm      - LLVM dialect for codegen");
    println!();
    println!("TARGETS:");
    println!("  x86_64-unknown-linux-gnu     Linux x86_64");
    println!("  x86_64-apple-darwin          macOS x86_64");
    println!("  aarch64-apple-darwin         macOS ARM64");
    println!("  aarch64-unknown-linux-gnu    Linux ARM64");
    println!("  wasm32-unknown-unknown       WebAssembly 32-bit");
    println!("  wasm64-unknown-unknown       WebAssembly 64-bit");
    println!("  riscv64-unknown-linux-gnu    Linux RISC-V 64-bit");
    println!();
    println!("OPTIMIZATION LEVELS:");
    println!("  O0  - No optimization");
    println!("  O1  - Basic optimizations (canonicalize, CSE, DCE)");
    println!("  O2  - Standard optimizations (+ inlining, LICM)");
    println!("  O3  - Aggressive optimizations (+ vectorization, unrolling)");
    println!("  Os  - Size optimization");
    println!("  Oz  - Aggressive size optimization");
    println!();
    println!("═══════════════════════════════════════════════════════════════════════════════");
}

// ─────────────────────────────────────────────────────────────────────────────
// Tests
// ─────────────────────────────────────────────────────────────────────────────

#[cfg(test)]
mod tests {
    use super::*;
    
    #[test]
    fn test_version() {
        assert_eq!(VERSION, "1.0.0");
        assert_eq!(VERSION_MAJOR, 1);
    }
    
    #[test]
    fn test_compile_config_default() {
        let config = CompileConfig::default();
        
        assert_eq!(config.opt_level, OptLevel::O2);
        assert!(config.pic);
        assert!(config.verify);
    }
    
    #[test]
    fn test_simple_compilation() {
        let functions = vec![
            MirFunction {
                name: "main".to_string(),
                params: vec![],
                return_type: MirType::Int(32, true),
                body: vec![
                    MirBlock {
                        id: 0,
                        statements: vec![],
                        terminator: MirTerminator::Return,
                    }
                ],
                is_public: true,
                is_async: false,
                attributes: vec![],
            }
        ];
        
        let config = CompileConfig {
            opt_level: OptLevel::O0,
            ..Default::default()
        };
        
        let result = compile_to_llvm_ir(&functions, &config);
        assert!(result.is_ok());
        
        let ir = result.unwrap();
        assert!(ir.contains("define"));
        assert!(ir.contains("main"));
    }
    
    #[test]
    fn test_context_creation() {
        let ctx = MlirContext::new();
        
        assert!(ctx.get_dialect("quanta").is_some());
        assert!(ctx.get_dialect("arith").is_some());
        assert!(ctx.get_dialect("llvm").is_some());
    }
}
