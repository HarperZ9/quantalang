// ─────────────────────────────────────────────────────────────────────────────
// High-Level Compilation API
// ─────────────────────────────────────────────────────────────────────────────

use alloc::vec::Vec;
use alloc::string::String;

/// Compilation configuration
#[derive(Debug, Clone)]
pub struct CompileConfig {
    /// Target triple
    pub target: TargetTriple,
    /// Optimization level
    pub opt_level: OptLevel,
    /// Enable debug info
    pub debug_info: bool,
    /// Enable PIC
    pub pic: bool,
    /// Print IR after passes
    pub print_ir: bool,
    /// Verify IR after passes
    pub verify: bool,
}

impl Default for CompileConfig {
    fn default() -> Self {
        CompileConfig {
            target: TargetTriple::host(),
            opt_level: OptLevel::O2,
            debug_info: false,
            pic: true,
            print_ir: false,
            verify: true,
        }
    }
}

/// Compile MIR functions to LLVM IR
pub fn compile_to_llvm_ir(
    functions: &[MirFunction],
    config: &CompileConfig,
) -> Result<String, CompileError> {
    // Create context
    let mut ctx = MlirContext::new();
    
    // Lower MIR to MLIR
    let mut lowering = MirToMlir::new(&mut ctx);
    let mut module = lowering.lower_module(functions);
    
    // Create pass manager
    let mut pm_options = PassManagerOptions::default();
    pm_options.print_after_all = config.print_ir;
    pm_options.verify_after_all = config.verify;
    
    // Run optimization passes
    let opt_pm = PassManager::create_optimization_pipeline(config.opt_level);
    if opt_pm.run(&mut module, &mut ctx) == PassResult::Failure {
        return Err(CompileError::OptimizationFailed);
    }
    
    // Run lowering passes
    let lower_pm = PassManager::create_lowering_pipeline();
    if lower_pm.run(&mut module, &mut ctx) == PassResult::Failure {
        return Err(CompileError::LoweringFailed);
    }
    
    // Create target machine
    let target_machine = TargetMachine::new(config.target.clone())
        .with_relocation_model(if config.pic {
            RelocationModel::Pic
        } else {
            RelocationModel::Static
        });
    
    // Translate to LLVM IR
    let mut translator = MlirToLlvm::new().with_target(target_machine);
    let llvm_module = translator.translate(&module);
    
    // Emit LLVM IR text
    Ok(llvm_module.emit())
}

/// Compilation error
#[derive(Debug, Clone)]
pub enum CompileError {
    ParseError(String),
    TypeError(String),
    LoweringFailed,
    OptimizationFailed,
    CodegenFailed,
    TargetError(String),
}

impl std::fmt::Display for CompileError {
    fn fmt(&self, f: &mut std::fmt::Formatter<'_>) -> std::fmt::Result {
        match self {
            CompileError::ParseError(msg) => write!(f, "Parse error: {}", msg),
            CompileError::TypeError(msg) => write!(f, "Type error: {}", msg),
            CompileError::LoweringFailed => write!(f, "MIR to MLIR lowering failed"),
            CompileError::OptimizationFailed => write!(f, "Optimization pass failed"),
            CompileError::CodegenFailed => write!(f, "Code generation failed"),
            CompileError::TargetError(msg) => write!(f, "Target error: {}", msg),
        }
    }
}

