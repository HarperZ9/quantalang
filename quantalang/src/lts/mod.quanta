// ═══════════════════════════════════════════════════════════════════════════════
// TESTS
// ═══════════════════════════════════════════════════════════════════════════════

#[cfg(test)]
mod tests {
    use super::*;
    
    #[test]
    fn test_version_info() {
        let info = VersionInfo::current();
        assert_eq!(info.version, CURRENT_VERSION);
        assert!(info.is_lts());
    }
    
    #[test]
    fn test_compatibility_same_version() {
        let v = Version::new(1, 0, 0);
        let result = check_compatibility(&v, &v);
        assert!(result.compatible);
        assert_eq!(result.level, CompatibilityLevel::Full);
    }
    
    #[test]
    fn test_compatibility_major_change() {
        let v1 = Version::new(1, 0, 0);
        let v2 = Version::new(2, 0, 0);
        let result = check_compatibility(&v1, &v2);
        assert!(!result.compatible);
        assert_eq!(result.level, CompatibilityLevel::Incompatible);
    }
    
    #[test]
    fn test_edition() {
        assert!(Edition::E2024.is_stable());
        assert!(!Edition::E2027.is_stable());
        assert!(Edition::E2024 < Edition::E2027);
    }
}
