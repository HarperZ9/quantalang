// VERSION CONSTANTS
// ═══════════════════════════════════════════════════════════════════════════════

/// Current QuantaLang version
pub const CURRENT_VERSION: &str = "1.0.0";

/// Current LTS version
pub const CURRENT_LTS: &str = "1.0.0";

/// Minimum supported version
pub const MIN_SUPPORTED: &str = "1.0.0";

// ═══════════════════════════════════════════════════════════════════════════════
// VERSION INFO
// ═══════════════════════════════════════════════════════════════════════════════

/// Detailed version information
#[derive(Debug, Clone)]
pub struct VersionInfo {
    /// Version string
    pub version: String,
    
    /// Channel
    pub channel: Channel,
    
    /// Commit hash
    pub commit: String,
    
    /// Build date
    pub build_date: String,
    
    /// Compiler version used
    pub compiler: String,
    
    /// Target triple
    pub target: String,
    
    /// Features enabled
    pub features: Vec<String>,
}

impl VersionInfo {
    /// Get current version info
    pub fn current() -> Self {
        VersionInfo {
            version: CURRENT_VERSION.to_string(),
            channel: Channel::Lts,
            commit: env!("CARGO_PKG_VERSION").to_string(),
            build_date: "2025-01-01".to_string(),
            compiler: "quantac 1.0.0".to_string(),
            target: std::env::consts::ARCH.to_string(),
            features: vec![
                "std".to_string(),
                "alloc".to_string(),
            ],
        }
    }
    
    /// Parse version
    pub fn parse_version(&self) -> Option<Version> {
        Version::parse(&self.version)
    }
    
    /// Is this an LTS version?
    pub fn is_lts(&self) -> bool {
        self.channel == Channel::Lts
    }
    
    /// Full version string
    pub fn full_string(&self) -> String {
        format!(
            "{} ({} {}) [{}]",
            self.version,
            self.commit,
            self.build_date,
            self.target
        )
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// COMPATIBILITY CHECK
// ═══════════════════════════════════════════════════════════════════════════════

/// Compatibility check result
#[derive(Debug, Clone)]
pub struct CompatibilityResult {
    /// Is compatible?
    pub compatible: bool,
    
    /// Compatibility level
    pub level: CompatibilityLevel,
    
    /// Warnings
    pub warnings: Vec<String>,
    
    /// Errors (if not compatible)
    pub errors: Vec<String>,
    
    /// Recommended version
    pub recommended: Option<Version>,
}

/// Compatibility level
#[derive(Debug, Clone, Copy, PartialEq, Eq)]
pub enum CompatibilityLevel {
    /// Fully compatible
    Full,
    /// Compatible with deprecation warnings
    Deprecated,
    /// Compatible but unsupported
    Unsupported,
    /// Incompatible
    Incompatible,
}

/// Check compatibility between versions
pub fn check_compatibility(from: &Version, to: &Version) -> CompatibilityResult {
    // Same version is always compatible
    if from == to {
        return CompatibilityResult {
            compatible: true,
            level: CompatibilityLevel::Full,
            warnings: vec![],
            errors: vec![],
            recommended: None,
        };
    }
    
    // Major version change = breaking
    if from.major != to.major {
        return CompatibilityResult {
            compatible: false,
            level: CompatibilityLevel::Incompatible,
            warnings: vec![],
            errors: vec![
                format!(
                    "Major version change from {} to {} may contain breaking changes",
                    from.major, to.major
                ),
            ],
            recommended: Some(Version::new(from.major, from.minor + 1, 0)),
        };
    }
    
    // Minor version increase is forward compatible
    if to.minor > from.minor {
        return CompatibilityResult {
            compatible: true,
            level: CompatibilityLevel::Full,
            warnings: vec![
                format!(
                    "Some features from {} may not be available in {}",
                    to, from
                ),
            ],
            errors: vec![],
            recommended: None,
        };
    }
    
    // Patch version is fully compatible
    CompatibilityResult {
        compatible: true,
        level: CompatibilityLevel::Full,
        warnings: vec![],
        errors: vec![],
        recommended: None,
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// EDITION
// ═══════════════════════════════════════════════════════════════════════════════

/// Language edition (like Rust editions)
#[derive(Debug, Clone, Copy, PartialEq, Eq, PartialOrd, Ord)]
pub enum Edition {
    /// 2024 edition (initial release)
    E2024,
    /// 2027 edition (planned)
    E2027,
    /// 2030 edition (planned)
    E2030,
}

impl Edition {
    pub fn year(&self) -> u32 {
        match self {
            Edition::E2024 => 2024,
            Edition::E2027 => 2027,
            Edition::E2030 => 2030,
        }
    }
    
    pub fn is_stable(&self) -> bool {
        match self {
            Edition::E2024 => true,
            Edition::E2027 => false,
            Edition::E2030 => false,
        }
    }
    
    /// Features enabled in this edition
    pub fn features(&self) -> &'static [&'static str] {
        match self {
            Edition::E2024 => &[
                "async_await",
                "pattern_matching",
                "type_inference",
                "generics",
                "traits",
                "modules",
                "error_handling",
            ],
            Edition::E2027 => &[
                // All 2024 features plus
                "effect_system",
                "linear_types",
                "compile_time_reflection",
            ],
            Edition::E2030 => &[
                // All 2027 features plus
                "dependent_types",
                "refinement_types",
            ],
        }
    }
}

impl Default for Edition {
    fn default() -> Self {
        Edition::E2024
    }
}

impl std::fmt::Display for Edition {
    fn fmt(&self, f: &mut std::fmt::Formatter<'_>) -> std::fmt::Result {
        write!(f, "{}", self.year())
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// MIGRATION
// ═══════════════════════════════════════════════════════════════════════════════

/// Migration assistance
pub struct MigrationGuide {
    from: Version,
    to: Version,
    steps: Vec<MigrationStep>,
}

pub struct MigrationStep {
    pub order: u32,
    pub title: String,
    pub description: String,
    pub automated: bool,
    pub command: Option<String>,
}

impl MigrationGuide {
    pub fn new(from: Version, to: Version) -> Self {
        MigrationGuide {
            from,
            to,
            steps: Vec::new(),
        }
    }
    
    pub fn add_step(&mut self, step: MigrationStep) {
        self.steps.push(step);
    }
    
    /// Generate migration guide text
    pub fn generate(&self) -> String {
        let mut guide = format!(
            "# Migration Guide: {} → {}\n\n",
            self.from, self.to
        );
        
        for step in &self.steps {
            guide.push_str(&format!("## Step {}: {}\n\n", step.order, step.title));
            guide.push_str(&step.description);
            guide.push_str("\n\n");
            
            if step.automated {
                if let Some(ref cmd) = step.command {
                    guide.push_str(&format!("```bash\n{}\n```\n\n", cmd));
                }
            }
        }
        
        guide
    }
}

