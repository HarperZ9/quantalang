// ═══════════════════════════════════════════════════════════════════════════════
// TESTS
// ═══════════════════════════════════════════════════════════════════════════════

#[cfg(test)]
mod tests {
    use super::*;
    
    #[test]
    fn test_worker_node_creation() {
        let addr = "127.0.0.1:9876".parse().unwrap();
        let worker = WorkerNode::new(
            addr,
            WorkerCapabilities::default(),
            WorkerConfig::default(),
        );
        
        assert!(!worker.is_running());
    }
    
    #[test]
    fn test_worker_info() {
        let addr = "127.0.0.1:9876".parse().unwrap();
        let worker = WorkerNode::new(
            addr,
            WorkerCapabilities::default(),
            WorkerConfig::default(),
        );
        
        let info = worker.info();
        assert_eq!(info.status, WorkerStatus::Idle);
        assert_eq!(info.load, 0.0);
    }
    
    #[test]
    fn test_build_client() {
        let addr = "127.0.0.1:9876".parse().unwrap();
        let client = BuildClient::new(addr, ClientConfig::default());
        
        assert!(client.submitted_jobs.is_empty());
    }
}
