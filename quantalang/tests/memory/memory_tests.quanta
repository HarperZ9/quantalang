// @test: ownership_clone
// @compile: success
// @run: exit(0), stdout_exact("hello\nhello\n")
// @tags: memory, ownership

fn main() {
    let s1 = String::from("hello");
    let s2 = s1.clone();  // Explicit clone
    
    println(s1);  // Still valid
    println(s2);
}

