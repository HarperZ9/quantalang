// ═══════════════════════════════════════════════════════════════════════════════
// tests/memory/slice_ref.quanta
// ═══════════════════════════════════════════════════════════════════════════════

// @test: slice_ref
// @compile: success
// @run: exit(0), stdout("15")
// @tags: memory, slices

fn sum(slice: &[i32]) -> i32 {
    let mut total = 0;
    for &x in slice {
        total += x;
    }
    total
}

fn main() {
    let arr = [1, 2, 3, 4, 5];
    println(sum(&arr));
}

// ═══════════════════════════════════════════════════════════════════════════════
// tests/memory/string_slice.quanta
// ═══════════════════════════════════════════════════════════════════════════════

// @test: string_slice
// @compile: success
// @run: exit(0), stdout("hello")
// @tags: memory, strings, slices

fn first_word(s: &str) -> &str {
    let bytes = s.as_bytes();
    
    for (i, &b) in bytes.iter().enumerate() {
        if b == b' ' {
            return &s[0..i];
        }
    }
    
    &s[..]
}

fn main() {
    let s = "hello world";
    let word = first_word(s);
    println(word);
}

