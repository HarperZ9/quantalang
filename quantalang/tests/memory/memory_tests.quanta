// @test: error_two_mut
// @compile: error("cannot borrow", kind:borrow)
// @tags: memory, errors

fn main() {
    let mut s = String::from("hello");
    
    let r1 = &mut s;
    let r2 = &mut s;  // Error: two mutable borrows
    
    println(r1);
    println(r2);
}

