// tests/memory/lifetime_basic.quanta
// ═══════════════════════════════════════════════════════════════════════════════

// @test: lifetime_basic
// @compile: success
// @run: exit(0), stdout("abc")
// @tags: memory, lifetimes

fn longest<'a>(x: &'a str, y: &'a str) -> &'a str {
    if x.len() > y.len() {
        x
    } else {
        y
    }
}

fn main() {
    let s1 = "abc";
    let s2 = "ab";
    
    let result = longest(s1, s2);
    println(result);
}

