// @test: error_dangling_ref
// @compile: error("does not live long enough", kind:borrow)
// @tags: memory, errors

fn dangle() -> &String {
    let s = String::from("hello");
    &s  // Error: returning reference to local
}

fn main() {
    let r = dangle();
}

