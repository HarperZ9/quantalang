// tests/memory/ownership_move.quanta
// ═══════════════════════════════════════════════════════════════════════════════

// @test: ownership_move
// @compile: success
// @run: exit(0), stdout("hello")
// @tags: memory, ownership

fn main() {
    let s1 = String::from("hello");
    let s2 = s1;  // s1 is moved to s2
    
    println(s2);
    // println(s1);  // Error: s1 was moved
}

// ═══════════════════════════════════════════════════════════════════════════════
// tests/memory/ownership_copy.quanta
// ═══════════════════════════════════════════════════════════════════════════════

// @test: ownership_copy
// @compile: success
// @run: exit(0), stdout_exact("5\n5\n")
// @tags: memory, ownership

fn main() {
    let x = 5;
    let y = x;  // x is copied (i32 implements Copy)
    
    println(x);  // Still valid
    println(y);
}

