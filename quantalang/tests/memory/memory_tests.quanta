// @test: refcell
// @compile: success
// @run: exit(0), stdout_exact("5\n10\n")
// @tags: memory, refcell

use std::cell::RefCell;

fn main() {
    let data = RefCell::new(5);
    
    println(*data.borrow());
    
    *data.borrow_mut() = 10;
    
    println(*data.borrow());
}

