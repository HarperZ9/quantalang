// @test: arc_basic
// @compile: success
// @run: exit(0), stdout("count: 3")
// @tags: memory, arc, threads

use std::sync::Arc;

fn main() {
    let data = Arc::new(vec![1, 2, 3]);
    
    let a = Arc::clone(&data);
    let b = Arc::clone(&data);
    
    println("count: {}", Arc::strong_count(&data));
}

