// tests/memory/error_mut_and_immut.quanta
// ═══════════════════════════════════════════════════════════════════════════════

// @test: error_mut_and_immut
// @compile: error("cannot borrow", kind:borrow)
// @tags: memory, errors

fn main() {
    let mut s = String::from("hello");
    
    let r1 = &s;      // Immutable borrow
    let r2 = &mut s;  // Error: mutable borrow while immutable exists
    
    println(r1);
}

