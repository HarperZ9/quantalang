// ═══════════════════════════════════════════════════════════════════════════════
// tests/memory/box_recursive.quanta
// ═══════════════════════════════════════════════════════════════════════════════

// @test: box_recursive
// @compile: success
// @run: exit(0), stdout("1 -> 2 -> 3 -> Nil")
// @tags: memory, heap, recursive

enum List {
    Cons(i32, Box<List>),
    Nil,
}

use List::{Cons, Nil};

fn print_list(list: &List) {
    match list {
        Cons(val, next) => {
            print("{} -> ", val);
            print_list(next);
        }
        Nil => println("Nil"),
    }
}

fn main() {
    let list = Cons(1, Box::new(Cons(2, Box::new(Cons(3, Box::new(Nil))))));
    print_list(&list);
}

// ═══════════════════════════════════════════════════════════════════════════════
// tests/memory/rc_basic.quanta
// ═══════════════════════════════════════════════════════════════════════════════

// @test: rc_basic
// @compile: success
// @run: exit(0), stdout_exact("a count: 1\na count: 2\nb count: 2\n")
// @tags: memory, rc

use std::rc::Rc;

fn main() {
    let a = Rc::new(5);
    println("a count: {}", Rc::strong_count(&a));
    
    let b = Rc::clone(&a);
    println("a count: {}", Rc::strong_count(&a));
    println("b count: {}", Rc::strong_count(&b));
}

