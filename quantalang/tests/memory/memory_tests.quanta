// tests/memory/error_lifetime_mismatch.quanta
// ═══════════════════════════════════════════════════════════════════════════════

// @test: error_lifetime_mismatch
// @compile: error("lifetime", kind:borrow)
// @tags: memory, errors, lifetimes

fn longest<'a>(x: &'a str, y: &str) -> &'a str {
    y  // Error: y doesn't have lifetime 'a
}

fn main() {
    let s1 = "hello";
    let s2 = "world";
    println(longest(s1, s2));
}

