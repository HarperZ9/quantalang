}

// ═══════════════════════════════════════════════════════════════════════════════
// tests/memory/drop_trait.quanta
// ═══════════════════════════════════════════════════════════════════════════════

// @test: drop_trait
// @compile: success
// @run: exit(0), stdout_exact("Created Resource\nDropping Resource!\nAfter drop\n")
// @tags: memory, drop

struct Resource {
    name: String,
}

impl Drop for Resource {
    fn drop(&mut self) {
        println("Dropping {}!", self.name);
    }
}

fn main() {
    let r = Resource { name: String::from("Resource") };
    println("Created {}", r.name);
    drop(r);  // Explicit drop
    println("After drop");
}

// ═══════════════════════════════════════════════════════════════════════════════
// tests/memory/weak_ref.quanta
// ═══════════════════════════════════════════════════════════════════════════════

// @test: weak_ref
// @compile: success
// @run: exit(0), stdout_exact("Some(5)\nNone\n")
// @tags: memory, weak

use std::rc::{Rc, Weak};

fn main() {
    let strong = Rc::new(5);
    let weak = Rc::downgrade(&strong);
    
    // Can upgrade while strong ref exists
    println("{:?}", weak.upgrade());
    
    drop(strong);
    
    // Cannot upgrade after strong refs gone
    println("{:?}", weak.upgrade());
}

