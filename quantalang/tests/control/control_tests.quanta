// ═══════════════════════════════════════════════════════════════════════════════
// tests/control/for_enumerate.quanta
// ═══════════════════════════════════════════════════════════════════════════════

// @test: for_enumerate
// @compile: success
// @run: exit(0), stdout_exact("0: a\n1: b\n2: c\n")
// @tags: control, loops, iterators

fn main() {
    let arr = ['a', 'b', 'c'];
    
    for (i, c) in arr.iter().enumerate() {
        println("{}: {}", i, c);
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// tests/control/break_outer.quanta
// ═══════════════════════════════════════════════════════════════════════════════

// @test: break_outer
// @compile: success
// @run: exit(0), stdout("found at 1, 2")
// @tags: control, loops

fn main() {
    'outer: for i in 0..5 {
        for j in 0..5 {
            if i == 1 && j == 2 {
                println("found at {}, {}", i, j);
                break 'outer;
            }
        }
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// tests/control/continue_loop.quanta
// ═══════════════════════════════════════════════════════════════════════════════

// @test: continue_loop
// @compile: success
// @run: exit(0), stdout_exact("1\n3\n5\n7\n9\n")
// @tags: control, loops

fn main() {
    for i in 0..10 {
        if i % 2 == 0 {
            continue;
        }
        println(i);
    }
}

