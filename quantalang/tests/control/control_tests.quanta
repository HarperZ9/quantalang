    println("got {}", x);
}

// ═══════════════════════════════════════════════════════════════════════════════
// tests/control/early_return.quanta
// ═══════════════════════════════════════════════════════════════════════════════

// @test: early_return
// @compile: success
// @run: exit(0), stdout("-1")
// @tags: control, functions

fn find_first_negative(arr: &[i32]) -> Option<i32> {
    for &x in arr {
        if x < 0 {
            return Some(x);
        }
    }
    None
}

fn main() {
    let arr = [1, 2, -1, 4];
    match find_first_negative(&arr) {
        Some(x) => println(x),
        None => println("none found"),
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// tests/control/question_mark.quanta
// ═══════════════════════════════════════════════════════════════════════════════

// @test: question_mark
// @compile: success
// @run: exit(0), stdout("21")
// @tags: control, error_handling

fn divide(a: i32, b: i32) -> Option<i32> {
    if b == 0 {
        None
    } else {
        Some(a / b)
    }
}

fn calculate() -> Option<i32> {
    let x = divide(100, 2)?;  // 50
    let y = divide(x, 2)?;    // 25
    let z = divide(y - 4, 1)?; // 21
    Some(z)
}

fn main() {
    match calculate() {
        Some(result) => println(result),
        None => println("error"),
    }
}
