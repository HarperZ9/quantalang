// ═══════════════════════════════════════════════════════════════════════════════
// tests/control/if_else.quanta
// ═══════════════════════════════════════════════════════════════════════════════

// @test: if_else
// @compile: success
// @run: exit(0), stdout("positive")
// @tags: control, if

fn main() {
    let x = 10;
    
    if x > 0 {
        println("positive");
    } else {
        println("non-positive");
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// tests/control/if_else_if.quanta
// ═══════════════════════════════════════════════════════════════════════════════

// @test: if_else_if
// @compile: success
// @run: exit(0), stdout("medium")
// @tags: control, if

fn main() {
    let x = 50;
    
    if x < 10 {
        println("small");
    } else if x < 100 {
        println("medium");
    } else {
        println("large");
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// tests/control/if_expression.quanta
// ═══════════════════════════════════════════════════════════════════════════════

// @test: if_expression
// @compile: success
// @run: exit(0), stdout("even")
// @tags: control, if

fn main() {
    let x = 10;
    
    let result = if x % 2 == 0 {
        "even"
    } else {
        "odd"
    };
    
    println(result);
}

// ═══════════════════════════════════════════════════════════════════════════════
// tests/control/nested_if.quanta
// ═══════════════════════════════════════════════════════════════════════════════

// @test: nested_if
// @compile: success
// @run: exit(0), stdout("A")
// @tags: control, if

fn main() {
    let score = 95;
    
    let grade = if score >= 90 {
        if score >= 97 {
            "A+"
        } else {
            "A"
        }
    } else if score >= 80 {
        "B"
    } else {
        "C"
    };
    
    println(grade);
}

// ═══════════════════════════════════════════════════════════════════════════════
// tests/control/while_loop.quanta
// ═══════════════════════════════════════════════════════════════════════════════

// @test: while_loop
// @compile: success
// @run: exit(0), stdout_exact("0\n1\n2\n3\n4\n")
// @tags: control, loops

fn main() {
    let mut i = 0;
    
    while i < 5 {
        println(i);
        i = i + 1;
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// tests/control/loop_infinite.quanta
// ═══════════════════════════════════════════════════════════════════════════════

// @test: loop_infinite
// @compile: success
// @run: exit(0), stdout("5")
// @tags: control, loops

fn main() {
    let mut i = 0;
    
    loop {
        i = i + 1;
        if i == 5 {
            break;
        }
    }
    
    println(i);
}

// ═══════════════════════════════════════════════════════════════════════════════
// tests/control/loop_with_value.quanta
// ═══════════════════════════════════════════════════════════════════════════════

// @test: loop_with_value
// @compile: success
// @run: exit(0), stdout("10")
// @tags: control, loops

fn main() {
    let mut counter = 0;
    
    let result = loop {
        counter = counter + 1;
        
        if counter == 10 {
            break counter;
        }
    };
    
    println(result);
}

