// @test: nested_loops
// @compile: success
// @run: exit(0), stdout_exact("0,0\n0,1\n0,2\n1,0\n1,1\n1,2\n")
// @tags: control, loops

fn main() {
    for i in 0..2 {
        for j in 0..3 {
            println("{},{}", i, j);
        }
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// tests/control/match_basic.quanta
// ═══════════════════════════════════════════════════════════════════════════════

// @test: match_basic
// @compile: success
// @run: exit(0), stdout("two")
// @tags: control, match

fn main() {
    let x = 2;
    
    let result = match x {
        1 => "one",
        2 => "two",
        3 => "three",
        _ => "other",
    };
    
    println(result);
}

// ═══════════════════════════════════════════════════════════════════════════════
// tests/control/match_range.quanta
// ═══════════════════════════════════════════════════════════════════════════════

// @test: match_range
// @compile: success
// @run: exit(0), stdout("child")
// @tags: control, match

fn main() {
    let age = 10;
    
    let category = match age {
        0..=12 => "child",
        13..=19 => "teenager",
        20..=64 => "adult",
        _ => "senior",
    };
    
    println(category);
}

// ═══════════════════════════════════════════════════════════════════════════════
// tests/control/match_or.quanta
// ═══════════════════════════════════════════════════════════════════════════════

// @test: match_or
// @compile: success
// @run: exit(0), stdout("small prime")
// @tags: control, match

fn main() {
    let x = 3;
    
    let result = match x {
        2 | 3 | 5 | 7 => "small prime",
        1 | 4 | 6 | 8 | 9 | 10 => "small composite",
        _ => "larger number",
    };
    
    println(result);
}

// ═══════════════════════════════════════════════════════════════════════════════
// tests/control/match_guard.quanta
// ═══════════════════════════════════════════════════════════════════════════════

// @test: match_guard
// @compile: success
// @run: exit(0), stdout("positive even")
// @tags: control, match

fn main() {
    let x = 4;
    
    let result = match x {
        n if n < 0 => "negative",
        n if n == 0 => "zero",
        n if n % 2 == 0 => "positive even",
        _ => "positive odd",
    };
    
    println(result);
}

// ═══════════════════════════════════════════════════════════════════════════════
// tests/control/match_binding.quanta
// ═══════════════════════════════════════════════════════════════════════════════

// @test: match_binding
// @compile: success
// @run: exit(0), stdout("got value: 42")
// @tags: control, match

fn main() {
    let x = Some(42);
    
    match x {
        Some(value) => println("got value: {}", value),
        None => println("got nothing"),
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// tests/control/match_tuple.quanta
// ═══════════════════════════════════════════════════════════════════════════════

// @test: match_tuple
// @compile: success
// @run: exit(0), stdout("first quadrant")
// @tags: control, match

fn main() {
    let point = (3, 5);
    
    let location = match point {
        (0, 0) => "origin",
        (x, 0) => "on x-axis",
        (0, y) => "on y-axis",
        (x, y) if x > 0 && y > 0 => "first quadrant",
        (x, y) if x < 0 && y > 0 => "second quadrant",
        (x, y) if x < 0 && y < 0 => "third quadrant",
        _ => "fourth quadrant",
    };
    
    println(location);
}

// ═══════════════════════════════════════════════════════════════════════════════
// tests/control/match_struct.quanta
// ═══════════════════════════════════════════════════════════════════════════════

// @test: match_struct
// @compile: success
// @run: exit(0), stdout("red pixel at (10, 20)")
// @tags: control, match, structs

struct Point { x: i32, y: i32 }
enum Color { Red, Green, Blue }
struct Pixel { pos: Point, color: Color }

fn main() {
    let pixel = Pixel {
        pos: Point { x: 10, y: 20 },
        color: Color::Red,
    };
    
    match pixel {
        Pixel { pos: Point { x, y }, color: Color::Red } => {
            println("red pixel at ({}, {})", x, y);
        }
        Pixel { color: Color::Green, .. } => println("green pixel"),
        Pixel { color: Color::Blue, .. } => println("blue pixel"),
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// tests/control/match_at.quanta
// ═══════════════════════════════════════════════════════════════════════════════

// @test: match_at
// @compile: success
// @run: exit(0), stdout("special value: 42")
// @tags: control, match

fn main() {
    let x = 42;
    
    match x {
        n @ 1..=50 if n % 2 == 0 => println("special value: {}", n),
        n @ 1..=50 => println("small odd: {}", n),
        n => println("large: {}", n),
    }
}

