module std::fs

use alloc::string::String;
use alloc::vec::Vec;
use crate::io::{self, Read, Write, Seek, SeekFrom, Result, Error, ErrorKind};
use crate::path::{Path, PathBuf};
use crate::time::SystemTime;

// ═══════════════════════════════════════════════════════════════════════════════
// FILE
// ═══════════════════════════════════════════════════════════════════════════════

/// A file handle
pub struct File {
    inner: crate::sys::File,
}

impl File {
    /// Open a file in read-only mode
    pub fn open<P: AsRef<Path>>(path: P) -> Result<File> {
        OpenOptions::new().read(true).open(path)
    }
    
    /// Create a file for writing (truncates if exists)
    pub fn create<P: AsRef<Path>>(path: P) -> Result<File> {
        OpenOptions::new()
            .write(true)
            .create(true)
            .truncate(true)
            .open(path)
    }
    
    /// Create a new file (fails if exists)
    pub fn create_new<P: AsRef<Path>>(path: P) -> Result<File> {
        OpenOptions::new()
            .write(true)
            .create_new(true)
            .open(path)
    }
    
    /// Open with options
    pub fn options() -> OpenOptions {
        OpenOptions::new()
    }
    
    /// Sync all data to disk
    pub fn sync_all(&self) -> Result<()> {
        self.inner.sync_all()
    }
    
    /// Sync data (not metadata) to disk
    pub fn sync_data(&self) -> Result<()> {
        self.inner.sync_data()
    }
    
    /// Set file length
    pub fn set_len(&self, size: u64) -> Result<()> {
        self.inner.set_len(size)
    }
    
    /// Get file metadata
    pub fn metadata(&self) -> Result<Metadata> {
        self.inner.metadata()
    }
    
    /// Try to clone the file handle
    pub fn try_clone(&self) -> Result<File> {
        Ok(File {
            inner: self.inner.try_clone()?,
        })
    }
    
    /// Set permissions
    pub fn set_permissions(&self, perm: Permissions) -> Result<()> {
        self.inner.set_permissions(perm)
    }
}

impl Read for File {
    fn read(&mut self, buf: &mut [u8]) -> Result<usize> {
        self.inner.read(buf)
    }
}

impl Write for File {
    fn write(&mut self, buf: &[u8]) -> Result<usize> {
        self.inner.write(buf)
    }
    
    fn flush(&mut self) -> Result<()> {
        self.inner.flush()
    }
}

impl Seek for File {
    fn seek(&mut self, pos: SeekFrom) -> Result<u64> {
        self.inner.seek(pos)
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// OPEN OPTIONS
// ═══════════════════════════════════════════════════════════════════════════════

/// Options for opening files
#[derive(Clone, Debug)]
pub struct OpenOptions {
    read: bool,
    write: bool,
    append: bool,
    truncate: bool,
    create: bool,
    create_new: bool,
    mode: u32,
}

impl OpenOptions {
    /// Create new open options
    pub fn new() -> Self {
        OpenOptions {
            read: false,
            write: false,
            append: false,
            truncate: false,
            create: false,
            create_new: false,
            mode: 0o666,
        }
    }
    
    /// Set read access
    pub fn read(&mut self, read: bool) -> &mut Self {
        self.read = read;
        self
    }
    
    /// Set write access
    pub fn write(&mut self, write: bool) -> &mut Self {
        self.write = write;
        self
    }
    
    /// Set append mode
    pub fn append(&mut self, append: bool) -> &mut Self {
        self.append = append;
        self
    }
    
    /// Set truncate mode
    pub fn truncate(&mut self, truncate: bool) -> &mut Self {
        self.truncate = truncate;
        self
    }
    
    /// Create file if not exists
    pub fn create(&mut self, create: bool) -> &mut Self {
        self.create = create;
        self
    }
    
    /// Create new file (fail if exists)
    pub fn create_new(&mut self, create_new: bool) -> &mut Self {
        self.create_new = create_new;
        self
    }
    
    /// Set Unix mode (permissions)
    pub fn mode(&mut self, mode: u32) -> &mut Self {
        self.mode = mode;
        self
    }
    
    /// Open the file
    pub fn open<P: AsRef<Path>>(&self, path: P) -> Result<File> {
        crate::sys::open(path.as_ref(), self).map(|inner| File { inner })
    }
}

impl Default for OpenOptions {
    fn default() -> Self {
        Self::new()
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// METADATA
// ═══════════════════════════════════════════════════════════════════════════════

/// File metadata
#[derive(Clone)]
pub struct Metadata {
    inner: crate::sys::Metadata,
}

impl Metadata {
    /// Returns true if this is a file
    pub fn is_file(&self) -> bool {
        self.inner.is_file()
    }
    
    /// Returns true if this is a directory
    pub fn is_dir(&self) -> bool {
        self.inner.is_dir()
    }
    
    /// Returns true if this is a symbolic link
    pub fn is_symlink(&self) -> bool {
        self.inner.is_symlink()
    }
    
    /// Get file size in bytes
    pub fn len(&self) -> u64 {
        self.inner.len()
    }
    
    /// Returns true if file is empty
    pub fn is_empty(&self) -> bool {
        self.len() == 0
    }
    
    /// Get file permissions
    pub fn permissions(&self) -> Permissions {
        self.inner.permissions()
    }
    
    /// Get modification time
    pub fn modified(&self) -> Result<SystemTime> {
        self.inner.modified()
    }
    
    /// Get access time
    pub fn accessed(&self) -> Result<SystemTime> {
        self.inner.accessed()
    }
    
    /// Get creation time
    pub fn created(&self) -> Result<SystemTime> {
        self.inner.created()
    }
    
    /// Get file type
    pub fn file_type(&self) -> FileType {
        self.inner.file_type()
    }
}

/// File type
#[derive(Clone, Copy, PartialEq, Eq, Debug)]
pub struct FileType {
    inner: crate::sys::FileType,
}

impl FileType {
    /// Returns true if this is a file
    pub fn is_file(&self) -> bool {
        self.inner.is_file()
    }
    
    /// Returns true if this is a directory
    pub fn is_dir(&self) -> bool {
        self.inner.is_dir()
    }
    
    /// Returns true if this is a symbolic link
    pub fn is_symlink(&self) -> bool {
        self.inner.is_symlink()
    }
}

/// File permissions
#[derive(Clone, Copy, PartialEq, Eq, Debug)]
pub struct Permissions {
    mode: u32,
}

impl Permissions {
    /// Returns true if the file is read-only
    pub fn readonly(&self) -> bool {
        (self.mode & 0o222) == 0
    }
    
    /// Set read-only mode
    pub fn set_readonly(&mut self, readonly: bool) {
        if readonly {
            self.mode &= !0o222;
        } else {
            self.mode |= 0o222;
        }
    }
    
    /// Get Unix mode
    pub fn mode(&self) -> u32 {
        self.mode
    }
    
    /// Set Unix mode
    pub fn set_mode(&mut self, mode: u32) {
        self.mode = mode;
    }
    
    /// Create from mode
    pub fn from_mode(mode: u32) -> Self {
        Permissions { mode }
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// DIRECTORY OPERATIONS
// ═══════════════════════════════════════════════════════════════════════════════

/// Directory entry
pub struct DirEntry {
    inner: crate::sys::DirEntry,
}

impl DirEntry {
    /// Get the path of this entry
    pub fn path(&self) -> PathBuf {
        self.inner.path()
    }
    
    /// Get the file name
    pub fn file_name(&self) -> String {
        self.inner.file_name()
    }
    
    /// Get metadata
    pub fn metadata(&self) -> Result<Metadata> {
        self.inner.metadata()
    }
    
    /// Get file type
    pub fn file_type(&self) -> Result<FileType> {
        self.inner.file_type()
    }
}

/// Directory iterator
pub struct ReadDir {
    inner: crate::sys::ReadDir,
}

impl Iterator for ReadDir {
    type Item = Result<DirEntry>;
    
    fn next(&mut self) -> Option<Self::Item> {
        self.inner.next().map(|r| r.map(|inner| DirEntry { inner }))
    }
}

/// Read a directory
pub fn read_dir<P: AsRef<Path>>(path: P) -> Result<ReadDir> {
    crate::sys::read_dir(path.as_ref()).map(|inner| ReadDir { inner })
}

/// Create a directory
pub fn create_dir<P: AsRef<Path>>(path: P) -> Result<()> {
    crate::sys::create_dir(path.as_ref())
}

/// Create a directory and all parent directories
pub fn create_dir_all<P: AsRef<Path>>(path: P) -> Result<()> {
    let path = path.as_ref();
    
    if path.is_dir() {
        return Ok(());
    }
    
    if let Some(parent) = path.parent() {
        if !parent.as_os_str().is_empty() {
            create_dir_all(parent)?;
        }
    }
    
    match create_dir(path) {
        Ok(()) => Ok(()),
        Err(ref e) if e.kind() == ErrorKind::AlreadyExists => Ok(()),
        Err(e) => Err(e),
    }
}

/// Remove an empty directory
pub fn remove_dir<P: AsRef<Path>>(path: P) -> Result<()> {
    crate::sys::remove_dir(path.as_ref())
}

/// Remove a directory and all its contents
pub fn remove_dir_all<P: AsRef<Path>>(path: P) -> Result<()> {
    let path = path.as_ref();
    
    for entry in read_dir(path)? {
        let entry = entry?;
        let entry_path = entry.path();
        
        if entry.file_type()?.is_dir() {
            remove_dir_all(&entry_path)?;
        } else {
            remove_file(&entry_path)?;
        }
    }
    
    remove_dir(path)
}

// ═══════════════════════════════════════════════════════════════════════════════
// FILE OPERATIONS
// ═══════════════════════════════════════════════════════════════════════════════

/// Read entire file contents as bytes
pub fn read<P: AsRef<Path>>(path: P) -> Result<Vec<u8>> {
    let mut file = File::open(path)?;
    let mut buf = Vec::new();
    file.read_to_end(&mut buf)?;
    Ok(buf)
}

/// Read entire file contents as string
pub fn read_to_string<P: AsRef<Path>>(path: P) -> Result<String> {
    let mut file = File::open(path)?;
    let mut s = String::new();
    file.read_to_string(&mut s)?;
    Ok(s)
}

/// Write bytes to a file
pub fn write<P: AsRef<Path>, C: AsRef<[u8]>>(path: P, contents: C) -> Result<()> {
    let mut file = File::create(path)?;
    file.write_all(contents.as_ref())
}

/// Remove a file
pub fn remove_file<P: AsRef<Path>>(path: P) -> Result<()> {
    crate::sys::remove_file(path.as_ref())
}

/// Rename a file or directory
pub fn rename<P: AsRef<Path>, Q: AsRef<Path>>(from: P, to: Q) -> Result<()> {
    crate::sys::rename(from.as_ref(), to.as_ref())
}

/// Copy a file
pub fn copy<P: AsRef<Path>, Q: AsRef<Path>>(from: P, to: Q) -> Result<u64> {
    let mut reader = File::open(from)?;
    let mut writer = File::create(to)?;
    io::copy(&mut reader, &mut writer)
}

/// Create a hard link
pub fn hard_link<P: AsRef<Path>, Q: AsRef<Path>>(original: P, link: Q) -> Result<()> {
    crate::sys::hard_link(original.as_ref(), link.as_ref())
}

/// Read a symbolic link
pub fn read_link<P: AsRef<Path>>(path: P) -> Result<PathBuf> {
    crate::sys::read_link(path.as_ref())
}

/// Get file metadata
pub fn metadata<P: AsRef<Path>>(path: P) -> Result<Metadata> {
    crate::sys::metadata(path.as_ref()).map(|inner| Metadata { inner })
}

/// Get symbolic link metadata
pub fn symlink_metadata<P: AsRef<Path>>(path: P) -> Result<Metadata> {
    crate::sys::symlink_metadata(path.as_ref()).map(|inner| Metadata { inner })
}

/// Get canonical path
pub fn canonicalize<P: AsRef<Path>>(path: P) -> Result<PathBuf> {
    crate::sys::canonicalize(path.as_ref())
}

/// Set file permissions
pub fn set_permissions<P: AsRef<Path>>(path: P, perm: Permissions) -> Result<()> {
    crate::sys::set_permissions(path.as_ref(), perm)
}

// ═══════════════════════════════════════════════════════════════════════════════
// UNIX-SPECIFIC OPERATIONS
// ═══════════════════════════════════════════════════════════════════════════════

#[cfg(unix)]
pub mod unix {
    use super::*;
    
    /// Create a symbolic link
    pub fn symlink<P: AsRef<Path>, Q: AsRef<Path>>(original: P, link: Q) -> Result<()> {
        crate::sys::symlink(original.as_ref(), link.as_ref())
    }
    
    /// Change file owner
    pub fn chown<P: AsRef<Path>>(path: P, uid: Option<u32>, gid: Option<u32>) -> Result<()> {
        crate::sys::chown(path.as_ref(), uid, gid)
    }
    
    /// Get file metadata without following symlinks
    pub fn lstat<P: AsRef<Path>>(path: P) -> Result<Metadata> {
        crate::sys::lstat(path.as_ref()).map(|inner| Metadata { inner })
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// TEMPORARY FILES
// ═══════════════════════════════════════════════════════════════════════════════

/// Create a temporary file
pub fn temp_file() -> Result<(File, PathBuf)> {
    let dir = temp_dir();
    let name = format!("quanta_temp_{}", crate::sys::random_u64());
    let path = dir.join(&name);
    let file = File::create(&path)?;
    Ok((file, path))
}

/// Get the temporary directory
pub fn temp_dir() -> PathBuf {
    crate::sys::temp_dir()
}

// ═══════════════════════════════════════════════════════════════════════════════
// PATH EXISTENCE CHECKS
// ═══════════════════════════════════════════════════════════════════════════════

/// Check if path exists
pub fn exists<P: AsRef<Path>>(path: P) -> bool {
    metadata(path).is_ok()
}

/// Try to check if path exists
pub fn try_exists<P: AsRef<Path>>(path: P) -> Result<bool> {
    match metadata(path) {
        Ok(_) => Ok(true),
        Err(e) if e.kind() == ErrorKind::NotFound => Ok(false),
        Err(e) => Err(e),
    }
}
