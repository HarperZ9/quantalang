fn main() {
    println(PI_INT);
}

// ═══════════════════════════════════════════════════════════════════════════════
// tests/basic/type_inference.quanta
// ═══════════════════════════════════════════════════════════════════════════════

// @test: type_inference
// @compile: success
// @run: exit(0), stdout("42")
// @tags: basic, types

fn main() {
    let x = 42;           // Inferred as i32
    let y = 3.14;         // Inferred as f64
    let z = true;         // Inferred as bool
    let s = "hello";      // Inferred as &str
    let arr = [1, 2, 3];  // Inferred as [i32; 3]
    
    println(x);
}

