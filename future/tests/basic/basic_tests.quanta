    println(x);
}

// ═══════════════════════════════════════════════════════════════════════════════
// tests/basic/numeric_literals.quanta
// ═══════════════════════════════════════════════════════════════════════════════

// @test: numeric_literals
// @compile: success
// @run: exit(0), stdout_exact("255\n255\n255\n1000000\n3.14\n")
// @tags: basic, literals

fn main() {
    let decimal = 255;
    let hex = 0xFF;
    let binary = 0b11111111;
    let with_underscores = 1_000_000;
    let float = 3.14;
    
    println(decimal);
    println(hex);
    println(binary);
    println(with_underscores);
    println(float);
}

// ═══════════════════════════════════════════════════════════════════════════════
// tests/basic/string_literals.quanta
// ═══════════════════════════════════════════════════════════════════════════════

// @test: string_literals
// @compile: success
// @run: exit(0), stdout("hello\nworld")
// @tags: basic, literals

fn main() {
    let s1 = "hello";
    let s2 = "hello\nworld";  // Escape sequence
    let s3 = r"raw\nstring";  // Raw string
    
    println(s2);
}

// ═══════════════════════════════════════════════════════════════════════════════
// tests/basic/char_literals.quanta
// ═══════════════════════════════════════════════════════════════════════════════

// @test: char_literals
// @compile: success
// @run: exit(0), stdout_exact("A\n\n\n")
// @tags: basic, literals

fn main() {
    let c1 = 'A';
    let c2 = '\n';  // Newline
    let c3 = '\t';  // Tab
    let c4 = '\'';  // Escaped quote
    let c5 = '\\';  // Escaped backslash
    let c6 = '\u{1F600}';  // Unicode emoji
    
    println(c1);
    println(c2);
}

// ═══════════════════════════════════════════════════════════════════════════════
// tests/basic/unit_type.quanta
// ═══════════════════════════════════════════════════════════════════════════════

// @test: unit_type
// @compile: success
// @run: exit(0)
// @tags: basic, types

fn returns_nothing() {
    // Implicitly returns ()
}

fn explicit_unit() -> () {
    ()
}

fn main() {
    let _x: () = returns_nothing();
    let _y: () = explicit_unit();
}

// ═══════════════════════════════════════════════════════════════════════════════
// tests/basic/never_type.quanta
// ═══════════════════════════════════════════════════════════════════════════════

// @test: never_type
// @compile: success
// @run: exit(0), stdout("before")
// @tags: basic, types

fn diverges() -> ! {
    loop {}
}

fn main() {
    println("before");
    
    let x: i32 = if true {
        42
    } else {
        diverges()  // ! coerces to i32
    };
}

