// ═══════════════════════════════════════════════════════════════════════════════
// tests/basic/operators.quanta
// ═══════════════════════════════════════════════════════════════════════════════

// @test: operators
// @compile: success
// @run: exit(0), stdout_exact("15\n3\n54\n2\n1\n")
// @tags: basic, operators

fn main() {
    let a = 9;
    let b = 6;
    
    println(a + b);   // 15
    println(a - b);   // 3
    println(a * b);   // 54
    println(a / b);   // 1 (integer division)
    println(a % b);   // 3
}

// ═══════════════════════════════════════════════════════════════════════════════
// tests/basic/bitwise.quanta
// ═══════════════════════════════════════════════════════════════════════════════

// @test: bitwise
// @compile: success
// @run: exit(0), stdout_exact("0\n15\n15\n-6\n20\n2\n")
// @tags: basic, operators

fn main() {
    let a: i32 = 5;   // 0101
    let b: i32 = 10;  // 1010
    
    println(a & b);   // 0000 = 0
    println(a | b);   // 1111 = 15
    println(a ^ b);   // 1111 = 15
    println(!a);      // -6 (two's complement)
    println(a << 2);  // 10100 = 20
    println(a >> 1);  // 0010 = 2
}

// ═══════════════════════════════════════════════════════════════════════════════
// tests/basic/comparison.quanta
// ═══════════════════════════════════════════════════════════════════════════════

// @test: comparison
// @compile: success
// @run: exit(0), stdout_exact("false\ntrue\ntrue\nfalse\nfalse\ntrue\n")
// @tags: basic, operators

fn main() {
    let a = 5;
    let b = 10;
    
    println(a == b);  // false
    println(a != b);  // true
    println(a < b);   // true
    println(a > b);   // false
    println(a >= b);  // false
    println(a <= b);  // true
}

// ═══════════════════════════════════════════════════════════════════════════════
// tests/basic/logical.quanta
// ═══════════════════════════════════════════════════════════════════════════════

// @test: logical
// @compile: success
// @run: exit(0), stdout_exact("true\nfalse\ntrue\nfalse\n")
// @tags: basic, operators

fn main() {
    let t = true;
    let f = false;
    
    println(t && t);  // true
    println(t && f);  // false
    println(t || f);  // true
    println(!t);      // false
}

