fn main() {
    let x = 10;
    let mut y = 10;
    
    println(x);
    
    y = 20;
    println(y);
}

// ═══════════════════════════════════════════════════════════════════════════════
// tests/basic/shadowing.quanta
// ═══════════════════════════════════════════════════════════════════════════════

// @test: shadowing
// @compile: success
// @run: exit(0), stdout_exact("5\n10\nhello\n")
// @tags: basic, variables

fn main() {
    let x = 5;
    println(x);
    
    let x = 10;  // Shadows previous x
    println(x);
    
    let x = "hello";  // Can change type when shadowing
    println(x);
}

