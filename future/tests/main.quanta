#![feature(test)]

mod framework;
mod lexer_tests;
mod parser_tests;
mod semantic_tests;
mod e2e_tests;

use framework::*;
use std::env;
use std::path::Path;
use std::time::Duration;

// ═══════════════════════════════════════════════════════════════════════════════
// MAIN
// ═══════════════════════════════════════════════════════════════════════════════

fn main() {
    let args: Vec<String> = env::args().collect();
    let config = parse_args(&args);
    
    println!("╔══════════════════════════════════════════════════════════════════════════════╗");
    println!("║             QUANTALANG Integration Test Suite v1.0.0                       ║");
    println!("╠══════════════════════════════════════════════════════════════════════════════╣");
    println!("║  Target: {:<66} ║", config.target);
    println!("║  Optimization: -O{:<62} ║", config.optimization);
    println!("║  Jobs: {:<68} ║", config.jobs);
    println!("╚══════════════════════════════════════════════════════════════════════════════╝");
    println!();
    
    let mut runner = TestRunner::new(config.clone());
    
    // Register all test categories
    register_all_tests(&mut runner);
    
    // Load test files from directory if present
    let test_dir = Path::new("tests/ui");
    if test_dir.exists() {
        match runner.load_tests(test_dir) {
            Ok(count) => println!("Loaded {} tests from {}\n", count, test_dir.display()),
            Err(e) => eprintln!("Warning: Failed to load tests from {}: {}\n", test_dir.display(), e),
        }
    }
    
    // Run tests
    let summary = runner.run();
    
    // Print summary
    println!();
    summary.print();
    
    // Exit with appropriate code
    std::process::exit(summary.exit_code());
}

// ═══════════════════════════════════════════════════════════════════════════════
// ARGUMENT PARSING
// ═══════════════════════════════════════════════════════════════════════════════

fn parse_args(args: &[String]) -> TestConfig {
    let mut config = TestConfig::default();
    
    let mut i = 1;
    while i < args.len() {
        match args[i].as_str() {
            "-v" | "--verbose" => {
                config.verbose = true;
            }
            "-j" | "--jobs" => {
                i += 1;
                if i < args.len() {
                    config.jobs = args[i].parse().unwrap_or(config.jobs);
                }
            }
            "--filter" | "-f" => {
                i += 1;
                if i < args.len() {
                    config.filter = Some(args[i].clone());
                }
            }
            "--target" => {
                i += 1;
                if i < args.len() {
                    config.target = args[i].clone();
                }
            }
            "-O" | "--opt-level" => {
                i += 1;
                if i < args.len() {
                    config.optimization = args[i].parse().unwrap_or(0);
                }
            }
            "--timeout" => {
                i += 1;
                if i < args.len() {
                    if let Ok(secs) = args[i].parse::<u64>() {
                        config.timeout = Duration::from_secs(secs);
                    }
                }
            }
            "--category" | "-c" => {
                i += 1;
                if i < args.len() {
                    config.categories = parse_categories(&args[i]);
                }
            }
            "--compiler" => {
                i += 1;
                if i < args.len() {
                    config.compiler_path = args[i].clone().into();
                }
            }
            "--output-dir" | "-o" => {
                i += 1;
                if i < args.len() {
                    config.output_dir = args[i].clone().into();
                }
            }
            "-h" | "--help" => {
                print_help();
                std::process::exit(0);
            }
            "--list" => {
                // List tests without running
                let mut runner = TestRunner::new(config.clone());
                register_all_tests(&mut runner);
                // Print test list
                std::process::exit(0);
            }
            arg if arg.starts_with('-') => {
                eprintln!("Unknown option: {}", arg);
                eprintln!("Use --help for usage information");
                std::process::exit(1);
            }
            _ => {
                // Treat as filter
                config.filter = Some(args[i].clone());
            }
        }
        i += 1;
    }
    
    config
}

fn parse_categories(s: &str) -> Vec<TestCategory> {
    s.split(',')
        .filter_map(|cat| match cat.trim() {
            "lexer" => Some(TestCategory::Lexer),
            "parser" => Some(TestCategory::Parser),
            "typecheck" | "type" => Some(TestCategory::TypeCheck),
            "borrowcheck" | "borrow" => Some(TestCategory::BorrowCheck),
            "codegen" => Some(TestCategory::Codegen),
            "e2e" | "run" => Some(TestCategory::EndToEnd),
            "opt" => Some(TestCategory::Optimization),
            "stdlib" => Some(TestCategory::Stdlib),
            "all" => None,  // Will use default (all)
            _ => {
                eprintln!("Unknown category: {}", cat);
                None
            }
        })
        .collect()
}

fn print_help() {
    println!(r#"
QuantaLang Integration Test Runner

USAGE:
    quantalang-test [OPTIONS] [FILTER]

OPTIONS:
    -v, --verbose           Enable verbose output
    -j, --jobs <N>          Number of parallel test jobs (default: number of CPUs)
    -f, --filter <PATTERN>  Only run tests matching PATTERN
    --target <TARGET>       Target triple (default: x86_64-unknown-linux-gnu)
    -O, --opt-level <N>     Optimization level 0-3 (default: 0)
    --timeout <SECS>        Test timeout in seconds (default: 60)
    -c, --category <CATS>   Run only specified categories (comma-separated)
    --compiler <PATH>       Path to quantac compiler (default: ./quantac)
    -o, --output-dir <DIR>  Directory for test outputs (default: ./target/test)
    --list                  List all tests without running
    -h, --help              Show this help message

CATEGORIES:
    lexer       Tokenization tests
    parser      AST construction tests
    typecheck   Type inference and checking tests
    borrowcheck Borrow checker tests
    codegen     Code generation tests
    e2e         End-to-end compilation and execution tests
    opt         Optimization tests
    stdlib      Standard library tests
    all         All categories (default)

EXAMPLES:
    quantalang-test                     Run all tests
    quantalang-test -v                  Run all tests with verbose output
    quantalang-test -c lexer,parser     Run only lexer and parser tests
    quantalang-test --filter fib        Run tests matching 'fib'
    quantalang-test -j 4 -O 2           Run with 4 jobs at -O2

TEST FILE FORMAT:
    Test files use directive comments to specify behavior:
    
    //@ category: e2e           Test category
    //@ run-pass                Should compile and run successfully
    //@ run-fail                Should compile but return non-zero
    //@ compile-fail            Should fail to compile
    //@ error: E0308            Expected error code
    //@ stdout: expected        Expected stdout output
    //@ ignore                  Skip this test
    //@ timeout: 30             Custom timeout in seconds
    //@ needs-std               Requires standard library
    //@ only-on: linux          Run only on specified targets
"#);
}

// ═══════════════════════════════════════════════════════════════════════════════
// TEST REGISTRATION
// ═══════════════════════════════════════════════════════════════════════════════

fn register_all_tests(runner: &mut TestRunner) {
    // Register programmatic tests
    lexer_tests::register_tests(runner);
    parser_tests::register_tests(runner);
    semantic_tests::register_typecheck_tests(runner);
    semantic_tests::register_borrowcheck_tests(runner);
    e2e_tests::register_tests(runner);
    
    // Register embedded test sources
    register_embedded_tests(runner);
}

fn register_embedded_tests(runner: &mut TestRunner) {
    // Lexer embedded tests
    runner.add_test(parse_embedded_test("lex_basic", lexer_tests::TEST_LEX_BASIC));
    runner.add_test(parse_embedded_test("lex_unicode", lexer_tests::TEST_LEX_UNICODE));
    runner.add_test(parse_embedded_test("lex_shebang", lexer_tests::TEST_LEX_SHEBANG));
    
    // Parser embedded tests
    runner.add_test(parse_embedded_test("parse_complex_expr", parser_tests::TEST_PARSE_COMPLEX_EXPR));
    runner.add_test(parse_embedded_test("parse_async_await", parser_tests::TEST_PARSE_ASYNC_AWAIT));
    runner.add_test(parse_embedded_test("parse_generics_complex", parser_tests::TEST_PARSE_GENERICS_COMPLEX));
    
    // Semantic embedded tests
    runner.add_test(parse_embedded_test("typecheck_complex_generics", semantic_tests::TEST_TYPECHECK_COMPLEX_GENERICS));
    runner.add_test(parse_embedded_test("borrow_complex_nll", semantic_tests::TEST_BORROW_COMPLEX_NLL));
    runner.add_test(parse_embedded_test("borrow_polonius", semantic_tests::TEST_BORROW_POLONIUS));
    
    // E2E embedded tests
    runner.add_test(parse_embedded_test("e2e_iterators", e2e_tests::TEST_E2E_ITERATORS));
    runner.add_test(parse_embedded_test("e2e_pattern_matching", e2e_tests::TEST_E2E_PATTERN_MATCHING));
    runner.add_test(parse_embedded_test("e2e_thread_local", e2e_tests::TEST_E2E_THREAD_LOCAL));
    runner.add_test(parse_embedded_test("e2e_drop_order", e2e_tests::TEST_E2E_DROP_ORDER));
}

fn parse_embedded_test(name: &str, source: &str) -> TestCase {
    let mut category = TestCategory::EndToEnd;
    let mut expected = Expected::CompileSuccess { stdout: None, exit_code: 0 };
    let mut timeout = Duration::from_secs(60);
    let mut attributes = TestAttributes::default();
    
    // Parse directives
    for line in source.lines() {
        let line = line.trim();
        if let Some(directive) = line.strip_prefix("//@") {
            let directive = directive.trim();
            let parts: Vec<&str> = directive.splitn(2, ':').collect();
            let key = parts[0].trim();
            let value = parts.get(1).map(|v| v.trim()).unwrap_or("");
            
            match key {
                "category" => {
                    category = match value {
                        "lexer" => TestCategory::Lexer,
                        "parser" => TestCategory::Parser,
                        "typecheck" => TestCategory::TypeCheck,
                        "borrowcheck" => TestCategory::BorrowCheck,
                        "codegen" => TestCategory::Codegen,
                        "e2e" | "run" => TestCategory::EndToEnd,
                        "opt" => TestCategory::Optimization,
                        "stdlib" => TestCategory::Stdlib,
                        _ => TestCategory::EndToEnd,
                    };
                }
                "run-pass" | "compile-pass" => {
                    expected = Expected::CompileSuccess { stdout: None, exit_code: 0 };
                }
                "run-fail" => {
                    let code = value.parse().unwrap_or(1);
                    expected = Expected::CompileSuccess { stdout: None, exit_code: code };
                }
                "compile-fail" => {
                    expected = Expected::CompileError {
                        error_code: value.to_string(),
                        message_contains: None,
                    };
                }
                "stdout" => {
                    if let Expected::CompileSuccess { stdout, .. } = &mut expected {
                        *stdout = Some(value.replace("\\n", "\n"));
                    }
                }
                "timeout" => {
                    if let Ok(secs) = value.parse::<u64>() {
                        timeout = Duration::from_secs(secs);
                    }
                }
                "ignore" => {
                    attributes.ignore = true;
                }
                "needs-std" => {
                    attributes.needs_std = true;
                }
                "needs-alloc" => {
                    attributes.needs_alloc = true;
                }
                "only-on" => {
                    attributes.only_on.push(value.to_string());
                }
                _ => {}
            }
        }
    }
    
    TestCase {
        name: name.to_string(),
        category,
        source: source.to_string(),
        expected,
        timeout,
        attributes,
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// TESTS FOR THE TEST FRAMEWORK ITSELF
// ═══════════════════════════════════════════════════════════════════════════════

#[cfg(test)]
mod tests {
    use super::*;
    
    #[test]
    fn test_parse_categories() {
        let cats = parse_categories("lexer,parser,e2e");
        assert_eq!(cats.len(), 3);
        assert!(cats.contains(&TestCategory::Lexer));
        assert!(cats.contains(&TestCategory::Parser));
        assert!(cats.contains(&TestCategory::EndToEnd));
    }
    
    #[test]
    fn test_parse_embedded_test() {
        let source = r#"
            //@ category: e2e
            //@ run-pass
            //@ stdout: hello
            
            fn main() {
                println!("hello");
            }
        "#;
        
        let test = parse_embedded_test("test", source);
        assert_eq!(test.category, TestCategory::EndToEnd);
        
        if let Expected::CompileSuccess { stdout, exit_code } = test.expected {
            assert_eq!(stdout, Some("hello".to_string()));
            assert_eq!(exit_code, 0);
        } else {
            panic!("Expected CompileSuccess");
        }
    }
    
    #[test]
    fn test_config_default() {
        let config = TestConfig::default();
        assert_eq!(config.optimization, 0);
        assert!(!config.verbose);
        assert!(config.filter.is_none());
    }
}
