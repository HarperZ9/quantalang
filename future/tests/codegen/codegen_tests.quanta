// @test: debug_assert
// @compile: success
// @run: exit(0)
// @tags: codegen, assert
// @flags: -O0

fn main() {
    // debug_assert is only checked in debug builds
    debug_assert!(true);
    debug_assert_eq!(1, 1);
}

