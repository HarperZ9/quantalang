// @test: opt_const_fold
// @compile: success
// @run: exit(0), stdout("100")
// @tags: codegen, optimization
// @flags: -O2

fn main() {
    // Should be folded to 100 at compile time
    let x = 10 * 10;
    println(x);
}

// ═══════════════════════════════════════════════════════════════════════════════
// tests/codegen/opt_inline.quanta
// ═══════════════════════════════════════════════════════════════════════════════

// @test: opt_inline
// @compile: success
// @run: exit(0), stdout("25")
// @tags: codegen, optimization
// @flags: -O2

#[inline]
fn square(x: i32) -> i32 {
    x * x
}

fn main() {
    // Should be inlined
    let result = square(5);
    println(result);
}

// ═══════════════════════════════════════════════════════════════════════════════
// tests/codegen/opt_loop_unroll.quanta
// ═══════════════════════════════════════════════════════════════════════════════

// @test: opt_loop_unroll
// @compile: success
// @run: exit(0), stdout("10")
// @tags: codegen, optimization
// @flags: -O3

fn main() {
    let mut sum = 0;
    
    // Small loop may be unrolled
    for i in 0..5 {
        sum += i;
    }
    
    println(sum);  // 0+1+2+3+4 = 10
}

// ═══════════════════════════════════════════════════════════════════════════════
// tests/codegen/alignment.quanta
// ═══════════════════════════════════════════════════════════════════════════════

// @test: alignment
// @compile: success
// @run: exit(0), stdout_exact("1\n4\n8\n")
// @tags: codegen, alignment

use core::mem;

fn main() {
    println(mem::align_of::<u8>());   // 1
    println(mem::align_of::<i32>());  // 4
    println(mem::align_of::<i64>());  // 8
}

// ═══════════════════════════════════════════════════════════════════════════════
// tests/codegen/size_of.quanta
// ═══════════════════════════════════════════════════════════════════════════════

// @test: size_of
// @compile: success
// @run: exit(0), stdout_exact("1\n4\n8\n")
// @tags: codegen, size

use core::mem;

fn main() {
    println(mem::size_of::<u8>());   // 1
    println(mem::size_of::<i32>());  // 4
    println(mem::size_of::<i64>());  // 8
}

// ═══════════════════════════════════════════════════════════════════════════════
// tests/codegen/repr_c.quanta
// ═══════════════════════════════════════════════════════════════════════════════

// @test: repr_c
// @compile: success
// @run: exit(0), stdout("16")
// @tags: codegen, ffi

use core::mem;

#[repr(C)]
struct CStruct {
    a: i32,
    b: i64,
}

fn main() {
    // With C repr: 4 (i32) + 4 (padding) + 8 (i64) = 16
    println(mem::size_of::<CStruct>());
}

// ═══════════════════════════════════════════════════════════════════════════════
// tests/codegen/repr_packed.quanta
// ═══════════════════════════════════════════════════════════════════════════════

// @test: repr_packed
// @compile: success
// @run: exit(0), stdout("12")
// @tags: codegen, ffi

use core::mem;

#[repr(C, packed)]
struct PackedStruct {
    a: i32,
    b: i64,
}

fn main() {
    // Packed: 4 (i32) + 8 (i64) = 12 (no padding)
    println(mem::size_of::<PackedStruct>());
}

// ═══════════════════════════════════════════════════════════════════════════════
// tests/codegen/transmute.quanta
// ═══════════════════════════════════════════════════════════════════════════════

// @test: transmute
// @compile: success
// @run: exit(0), stdout("1065353216")
// @tags: codegen, unsafe

use core::mem;

fn main() {
    let f: f32 = 1.0;
    
    // Transmute float bits to integer
    let bits: u32 = unsafe { mem::transmute(f) };
    
    println(bits);  // IEEE 754 representation of 1.0
}

// ═══════════════════════════════════════════════════════════════════════════════
// tests/codegen/volatile.quanta
// ═══════════════════════════════════════════════════════════════════════════════

// @test: volatile
// @compile: success
// @run: exit(0), stdout("42")
// @tags: codegen, unsafe

use core::ptr;

fn main() {
    let mut x = 0i32;
    
    unsafe {
        ptr::write_volatile(&mut x, 42);
        let val = ptr::read_volatile(&x);
        println(val);
    }
}

