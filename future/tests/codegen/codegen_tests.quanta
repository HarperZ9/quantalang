// @test: extern_fn
// @compile: success
// @run: exit(0), stdout("8")
// @tags: codegen, ffi

extern "C" fn add(a: i32, b: i32) -> i32 {
    a + b
}

fn main() {
    let result = add(3, 5);
    println(result);
}

