// ═══════════════════════════════════════════════════════════════════════════════
// tests/codegen/unreachable.quanta
// ═══════════════════════════════════════════════════════════════════════════════

// @test: unreachable
// @compile: success
// @run: exit(0), stdout("valid")
// @tags: codegen, control

fn process(x: i32) -> &'static str {
    match x {
        0..=100 => "valid",
        _ => unreachable!("x should be 0-100"),
    }
}

fn main() {
    println(process(50));
}

