// ═══════════════════════════════════════════════════════════════════════════════
// tests/codegen/inline_asm.quanta
// ═══════════════════════════════════════════════════════════════════════════════

// @test: inline_asm
// @compile: success
// @run: exit(0), stdout("42")
// @tags: codegen, asm
// @target: x86_64-unknown-linux-gnu

fn main() {
    let result: i32;
    
    unsafe {
        asm!(
            "mov {0}, 42",
            out(reg) result,
        );
    }
    
    println(result);
}

// ═══════════════════════════════════════════════════════════════════════════════
// tests/codegen/simd_add.quanta
// ═══════════════════════════════════════════════════════════════════════════════

// @test: simd_add
// @compile: success
// @run: exit(0), stdout_exact("5\n7\n9\n11\n")
// @tags: codegen, simd
// @target: x86_64-unknown-linux-gnu

use core::simd::*;

fn main() {
    let a = i32x4::from_array([1, 2, 3, 4]);
    let b = i32x4::from_array([4, 5, 6, 7]);
    let c = a + b;
    
    for i in 0..4 {
        println(c[i]);
    }
}

