// @test: intrinsic_ctlz
// @compile: success
// @run: exit(0), stdout("24")
// @tags: codegen, intrinsics

fn main() {
    let x: u32 = 0x000000FF;
    let leading_zeros = x.leading_zeros();
    println(leading_zeros);
}

// ═══════════════════════════════════════════════════════════════════════════════
// tests/codegen/intrinsic_cttz.quanta
// ═══════════════════════════════════════════════════════════════════════════════

// @test: intrinsic_cttz
// @compile: success
// @run: exit(0), stdout("4")
// @tags: codegen, intrinsics

fn main() {
    let x: u32 = 0xF0;  // 11110000 in binary
    let trailing_zeros = x.trailing_zeros();
    println(trailing_zeros);
}

// ═══════════════════════════════════════════════════════════════════════════════
// tests/codegen/intrinsic_bswap.quanta
// ═══════════════════════════════════════════════════════════════════════════════

// @test: intrinsic_bswap
// @compile: success
// @run: exit(0), stdout("4278190080")
// @tags: codegen, intrinsics

fn main() {
    let x: u32 = 0x000000FF;
    let swapped = x.swap_bytes();
    println(swapped);  // 0xFF000000 = 4278190080
}

// ═══════════════════════════════════════════════════════════════════════════════
// tests/codegen/overflow_check.quanta
// ═══════════════════════════════════════════════════════════════════════════════

// @test: overflow_check
// @compile: success
// @run: exit(0), stdout_exact("Some(200)\nNone\n")
// @tags: codegen, overflow

fn main() {
    let a: u8 = 100;
    let b: u8 = 100;
    let c: u8 = 200;
    
    // Checked addition
    println("{:?}", a.checked_add(b));  // Some(200)
    println("{:?}", c.checked_add(b));  // None (overflow)
}

// ═══════════════════════════════════════════════════════════════════════════════
// tests/codegen/wrapping_ops.quanta
// ═══════════════════════════════════════════════════════════════════════════════

// @test: wrapping_ops
// @compile: success
// @run: exit(0), stdout("44")
// @tags: codegen, wrapping

fn main() {
    let a: u8 = 200;
    let b: u8 = 100;
    
    // Wrapping addition: (200 + 100) mod 256 = 44
    let result = a.wrapping_add(b);
    println(result);
}

// ═══════════════════════════════════════════════════════════════════════════════
// tests/codegen/saturating_ops.quanta
// ═══════════════════════════════════════════════════════════════════════════════

// @test: saturating_ops
// @compile: success
// @run: exit(0), stdout("255")
// @tags: codegen, saturating

fn main() {
    let a: u8 = 200;
    let b: u8 = 100;
    
    // Saturating addition: min(200 + 100, 255) = 255
    let result = a.saturating_add(b);
    println(result);
}

// ═══════════════════════════════════════════════════════════════════════════════
// tests/codegen/opt_dead_code.quanta
// ═══════════════════════════════════════════════════════════════════════════════

// @test: opt_dead_code
// @compile: success
// @run: exit(0), stdout("42")
// @tags: codegen, optimization
// @flags: -O2

fn main() {
    let x = 42;
    
    // This code is never executed (dead)
    if false {
        println("This should be eliminated");
    }
    
    println(x);
}

