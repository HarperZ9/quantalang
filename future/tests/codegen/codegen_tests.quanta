// ═══════════════════════════════════════════════════════════════════════════════
// tests/codegen/cold_hot.quanta
// ═══════════════════════════════════════════════════════════════════════════════

// @test: cold_hot
// @compile: success
// @run: exit(0), stdout("hot path")
// @tags: codegen, optimization

#[cold]
fn error_handler() {
    println("error");
}

#[inline]
fn hot_path() {
    println("hot path");
}

fn main() {
    hot_path();
}
