// tests/types/trait_object.quanta
// ═══════════════════════════════════════════════════════════════════════════════

// @test: trait_object
// @compile: success
// @run: exit(0), stdout_exact("Woof!\nMeow!\nWoof!\n")
// @tags: types, traits, dynamic

trait Animal {
    fn speak(&self) -> &'static str;
}

struct Dog;
struct Cat;

impl Animal for Dog {
    fn speak(&self) -> &'static str { "Woof!" }
}

impl Animal for Cat {
    fn speak(&self) -> &'static str { "Meow!" }
}

fn main() {
    let animals: Vec<Box<dyn Animal>> = vec![
        Box::new(Dog),
        Box::new(Cat),
        Box::new(Dog),
    ];
    
    for animal in animals {
        println(animal.speak());
    }
}

