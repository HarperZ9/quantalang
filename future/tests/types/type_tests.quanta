// @test: struct_impl
// @compile: success
// @run: exit(0), stdout("50")
// @tags: types, structs, methods

struct Rectangle {
    width: i32,
    height: i32,
}

impl Rectangle {
    fn area(&self) -> i32 {
        self.width * self.height
    }
}

fn main() {
    let rect = Rectangle { width: 5, height: 10 };
    println(rect.area());
}

// ═══════════════════════════════════════════════════════════════════════════════
// tests/types/struct_constructor.quanta
// ═══════════════════════════════════════════════════════════════════════════════

// @test: struct_constructor
// @compile: success
// @run: exit(0), stdout("Circle at (0, 0) with radius 5")
// @tags: types, structs, methods

struct Circle {
    x: i32,
    y: i32,
    radius: i32,
}

impl Circle {
    fn new(radius: i32) -> Self {
        Circle { x: 0, y: 0, radius }
    }
    
    fn at(x: i32, y: i32, radius: i32) -> Self {
        Circle { x, y, radius }
    }
}

fn main() {
    let c = Circle::new(5);
    println("Circle at ({}, {}) with radius {}", c.x, c.y, c.radius);
}

// ═══════════════════════════════════════════════════════════════════════════════
// tests/types/struct_methods.quanta
// ═══════════════════════════════════════════════════════════════════════════════

// @test: struct_methods
// @compile: success
// @run: exit(0), stdout_exact("78\ntrue\n")
// @tags: types, structs, methods

struct Circle {
    radius: i32,
}

impl Circle {
    fn new(radius: i32) -> Self {
        Circle { radius }
    }
    
    fn area(&self) -> i32 {
        3 * self.radius * self.radius  // Simplified PI
    }
    
    fn is_larger_than(&self, other: &Circle) -> bool {
        self.radius > other.radius
    }
}

fn main() {
    let c1 = Circle::new(5);
    let c2 = Circle::new(3);
    
    println(c1.area());
    println(c1.is_larger_than(&c2));
}

// ═══════════════════════════════════════════════════════════════════════════════
// tests/types/struct_mut_self.quanta
// ═══════════════════════════════════════════════════════════════════════════════

// @test: struct_mut_self
// @compile: success
// @run: exit(0), stdout("Counter: 3")
// @tags: types, structs, methods

struct Counter {
    count: i32,
}

impl Counter {
    fn new() -> Self {
        Counter { count: 0 }
    }
    
    fn increment(&mut self) {
        self.count += 1;
    }
    
    fn get(&self) -> i32 {
        self.count
    }
}

fn main() {
    let mut c = Counter::new();
    c.increment();
    c.increment();
    c.increment();
    println("Counter: {}", c.get());
}

