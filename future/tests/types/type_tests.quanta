// @test: enum_basic
// @compile: success
// @run: exit(0), stdout("North")
// @tags: types, enums

enum Direction {
    North,
    South,
    East,
    West,
}

fn main() {
    let d = Direction::North;
    
    match d {
        Direction::North => println("North"),
        Direction::South => println("South"),
        Direction::East => println("East"),
        Direction::West => println("West"),
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// tests/types/enum_data.quanta
// ═══════════════════════════════════════════════════════════════════════════════

// @test: enum_data
// @compile: success
// @run: exit(0), stdout("Move to (10, 20)")
// @tags: types, enums

enum Message {
    Quit,
    Move { x: i32, y: i32 },
    Write(String),
    ChangeColor(i32, i32, i32),
}

fn main() {
    let msg = Message::Move { x: 10, y: 20 };
    
    match msg {
        Message::Quit => println("Quit"),
        Message::Move { x, y } => println("Move to ({}, {})", x, y),
        Message::Write(s) => println("Write: {}", s),
        Message::ChangeColor(r, g, b) => println("Color: {}, {}, {}", r, g, b),
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// tests/types/enum_impl.quanta
// ═══════════════════════════════════════════════════════════════════════════════

// @test: enum_impl
// @compile: success
// @run: exit(0), stdout("Message::Write")
// @tags: types, enums, methods

enum Message {
    Quit,
    Move { x: i32, y: i32 },
    Write(String),
}

impl Message {
    fn name(&self) -> &'static str {
        match self {
            Message::Quit => "Message::Quit",
            Message::Move { .. } => "Message::Move",
            Message::Write(_) => "Message::Write",
        }
    }
}

fn main() {
    let msg = Message::Write(String::from("hello"));
    println(msg.name());
}

// ═══════════════════════════════════════════════════════════════════════════════
// tests/types/option.quanta
// ═══════════════════════════════════════════════════════════════════════════════

// @test: option
// @compile: success
// @run: exit(0), stdout_exact("Found: 2\nNot found\n")
// @tags: types, option

fn find_first_even(arr: &[i32]) -> Option<i32> {
    for &x in arr {
        if x % 2 == 0 {
            return Some(x);
        }
    }
    None
}

fn main() {
    let arr1 = [1, 2, 3, 4];
    let arr2 = [1, 3, 5, 7];
    
    match find_first_even(&arr1) {
        Some(x) => println("Found: {}", x),
        None => println("Not found"),
    }
    
    match find_first_even(&arr2) {
        Some(x) => println("Found: {}", x),
        None => println("Not found"),
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// tests/types/result.quanta
// ═══════════════════════════════════════════════════════════════════════════════

// @test: result
// @compile: success
// @run: exit(0), stdout_exact("Result: 5\nError: division by zero\n")
// @tags: types, result

fn divide(a: i32, b: i32) -> Result<i32, &'static str> {
    if b == 0 {
        Err("division by zero")
    } else {
        Ok(a / b)
    }
}

fn main() {
    match divide(10, 2) {
        Ok(x) => println("Result: {}", x),
        Err(e) => println("Error: {}", e),
    }
    
    match divide(10, 0) {
        Ok(x) => println("Result: {}", x),
        Err(e) => println("Error: {}", e),
    }
}

