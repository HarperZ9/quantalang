// ═══════════════════════════════════════════════════════════════════════════════

// @test: trait_default
// @compile: success
// @run: exit(0), stdout("Summary: (Read more...)")
// @tags: types, traits

trait Summary {
    fn summarize(&self) -> String {
        String::from("(Read more...)")
    }
}

struct Article {
    title: String,
    content: String,
}

impl Summary for Article {
    // Use default implementation
}

fn main() {
    let article = Article {
        title: String::from("News"),
        content: String::from("Content here"),
    };
    
    println("Summary: {}", article.summarize());
}

