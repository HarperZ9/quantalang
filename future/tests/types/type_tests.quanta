// @test: struct_update
// @compile: success
// @run: exit(0), stdout("Point(100, 20)")
// @tags: types, structs

struct Point {
    x: i32,
    y: i32,
}

fn main() {
    let p1 = Point { x: 10, y: 20 };
    let p2 = Point { x: 100, ..p1 };  // Update syntax
    println("Point({}, {})", p2.x, p2.y);
}

