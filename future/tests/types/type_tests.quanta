// tests/types/tuple_return.quanta
// ═══════════════════════════════════════════════════════════════════════════════

// @test: tuple_return
// @compile: success
// @run: exit(0), stdout("min: 1, max: 5")
// @tags: types, tuples

fn min_max(arr: &[i32]) -> (i32, i32) {
    let mut min = arr[0];
    let mut max = arr[0];
    
    for &x in arr {
        if x < min { min = x; }
        if x > max { max = x; }
    }
    
    (min, max)
}

fn main() {
    let arr = [3, 1, 4, 1, 5, 9, 2, 6];
    let (min, max) = min_max(&arr);
    println("min: {}, max: {}", min, max);
}

