// @run: exit(0), stdout("100")
// @tags: types, alias

type Kilometers = i32;
type Meters = i32;

fn km_to_m(km: Kilometers) -> Meters {
    km * 1000
}

fn main() {
    let distance: Kilometers = 100;
    println(distance);
}

// ═══════════════════════════════════════════════════════════════════════════════
// tests/types/associated_types.quanta
// ═══════════════════════════════════════════════════════════════════════════════

// @test: associated_types
// @compile: success
// @run: exit(0), stdout("8")
// @tags: types, traits, associated

trait Container {
    type Item;
    
    fn contains(&self, item: &Self::Item) -> bool;
    fn first(&self) -> Option<&Self::Item>;
}

struct IntVec(Vec<i32>);

impl Container for IntVec {
    type Item = i32;
    
    fn contains(&self, item: &i32) -> bool {
        self.0.contains(item)
    }
    
    fn first(&self) -> Option<&i32> {
        self.0.first()
    }
}

fn main() {
    let v = IntVec(vec![8, 16, 32]);
    if let Some(x) = v.first() {
        println(x);
    }
}
