// tests/types/trait_basic.quanta
// ═══════════════════════════════════════════════════════════════════════════════

// @test: trait_basic
// @compile: success
// @run: exit(0), stdout_exact("Woof!\nMeow!\n")
// @tags: types, traits

trait Animal {
    fn speak(&self) -> &'static str;
}

struct Dog;
struct Cat;

impl Animal for Dog {
    fn speak(&self) -> &'static str {
        "Woof!"
    }
}

impl Animal for Cat {
    fn speak(&self) -> &'static str {
        "Meow!"
    }
}

fn main() {
    let dog = Dog;
    let cat = Cat;
    
    println(dog.speak());
    println(cat.speak());
}

