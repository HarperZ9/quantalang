// @test: trait_derive
// @compile: success
// @run: exit(0), stdout_exact("true\nfalse\n")
// @tags: types, traits, derive

#[derive(Debug, Clone, Copy, PartialEq, Eq)]
struct Point {
    x: i32,
    y: i32,
}

fn main() {
    let p1 = Point { x: 10, y: 20 };
    let p2 = Point { x: 10, y: 20 };
    let p3 = Point { x: 5, y: 5 };
    
    println(p1 == p2);
    println(p1 == p3);
}

// ═══════════════════════════════════════════════════════════════════════════════
// tests/types/generic_struct.quanta
// ═══════════════════════════════════════════════════════════════════════════════

// @test: generic_struct
// @compile: success
// @run: exit(0), stdout_exact("10\nhello\n")
// @tags: types, generics

struct Container<T> {
    value: T,
}

impl<T> Container<T> {
    fn new(value: T) -> Self {
        Container { value }
    }
    
    fn get(&self) -> &T {
        &self.value
    }
}

fn main() {
    let int_container = Container::new(10);
    let str_container = Container::new("hello");
    
    println(int_container.get());
    println(str_container.get());
}

// ═══════════════════════════════════════════════════════════════════════════════
// tests/types/generic_enum.quanta
// ═══════════════════════════════════════════════════════════════════════════════

// @test: generic_enum
// @compile: success
// @run: exit(0), stdout_exact("Ok: 42\nErr: not found\n")
// @tags: types, generics, enums

enum MyResult<T, E> {
    Ok(T),
    Err(E),
}

fn main() {
    let ok: MyResult<i32, &str> = MyResult::Ok(42);
    let err: MyResult<i32, &str> = MyResult::Err("not found");
    
    match ok {
        MyResult::Ok(v) => println("Ok: {}", v),
        MyResult::Err(e) => println("Err: {}", e),
    }
    
    match err {
        MyResult::Ok(v) => println("Ok: {}", v),
        MyResult::Err(e) => println("Err: {}", e),
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// tests/types/newtype.quanta
// ═══════════════════════════════════════════════════════════════════════════════

// @test: newtype
// @compile: success
// @run: exit(0), stdout("100")
// @tags: types, newtype

struct Meters(f64);
struct Kilometers(f64);

impl Meters {
    fn to_km(&self) -> Kilometers {
        Kilometers(self.0 / 1000.0)
    }
}

impl Kilometers {
    fn to_m(&self) -> Meters {
        Meters(self.0 * 1000.0)
    }
}

fn main() {
    let km = Kilometers(0.1);
    let m = km.to_m();
    println(m.0 as i32);
}

