// @test: struct_basic
// @compile: success
// @run: exit(0), stdout("Point(10, 20)")
// @tags: types, structs

struct Point {
    x: i32,
    y: i32,
}

fn main() {
    let p = Point { x: 10, y: 20 };
    println("Point({}, {})", p.x, p.y);
}

