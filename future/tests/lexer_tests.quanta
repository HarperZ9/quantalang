// ═══════════════════════════════════════════════════════════════════════════════
// QUANTALANG — Lexer Integration Tests
// ═══════════════════════════════════════════════════════════════════════════════

module quantalang::tests::lexer

use crate::tests::framework::*;

// ═══════════════════════════════════════════════════════════════════════════════
// TEST CASES
// ═══════════════════════════════════════════════════════════════════════════════

pub fn register_tests(runner: &mut TestRunner) {
    // ─────────────────────────────────────────────────────────────────────────
    // Basic Token Tests
    // ─────────────────────────────────────────────────────────────────────────
    
    runner.add_test(TestCase {
        name: "lex_keywords".into(),
        category: TestCategory::Lexer,
        source: r#"
            fn let mut const if else while for loop match return
            struct enum impl trait pub mod use
            true false self Self super crate
        "#.into(),
        expected: Expected::Tokens(vec![
            ExpectedToken { kind: "Fn".into(), lexeme: Some("fn".into()), line: None },
            ExpectedToken { kind: "Let".into(), lexeme: Some("let".into()), line: None },
            ExpectedToken { kind: "Mut".into(), lexeme: Some("mut".into()), line: None },
            ExpectedToken { kind: "Const".into(), lexeme: Some("const".into()), line: None },
            ExpectedToken { kind: "If".into(), lexeme: Some("if".into()), line: None },
            ExpectedToken { kind: "Else".into(), lexeme: Some("else".into()), line: None },
            ExpectedToken { kind: "While".into(), lexeme: Some("while".into()), line: None },
            ExpectedToken { kind: "For".into(), lexeme: Some("for".into()), line: None },
            ExpectedToken { kind: "Loop".into(), lexeme: Some("loop".into()), line: None },
            ExpectedToken { kind: "Match".into(), lexeme: Some("match".into()), line: None },
            ExpectedToken { kind: "Return".into(), lexeme: Some("return".into()), line: None },
            ExpectedToken { kind: "Struct".into(), lexeme: Some("struct".into()), line: None },
            ExpectedToken { kind: "Enum".into(), lexeme: Some("enum".into()), line: None },
            ExpectedToken { kind: "Impl".into(), lexeme: Some("impl".into()), line: None },
            ExpectedToken { kind: "Trait".into(), lexeme: Some("trait".into()), line: None },
            ExpectedToken { kind: "Pub".into(), lexeme: Some("pub".into()), line: None },
            ExpectedToken { kind: "Mod".into(), lexeme: Some("mod".into()), line: None },
            ExpectedToken { kind: "Use".into(), lexeme: Some("use".into()), line: None },
            ExpectedToken { kind: "True".into(), lexeme: Some("true".into()), line: None },
            ExpectedToken { kind: "False".into(), lexeme: Some("false".into()), line: None },
        ]),
        timeout: Duration::from_secs(5),
        attributes: TestAttributes::default(),
    });
    
    runner.add_test(TestCase {
        name: "lex_identifiers".into(),
        category: TestCategory::Lexer,
        source: r#"
            foo bar_baz _underscore __double
            camelCase PascalCase SCREAMING_CASE
            r#type r#fn r#match
            变量 переменная 変数
        "#.into(),
        expected: Expected::Tokens(vec![
            ExpectedToken { kind: "Ident".into(), lexeme: Some("foo".into()), line: None },
            ExpectedToken { kind: "Ident".into(), lexeme: Some("bar_baz".into()), line: None },
            ExpectedToken { kind: "Ident".into(), lexeme: Some("_underscore".into()), line: None },
            ExpectedToken { kind: "Ident".into(), lexeme: Some("__double".into()), line: None },
            ExpectedToken { kind: "RawIdent".into(), lexeme: Some("type".into()), line: None },
        ]),
        timeout: Duration::from_secs(5),
        attributes: TestAttributes::default(),
    });
    
    runner.add_test(TestCase {
        name: "lex_integers".into(),
        category: TestCategory::Lexer,
        source: r#"
            0 1 42 1_000_000
            0xFF 0xff 0x_DEAD_BEEF
            0o777 0o_123
            0b1010 0b_1111_0000
        "#.into(),
        expected: Expected::Tokens(vec![
            ExpectedToken { kind: "IntLit".into(), lexeme: Some("0".into()), line: None },
            ExpectedToken { kind: "IntLit".into(), lexeme: Some("1".into()), line: None },
            ExpectedToken { kind: "IntLit".into(), lexeme: Some("42".into()), line: None },
            ExpectedToken { kind: "IntLit".into(), lexeme: Some("1_000_000".into()), line: None },
            ExpectedToken { kind: "IntLit".into(), lexeme: Some("0xFF".into()), line: None },
            ExpectedToken { kind: "IntLit".into(), lexeme: Some("0o777".into()), line: None },
            ExpectedToken { kind: "IntLit".into(), lexeme: Some("0b1010".into()), line: None },
        ]),
        timeout: Duration::from_secs(5),
        attributes: TestAttributes::default(),
    });
    
    runner.add_test(TestCase {
        name: "lex_floats".into(),
        category: TestCategory::Lexer,
        source: r#"
            0.0 1.0 3.14159
            1e10 2.5e-3 1E+100
            1_000.000_001
            inf NaN
        "#.into(),
        expected: Expected::Tokens(vec![
            ExpectedToken { kind: "FloatLit".into(), lexeme: Some("0.0".into()), line: None },
            ExpectedToken { kind: "FloatLit".into(), lexeme: Some("1.0".into()), line: None },
            ExpectedToken { kind: "FloatLit".into(), lexeme: Some("3.14159".into()), line: None },
            ExpectedToken { kind: "FloatLit".into(), lexeme: Some("1e10".into()), line: None },
            ExpectedToken { kind: "FloatLit".into(), lexeme: Some("2.5e-3".into()), line: None },
        ]),
        timeout: Duration::from_secs(5),
        attributes: TestAttributes::default(),
    });
    
    runner.add_test(TestCase {
        name: "lex_strings".into(),
        category: TestCategory::Lexer,
        source: r#"
            "hello"
            "with\nescape\tsequences"
            "unicode: \u{1F600}"
            r"raw string with \ no escapes"
            r#"raw with "quotes" inside"#
        "#.into(),
        expected: Expected::Tokens(vec![
            ExpectedToken { kind: "StringLit".into(), lexeme: Some("hello".into()), line: None },
            ExpectedToken { kind: "StringLit".into(), lexeme: None, line: None },
            ExpectedToken { kind: "RawStringLit".into(), lexeme: None, line: None },
        ]),
        timeout: Duration::from_secs(5),
        attributes: TestAttributes::default(),
    });
    
    runner.add_test(TestCase {
        name: "lex_chars".into(),
        category: TestCategory::Lexer,
        source: r#"
            'a' 'Z' '0'
            '\n' '\t' '\r' '\\'
            '\'' '\"'
            '\u{0}' '\u{7F}' '\u{10FFFF}'
        "#.into(),
        expected: Expected::Tokens(vec![
            ExpectedToken { kind: "CharLit".into(), lexeme: Some("a".into()), line: None },
            ExpectedToken { kind: "CharLit".into(), lexeme: Some("Z".into()), line: None },
            ExpectedToken { kind: "CharLit".into(), lexeme: Some("0".into()), line: None },
        ]),
        timeout: Duration::from_secs(5),
        attributes: TestAttributes::default(),
    });
    
    runner.add_test(TestCase {
        name: "lex_operators".into(),
        category: TestCategory::Lexer,
        source: r#"
            + - * / % ^ & | ! ~ << >>
            += -= *= /= %= ^= &= |= <<= >>=
            == != < > <= >=
            && || -> => :: . .. ... ..=
            @ # $ ? ; , : ( ) [ ] { }
        "#.into(),
        expected: Expected::Tokens(vec![
            ExpectedToken { kind: "Plus".into(), lexeme: None, line: None },
            ExpectedToken { kind: "Minus".into(), lexeme: None, line: None },
            ExpectedToken { kind: "Star".into(), lexeme: None, line: None },
            ExpectedToken { kind: "Slash".into(), lexeme: None, line: None },
            ExpectedToken { kind: "Percent".into(), lexeme: None, line: None },
            ExpectedToken { kind: "Caret".into(), lexeme: None, line: None },
            ExpectedToken { kind: "And".into(), lexeme: None, line: None },
            ExpectedToken { kind: "Or".into(), lexeme: None, line: None },
            ExpectedToken { kind: "Not".into(), lexeme: None, line: None },
            ExpectedToken { kind: "Tilde".into(), lexeme: None, line: None },
            ExpectedToken { kind: "Shl".into(), lexeme: None, line: None },
            ExpectedToken { kind: "Shr".into(), lexeme: None, line: None },
            ExpectedToken { kind: "Arrow".into(), lexeme: None, line: None },
            ExpectedToken { kind: "FatArrow".into(), lexeme: None, line: None },
            ExpectedToken { kind: "PathSep".into(), lexeme: None, line: None },
        ]),
        timeout: Duration::from_secs(5),
        attributes: TestAttributes::default(),
    });
    
    runner.add_test(TestCase {
        name: "lex_comments".into(),
        category: TestCategory::Lexer,
        source: r#"
            // line comment
            /* block comment */
            /*
             * multi-line
             * block comment
             */
            /// doc comment
            //! inner doc comment
            /** block doc comment */
        "#.into(),
        expected: Expected::Tokens(vec![
            ExpectedToken { kind: "LineComment".into(), lexeme: None, line: None },
            ExpectedToken { kind: "BlockComment".into(), lexeme: None, line: None },
            ExpectedToken { kind: "DocComment".into(), lexeme: None, line: None },
        ]),
        timeout: Duration::from_secs(5),
        attributes: TestAttributes::default(),
    });
    
    // ─────────────────────────────────────────────────────────────────────────
    // Error Cases
    // ─────────────────────────────────────────────────────────────────────────
    
    runner.add_test(TestCase {
        name: "lex_error_unterminated_string".into(),
        category: TestCategory::Lexer,
        source: r#"let x = "unterminated"#.into(),
        expected: Expected::PhaseError {
            phase: CompilePhase::Lex,
            error_contains: "unterminated string".into(),
        },
        timeout: Duration::from_secs(5),
        attributes: TestAttributes::default(),
    });
    
    runner.add_test(TestCase {
        name: "lex_error_invalid_escape".into(),
        category: TestCategory::Lexer,
        source: r#"let x = "invalid \q escape""#.into(),
        expected: Expected::PhaseError {
            phase: CompilePhase::Lex,
            error_contains: "invalid escape".into(),
        },
        timeout: Duration::from_secs(5),
        attributes: TestAttributes::default(),
    });
    
    runner.add_test(TestCase {
        name: "lex_error_invalid_unicode".into(),
        category: TestCategory::Lexer,
        source: r#"let x = '\u{FFFFFF}'"#.into(),
        expected: Expected::PhaseError {
            phase: CompilePhase::Lex,
            error_contains: "invalid unicode".into(),
        },
        timeout: Duration::from_secs(5),
        attributes: TestAttributes::default(),
    });
    
    runner.add_test(TestCase {
        name: "lex_error_empty_char".into(),
        category: TestCategory::Lexer,
        source: r#"let x = ''"#.into(),
        expected: Expected::PhaseError {
            phase: CompilePhase::Lex,
            error_contains: "empty character".into(),
        },
        timeout: Duration::from_secs(5),
        attributes: TestAttributes::default(),
    });
    
    runner.add_test(TestCase {
        name: "lex_error_unclosed_block_comment".into(),
        category: TestCategory::Lexer,
        source: r#"/* unclosed"#.into(),
        expected: Expected::PhaseError {
            phase: CompilePhase::Lex,
            error_contains: "unclosed block comment".into(),
        },
        timeout: Duration::from_secs(5),
        attributes: TestAttributes::default(),
    });
    
    // ─────────────────────────────────────────────────────────────────────────
    // Edge Cases
    // ─────────────────────────────────────────────────────────────────────────
    
    runner.add_test(TestCase {
        name: "lex_adjacent_operators".into(),
        category: TestCategory::Lexer,
        source: r#"a+b*c-d/e%f"#.into(),
        expected: Expected::Tokens(vec![
            ExpectedToken { kind: "Ident".into(), lexeme: Some("a".into()), line: None },
            ExpectedToken { kind: "Plus".into(), lexeme: None, line: None },
            ExpectedToken { kind: "Ident".into(), lexeme: Some("b".into()), line: None },
            ExpectedToken { kind: "Star".into(), lexeme: None, line: None },
            ExpectedToken { kind: "Ident".into(), lexeme: Some("c".into()), line: None },
        ]),
        timeout: Duration::from_secs(5),
        attributes: TestAttributes::default(),
    });
    
    runner.add_test(TestCase {
        name: "lex_nested_block_comments".into(),
        category: TestCategory::Lexer,
        source: r#"/* outer /* nested */ still outer */"#.into(),
        expected: Expected::Tokens(vec![
            ExpectedToken { kind: "BlockComment".into(), lexeme: None, line: None },
        ]),
        timeout: Duration::from_secs(5),
        attributes: TestAttributes::default(),
    });
    
    runner.add_test(TestCase {
        name: "lex_lifetime_vs_char".into(),
        category: TestCategory::Lexer,
        source: r#"
            'a
            'static
            'a'
        "#.into(),
        expected: Expected::Tokens(vec![
            ExpectedToken { kind: "Lifetime".into(), lexeme: Some("'a".into()), line: None },
            ExpectedToken { kind: "Lifetime".into(), lexeme: Some("'static".into()), line: None },
            ExpectedToken { kind: "CharLit".into(), lexeme: Some("a".into()), line: None },
        ]),
        timeout: Duration::from_secs(5),
        attributes: TestAttributes::default(),
    });
    
    runner.add_test(TestCase {
        name: "lex_byte_literals".into(),
        category: TestCategory::Lexer,
        source: r#"
            b'A'
            b'\n'
            b"hello bytes"
            br"raw bytes"
        "#.into(),
        expected: Expected::Tokens(vec![
            ExpectedToken { kind: "ByteLit".into(), lexeme: Some("A".into()), line: None },
            ExpectedToken { kind: "ByteStringLit".into(), lexeme: None, line: None },
            ExpectedToken { kind: "RawByteStringLit".into(), lexeme: None, line: None },
        ]),
        timeout: Duration::from_secs(5),
        attributes: TestAttributes::default(),
    });
    
    runner.add_test(TestCase {
        name: "lex_suffixed_literals".into(),
        category: TestCategory::Lexer,
        source: r#"
            42i32 42u64 42usize
            3.14f32 2.718f64
        "#.into(),
        expected: Expected::Tokens(vec![
            ExpectedToken { kind: "IntLit".into(), lexeme: Some("42i32".into()), line: None },
            ExpectedToken { kind: "IntLit".into(), lexeme: Some("42u64".into()), line: None },
            ExpectedToken { kind: "IntLit".into(), lexeme: Some("42usize".into()), line: None },
            ExpectedToken { kind: "FloatLit".into(), lexeme: Some("3.14f32".into()), line: None },
        ]),
        timeout: Duration::from_secs(5),
        attributes: TestAttributes::default(),
    });
}

// ═══════════════════════════════════════════════════════════════════════════════
// TEST FILES (embedded)
// ═══════════════════════════════════════════════════════════════════════════════

pub const TEST_LEX_BASIC: &str = r#"
//@ category: lexer
//@ compile-pass

fn main() {
    let x = 42;
    let y = 3.14;
    let s = "hello";
}
"#;

pub const TEST_LEX_UNICODE: &str = r#"
//@ category: lexer
//@ compile-pass

fn main() {
    let π = 3.14159;
    let こんにちは = "hello";
    let 🦀 = "crab";
}
"#;

pub const TEST_LEX_SHEBANG: &str = r#"#!/usr/bin/env quantac
//@ category: lexer
//@ compile-pass

fn main() {
    println!("Hello from script!");
}
"#;
