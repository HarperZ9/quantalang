// ═══════════════════════════════════════════════════════════════════════════════
// QUANTALANG — Parser Integration Tests
// ═══════════════════════════════════════════════════════════════════════════════

module quantalang::tests::parser

use crate::tests::framework::*;

// ═══════════════════════════════════════════════════════════════════════════════
// TEST CASES
// ═══════════════════════════════════════════════════════════════════════════════

pub fn register_tests(runner: &mut TestRunner) {
    // ─────────────────────────────────────────────────────────────────────────
    // Expression Parsing
    // ─────────────────────────────────────────────────────────────────────────
    
    runner.add_test(TestCase {
        name: "parse_arithmetic_precedence".into(),
        category: TestCategory::Parser,
        source: r#"
            fn main() {
                let x = 1 + 2 * 3;      // 7, not 9
                let y = (1 + 2) * 3;    // 9
                let z = 1 + 2 + 3 + 4;  // left-associative
                let w = 2 ** 3 ** 2;    // right-associative: 2^(3^2) = 512
            }
        "#.into(),
        expected: Expected::CompileSuccess { stdout: None, exit_code: 0 },
        timeout: Duration::from_secs(5),
        attributes: TestAttributes::default(),
    });
    
    runner.add_test(TestCase {
        name: "parse_comparison_chaining".into(),
        category: TestCategory::Parser,
        source: r#"
            fn main() {
                let x = 1 < 2 && 2 < 3;  // valid
                let y = 1 <= 2;
                let z = 3 >= 2;
            }
        "#.into(),
        expected: Expected::CompileSuccess { stdout: None, exit_code: 0 },
        timeout: Duration::from_secs(5),
        attributes: TestAttributes::default(),
    });
    
    runner.add_test(TestCase {
        name: "parse_unary_operators".into(),
        category: TestCategory::Parser,
        source: r#"
            fn main() {
                let x = -5;
                let y = !true;
                let z = *ptr;
                let w = &value;
                let v = &mut mutable;
                let u = --x;  // double negation
            }
        "#.into(),
        expected: Expected::CompileSuccess { stdout: None, exit_code: 0 },
        timeout: Duration::from_secs(5),
        attributes: TestAttributes::default(),
    });
    
    runner.add_test(TestCase {
        name: "parse_method_chains".into(),
        category: TestCategory::Parser,
        source: r#"
            fn main() {
                let x = foo.bar().baz(1, 2).qux;
                let y = vec.iter().map(|x| x * 2).collect::<Vec<_>>();
            }
        "#.into(),
        expected: Expected::CompileSuccess { stdout: None, exit_code: 0 },
        timeout: Duration::from_secs(5),
        attributes: TestAttributes::default(),
    });
    
    runner.add_test(TestCase {
        name: "parse_closures".into(),
        category: TestCategory::Parser,
        source: r#"
            fn main() {
                let f = || 42;
                let g = |x| x + 1;
                let h = |x, y| x + y;
                let i = |x: i32, y: i32| -> i32 { x + y };
                let j = move |x| x * 2;
                let k = |x| async { x.await };
            }
        "#.into(),
        expected: Expected::CompileSuccess { stdout: None, exit_code: 0 },
        timeout: Duration::from_secs(5),
        attributes: TestAttributes::default(),
    });
    
    runner.add_test(TestCase {
        name: "parse_if_expressions".into(),
        category: TestCategory::Parser,
        source: r#"
            fn main() {
                let x = if true { 1 } else { 2 };
                let y = if a { 1 } else if b { 2 } else { 3 };
                let z = if let Some(v) = opt { v } else { 0 };
            }
        "#.into(),
        expected: Expected::CompileSuccess { stdout: None, exit_code: 0 },
        timeout: Duration::from_secs(5),
        attributes: TestAttributes::default(),
    });
    
    runner.add_test(TestCase {
        name: "parse_match_expressions".into(),
        category: TestCategory::Parser,
        source: r#"
            fn main() {
                let x = match val {
                    0 => "zero",
                    1 | 2 | 3 => "small",
                    n @ 4..=10 => "medium",
                    n if n < 0 => "negative",
                    _ => "large",
                };
            }
        "#.into(),
        expected: Expected::CompileSuccess { stdout: None, exit_code: 0 },
        timeout: Duration::from_secs(5),
        attributes: TestAttributes::default(),
    });
    
    runner.add_test(TestCase {
        name: "parse_struct_expressions".into(),
        category: TestCategory::Parser,
        source: r#"
            fn main() {
                let p = Point { x: 1, y: 2 };
                let q = Point { x, y };  // shorthand
                let r = Point { x: 1, ..default };  // struct update
                let s = Point { ..other };
            }
        "#.into(),
        expected: Expected::CompileSuccess { stdout: None, exit_code: 0 },
        timeout: Duration::from_secs(5),
        attributes: TestAttributes::default(),
    });
    
    runner.add_test(TestCase {
        name: "parse_array_and_tuple".into(),
        category: TestCategory::Parser,
        source: r#"
            fn main() {
                let arr = [1, 2, 3, 4, 5];
                let arr2 = [0; 100];
                let tup = (1, "hello", 3.14);
                let unit = ();
                let single = (42,);
            }
        "#.into(),
        expected: Expected::CompileSuccess { stdout: None, exit_code: 0 },
        timeout: Duration::from_secs(5),
        attributes: TestAttributes::default(),
    });
    
    runner.add_test(TestCase {
        name: "parse_range_expressions".into(),
        category: TestCategory::Parser,
        source: r#"
            fn main() {
                let r1 = 0..10;
                let r2 = 0..=10;
                let r3 = ..10;
                let r4 = 0..;
                let r5 = ..;
                let r6 = ..=10;
            }
        "#.into(),
        expected: Expected::CompileSuccess { stdout: None, exit_code: 0 },
        timeout: Duration::from_secs(5),
        attributes: TestAttributes::default(),
    });
    
    // ─────────────────────────────────────────────────────────────────────────
    // Statement Parsing
    // ─────────────────────────────────────────────────────────────────────────
    
    runner.add_test(TestCase {
        name: "parse_let_patterns".into(),
        category: TestCategory::Parser,
        source: r#"
            fn main() {
                let x = 1;
                let (a, b) = (1, 2);
                let [first, .., last] = array;
                let Point { x, y } = point;
                let Some(value) = option else { return };
                let ref r = value;
                let ref mut rm = value;
            }
        "#.into(),
        expected: Expected::CompileSuccess { stdout: None, exit_code: 0 },
        timeout: Duration::from_secs(5),
        attributes: TestAttributes::default(),
    });
    
    runner.add_test(TestCase {
        name: "parse_loops".into(),
        category: TestCategory::Parser,
        source: r#"
            fn main() {
                loop { break; }
                while condition { continue; }
                while let Some(x) = iter.next() { }
                for i in 0..10 { }
                for (k, v) in map { }
                'outer: loop {
                    'inner: loop {
                        break 'outer;
                    }
                }
            }
        "#.into(),
        expected: Expected::CompileSuccess { stdout: None, exit_code: 0 },
        timeout: Duration::from_secs(5),
        attributes: TestAttributes::default(),
    });
    
    // ─────────────────────────────────────────────────────────────────────────
    // Item Parsing
    // ─────────────────────────────────────────────────────────────────────────
    
    runner.add_test(TestCase {
        name: "parse_functions".into(),
        category: TestCategory::Parser,
        source: r#"
            fn simple() {}
            fn with_args(x: i32, y: i32) {}
            fn with_return() -> i32 { 42 }
            fn generic<T>(x: T) -> T { x }
            fn constrained<T: Clone + Debug>(x: T) {}
            fn with_where<T>(x: T) where T: Clone + Debug {}
            async fn async_fn() -> Result<(), Error> {}
            const fn const_fn() -> i32 { 42 }
            unsafe fn unsafe_fn() {}
            extern "C" fn extern_fn() {}
            fn variadic(x: i32, ...) {}
        "#.into(),
        expected: Expected::CompileSuccess { stdout: None, exit_code: 0 },
        timeout: Duration::from_secs(5),
        attributes: TestAttributes::default(),
    });
    
    runner.add_test(TestCase {
        name: "parse_structs".into(),
        category: TestCategory::Parser,
        source: r#"
            struct Unit;
            struct Tuple(i32, String);
            struct Named { x: i32, y: i32 }
            struct Generic<T> { value: T }
            struct WithLifetime<'a> { data: &'a str }
            struct Mixed<'a, T: Clone> { data: &'a T }
            
            #[derive(Debug, Clone)]
            pub struct Public {
                pub visible: i32,
                private: i32,
            }
        "#.into(),
        expected: Expected::CompileSuccess { stdout: None, exit_code: 0 },
        timeout: Duration::from_secs(5),
        attributes: TestAttributes::default(),
    });
    
    runner.add_test(TestCase {
        name: "parse_enums".into(),
        category: TestCategory::Parser,
        source: r#"
            enum Simple { A, B, C }
            enum WithValues { A = 1, B = 2, C = 3 }
            enum WithData {
                Unit,
                Tuple(i32, String),
                Struct { x: i32, y: i32 },
            }
            enum Generic<T> {
                Some(T),
                None,
            }
            
            #[repr(u8)]
            enum Repr { A = 0, B = 1 }
        "#.into(),
        expected: Expected::CompileSuccess { stdout: None, exit_code: 0 },
        timeout: Duration::from_secs(5),
        attributes: TestAttributes::default(),
    });
    
    runner.add_test(TestCase {
        name: "parse_traits".into(),
        category: TestCategory::Parser,
        source: r#"
            trait Simple {}
            
            trait WithMethods {
                fn required(&self);
                fn provided(&self) { }
            }
            
            trait WithTypes {
                type Output;
                type Error: std::error::Error;
            }
            
            trait WithConsts {
                const VALUE: i32;
                const DEFAULT: i32 = 0;
            }
            
            trait Bounded: Clone + Debug {}
            
            trait WithLifetime<'a> {
                fn get(&'a self) -> &'a str;
            }
            
            unsafe trait Unsafe {}
            auto trait Auto {}
        "#.into(),
        expected: Expected::CompileSuccess { stdout: None, exit_code: 0 },
        timeout: Duration::from_secs(5),
        attributes: TestAttributes::default(),
    });
    
    runner.add_test(TestCase {
        name: "parse_impls".into(),
        category: TestCategory::Parser,
        source: r#"
            impl Point {
                fn new(x: i32, y: i32) -> Self {
                    Point { x, y }
                }
                
                fn distance(&self, other: &Point) -> f64 {
                    // ...
                }
            }
            
            impl<T> Vec<T> {
                fn len(&self) -> usize { self.len }
            }
            
            impl Clone for Point {
                fn clone(&self) -> Self {
                    Point { x: self.x, y: self.y }
                }
            }
            
            impl<T: Clone> Clone for Container<T> {
                fn clone(&self) -> Self {
                    Container { value: self.value.clone() }
                }
            }
            
            unsafe impl Send for MyType {}
        "#.into(),
        expected: Expected::CompileSuccess { stdout: None, exit_code: 0 },
        timeout: Duration::from_secs(5),
        attributes: TestAttributes::default(),
    });
    
    runner.add_test(TestCase {
        name: "parse_type_aliases".into(),
        category: TestCategory::Parser,
        source: r#"
            type Result<T> = std::result::Result<T, Error>;
            type Callback = fn(i32) -> i32;
            type BoxedFuture<'a, T> = Box<dyn Future<Output = T> + Send + 'a>;
        "#.into(),
        expected: Expected::CompileSuccess { stdout: None, exit_code: 0 },
        timeout: Duration::from_secs(5),
        attributes: TestAttributes::default(),
    });
    
    runner.add_test(TestCase {
        name: "parse_modules".into(),
        category: TestCategory::Parser,
        source: r#"
            mod inline {
                pub fn inner() {}
            }
            
            pub mod public {
                pub(crate) fn crate_visible() {}
                pub(super) fn parent_visible() {}
                pub(in crate::path) fn path_visible() {}
            }
            
            #[path = "custom_path.quanta"]
            mod custom;
        "#.into(),
        expected: Expected::CompileSuccess { stdout: None, exit_code: 0 },
        timeout: Duration::from_secs(5),
        attributes: TestAttributes::default(),
    });
    
    runner.add_test(TestCase {
        name: "parse_use_statements".into(),
        category: TestCategory::Parser,
        source: r#"
            use std::io;
            use std::io::Read;
            use std::io::{Read, Write};
            use std::collections::*;
            use std::io::Result as IoResult;
            use crate::module::function;
            use super::parent_module;
            use self::sibling_module;
        "#.into(),
        expected: Expected::CompileSuccess { stdout: None, exit_code: 0 },
        timeout: Duration::from_secs(5),
        attributes: TestAttributes::default(),
    });
    
    // ─────────────────────────────────────────────────────────────────────────
    // Type Parsing
    // ─────────────────────────────────────────────────────────────────────────
    
    runner.add_test(TestCase {
        name: "parse_types".into(),
        category: TestCategory::Parser,
        source: r#"
            fn types(
                a: i32,
                b: &str,
                c: &'a str,
                d: &'static str,
                e: &mut i32,
                f: *const i32,
                g: *mut i32,
                h: [i32; 10],
                i: (i32, String, bool),
                j: fn(i32) -> i32,
                k: impl Fn(i32) -> i32,
                l: dyn Fn(i32) -> i32,
                m: Box<dyn Fn(i32) -> i32 + Send + 'static>,
                n: Vec<HashMap<String, Vec<i32>>>,
                o: Option<Result<T, E>>,
                p: <T as Trait>::Associated,
                q: Self::Type,
                r: !,
                s: _,
            ) {}
        "#.into(),
        expected: Expected::CompileSuccess { stdout: None, exit_code: 0 },
        timeout: Duration::from_secs(5),
        attributes: TestAttributes::default(),
    });
    
    // ─────────────────────────────────────────────────────────────────────────
    // Pattern Parsing
    // ─────────────────────────────────────────────────────────────────────────
    
    runner.add_test(TestCase {
        name: "parse_patterns".into(),
        category: TestCategory::Parser,
        source: r#"
            fn patterns() {
                match value {
                    _ => {},
                    x => {},
                    ref x => {},
                    ref mut x => {},
                    mut x => {},
                    1 => {},
                    1 | 2 | 3 => {},
                    1..=10 => {},
                    "literal" => {},
                    true | false => {},
                    (a, b) => {},
                    (a, ..) => {},
                    [a, b, c] => {},
                    [first, .., last] => {},
                    Point { x, y } => {},
                    Point { x: a, y: b } => {},
                    Point { x, .. } => {},
                    Some(x) => {},
                    Some(Some(x)) => {},
                    x @ 1..=10 => {},
                    x @ Some(_) => {},
                    &x => {},
                    &mut x => {},
                    box x => {},
                }
            }
        "#.into(),
        expected: Expected::CompileSuccess { stdout: None, exit_code: 0 },
        timeout: Duration::from_secs(5),
        attributes: TestAttributes::default(),
    });
    
    // ─────────────────────────────────────────────────────────────────────────
    // Attribute Parsing
    // ─────────────────────────────────────────────────────────────────────────
    
    runner.add_test(TestCase {
        name: "parse_attributes".into(),
        category: TestCategory::Parser,
        source: r#"
            #![crate_type = "lib"]
            #![feature(advanced_slice_patterns)]
            
            #[derive(Debug, Clone, Copy)]
            #[repr(C)]
            #[cfg(target_os = "linux")]
            #[cfg_attr(test, derive(Eq, PartialEq))]
            #[allow(unused)]
            #[deny(unsafe_code)]
            #[warn(missing_docs)]
            #[deprecated(since = "1.0", note = "use new_function instead")]
            #[doc = "Documentation"]
            /// Doc comment
            #[inline]
            #[inline(always)]
            #[cold]
            #[must_use]
            #[non_exhaustive]
            pub struct Attributed {
                #[serde(rename = "value")]
                field: i32,
            }
        "#.into(),
        expected: Expected::CompileSuccess { stdout: None, exit_code: 0 },
        timeout: Duration::from_secs(5),
        attributes: TestAttributes::default(),
    });
    
    // ─────────────────────────────────────────────────────────────────────────
    // Macro Parsing
    // ─────────────────────────────────────────────────────────────────────────
    
    runner.add_test(TestCase {
        name: "parse_macro_invocations".into(),
        category: TestCategory::Parser,
        source: r#"
            fn main() {
                println!("Hello, {}!", name);
                vec![1, 2, 3];
                format!("{:?}", value);
                assert!(condition);
                assert_eq!(a, b);
                debug!("debug message");
                custom_macro! { arbitrary tokens };
                sql!(SELECT * FROM users WHERE id = ?id);
            }
        "#.into(),
        expected: Expected::CompileSuccess { stdout: None, exit_code: 0 },
        timeout: Duration::from_secs(5),
        attributes: TestAttributes::default(),
    });
    
    runner.add_test(TestCase {
        name: "parse_macro_definitions".into(),
        category: TestCategory::Parser,
        source: r#"
            macro_rules! my_macro {
                () => {};
                ($x:expr) => { $x };
                ($($x:expr),*) => { $($x)* };
                ($($x:expr),+ $(,)?) => { $($x)+ };
                ($x:ident : $t:ty = $v:expr) => {
                    let $x: $t = $v;
                };
            }
            
            macro_rules! recursive {
                ([$($acc:tt)*]) => { [$($acc)*] };
                ([$($acc:tt)*] $x:tt $($rest:tt)*) => {
                    recursive!([$($acc)* $x] $($rest)*)
                };
            }
        "#.into(),
        expected: Expected::CompileSuccess { stdout: None, exit_code: 0 },
        timeout: Duration::from_secs(5),
        attributes: TestAttributes::default(),
    });
    
    // ─────────────────────────────────────────────────────────────────────────
    // Error Cases
    // ─────────────────────────────────────────────────────────────────────────
    
    runner.add_test(TestCase {
        name: "parse_error_missing_semicolon".into(),
        category: TestCategory::Parser,
        source: r#"
            fn main() {
                let x = 1
                let y = 2;
            }
        "#.into(),
        expected: Expected::PhaseError {
            phase: CompilePhase::Parse,
            error_contains: "expected `;`".into(),
        },
        timeout: Duration::from_secs(5),
        attributes: TestAttributes::default(),
    });
    
    runner.add_test(TestCase {
        name: "parse_error_unmatched_paren".into(),
        category: TestCategory::Parser,
        source: r#"
            fn main() {
                let x = (1 + 2;
            }
        "#.into(),
        expected: Expected::PhaseError {
            phase: CompilePhase::Parse,
            error_contains: "unmatched `(`".into(),
        },
        timeout: Duration::from_secs(5),
        attributes: TestAttributes::default(),
    });
    
    runner.add_test(TestCase {
        name: "parse_error_unexpected_token".into(),
        category: TestCategory::Parser,
        source: r#"
            fn main() {
                let = 1;
            }
        "#.into(),
        expected: Expected::PhaseError {
            phase: CompilePhase::Parse,
            error_contains: "expected pattern".into(),
        },
        timeout: Duration::from_secs(5),
        attributes: TestAttributes::default(),
    });
    
    runner.add_test(TestCase {
        name: "parse_error_invalid_item".into(),
        category: TestCategory::Parser,
        source: r#"
            hello world;
        "#.into(),
        expected: Expected::PhaseError {
            phase: CompilePhase::Parse,
            error_contains: "expected item".into(),
        },
        timeout: Duration::from_secs(5),
        attributes: TestAttributes::default(),
    });
}

// ═══════════════════════════════════════════════════════════════════════════════
// EMBEDDED TEST FILES
// ═══════════════════════════════════════════════════════════════════════════════

pub const TEST_PARSE_COMPLEX_EXPR: &str = r#"
//@ category: parser
//@ compile-pass

fn main() {
    // Complex nested expression
    let result = if let Some(x) = option {
        match x {
            Value::Int(n) => n * 2,
            Value::Float(f) => f as i32,
            _ => 0,
        }
    } else {
        default_value()
    };
}
"#;

pub const TEST_PARSE_ASYNC_AWAIT: &str = r#"
//@ category: parser
//@ compile-pass

async fn fetch_data(url: &str) -> Result<Data, Error> {
    let response = client.get(url).await?;
    let data = response.json().await?;
    Ok(data)
}

async fn process() {
    let future = async {
        let data = fetch_data("http://example.com").await?;
        transform(data)
    };
    
    let result = future.await;
}
"#;

pub const TEST_PARSE_GENERICS_COMPLEX: &str = r#"
//@ category: parser
//@ compile-pass

struct Complex<'a, 'b: 'a, T, U, V>
where
    T: Clone + Debug + 'a,
    U: From<T> + Into<V>,
    V: Default,
{
    data: &'a T,
    converted: U,
    phantom: PhantomData<&'b V>,
}

impl<'a, 'b: 'a, T, U, V> Complex<'a, 'b, T, U, V>
where
    T: Clone + Debug + 'a,
    U: From<T> + Into<V>,
    V: Default,
{
    fn new(data: &'a T) -> Self {
        Complex {
            data,
            converted: U::from(data.clone()),
            phantom: PhantomData,
        }
    }
}
"#;
