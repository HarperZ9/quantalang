// tests/functions/higher_order.quanta
// ═══════════════════════════════════════════════════════════════════════════════

// @test: higher_order
// @compile: success
// @run: exit(0), stdout_exact("1\n4\n9\n16\n25\n")
// @tags: functions, closures, iterators

fn main() {
    let numbers = [1, 2, 3, 4, 5];
    
    let squares: Vec<i32> = numbers.iter()
        .map(|x| x * x)
        .collect();
    
    for sq in squares {
        println(sq);
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// tests/functions/filter_map.quanta
// ═══════════════════════════════════════════════════════════════════════════════

// @test: filter_map
// @compile: success
// @run: exit(0), stdout_exact("4\n16\n")
// @tags: functions, closures, iterators

fn main() {
    let numbers = [1, 2, 3, 4, 5];
    
    let result: Vec<i32> = numbers.iter()
        .filter(|&&x| x % 2 == 0)
        .map(|&x| x * x)
        .collect();
    
    for x in result {
        println(x);
    }
}

