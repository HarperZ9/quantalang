// tests/functions/fn_once_trait.quanta
// ═══════════════════════════════════════════════════════════════════════════════

// @test: fn_once_trait
// @compile: success
// @run: exit(0), stdout("hello")
// @tags: functions, closures, traits

fn consume<F>(f: F)
where
    F: FnOnce() -> String,
{
    let s = f();
    println(s);
}

fn main() {
    let s = String::from("hello");
    consume(move || s);
}

