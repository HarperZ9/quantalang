// @test: where_clause
// @compile: success
// @run: exit(0), stdout("true")
// @tags: functions, generics, traits

fn compare_and_display<T, U>(t: T, u: U) -> bool
where
    T: PartialEq<U> + Display,
    U: Display,
{
    t == u
}

fn main() {
    println(compare_and_display(42, 42));
}

