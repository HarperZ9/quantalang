// ═══════════════════════════════════════════════════════════════════════════════
// tests/functions/compose.quanta
// ═══════════════════════════════════════════════════════════════════════════════

// @test: compose
// @compile: success
// @run: exit(0), stdout("12")
// @tags: functions, closures

fn compose<A, B, C, F, G>(f: F, g: G) -> impl Fn(A) -> C
where
    F: Fn(A) -> B,
    G: Fn(B) -> C,
{
    move |x| g(f(x))
}

fn main() {
    let add_one = |x| x + 1;
    let double = |x| x * 2;
    
    let add_then_double = compose(add_one, double);
    
    println(add_then_double(5));  // (5 + 1) * 2 = 12
}
