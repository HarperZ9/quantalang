// ═══════════════════════════════════════════════════════════════════════════════
// tests/functions/recursion.quanta
// ═══════════════════════════════════════════════════════════════════════════════

// @test: recursion
// @compile: success
// @run: exit(0), stdout("120")
// @tags: functions, recursion

fn factorial(n: i32) -> i32 {
    if n <= 1 {
        1
    } else {
        n * factorial(n - 1)
    }
}

fn main() {
    println(factorial(5));
}

// ═══════════════════════════════════════════════════════════════════════════════
// tests/functions/tail_recursion.quanta
// ═══════════════════════════════════════════════════════════════════════════════

// @test: tail_recursion
// @compile: success
// @run: exit(0), stdout("120")
// @tags: functions, recursion

fn factorial_tail(n: i32, acc: i32) -> i32 {
    if n <= 1 {
        acc
    } else {
        factorial_tail(n - 1, n * acc)
    }
}

fn factorial(n: i32) -> i32 {
    factorial_tail(n, 1)
}

fn main() {
    println(factorial(5));
}

// ═══════════════════════════════════════════════════════════════════════════════
// tests/functions/fibonacci.quanta
// ═══════════════════════════════════════════════════════════════════════════════

// @test: fibonacci
// @compile: success
// @run: exit(0), stdout("55")
// @tags: functions, recursion

fn fib(n: i32) -> i32 {
    match n {
        0 => 0,
        1 => 1,
        _ => fib(n - 1) + fib(n - 2),
    }
}

fn main() {
    println(fib(10));
}

// ═══════════════════════════════════════════════════════════════════════════════
// tests/functions/mutual_recursion.quanta
// ═══════════════════════════════════════════════════════════════════════════════

// @test: mutual_recursion
// @compile: success
// @run: exit(0), stdout_exact("true\nfalse\n")
// @tags: functions, recursion

fn is_even(n: u32) -> bool {
    if n == 0 {
        true
    } else {
        is_odd(n - 1)
    }
}

fn is_odd(n: u32) -> bool {
    if n == 0 {
        false
    } else {
        is_even(n - 1)
    }
}

fn main() {
    println(is_even(4));
    println(is_even(5));
}

