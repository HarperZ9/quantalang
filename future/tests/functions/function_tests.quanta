// @test: fn_trait
// @compile: success
// @run: exit(0), stdout("16")
// @tags: functions, closures, traits

fn apply<F>(f: F, x: i32) -> i32
where
    F: Fn(i32) -> i32,
{
    f(x)
}

fn double(x: i32) -> i32 {
    x * 2
}

fn main() {
    // Can pass a function
    println(apply(double, 8));
}

// ═══════════════════════════════════════════════════════════════════════════════
// tests/functions/fn_mut_trait.quanta
// ═══════════════════════════════════════════════════════════════════════════════

// @test: fn_mut_trait
// @compile: success
// @run: exit(0), stdout("3")
// @tags: functions, closures, traits

fn call_three_times<F>(mut f: F)
where
    F: FnMut(),
{
    f();
    f();
    f();
}

fn main() {
    let mut count = 0;
    call_three_times(|| count += 1);
    println(count);
}

