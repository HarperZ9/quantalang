// @test: generic_function
// @compile: success
// @run: exit(0), stdout_exact("42\nhello\n")
// @tags: functions, generics

fn identity<T>(x: T) -> T {
    x
}

fn main() {
    let a = identity(42);
    let b = identity("hello");
    
    println(a);
    println(b);
}

// ═══════════════════════════════════════════════════════════════════════════════
// tests/functions/generic_swap.quanta
// ═══════════════════════════════════════════════════════════════════════════════

// @test: generic_swap
// @compile: success
// @run: exit(0), stdout_exact("20\n10\n")
// @tags: functions, generics

fn swap<T>(a: &mut T, b: &mut T) {
    let temp = *a;
    *a = *b;
    *b = temp;
}

fn main() {
    let mut x = 10;
    let mut y = 20;
    
    swap(&mut x, &mut y);
    
    println(x);
    println(y);
}

