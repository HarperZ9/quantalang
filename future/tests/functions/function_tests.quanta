// @test: function_pointer
// @compile: success
// @run: exit(0), stdout_exact("8\n6\n")
// @tags: functions, pointers

fn add(a: i32, b: i32) -> i32 { a + b }
fn sub(a: i32, b: i32) -> i32 { a - b }

fn main() {
    let op: fn(i32, i32) -> i32 = add;
    println(op(3, 5));
    
    let op = sub;
    println(op(10, 4));
}

