// @test: explicit_return
// @compile: success
// @run: exit(0), stdout("positive")
// @tags: functions, return

fn sign(x: i32) -> &'static str {
    if x > 0 {
        return "positive";
    }
    if x < 0 {
        return "negative";
    }
    "zero"
}

fn main() {
    println(sign(5));
}

