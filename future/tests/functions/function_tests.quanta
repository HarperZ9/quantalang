// ═══════════════════════════════════════════════════════════════════════════════

// @test: closure_capture_mut
// @compile: success
// @run: exit(0), stdout("3")
// @tags: functions, closures

fn main() {
    let mut count = 0;
    
    let mut increment = || {
        count += 1;
    };
    
    increment();
    increment();
    increment();
    
    println(count);
}

