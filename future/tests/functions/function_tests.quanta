// ═══════════════════════════════════════════════════════════════════════════════

// @test: closure_move
// @compile: success
// @run: exit(0), stdout("hello")
// @tags: functions, closures

fn main() {
    let s = String::from("hello");
    
    let print_s = move || {
        println(s);
    };
    
    print_s();
    // s is no longer accessible here
}

// ═══════════════════════════════════════════════════════════════════════════════
// tests/functions/closure_as_param.quanta
// ═══════════════════════════════════════════════════════════════════════════════

// @test: closure_as_param
// @compile: success
// @run: exit(0), stdout_exact("2\n4\n6\n")
// @tags: functions, closures

fn apply_to_each<F>(arr: &[i32], f: F)
where
    F: Fn(i32),
{
    for &x in arr {
        f(x);
    }
}

fn main() {
    let arr = [1, 2, 3];
    apply_to_each(&arr, |x| println(x * 2));
}

