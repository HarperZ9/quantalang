#[cfg(test)]
mod tests {
    use super::*;
    
    #[test]
    fn test_worker_id() {
        let id = WorkerId::generate();
        assert!(id.0.starts_with("worker-"));
    }
    
    #[test]
    fn test_job_id() {
        let id = JobId::generate();
        assert!(id.0.starts_with("job-"));
    }
    
    #[test]
    fn test_scheduler_submit() {
        let scheduler = Scheduler::new(SchedulingPolicy::default());
        
        let job = CompilationJob {
            id: JobId::new("test-job"),
            unit_id: "main".to_string(),
            source_hash: [0; 32],
            target: "x86_64-unknown-linux".to_string(),
            opt_level: OptLevel::O2,
            dependencies: vec![],
            priority: 0,
            requirements: JobRequirements::default(),
            created_at: SystemTime::now(),
            deadline: None,
        };
        
        let id = scheduler.submit(job);
        assert_eq!(id.0, "test-job");
        
        let status = scheduler.status(&id).unwrap();
        assert!(matches!(status, JobStatus::Queued));
    }
    
    #[test]
    fn test_scheduler_dependencies() {
        let scheduler = Scheduler::new(SchedulingPolicy::default());
        
        let dep_job = CompilationJob {
            id: JobId::new("dep"),
            unit_id: "dep".to_string(),
            source_hash: [0; 32],
            target: "x86_64-unknown-linux".to_string(),
            opt_level: OptLevel::O2,
            dependencies: vec![],
            priority: 0,
            requirements: JobRequirements::default(),
            created_at: SystemTime::now(),
            deadline: None,
        };
        
        let main_job = CompilationJob {
            id: JobId::new("main"),
            unit_id: "main".to_string(),
            source_hash: [0; 32],
            target: "x86_64-unknown-linux".to_string(),
            opt_level: OptLevel::O2,
            dependencies: vec![JobId::new("dep")],
            priority: 0,
            requirements: JobRequirements::default(),
            created_at: SystemTime::now(),
            deadline: None,
        };
        
        scheduler.submit(dep_job);
        scheduler.submit(main_job);
        
        // Main should be pending
        let status = scheduler.status(&JobId::new("main")).unwrap();
        assert!(matches!(status, JobStatus::Pending { .. }));
        
        // Complete dep
        scheduler.complete(&JobId::new("dep"), vec![], Duration::from_secs(1));
        
        // Main should now be queued
        let status = scheduler.status(&JobId::new("main")).unwrap();
        assert!(matches!(status, JobStatus::Queued));
    }
    
    #[test]
    fn test_worker_capabilities() {
        let caps = WorkerCapabilities::default();
        assert_eq!(caps.cores, 4);
        assert!(caps.targets.contains(&"x86_64-unknown-linux".to_string()));
    }
}
