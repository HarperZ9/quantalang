// CONVENIENCE API
// ═══════════════════════════════════════════════════════════════════════════════

/// Quick compliance check with default settings
pub fn check_file(path: &Path) -> Result<ComplianceReport, CheckerError> {
    let checker = ComplianceChecker::new(CheckerConfig::default());
    checker.check_file(path)?;
    Ok(checker.generate_report())
}

/// Quick compliance check with profile
pub fn check_file_with_profile(
    path: &Path,
    profile: ComplianceProfile,
) -> Result<ComplianceReport, CheckerError> {
    let checker = ComplianceChecker::new(CheckerConfig {
        profile,
        ..Default::default()
    });
    checker.check_file(path)?;
    Ok(checker.generate_report())
}

/// Check source string
pub fn check_source(source: &str) -> Result<ComplianceReport, CheckerError> {
    let checker = ComplianceChecker::new(CheckerConfig::default());
    checker.check_source(Path::new("<source>"), source)?;
    Ok(checker.generate_report())
}

/// Get all available rules
pub fn all_rules() -> Vec<Rule> {
    let db = RuleDatabase::new();
    db.rules_for_standard(Standard::MisraC2012)
        .into_iter()
        .chain(db.rules_for_standard(Standard::CertC))
        .cloned()
        .collect()
}

/// Get rules for standard
pub fn rules_for(standard: Standard) -> Vec<Rule> {
    let db = RuleDatabase::new();
    db.rules_for_standard(standard)
        .into_iter()
        .cloned()
        .collect()
}

