// CHECKER BUILDER
// ═══════════════════════════════════════════════════════════════════════════════

/// Builder for compliance checker
pub struct CheckerBuilder {
    config: CheckerConfig,
    checkers: Vec<Box<dyn RuleChecker>>,
}

impl CheckerBuilder {
    /// Create new builder
    pub fn new() -> Self {
        CheckerBuilder {
            config: CheckerConfig::default(),
            checkers: Vec::new(),
        }
    }
    
    /// Set profile
    pub fn profile(mut self, profile: ComplianceProfile) -> Self {
        self.config.profile = profile;
        self
    }
    
    /// Automotive profile
    pub fn automotive(mut self, asil: Asil) -> Self {
        self.config.profile = ComplianceProfile::automotive(asil);
        self
    }
    
    /// Avionics profile
    pub fn avionics(mut self, dal: Dal) -> Self {
        self.config.profile = ComplianceProfile::avionics(dal);
        self
    }
    
    /// Security profile
    pub fn security(mut self) -> Self {
        self.config.profile = ComplianceProfile::security();
        self
    }
    
    /// Treat warnings as errors
    pub fn warnings_as_errors(mut self, enabled: bool) -> Self {
        self.config.warnings_as_errors = enabled;
        self
    }
    
    /// Set max violations
    pub fn max_violations(mut self, max: usize) -> Self {
        self.config.max_violations = Some(max);
        self
    }
    
    /// Enable fix suggestions
    pub fn suggest_fixes(mut self, enabled: bool) -> Self {
        self.config.suggest_fixes = enabled;
        self
    }
    
    /// Enable parallel checking
    pub fn parallel(mut self, enabled: bool) -> Self {
        self.config.parallel = enabled;
        self
    }
    
    /// Add custom checker
    pub fn checker(mut self, checker: Box<dyn RuleChecker>) -> Self {
        self.checkers.push(checker);
        self
    }
    
    /// Add all built-in checkers
    pub fn with_builtin_checkers(mut self) -> Self {
        self.checkers.push(Box::new(UnusedReturnChecker));
        self.checkers.push(Box::new(GotoChecker));
        self
    }
    
    /// Build checker
    pub fn build(self) -> ComplianceChecker {
        let mut checker = ComplianceChecker::new(self.config);
        for c in self.checkers {
            checker.register_checker(c);
        }
        checker
    }
}

impl Default for CheckerBuilder {
    fn default() -> Self {
        Self::new()
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// REPORT FORMATTERS
// ═══════════════════════════════════════════════════════════════════════════════

/// Report output format
#[derive(Debug, Clone, Copy, PartialEq, Eq)]
pub enum ReportFormat {
    Text,
    Json,
    Sarif,
    Html,
    Csv,
}

/// Format report
pub fn format_report(report: &ComplianceReport, format: ReportFormat) -> String {
    match format {
        ReportFormat::Text => report.to_text(),
        ReportFormat::Json => report.to_json(),
        ReportFormat::Sarif => report.to_sarif(),
        ReportFormat::Html => format_html(report),
        ReportFormat::Csv => format_csv(report),
    }
}

fn format_html(report: &ComplianceReport) -> String {
    let mut html = String::from("<!DOCTYPE html>\n<html>\n<head>\n");
    html.push_str("<title>Compliance Report</title>\n");
    html.push_str("<style>\n");
    html.push_str("body { font-family: system-ui; margin: 2em; }\n");
    html.push_str("table { border-collapse: collapse; width: 100%; }\n");
    html.push_str("th, td { border: 1px solid #ddd; padding: 8px; text-align: left; }\n");
    html.push_str("th { background-color: #4CAF50; color: white; }\n");
    html.push_str(".error { color: red; }\n");
    html.push_str(".warning { color: orange; }\n");
    html.push_str(".info { color: blue; }\n");
    html.push_str(".compliant { color: green; font-weight: bold; }\n");
    html.push_str(".non-compliant { color: red; font-weight: bold; }\n");
    html.push_str("</style>\n");
    html.push_str("</head>\n<body>\n");
    
    html.push_str("<h1>Compliance Report</h1>\n");
    html.push_str(&format!("<p>Profile: <strong>{}</strong></p>\n", report.profile));
    html.push_str(&format!(
        "<p>Status: <span class=\"{}\">{}</span></p>\n",
        if report.compliant { "compliant" } else { "non-compliant" },
        if report.compliant { "✓ COMPLIANT" } else { "✗ NON-COMPLIANT" }
    ));
    
    html.push_str("<h2>Statistics</h2>\n");
    html.push_str("<ul>\n");
    html.push_str(&format!("<li>Files checked: {}</li>\n", report.stats.files_checked));
    html.push_str(&format!("<li>Lines checked: {}</li>\n", report.stats.lines_checked));
    html.push_str(&format!("<li>Violations: {}</li>\n", report.stats.violations_found));
    html.push_str("</ul>\n");
    
    if !report.violations.is_empty() {
        html.push_str("<h2>Violations</h2>\n");
        html.push_str("<table>\n");
        html.push_str("<tr><th>Severity</th><th>Rule</th><th>Location</th><th>Message</th></tr>\n");
        
        for v in &report.violations {
            if v.suppressed {
                continue;
            }
            html.push_str(&format!(
                "<tr class=\"{}\"><td>{}</td><td>{}</td><td>{}:{}:{}</td><td>{}</td></tr>\n",
                v.severity.name(),
                v.severity.name(),
                v.rule_id,
                v.location.file.display(),
                v.location.line,
                v.location.column,
                html_escape(&v.message)
            ));
        }
        
        html.push_str("</table>\n");
    }
    
    html.push_str("</body>\n</html>\n");
    html
}

fn format_csv(report: &ComplianceReport) -> String {
    let mut csv = String::from("Severity,Rule,File,Line,Column,Message,Suppressed\n");
    
    for v in &report.violations {
        csv.push_str(&format!(
            "{},{},{},{},{},\"{}\",{}\n",
            v.severity.name(),
            v.rule_id,
            v.location.file.display(),
            v.location.line,
            v.location.column,
            csv_escape(&v.message),
            v.suppressed
        ));
    }
    
    csv
}

fn html_escape(s: &str) -> String {
    s.replace('&', "&amp;")
        .replace('<', "&lt;")
        .replace('>', "&gt;")
        .replace('"', "&quot;")
}

fn csv_escape(s: &str) -> String {
    s.replace('"', "\"\"")
}

