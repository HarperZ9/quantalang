// DEVIATION MANAGEMENT
// ═══════════════════════════════════════════════════════════════════════════════

/// Deviation record
#[derive(Debug, Clone)]
pub struct Deviation {
    /// Unique identifier
    pub id: String,
    
    /// Rule being deviated
    pub rule_id: String,
    
    /// Justification
    pub justification: String,
    
    /// Risk assessment
    pub risk_assessment: String,
    
    /// Mitigations
    pub mitigations: Vec<String>,
    
    /// Approved by
    pub approved_by: String,
    
    /// Approval date
    pub approval_date: String,
    
    /// Expiration (if any)
    pub expires: Option<String>,
    
    /// Locations covered
    pub locations: Vec<SuppressionLocation>,
}

impl Deviation {
    pub fn new(id: impl Into<String>, rule_id: impl Into<String>) -> Self {
        Deviation {
            id: id.into(),
            rule_id: rule_id.into(),
            justification: String::new(),
            risk_assessment: String::new(),
            mitigations: Vec::new(),
            approved_by: String::new(),
            approval_date: String::new(),
            expires: None,
            locations: Vec::new(),
        }
    }
    
    pub fn justification(mut self, j: impl Into<String>) -> Self {
        self.justification = j.into();
        self
    }
    
    pub fn risk_assessment(mut self, r: impl Into<String>) -> Self {
        self.risk_assessment = r.into();
        self
    }
    
    pub fn mitigation(mut self, m: impl Into<String>) -> Self {
        self.mitigations.push(m.into());
        self
    }
    
    pub fn approved_by(mut self, a: impl Into<String>) -> Self {
        self.approved_by = a.into();
        self
    }
    
    pub fn approval_date(mut self, d: impl Into<String>) -> Self {
        self.approval_date = d.into();
        self
    }
    
    pub fn location(mut self, loc: SuppressionLocation) -> Self {
        self.locations.push(loc);
        self
    }
    
    /// Convert to suppression
    pub fn to_suppression(&self) -> Suppression {
        Suppression {
            location: self.locations.first()
                .cloned()
                .unwrap_or(SuppressionLocation::Project),
            justification: self.justification.clone(),
            approved_by: Some(self.approved_by.clone()),
            approved_date: Some(self.approval_date.clone()),
        }
    }
}

/// Deviation database
pub struct DeviationDatabase {
    deviations: Vec<Deviation>,
}

impl DeviationDatabase {
    pub fn new() -> Self {
        DeviationDatabase {
            deviations: Vec::new(),
        }
    }
    
    pub fn add(&mut self, deviation: Deviation) {
        self.deviations.push(deviation);
    }
    
    pub fn get(&self, id: &str) -> Option<&Deviation> {
        self.deviations.iter().find(|d| d.id == id)
    }
    
    pub fn for_rule(&self, rule_id: &str) -> Vec<&Deviation> {
        self.deviations.iter()
            .filter(|d| d.rule_id == rule_id)
            .collect()
    }
    
    pub fn all(&self) -> &[Deviation] {
        &self.deviations
    }
}

impl Default for DeviationDatabase {
    fn default() -> Self {
        Self::new()
    }
}

