// ═══════════════════════════════════════════════════════════════════════════════
// TESTS
// ═══════════════════════════════════════════════════════════════════════════════

#[cfg(test)]
mod tests {
    use super::*;
    
    #[test]
    fn test_checker_builder() {
        let checker = CheckerBuilder::new()
            .automotive(Asil::B)
            .warnings_as_errors(true)
            .with_builtin_checkers()
            .build();
        
        assert_eq!(checker.config.profile.name, "Automotive ASIL B");
    }
    
    #[test]
    fn test_report_formats() {
        let report = ComplianceReport {
            profile: "test".to_string(),
            compliant: true,
            violations: vec![],
            stats: CheckerStats::default(),
            by_severity: std::collections::BTreeMap::new(),
            by_rule: std::collections::BTreeMap::new(),
            by_file: std::collections::BTreeMap::new(),
        };
        
        let text = format_report(&report, ReportFormat::Text);
        assert!(text.contains("COMPLIANT"));
        
        let html = format_report(&report, ReportFormat::Html);
        assert!(html.contains("<html>"));
        
        let csv = format_report(&report, ReportFormat::Csv);
        assert!(csv.contains("Severity"));
    }
    
    #[test]
    fn test_deviation() {
        let deviation = Deviation::new("DEV-001", "MISRA-C:2012-R15.1")
            .justification("Required for error handling in legacy code")
            .risk_assessment("Low - limited to specific module")
            .mitigation("Code review required for all changes")
            .approved_by("Safety Engineer")
            .approval_date("2025-01-15");
        
        assert_eq!(deviation.id, "DEV-001");
        assert!(!deviation.mitigations.is_empty());
    }
}
