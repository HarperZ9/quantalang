//
// Foreign Function Interface for C/C++ interoperability.
//
// Features:
// - Safe wrappers for foreign functions
// - Automatic binding generation from C headers
// - Multiple ABI support (System V, Windows, ARM)
// - Runtime safety checks
// - Callback support with trampolines
//
// ═══════════════════════════════════════════════════════════════════════════════

//! # QuantaLang FFI
//!
//! Safe foreign function interface for calling C libraries.
//!
//! ## Quick Start
//!
//! ```quanta
//! // Load a shared library
//! use quantalang::ffi::{Library, link};
//!
//! let lib = Library::open("libm.so")?;
//! let sqrt: extern "C" fn(f64) -> f64 = lib.get("sqrt")?;
//! println!("sqrt(2) = {}", sqrt(2.0));
//! ```
//!
//! ## Automatic Bindings
//!
//! ```bash
//! # Generate bindings from C header
//! quanta-ffi generate --header math.h --output math_ffi.quanta
//! ```
//!
//! ## Inline FFI
//!
//! ```quanta
//! #[link(name = "c")]
//! extern "C" {
//!     fn strlen(s: *const c_char) -> usize;
//!     fn printf(format: *const c_char, ...) -> c_int;
//! }
//! ```
//!
//! ## Safety
//!
//! All FFI calls are inherently unsafe. Use the `unsafe` block:
//!
//! ```quanta
//! unsafe {
//!     let len = strlen(c"hello".as_ptr());
//! }
//! ```

