// PRIMITIVE C TYPES
// ═══════════════════════════════════════════════════════════════════════════════

/// C char type
pub type c_char = i8;

/// C signed char type
pub type c_schar = i8;

/// C unsigned char type
pub type c_uchar = u8;

/// C short type
pub type c_short = i16;

/// C unsigned short type
pub type c_ushort = u16;

/// C int type
pub type c_int = i32;

/// C unsigned int type
pub type c_uint = u32;

/// C long type (platform-dependent)
#[cfg(target_pointer_width = "64")]
pub type c_long = i64;
#[cfg(target_pointer_width = "32")]
pub type c_long = i32;

/// C unsigned long type (platform-dependent)
#[cfg(target_pointer_width = "64")]
pub type c_ulong = u64;
#[cfg(target_pointer_width = "32")]
pub type c_ulong = u32;

/// C long long type
pub type c_longlong = i64;

/// C unsigned long long type
pub type c_ulonglong = u64;

/// C float type
pub type c_float = f32;

/// C double type
pub type c_double = f64;

/// C size_t type
pub type c_size_t = usize;

/// C ssize_t type
pub type c_ssize_t = isize;

/// C void type (for pointers)
pub type c_void = ();

/// C intptr_t type
pub type c_intptr_t = isize;

/// C uintptr_t type
pub type c_uintptr_t = usize;

