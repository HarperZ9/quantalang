// QUANTA Standard Library - String
// UTF-8 encoded, growable string type

module std::string;

use std::vec::Vec;
use runtime::allocator::{Allocator, GlobalAllocator, Layout};
use core::mem::{size_of, swap};
use core::ptr::{copy_nonoverlapping};
use core::iter::{Iterator, IntoIterator, FromIterator, DoubleEndedIterator};
use core::cmp::{Ordering, PartialEq, Eq, PartialOrd, Ord};
use core::hash::{Hash, Hasher};
use core::ops::{Index, Add, AddAssign, Deref, DerefMut};
use core::fmt::{Debug, Display, Formatter, Result as FmtResult, Write};
use core::option::Option::{self, Some, None};
use core::result::Result::{self, Ok, Err};
use core::clone::Clone;

/// UTF-8 encoded string
pub struct String {
    vec: Vec<u8>,
}

impl String {
    /// Create empty string
    #[inline]
    pub const fn new() -> Self {
        Self { vec: Vec::new() }
    }
    
    /// Create with capacity
    #[inline]
    pub fn with_capacity(capacity: usize) -> Self {
        Self { vec: Vec::with_capacity(capacity) }
    }
    
    /// Create from UTF-8 bytes (unsafe, no validation)
    #[inline]
    pub unsafe fn from_utf8_unchecked(bytes: Vec<u8>) -> Self {
        Self { vec: bytes }
    }
    
    /// Create from UTF-8 bytes with validation
    pub fn from_utf8(bytes: Vec<u8>) -> Result<Self, Utf8Error> {
        match validate_utf8(&bytes) {
            Ok(()) => Ok(Self { vec: bytes }),
            Err(e) => Err(e),
        }
    }
    
    /// Create from byte slice
    pub fn from_utf8_lossy(bytes: &[u8]) -> Self {
        let mut s = String::with_capacity(bytes.len());
        let mut i = 0;
        
        while i < bytes.len() {
            match decode_utf8(&bytes[i..]) {
                Ok((ch, len)) => {
                    s.push(ch);
                    i += len;
                }
                Err(_) => {
                    s.push('\u{FFFD}');  // Replacement character
                    i += 1;
                }
            }
        }
        
        s
    }
    
    /// Create from &str
    pub fn from_str(s: &str) -> Self {
        let mut string = Self::with_capacity(s.len());
        string.push_str(s);
        string
    }
    
    /// Length in bytes
    #[inline]
    pub fn len(&self) -> usize {
        self.vec.len()
    }
    
    /// Check if empty
    #[inline]
    pub fn is_empty(&self) -> bool {
        self.vec.is_empty()
    }
    
    /// Capacity in bytes
    #[inline]
    pub fn capacity(&self) -> usize {
        self.vec.capacity()
    }
    
    /// Reserve capacity
    #[inline]
    pub fn reserve(&mut self, additional: usize) {
        self.vec.reserve(additional);
    }
    
    /// Shrink to fit
    #[inline]
    pub fn shrink_to_fit(&mut self) {
        self.vec.shrink_to_fit();
    }
    
    /// Push character
    pub fn push(&mut self, ch: char) {
        let mut buf = [0u8; 4];
        let len = encode_utf8(ch, &mut buf);
        self.vec.extend(buf[..len].iter().copied());
    }
    
    /// Push string slice
    pub fn push_str(&mut self, s: &str) {
        self.vec.extend(s.as_bytes().iter().copied());
    }
    
    /// Pop character
    pub fn pop(&mut self) -> Option<char> {
        if self.is_empty() {
            return None;
        }
        
        let ch = self.chars().next_back()?;
        let new_len = self.len() - ch.len_utf8();
        self.vec.truncate(new_len);
        Some(ch)
    }
    
    /// Clear string
    #[inline]
    pub fn clear(&mut self) {
        self.vec.clear();
    }
    
    /// Truncate to byte position (must be char boundary)
    pub fn truncate(&mut self, new_len: usize) {
        if new_len < self.len() {
            assert!(self.is_char_boundary(new_len));
            self.vec.truncate(new_len);
        }
    }
    
    /// Remove character at byte index
    pub fn remove(&mut self, idx: usize) -> char {
        assert!(self.is_char_boundary(idx));
        let ch = self[idx..].chars().next().unwrap();
        let next = idx + ch.len_utf8();
        
        // Shift bytes left
        let len = self.len();
        unsafe {
            copy_nonoverlapping(
                self.vec.as_ptr().add(next),
                self.vec.as_mut_ptr().add(idx),
                len - next
            );
        }
        self.vec.truncate(len - (next - idx));
        ch
    }
    
    /// Insert character at byte index
    pub fn insert(&mut self, idx: usize, ch: char) {
        assert!(self.is_char_boundary(idx));
        
        let mut buf = [0u8; 4];
        let len = encode_utf8(ch, &mut buf);
        
        self.vec.reserve(len);
        let old_len = self.len();
        
        // Shift bytes right
        unsafe {
            self.vec.set_len(old_len + len);
            copy_nonoverlapping(
                self.vec.as_ptr().add(idx),
                self.vec.as_mut_ptr().add(idx + len),
                old_len - idx
            );
            copy_nonoverlapping(
                buf.as_ptr(),
                self.vec.as_mut_ptr().add(idx),
                len
            );
        }
    }
    
    /// Insert string at byte index
    pub fn insert_str(&mut self, idx: usize, s: &str) {
        assert!(self.is_char_boundary(idx));
        
        let insert_len = s.len();
        self.vec.reserve(insert_len);
        let old_len = self.len();
        
        unsafe {
            self.vec.set_len(old_len + insert_len);
            copy_nonoverlapping(
                self.vec.as_ptr().add(idx),
                self.vec.as_mut_ptr().add(idx + insert_len),
                old_len - idx
            );
            copy_nonoverlapping(
                s.as_ptr(),
                self.vec.as_mut_ptr().add(idx),
                insert_len
            );
        }
    }
    
    /// Check if index is char boundary
    pub fn is_char_boundary(&self, idx: usize) -> bool {
        if idx == 0 || idx == self.len() {
            return true;
        }
        if idx > self.len() {
            return false;
        }
        // Not a continuation byte (0b10xxxxxx)
        (self.vec[idx] & 0xC0) != 0x80
    }
    
    /// Get as &str
    #[inline]
    pub fn as_str(&self) -> &str {
        unsafe { core::str::from_utf8_unchecked(&self.vec) }
    }
    
    /// Get as &mut str
    #[inline]
    pub fn as_mut_str(&mut self) -> &mut str {
        unsafe { core::str::from_utf8_unchecked_mut(&mut self.vec) }
    }
    
    /// Get as bytes
    #[inline]
    pub fn as_bytes(&self) -> &[u8] {
        &self.vec
    }
    
    /// Get mutable bytes (unsafe)
    #[inline]
    pub unsafe fn as_bytes_mut(&mut self) -> &mut [u8] {
        &mut self.vec
    }
    
    /// Into bytes
    #[inline]
    pub fn into_bytes(self) -> Vec<u8> {
        self.vec
    }
    
    /// Character iterator
    #[inline]
    pub fn chars(&self) -> Chars {
        Chars { bytes: self.as_bytes(), pos: 0 }
    }
    
    /// Character indices iterator
    #[inline]
    pub fn char_indices(&self) -> CharIndices {
        CharIndices { bytes: self.as_bytes(), pos: 0 }
    }
    
    /// Byte iterator
    #[inline]
    pub fn bytes(&self) -> core::slice::Iter<u8> {
        self.vec.iter()
    }
    
    /// Line iterator
    pub fn lines(&self) -> Lines {
        Lines { remaining: self.as_str() }
    }
    
    /// Split by pattern
    pub fn split<'a>(&'a self, pattern: char) -> Split<'a> {
        Split { 
            remaining: self.as_str(),
            pattern,
            finished: false,
        }
    }
    
    /// Split whitespace
    pub fn split_whitespace(&self) -> SplitWhitespace {
        SplitWhitespace { remaining: self.as_str() }
    }
    
    /// Trim whitespace
    pub fn trim(&self) -> &str {
        self.trim_start().trim_end_str()
    }
    
    /// Trim leading whitespace
    pub fn trim_start(&self) -> &str {
        let bytes = self.as_bytes();
        let mut start = 0;
        
        while start < bytes.len() {
            if let Ok((ch, len)) = decode_utf8(&bytes[start..]) {
                if ch.is_whitespace() {
                    start += len;
                } else {
                    break;
                }
            } else {
                break;
            }
        }
        
        unsafe { core::str::from_utf8_unchecked(&bytes[start..]) }
    }
    
    /// Trim trailing whitespace
    pub fn trim_end(&self) -> &str {
        self.as_str().trim_end_str()
    }
    
    /// Contains substring
    pub fn contains(&self, pattern: &str) -> bool {
        self.find(pattern).is_some()
    }
    
    /// Find substring
    pub fn find(&self, pattern: &str) -> Option<usize> {
        if pattern.is_empty() {
            return Some(0);
        }
        if pattern.len() > self.len() {
            return None;
        }
        
        let bytes = self.as_bytes();
        let pat_bytes = pattern.as_bytes();
        
        for i in 0..=(bytes.len() - pat_bytes.len()) {
            if &bytes[i..i + pat_bytes.len()] == pat_bytes {
                return Some(i);
            }
        }
        
        None
    }
    
    /// Rfind substring
    pub fn rfind(&self, pattern: &str) -> Option<usize> {
        if pattern.is_empty() {
            return Some(self.len());
        }
        if pattern.len() > self.len() {
            return None;
        }
        
        let bytes = self.as_bytes();
        let pat_bytes = pattern.as_bytes();
        
        for i in (0..=(bytes.len() - pat_bytes.len())).rev() {
            if &bytes[i..i + pat_bytes.len()] == pat_bytes {
                return Some(i);
            }
        }
        
        None
    }
    
    /// Starts with prefix
    pub fn starts_with(&self, pattern: &str) -> bool {
        self.as_bytes().starts_with(pattern.as_bytes())
    }
    
    /// Ends with suffix
    pub fn ends_with(&self, pattern: &str) -> bool {
        self.as_bytes().ends_with(pattern.as_bytes())
    }
    
    /// Replace all occurrences
    pub fn replace(&self, from: &str, to: &str) -> String {
        let mut result = String::with_capacity(self.len());
        let mut last_end = 0;
        
        let mut search_start = 0;
        while search_start <= self.len() {
            if let Some(start) = self[search_start..].find(from).map(|i| search_start + i) {
                result.push_str(&self[last_end..start]);
                result.push_str(to);
                last_end = start + from.len();
                search_start = last_end;
            } else {
                break;
            }
        }
        
        result.push_str(&self[last_end..]);
        result
    }
    
    /// To uppercase
    pub fn to_uppercase(&self) -> String {
        let mut result = String::with_capacity(self.len());
        for ch in self.chars() {
            for upper in ch.to_uppercase() {
                result.push(upper);
            }
        }
        result
    }
    
    /// To lowercase
    pub fn to_lowercase(&self) -> String {
        let mut result = String::with_capacity(self.len());
        for ch in self.chars() {
            for lower in ch.to_lowercase() {
                result.push(lower);
            }
        }
        result
    }
    
    /// Repeat n times
    pub fn repeat(&self, n: usize) -> String {
        let mut result = String::with_capacity(self.len() * n);
        for _ in 0..n {
            result.push_str(self.as_str());
        }
        result
    }
}

// UTF-8 encoding helpers
fn encode_utf8(ch: char, buf: &mut [u8; 4]) -> usize {
    let code = ch as u32;
    
    if code < 0x80 {
        buf[0] = code as u8;
        1
    } else if code < 0x800 {
        buf[0] = 0xC0 | ((code >> 6) as u8);
        buf[1] = 0x80 | ((code & 0x3F) as u8);
        2
    } else if code < 0x10000 {
        buf[0] = 0xE0 | ((code >> 12) as u8);
        buf[1] = 0x80 | (((code >> 6) & 0x3F) as u8);
        buf[2] = 0x80 | ((code & 0x3F) as u8);
        3
    } else {
        buf[0] = 0xF0 | ((code >> 18) as u8);
        buf[1] = 0x80 | (((code >> 12) & 0x3F) as u8);
        buf[2] = 0x80 | (((code >> 6) & 0x3F) as u8);
        buf[3] = 0x80 | ((code & 0x3F) as u8);
        4
    }
}

fn decode_utf8(bytes: &[u8]) -> Result<(char, usize), Utf8Error> {
    if bytes.is_empty() {
        return Err(Utf8Error { valid_up_to: 0, error_len: None });
    }
    
    let b0 = bytes[0];
    
    if b0 < 0x80 {
        return Ok((b0 as char, 1));
    }
    
    let (len, min_code) = if b0 & 0xE0 == 0xC0 {
        (2, 0x80u32)
    } else if b0 & 0xF0 == 0xE0 {
        (3, 0x800u32)
    } else if b0 & 0xF8 == 0xF0 {
        (4, 0x10000u32)
    } else {
        return Err(Utf8Error { valid_up_to: 0, error_len: Some(1) });
    };
    
    if bytes.len() < len {
        return Err(Utf8Error { valid_up_to: 0, error_len: None });
    }
    
    let mut code = (b0 & (0x7F >> len)) as u32;
    
    for i in 1..len {
        let b = bytes[i];
        if b & 0xC0 != 0x80 {
            return Err(Utf8Error { valid_up_to: 0, error_len: Some(i) });
        }
        code = (code << 6) | (b & 0x3F) as u32;
    }
    
    if code < min_code || (0xD800 <= code && code <= 0xDFFF) || code > 0x10FFFF {
        return Err(Utf8Error { valid_up_to: 0, error_len: Some(len) });
    }
    
    Ok((unsafe { char::from_u32_unchecked(code) }, len))
}

fn validate_utf8(bytes: &[u8]) -> Result<(), Utf8Error> {
    let mut i = 0;
    while i < bytes.len() {
        match decode_utf8(&bytes[i..]) {
            Ok((_, len)) => i += len,
            Err(mut e) => {
                e.valid_up_to = i;
                return Err(e);
            }
        }
    }
    Ok(())
}

/// UTF-8 decoding error
#[derive(Debug, Clone, Copy)]
pub struct Utf8Error {
    pub valid_up_to: usize,
    pub error_len: Option<usize>,
}

// Trait implementations
impl Clone for String {
    fn clone(&self) -> Self {
        Self { vec: self.vec.clone() }
    }
}

impl PartialEq for String {
    fn eq(&self, other: &Self) -> bool {
        self.vec == other.vec
    }
}

impl Eq for String {}

impl PartialOrd for String {
    fn partial_cmp(&self, other: &Self) -> Option<Ordering> {
        Some(self.cmp(other))
    }
}

impl Ord for String {
    fn cmp(&self, other: &Self) -> Ordering {
        self.as_bytes().cmp(other.as_bytes())
    }
}

impl Hash for String {
    fn hash<H: Hasher>(&self, state: &mut H) {
        self.as_bytes().hash(state);
    }
}

impl Debug for String {
    fn fmt(&self, f: &mut Formatter) -> FmtResult {
        write!(f, "\"{}\"", self.as_str())
    }
}

impl Display for String {
    fn fmt(&self, f: &mut Formatter) -> FmtResult {
        f.write_str(self.as_str())
    }
}

impl Default for String {
    fn default() -> Self {
        Self::new()
    }
}

impl Deref for String {
    type Target = str;
    
    fn deref(&self) -> &str {
        self.as_str()
    }
}

impl DerefMut for String {
    fn deref_mut(&mut self) -> &mut str {
        self.as_mut_str()
    }
}

impl Index<core::ops::Range<usize>> for String {
    type Output = str;
    
    fn index(&self, range: core::ops::Range<usize>) -> &str {
        &self.as_str()[range]
    }
}

impl Index<core::ops::RangeFrom<usize>> for String {
    type Output = str;
    
    fn index(&self, range: core::ops::RangeFrom<usize>) -> &str {
        &self.as_str()[range]
    }
}

impl Index<core::ops::RangeTo<usize>> for String {
    type Output = str;
    
    fn index(&self, range: core::ops::RangeTo<usize>) -> &str {
        &self.as_str()[range]
    }
}

impl Index<core::ops::RangeFull> for String {
    type Output = str;
    
    fn index(&self, _: core::ops::RangeFull) -> &str {
        self.as_str()
    }
}

impl Add<&str> for String {
    type Output = String;
    
    fn add(mut self, rhs: &str) -> String {
        self.push_str(rhs);
        self
    }
}

impl AddAssign<&str> for String {
    fn add_assign(&mut self, rhs: &str) {
        self.push_str(rhs);
    }
}

impl Write for String {
    fn write_str(&mut self, s: &str) -> FmtResult {
        self.push_str(s);
        Ok(())
    }
}

impl FromIterator<char> for String {
    fn from_iter<I: IntoIterator<Item = char>>(iter: I) -> Self {
        let mut s = String::new();
        for ch in iter {
            s.push(ch);
        }
        s
    }
}

impl<'a> FromIterator<&'a str> for String {
    fn from_iter<I: IntoIterator<Item = &'a str>>(iter: I) -> Self {
        let mut s = String::new();
        for part in iter {
            s.push_str(part);
        }
        s
    }
}

// Iterators
pub struct Chars<'a> {
    bytes: &'a [u8],
    pos: usize,
}

impl<'a> Iterator for Chars<'a> {
    type Item = char;
    
    fn next(&mut self) -> Option<char> {
        if self.pos >= self.bytes.len() {
            return None;
        }
        
        match decode_utf8(&self.bytes[self.pos..]) {
            Ok((ch, len)) => {
                self.pos += len;
                Some(ch)
            }
            Err(_) => None,
        }
    }
    
    fn size_hint(&self) -> (usize, Option<usize>) {
        let remaining = self.bytes.len() - self.pos;
        // At least 1 char per 4 bytes, at most 1 char per byte
        (remaining / 4, Some(remaining))
    }
}

impl<'a> DoubleEndedIterator for Chars<'a> {
    fn next_back(&mut self) -> Option<char> {
        if self.pos >= self.bytes.len() {
            return None;
        }
        
        // Find start of last character
        let mut end = self.bytes.len();
        while end > self.pos && (self.bytes[end - 1] & 0xC0) == 0x80 {
            end -= 1;
        }
        
        if end > self.pos {
            end -= 1;
            match decode_utf8(&self.bytes[end..self.bytes.len()]) {
                Ok((ch, _)) => {
                    // Shrink bytes slice
                    self.bytes = &self.bytes[..end];
                    Some(ch)
                }
                Err(_) => None,
            }
        } else {
            None
        }
    }
}

pub struct CharIndices<'a> {
    bytes: &'a [u8],
    pos: usize,
}

impl<'a> Iterator for CharIndices<'a> {
    type Item = (usize, char);
    
    fn next(&mut self) -> Option<(usize, char)> {
        if self.pos >= self.bytes.len() {
            return None;
        }
        
        let start = self.pos;
        match decode_utf8(&self.bytes[self.pos..]) {
            Ok((ch, len)) => {
                self.pos += len;
                Some((start, ch))
            }
            Err(_) => None,
        }
    }
}

pub struct Lines<'a> {
    remaining: &'a str,
}

impl<'a> Iterator for Lines<'a> {
    type Item = &'a str;
    
    fn next(&mut self) -> Option<&'a str> {
        if self.remaining.is_empty() {
            return None;
        }
        
        let bytes = self.remaining.as_bytes();
        let mut end = 0;
        let mut line_end = 0;
        
        while end < bytes.len() {
            if bytes[end] == b'\n' {
                line_end = end;
                end += 1;
                break;
            } else if bytes[end] == b'\r' {
                line_end = end;
                end += 1;
                if end < bytes.len() && bytes[end] == b'\n' {
                    end += 1;
                }
                break;
            }
            end += 1;
            line_end = end;
        }
        
        let line = &self.remaining[..line_end];
        self.remaining = &self.remaining[end..];
        Some(line)
    }
}

pub struct Split<'a> {
    remaining: &'a str,
    pattern: char,
    finished: bool,
}

impl<'a> Iterator for Split<'a> {
    type Item = &'a str;
    
    fn next(&mut self) -> Option<&'a str> {
        if self.finished {
            return None;
        }
        
        let bytes = self.remaining.as_bytes();
        let pat_bytes = {
            let mut buf = [0u8; 4];
            let len = encode_utf8(self.pattern, &mut buf);
            (buf, len)
        };
        
        for i in 0..bytes.len() {
            if bytes[i..].starts_with(&pat_bytes.0[..pat_bytes.1]) {
                let result = &self.remaining[..i];
                self.remaining = &self.remaining[i + pat_bytes.1..];
                return Some(result);
            }
        }
        
        self.finished = true;
        Some(self.remaining)
    }
}

pub struct SplitWhitespace<'a> {
    remaining: &'a str,
}

impl<'a> Iterator for SplitWhitespace<'a> {
    type Item = &'a str;
    
    fn next(&mut self) -> Option<&'a str> {
        // Skip leading whitespace
        let bytes = self.remaining.as_bytes();
        let mut start = 0;
        
        while start < bytes.len() {
            if let Ok((ch, len)) = decode_utf8(&bytes[start..]) {
                if ch.is_whitespace() {
                    start += len;
                } else {
                    break;
                }
            } else {
                break;
            }
        }
        
        if start >= bytes.len() {
            return None;
        }
        
        // Find end of word
        let mut end = start;
        while end < bytes.len() {
            if let Ok((ch, len)) = decode_utf8(&bytes[end..]) {
                if ch.is_whitespace() {
                    break;
                }
                end += len;
            } else {
                break;
            }
        }
        
        let result = unsafe { core::str::from_utf8_unchecked(&bytes[start..end]) };
        self.remaining = unsafe { core::str::from_utf8_unchecked(&bytes[end..]) };
        Some(result)
    }
}

// Helper trait for str
trait StrExt {
    fn trim_end_str(&self) -> &str;
}

impl StrExt for str {
    fn trim_end_str(&self) -> &str {
        let bytes = self.as_bytes();
        let mut end = bytes.len();
        
        while end > 0 {
            // Find char start
            let mut start = end - 1;
            while start > 0 && (bytes[start] & 0xC0) == 0x80 {
                start -= 1;
            }
            
            if let Ok((ch, _)) = decode_utf8(&bytes[start..end]) {
                if ch.is_whitespace() {
                    end = start;
                } else {
                    break;
                }
            } else {
                break;
            }
        }
        
        unsafe { core::str::from_utf8_unchecked(&bytes[..end]) }
    }
}

// Formatting
pub fn format_args(args: core::fmt::Arguments) -> String {
    let mut s = String::new();
    core::fmt::write(&mut s, args).unwrap();
    s
}

#[macro_export]
macro_rules! format {
    ($($arg:tt)*) => {{
        $crate::std::string::format_args(core::format_args!($($arg)*))
    }};
}

// ToString trait
pub trait ToString {
    fn to_string(&self) -> String;
}

impl<T: Display> ToString for T {
    fn to_string(&self) -> String {
        let mut s = String::new();
        write!(&mut s, "{}", self).unwrap();
        s
    }
}

// Parse trait
pub trait FromStr: Sized {
    type Err;
    fn from_str(s: &str) -> Result<Self, Self::Err>;
}

impl FromStr for i32 {
    type Err = ParseIntError;
    
    fn from_str(s: &str) -> Result<i32, ParseIntError> {
        let s = s.trim();
        if s.is_empty() {
            return Err(ParseIntError::Empty);
        }
        
        let (neg, s) = if s.starts_with('-') {
            (true, &s[1..])
        } else if s.starts_with('+') {
            (false, &s[1..])
        } else {
            (false, s)
        };
        
        let mut result: i32 = 0;
        for ch in s.chars() {
            let digit = ch.to_digit(10).ok_or(ParseIntError::InvalidDigit)?;
            result = result.checked_mul(10).ok_or(ParseIntError::Overflow)?;
            result = result.checked_add(digit as i32).ok_or(ParseIntError::Overflow)?;
        }
        
        if neg {
            Ok(-result)
        } else {
            Ok(result)
        }
    }
}

impl FromStr for i64 {
    type Err = ParseIntError;
    
    fn from_str(s: &str) -> Result<i64, ParseIntError> {
        let s = s.trim();
        if s.is_empty() {
            return Err(ParseIntError::Empty);
        }
        
        let (neg, s) = if s.starts_with('-') {
            (true, &s[1..])
        } else if s.starts_with('+') {
            (false, &s[1..])
        } else {
            (false, s)
        };
        
        let mut result: i64 = 0;
        for ch in s.chars() {
            let digit = ch.to_digit(10).ok_or(ParseIntError::InvalidDigit)?;
            result = result.checked_mul(10).ok_or(ParseIntError::Overflow)?;
            result = result.checked_add(digit as i64).ok_or(ParseIntError::Overflow)?;
        }
        
        if neg {
            Ok(-result)
        } else {
            Ok(result)
        }
    }
}

impl FromStr for f64 {
    type Err = ParseFloatError;
    
    fn from_str(s: &str) -> Result<f64, ParseFloatError> {
        let s = s.trim();
        if s.is_empty() {
            return Err(ParseFloatError::Empty);
        }
        
        // Simple float parsing (full impl would handle more cases)
        let (neg, s) = if s.starts_with('-') {
            (true, &s[1..])
        } else if s.starts_with('+') {
            (false, &s[1..])
        } else {
            (false, s)
        };
        
        let mut integer: f64 = 0.0;
        let mut fraction: f64 = 0.0;
        let mut frac_divisor: f64 = 1.0;
        let mut in_fraction = false;
        
        for ch in s.chars() {
            if ch == '.' {
                if in_fraction {
                    return Err(ParseFloatError::Invalid);
                }
                in_fraction = true;
            } else if let Some(digit) = ch.to_digit(10) {
                if in_fraction {
                    frac_divisor *= 10.0;
                    fraction += digit as f64 / frac_divisor;
                } else {
                    integer = integer * 10.0 + digit as f64;
                }
            } else {
                return Err(ParseFloatError::Invalid);
            }
        }
        
        let result = integer + fraction;
        if neg { Ok(-result) } else { Ok(result) }
    }
}

#[derive(Debug, Clone, Copy)]
pub enum ParseIntError {
    Empty,
    InvalidDigit,
    Overflow,
}

#[derive(Debug, Clone, Copy)]
pub enum ParseFloatError {
    Empty,
    Invalid,
}

#[cfg(test)]
mod tests {
    use super::*;
    
    #[test]
    fn test_push_pop() {
        let mut s = String::new();
        s.push('H');
        s.push('i');
        s.push('!');
        assert_eq!(s.as_str(), "Hi!");
        assert_eq!(s.pop(), Some('!'));
        assert_eq!(s.as_str(), "Hi");
    }
    
    #[test]
    fn test_unicode() {
        let mut s = String::new();
        s.push('日');
        s.push('本');
        s.push('語');
        assert_eq!(s.len(), 9);  // 3 bytes each
        assert_eq!(s.chars().count(), 3);
    }
    
    #[test]
    fn test_find() {
        let s = String::from_str("hello world");
        assert_eq!(s.find("world"), Some(6));
        assert_eq!(s.find("xyz"), None);
    }
    
    #[test]
    fn test_parse() {
        let n: i32 = "42".parse().unwrap();
        assert_eq!(n, 42);
        
        let f: f64 = "3.14".parse().unwrap();
        assert!((f - 3.14).abs() < 0.001);
    }
}
