// TESTS
// ═══════════════════════════════════════════════════════════════════════════════

#[cfg(test)]
mod tests {
    use super::*;
    
    #[test]
    fn test_criterion_new() {
        let c = Criterion::new();
        assert_eq!(c.config.sample_count, 100);
        assert!(c.groups.is_empty());
    }
    
    #[test]
    fn test_criterion_config() {
        let c = Criterion::new()
            .warm_up_time(Duration::from_secs(1))
            .measurement_time(Duration::from_secs(2))
            .sample_size(50)
            .confidence_level(0.99);
        
        assert_eq!(c.config.warm_up_time, Duration::from_secs(1));
        assert_eq!(c.config.measurement_time, Duration::from_secs(2));
        assert_eq!(c.config.sample_count, 50);
        assert_eq!(c.config.confidence_level, 0.99);
    }
    
    #[test]
    fn test_time_it() {
        let (result, duration) = time_it(|| {
            let mut sum = 0u64;
            for i in 0..1000 {
                sum += i;
            }
            sum
        });
        
        assert_eq!(result, 499500);
        assert!(duration.as_nanos() > 0);
    }
    
    #[test]
    fn test_quick_bench() {
        let duration = quick_bench(100, || {
            let _ = black_box(1 + 1);
        });
        
        assert!(duration.as_nanos() >= 0);
    }
    
    #[test]
    fn test_parse_args_run() {
        let args = vec!["run".to_string(), "benchmarks/".to_string()];
        let cli = parse_args(&args).unwrap();
        
        match cli.command {
            BenchCommand::Run { path, filter } => {
                assert_eq!(path, PathBuf::from("benchmarks/"));
                assert!(filter.is_none());
            }
            _ => panic!("expected Run command"),
        }
    }
    
    #[test]
    fn test_parse_args_format() {
        let args = vec![
            "--format".to_string(),
            "html".to_string(),
            "run".to_string(),
            "benchmarks/".to_string(),
        ];
        let cli = parse_args(&args).unwrap();
        
        assert_eq!(cli.report_config.format, ReportFormat::Html);
    }
    
    #[test]
    fn test_parse_baseline_json() {
        let json = r#"{"results": {"bench1": 100.5, "bench2": 200.0}}"#;
        let results = parse_baseline_json(json).unwrap();
        
        assert_eq!(results.get("bench1"), Some(&100.5));
        assert_eq!(results.get("bench2"), Some(&200.0));
    }
    
    #[test]
    fn test_format_ns() {
        assert_eq!(format_ns(500.0), "500.00 ns");
        assert_eq!(format_ns(5000.0), "5.00 µs");
        assert_eq!(format_ns(5_000_000.0), "5.00 ms");
        assert_eq!(format_ns(5_000_000_000.0), "5.00 s");
    }
}
