//
// Criterion-style benchmarking framework with statistical rigor.
//
// Features:
// - Warm-up and measurement phases
// - Bootstrap confidence intervals
// - Outlier detection and classification
// - Baseline comparison with regression detection
// - Multiple output formats (HTML, JSON, CSV, Markdown)
// - Historical tracking with trend analysis
// - Throughput analysis for varying input sizes
//
// ═══════════════════════════════════════════════════════════════════════════════

//! # QuantaLang Benchmark Framework
//!
//! A statistically rigorous benchmarking framework for QuantaLang programs.
//!
//! ## Quick Start
//!
//! ```bash
//! # Run benchmarks
//! quanta-bench run benchmarks/
//!
//! # Compare against baseline
//! quanta-bench run --baseline target/bench/baseline benchmarks/
//!
//! # Generate HTML report
//! quanta-bench run --format html --output report.html benchmarks/
//! ```
//!
//! ## Programmatic API
//!
//! ```quanta
//! use quantalang::bench::{bench_group, Criterion};
//!
//! fn fibonacci(n: u64) -> u64 {
//!     if n < 2 { n } else { fibonacci(n - 1) + fibonacci(n - 2) }
//! }
//!
//! fn main() {
//!     let mut c = Criterion::default();
//!     
//!     c.bench_function("fibonacci_20", |b| {
//!         b.iter(|| fibonacci(20))
//!     });
//!     
//!     c.bench_with_input("fibonacci", &[10, 15, 20, 25], |b, &n| {
//!         b.iter(|| fibonacci(n))
//!     });
//!     
//!     c.finish();
//! }
//! ```
//!
//! ## Attributes
//!
//! ```quanta
//! #[bench]
//! fn bench_sort(b: &mut Bencher) {
//!     let data: Vec<i32> = (0..1000).rev().collect();
//!     b.iter(|| {
//!         let mut v = data.clone();
//!         v.sort();
//!         v
//!     })
//! }
//! ```

