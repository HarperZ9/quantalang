// ═══════════════════════════════════════════════════════════════════════════════
// HELPERS
// ═══════════════════════════════════════════════════════════════════════════════

fn parse_baseline_json(json: &str) -> Result<BTreeMap<String, f64>, String> {
    let mut results = BTreeMap::new();
    
    // Find "results" section
    if let Some(start) = json.find("\"results\"") {
        if let Some(brace_start) = json[start..].find('{') {
            let offset = start + brace_start;
            if let Some(brace_end) = json[offset..].find('}') {
                let section = &json[offset + 1..offset + brace_end];
                
                for line in section.lines() {
                    let line = line.trim().trim_end_matches(',');
                    if let Some(colon) = line.find(':') {
                        let key = line[..colon].trim().trim_matches('"');
                        let value = line[colon + 1..].trim();
                        if let Ok(v) = value.parse::<f64>() {
                            results.insert(key.to_string(), v);
                        }
                    }
                }
            }
        }
    }
    
    if results.is_empty() {
        // Try direct key-value format
        for line in json.lines() {
            let line = line.trim().trim_end_matches(',');
            if let Some(colon) = line.find(':') {
                let key = line[..colon].trim().trim_matches('"');
                let value = line[colon + 1..].trim();
                if let Ok(v) = value.parse::<f64>() {
                    results.insert(key.to_string(), v);
                }
            }
        }
    }
    
    Ok(results)
}

fn format_ns(ns: f64) -> String {
    if ns < 1_000.0 {
        format!("{:.2} ns", ns)
    } else if ns < 1_000_000.0 {
        format!("{:.2} µs", ns / 1_000.0)
    } else if ns < 1_000_000_000.0 {
        format!("{:.2} ms", ns / 1_000_000.0)
    } else {
        format!("{:.2} s", ns / 1_000_000_000.0)
    }
}

/// Main entry point
pub fn main() -> Result<i32, String> {
    let args: Vec<String> = std::env::args().skip(1).collect();
    
    if args.is_empty() {
        print_help();
        return Ok(0);
    }
    
    let cli = parse_args(&args)?;
    run(&cli)
}

