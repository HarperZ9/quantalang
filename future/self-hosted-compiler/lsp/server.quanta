        let uri = params.and_then(|p| p.get("textDocument"))
            .and_then(|td| td.get_str("uri"));
        let position = params.and_then(|p| p.get("position"))
            .and_then(Position::from_json);
        
        let (uri, position) = match (uri, position) {
            (Some(u), Some(p)) => (u, p),
            _ => return self.transport.send_error(req.id, INVALID_PARAMS, "Invalid params"),
        };
        
        let doc = match self.documents.get(uri) {
            Some(d) => d,
            None => return self.transport.send_response(req.id, JsonValue::Null),
        };
        
        let cache = self.cache.get(uri, doc.version);
        let type_info = cache.as_ref().and_then(|c| c.types.as_ref()).map(|t| t.as_ref());
        
        match self.analysis.signature_help(&doc, position, type_info) {
