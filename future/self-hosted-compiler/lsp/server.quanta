module quantalang::lsp::server

use std::io::{self, Read, Write, stdin, stdout};
use std::sync::{Arc, RwLock};
use std::collections::HashMap;

use crate::lsp::protocol::*;
use crate::lsp::types::*;
use crate::lsp::documents::*;
use crate::lsp::analysis::*;

// ═══════════════════════════════════════════════════════════════════════════════
// SERVER STATE
// ═══════════════════════════════════════════════════════════════════════════════

/// Server initialization state
#[derive(Debug, Clone, Copy, PartialEq, Eq)]
pub enum ServerState {
    Uninitialized,
    Initializing,
    Initialized,
    ShuttingDown,
}

/// Server capabilities
#[derive(Debug, Clone)]
pub struct ServerCapabilities {
    pub text_document_sync: TextDocumentSyncKind,
    pub completion_provider: bool,
    pub hover_provider: bool,
    pub signature_help_provider: bool,
    pub definition_provider: bool,
    pub references_provider: bool,
    pub document_symbol_provider: bool,
    pub workspace_symbol_provider: bool,
    pub code_action_provider: bool,
    pub rename_provider: bool,
    pub formatting_provider: bool,
    pub semantic_tokens_provider: bool,
}

impl Default for ServerCapabilities {
    fn default() -> Self {
        ServerCapabilities {
            text_document_sync: TextDocumentSyncKind::Incremental,
            completion_provider: true,
            hover_provider: true,
            signature_help_provider: true,
            definition_provider: true,
            references_provider: true,
            document_symbol_provider: true,
            workspace_symbol_provider: true,
            code_action_provider: true,
            rename_provider: true,
            formatting_provider: true,
            semantic_tokens_provider: true,
        }
    }
}

#[derive(Debug, Clone, Copy, PartialEq, Eq)]
#[repr(u8)]
pub enum TextDocumentSyncKind {
    None = 0,
    Full = 1,
    Incremental = 2,
}

// ═══════════════════════════════════════════════════════════════════════════════
// LANGUAGE SERVER
// ═══════════════════════════════════════════════════════════════════════════════

/// The QuantaLang Language Server
pub struct LanguageServer<R: Read, W: Write> {
    /// Transport layer
    transport: Transport<R, W>,
    /// Server state
    state: ServerState,
    /// Server capabilities
    capabilities: ServerCapabilities,
    /// Document manager
    documents: Arc<DocumentManager>,
    /// Analysis cache
    cache: Arc<AnalysisCache>,
    /// Analysis engine
    analysis: AnalysisEngine,
    /// Client capabilities
    client_capabilities: Option<ClientCapabilities>,
    /// Workspace root
    workspace_root: Option<String>,
}

/// Client capabilities (simplified)
#[derive(Debug, Clone, Default)]
pub struct ClientCapabilities {
    pub supports_dynamic_registration: bool,
    pub supports_workspace_edit: bool,
    pub supports_snippet: bool,
    pub supports_markdown: bool,
    pub supports_code_action_literals: bool,
    pub supports_hierarchical_symbols: bool,
}

impl<R: Read, W: Write> LanguageServer<R, W> {
    pub fn new(reader: R, writer: W) -> Self {
        LanguageServer {
            transport: Transport::new(reader, writer),
            state: ServerState::Uninitialized,
            capabilities: ServerCapabilities::default(),
            documents: Arc::new(DocumentManager::new()),
            cache: Arc::new(AnalysisCache::new()),
            analysis: AnalysisEngine::new(),
            client_capabilities: None,
            workspace_root: None,
        }
    }
    
    /// Run the server main loop
    pub fn run(&mut self) -> io::Result<()> {
        loop {
            let message = self.transport.read_message()?;
            
            match message {
                Message::Request(req) => {
                    self.handle_request(req)?;
                }
                Message::Notification(notif) => {
                    if notif.method == "exit" {
                        return Ok(());
                    }
                    self.handle_notification(notif)?;
                }
                Message::Response(_) => {
                    // We don't send requests, so ignore responses
                }
            }
        }
    }
    
    // ═══════════════════════════════════════════════════════════════════════════
    // REQUEST HANDLERS
    // ═══════════════════════════════════════════════════════════════════════════
    
    fn handle_request(&mut self, req: Request) -> io::Result<()> {
        // Check state
        if self.state == ServerState::Uninitialized && req.method != "initialize" {
            return self.transport.send_error(
                req.id,
                SERVER_NOT_INITIALIZED,
                "Server not initialized",
            );
        }
        
        match req.method.as_str() {
            "initialize" => self.handle_initialize(req),
            "shutdown" => self.handle_shutdown(req),
            "textDocument/completion" => self.handle_completion(req),
            "textDocument/hover" => self.handle_hover(req),
            "textDocument/signatureHelp" => self.handle_signature_help(req),
            "textDocument/definition" => self.handle_definition(req),
            "textDocument/references" => self.handle_references(req),
            "textDocument/documentSymbol" => self.handle_document_symbol(req),
            "textDocument/codeAction" => self.handle_code_action(req),
            "textDocument/rename" => self.handle_rename(req),
            "textDocument/formatting" => self.handle_formatting(req),
            "textDocument/semanticTokens/full" => self.handle_semantic_tokens(req),
            "workspace/symbol" => self.handle_workspace_symbol(req),
            _ => self.transport.send_error(
                req.id,
                METHOD_NOT_FOUND,
                &format!("Method not found: {}", req.method),
            ),
        }
    }
    
    fn handle_initialize(&mut self, req: Request) -> io::Result<()> {
        self.state = ServerState::Initializing;
        
        // Parse client capabilities
        if let Some(params) = &req.params {
            self.client_capabilities = Some(self.parse_client_capabilities(params));
            
            if let Some(root) = params.get_str("rootUri") {
                self.workspace_root = Some(root.to_string());
            }
        }
        
        // Build response
        let result = self.build_initialize_result();
        self.transport.send_response(req.id, result)?;
        
        self.state = ServerState::Initialized;
        Ok(())
    }
    
    fn parse_client_capabilities(&self, params: &JsonValue) -> ClientCapabilities {
        let mut caps = ClientCapabilities::default();
        
        if let Some(client_caps) = params.get("capabilities") {
            // Text document capabilities
            if let Some(text_doc) = client_caps.get("textDocument") {
                // Completion
                if let Some(completion) = text_doc.get("completion") {
                    if let Some(item) = completion.get("completionItem") {
                        caps.supports_snippet = item.get_bool("snippetSupport").unwrap_or(false);
                    }
                }
                
                // Hover
                if let Some(hover) = text_doc.get("hover") {
                    if let Some(formats) = hover.get("contentFormat") {
                        if let Some(arr) = formats.as_array() {
                            caps.supports_markdown = arr.iter()
                                .any(|v| v.as_str() == Some("markdown"));
                        }
                    }
                }
                
                // Document symbols
                if let Some(symbols) = text_doc.get("documentSymbol") {
                    caps.supports_hierarchical_symbols = 
                        symbols.get_bool("hierarchicalDocumentSymbolSupport").unwrap_or(false);
                }
            }
            
            // Workspace capabilities
            if let Some(workspace) = client_caps.get("workspace") {
                if let Some(edit) = workspace.get("workspaceEdit") {
                    caps.supports_workspace_edit = 
                        edit.get_bool("documentChanges").unwrap_or(false);
                }
            }
        }
        
        caps
    }
    
    fn build_initialize_result(&self) -> JsonValue {
        let mut caps = HashMap::new();
        
        // Text document sync
        caps.insert("textDocumentSync".to_string(), 
            JsonValue::Number(self.capabilities.text_document_sync as u8 as f64));
        
        // Completion
        if self.capabilities.completion_provider {
            let mut completion = HashMap::new();
            completion.insert("triggerCharacters".to_string(), 
                JsonValue::Array(vec![
                    JsonValue::String(".".to_string()),
                    JsonValue::String(":".to_string()),
                ]));
            completion.insert("resolveProvider".to_string(), JsonValue::Bool(false));
            caps.insert("completionProvider".to_string(), JsonValue::Object(completion));
        }
        
        // Hover
        if self.capabilities.hover_provider {
            caps.insert("hoverProvider".to_string(), JsonValue::Bool(true));
        }
        
        // Signature help
        if self.capabilities.signature_help_provider {
            let mut sig_help = HashMap::new();
            sig_help.insert("triggerCharacters".to_string(),
                JsonValue::Array(vec![
                    JsonValue::String("(".to_string()),
                    JsonValue::String(",".to_string()),
                ]));
            caps.insert("signatureHelpProvider".to_string(), JsonValue::Object(sig_help));
        }
        
        // Definition
        if self.capabilities.definition_provider {
            caps.insert("definitionProvider".to_string(), JsonValue::Bool(true));
        }
        
        // References
        if self.capabilities.references_provider {
            caps.insert("referencesProvider".to_string(), JsonValue::Bool(true));
        }
        
        // Document symbol
        if self.capabilities.document_symbol_provider {
            caps.insert("documentSymbolProvider".to_string(), JsonValue::Bool(true));
        }
        
        // Workspace symbol
        if self.capabilities.workspace_symbol_provider {
            caps.insert("workspaceSymbolProvider".to_string(), JsonValue::Bool(true));
        }
        
        // Code action
        if self.capabilities.code_action_provider {
            caps.insert("codeActionProvider".to_string(), JsonValue::Bool(true));
        }
        
        // Rename
        if self.capabilities.rename_provider {
            let mut rename = HashMap::new();
            rename.insert("prepareProvider".to_string(), JsonValue::Bool(true));
            caps.insert("renameProvider".to_string(), JsonValue::Object(rename));
        }
        
        // Formatting
        if self.capabilities.formatting_provider {
            caps.insert("documentFormattingProvider".to_string(), JsonValue::Bool(true));
        }
        
        // Semantic tokens
        if self.capabilities.semantic_tokens_provider {
            let mut semantic = HashMap::new();
            let mut legend = HashMap::new();
            
            // Token types
            let token_types = vec![
                "namespace", "type", "class", "enum", "interface", "struct",
                "typeParameter", "parameter", "variable", "property", "enumMember",
                "event", "function", "method", "macro", "keyword", "modifier",
                "comment", "string", "number", "regexp", "operator",
            ];
            legend.insert("tokenTypes".to_string(),
                JsonValue::Array(token_types.into_iter().map(|s| JsonValue::String(s.to_string())).collect()));
            
            // Token modifiers
            let token_modifiers = vec![
                "declaration", "definition", "readonly", "static", "deprecated",
                "abstract", "async", "modification", "documentation", "defaultLibrary",
            ];
            legend.insert("tokenModifiers".to_string(),
                JsonValue::Array(token_modifiers.into_iter().map(|s| JsonValue::String(s.to_string())).collect()));
            
            semantic.insert("legend".to_string(), JsonValue::Object(legend));
            semantic.insert("full".to_string(), JsonValue::Bool(true));
            caps.insert("semanticTokensProvider".to_string(), JsonValue::Object(semantic));
        }
        
        // Build result
        let mut result = HashMap::new();
        result.insert("capabilities".to_string(), JsonValue::Object(caps));
        
        let mut server_info = HashMap::new();
        server_info.insert("name".to_string(), JsonValue::String("quantalang-lsp".to_string()));
        server_info.insert("version".to_string(), JsonValue::String("1.0.0".to_string()));
        result.insert("serverInfo".to_string(), JsonValue::Object(server_info));
        
        JsonValue::Object(result)
    }
    
    fn handle_shutdown(&mut self, req: Request) -> io::Result<()> {
        self.state = ServerState::ShuttingDown;
        self.transport.send_response(req.id, JsonValue::Null)
    }
    
    fn handle_completion(&mut self, req: Request) -> io::Result<()> {
        let params = req.params.as_ref();
        
        let uri = params.and_then(|p| p.get("textDocument"))
            .and_then(|td| td.get_str("uri"));
        let position = params.and_then(|p| p.get("position"))
            .and_then(Position::from_json);
        
        let (uri, position) = match (uri, position) {
            (Some(u), Some(p)) => (u, p),
            _ => return self.transport.send_error(req.id, INVALID_PARAMS, "Invalid params"),
        };
        
        let doc = match self.documents.get(uri) {
            Some(d) => d,
            None => return self.transport.send_response(req.id, JsonValue::Null),
        };
        
        // Get type info from cache
        let cache = self.cache.get(uri, doc.version);
        let type_info = cache.as_ref().and_then(|c| c.types.as_ref()).map(|t| t.as_ref());
        
        let completions = self.analysis.complete(&doc, position, type_info);
        self.transport.send_response(req.id, completions.to_json())
    }
    
    fn handle_hover(&mut self, req: Request) -> io::Result<()> {
        let params = req.params.as_ref();
        
        let uri = params.and_then(|p| p.get("textDocument"))
            .and_then(|td| td.get_str("uri"));
        let position = params.and_then(|p| p.get("position"))
            .and_then(Position::from_json);
        
        let (uri, position) = match (uri, position) {
            (Some(u), Some(p)) => (u, p),
            _ => return self.transport.send_error(req.id, INVALID_PARAMS, "Invalid params"),
        };
        
        let doc = match self.documents.get(uri) {
            Some(d) => d,
            None => return self.transport.send_response(req.id, JsonValue::Null),
        };
        
        let cache = self.cache.get(uri, doc.version);
        let type_info = cache.as_ref().and_then(|c| c.types.as_ref()).map(|t| t.as_ref());
        
        match self.analysis.hover(&doc, position, type_info) {
            Some(hover) => self.transport.send_response(req.id, hover.to_json()),
            None => self.transport.send_response(req.id, JsonValue::Null),
        }
    }
    
