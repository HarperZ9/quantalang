// FOLDING RANGES
// ═══════════════════════════════════════════════════════════════════════════════

/// Folding range kind
#[derive(Debug, Clone, Copy, PartialEq, Eq)]
pub enum FoldingRangeKind {
    /// Comment block
    Comment,
    /// Import statements
    Imports,
    /// Code region
    Region,
}

/// Folding range
#[derive(Debug, Clone)]
pub struct FoldingRange {
    /// Start line (0-indexed)
    pub start_line: u32,
    /// Start character (optional)
    pub start_character: Option<u32>,
    /// End line (0-indexed)
    pub end_line: u32,
    /// End character (optional)
    pub end_character: Option<u32>,
    /// Folding kind
    pub kind: Option<FoldingRangeKind>,
    /// Collapsed text (shown when folded)
    pub collapsed_text: Option<String>,
}

impl FoldingRange {
    pub fn new(start_line: u32, end_line: u32) -> Self {
        FoldingRange {
            start_line,
            start_character: None,
            end_line,
            end_character: None,
            kind: None,
            collapsed_text: None,
        }
    }
    
    pub fn with_kind(mut self, kind: FoldingRangeKind) -> Self {
        self.kind = Some(kind);
        self
    }
    
    pub fn with_collapsed_text(mut self, text: impl Into<String>) -> Self {
        self.collapsed_text = Some(text.into());
        self
    }
    
    pub fn comment(start_line: u32, end_line: u32) -> Self {
        FoldingRange::new(start_line, end_line)
            .with_kind(FoldingRangeKind::Comment)
    }
    
    pub fn imports(start_line: u32, end_line: u32) -> Self {
        FoldingRange::new(start_line, end_line)
            .with_kind(FoldingRangeKind::Imports)
            .with_collapsed_text("...")
    }
    
    pub fn region(start_line: u32, end_line: u32, name: Option<String>) -> Self {
        let mut range = FoldingRange::new(start_line, end_line)
            .with_kind(FoldingRangeKind::Region);
        
        if let Some(n) = name {
            range.collapsed_text = Some(format!("// {}", n));
        }
        
        range
    }
}

/// Folding range provider configuration
#[derive(Debug, Clone)]
pub struct FoldingConfig {
    /// Fold braces (functions, structs, etc.)
    pub fold_braces: bool,
    /// Fold comments
    pub fold_comments: bool,
    /// Fold imports
    pub fold_imports: bool,
    /// Fold region markers
    pub fold_regions: bool,
    /// Minimum lines for folding
    pub min_lines: u32,
    /// Collapse all by default
    pub collapse_all: bool,
}

impl Default for FoldingConfig {
    fn default() -> Self {
        FoldingConfig {
            fold_braces: true,
            fold_comments: true,
            fold_imports: true,
            fold_regions: true,
            min_lines: 2,
            collapse_all: false,
        }
    }
}

/// Folding range provider
pub struct FoldingRangeProvider {
    config: FoldingConfig,
}

impl FoldingRangeProvider {
    pub fn new(config: FoldingConfig) -> Self {
        FoldingRangeProvider { config }
    }
    
    /// Get folding ranges for document
    pub fn ranges(&self, analysis: &FoldingAnalysis) -> Vec<FoldingRange> {
        let mut ranges = Vec::new();
        
        // Brace-based folding
        if self.config.fold_braces {
            for block in &analysis.blocks {
                if block.end_line - block.start_line >= self.config.min_lines {
                    let mut range = FoldingRange::new(block.start_line, block.end_line);
                    
                    if let Some(name) = &block.name {
                        range.collapsed_text = Some(format!("{} {{ ... }}", name));
                    }
                    
                    ranges.push(range);
                }
            }
        }
        
        // Comment folding
        if self.config.fold_comments {
            for comment in &analysis.comments {
                if comment.end_line - comment.start_line >= self.config.min_lines {
                    ranges.push(FoldingRange::comment(comment.start_line, comment.end_line));
                }
            }
        }
        
        // Import folding
        if self.config.fold_imports {
            if let Some(imports) = &analysis.import_range {
                if imports.end_line - imports.start_line >= self.config.min_lines {
                    ranges.push(FoldingRange::imports(imports.start_line, imports.end_line));
                }
            }
        }
        
        // Region markers
        if self.config.fold_regions {
            for region in &analysis.regions {
                ranges.push(FoldingRange::region(
                    region.start_line,
                    region.end_line,
                    region.name.clone(),
                ));
            }
        }
        
        // Sort by start line
        ranges.sort_by_key(|r| r.start_line);
        
        ranges
    }
}

impl Default for FoldingRangeProvider {
    fn default() -> Self {
        Self::new(FoldingConfig::default())
    }
}

/// Analysis result for folding
#[derive(Debug, Clone, Default)]
pub struct FoldingAnalysis {
    pub blocks: Vec<BlockInfo>,
    pub comments: Vec<CommentRange>,
    pub import_range: Option<LineRange>,
    pub regions: Vec<RegionInfo>,
}

#[derive(Debug, Clone)]
pub struct BlockInfo {
    pub start_line: u32,
    pub end_line: u32,
    pub name: Option<String>,
}

#[derive(Debug, Clone)]
pub struct CommentRange {
    pub start_line: u32,
    pub end_line: u32,
}

#[derive(Debug, Clone)]
pub struct LineRange {
    pub start_line: u32,
    pub end_line: u32,
}

#[derive(Debug, Clone)]
pub struct RegionInfo {
    pub start_line: u32,
    pub end_line: u32,
    pub name: Option<String>,
}

