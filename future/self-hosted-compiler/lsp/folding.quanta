// SELECTION RANGES
// ═══════════════════════════════════════════════════════════════════════════════

/// Selection range (hierarchical)
#[derive(Debug, Clone)]
pub struct SelectionRange {
    /// Range for this selection level
    pub range: Range,
    /// Parent selection (outer range)
    pub parent: Option<Box<SelectionRange>>,
}

impl SelectionRange {
    pub fn new(range: Range) -> Self {
        SelectionRange {
            range,
            parent: None,
        }
    }
    
    pub fn with_parent(mut self, parent: SelectionRange) -> Self {
        self.parent = Some(Box::new(parent));
        self
    }
    
    /// Build selection chain from innermost to outermost
    pub fn from_chain(ranges: Vec<Range>) -> Option<Self> {
        if ranges.is_empty() {
            return None;
        }
        
        let mut iter = ranges.into_iter().rev();
        let mut current = SelectionRange::new(iter.next()?);
        
        for range in iter {
            current = SelectionRange::new(range).with_parent(current);
        }
        
        // Reverse so innermost is returned
        Self::reverse(current)
    }
    
    fn reverse(mut sel: SelectionRange) -> Option<SelectionRange> {
        let mut stack = vec![];
        
        loop {
            let parent = sel.parent.take();
            stack.push(sel.range);
            
            match parent {
                Some(p) => sel = *p,
                None => break,
            }
        }
        
        Self::from_chain(stack)
    }
    
    /// Get depth of selection hierarchy
    pub fn depth(&self) -> usize {
        1 + self.parent.as_ref().map(|p| p.depth()).unwrap_or(0)
    }
}

/// Selection range provider
pub struct SelectionRangeProvider {
    /// Configuration
    config: SelectionConfig,
}

#[derive(Debug, Clone)]
pub struct SelectionConfig {
    /// Include whitespace
    pub include_whitespace: bool,
    /// Expand to line on single word
    pub expand_to_line: bool,
}

impl Default for SelectionConfig {
    fn default() -> Self {
        SelectionConfig {
            include_whitespace: false,
            expand_to_line: true,
        }
    }
}

impl SelectionRangeProvider {
    pub fn new(config: SelectionConfig) -> Self {
        SelectionRangeProvider { config }
    }
    
    /// Get selection range at position
    pub fn selection_at(&self, pos: Position, analysis: &SelectionAnalysis) -> SelectionRange {
        // Find all ranges containing position, from innermost to outermost
        let mut containing: Vec<Range> = analysis.ranges.iter()
            .filter(|r| r.contains(pos))
            .cloned()
            .collect();
        
        // Sort by size (smallest first = innermost)
        containing.sort_by_key(|r| {
            let lines = r.end.line - r.start.line;
            let chars = if lines == 0 {
                r.end.character - r.start.character
            } else {
                0
            };
            (lines, chars)
        });
        
        // Build chain
        SelectionRange::from_chain(containing).unwrap_or_else(|| {
            // Fallback: word at position
            SelectionRange::new(Range::new(pos, pos))
        })
    }
    
    /// Get selection ranges for multiple positions
    pub fn selections_at(
        &self,
        positions: &[Position],
        analysis: &SelectionAnalysis,
    ) -> Vec<SelectionRange> {
        positions.iter()
            .map(|&pos| self.selection_at(pos, analysis))
            .collect()
    }
}

impl Default for SelectionRangeProvider {
    fn default() -> Self {
        Self::new(SelectionConfig::default())
    }
}

/// Analysis for selection ranges
#[derive(Debug, Clone, Default)]
pub struct SelectionAnalysis {
    /// All ranges (tokens, expressions, statements, blocks)
    pub ranges: Vec<Range>,
}

