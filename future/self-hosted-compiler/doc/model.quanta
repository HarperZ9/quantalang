// ═══════════════════════════════════════════════════════════════════════════════

/// A documented impl block
#[derive(Debug, Clone)]
pub struct DocImpl {
    pub doc: ParsedDoc,
    pub path: ItemPath,
    pub location: Option<SourceLocation>,
    /// Generic parameters
    pub generics: Generics,
    /// Self type
    pub self_ty: String,
    /// Trait being implemented (if any)
    pub trait_ref: Option<TraitRef>,
    /// Is this a negative impl?
    pub is_negative: bool,
    /// Associated types
    pub assoc_types: Vec<DocAssocType>,
    /// Associated constants
    pub assoc_consts: Vec<DocAssocConst>,
    /// Methods
    pub methods: Vec<DocFunction>,
}

#[derive(Debug, Clone)]
pub struct ImplRef {
    pub trait_ref: Option<TraitRef>,
    pub path: ItemPath,
}

#[derive(Debug, Clone)]
pub struct TraitRef {
    pub path: ItemPath,
    pub generics: Vec<TypeRef>,
}

