/// A documented trait
#[derive(Debug, Clone)]
pub struct DocTrait {
    pub name: String,
    pub visibility: Visibility,
    pub doc: ParsedDoc,
    pub path: ItemPath,
    pub location: Option<SourceLocation>,
    /// Generic parameters
    pub generics: Generics,
    /// Super traits
    pub super_traits: Vec<TraitBound>,
    /// Associated types
    pub assoc_types: Vec<DocAssocType>,
    /// Associated constants
    pub assoc_consts: Vec<DocAssocConst>,
    /// Required methods
    pub required_methods: Vec<DocFunction>,
    /// Provided methods
    pub provided_methods: Vec<DocFunction>,
    /// Is this an auto trait?
    pub is_auto: bool,
    /// Is this unsafe?
    pub is_unsafe: bool,
    /// Known implementors
    pub implementors: Vec<String>,
}

#[derive(Debug, Clone)]
pub struct DocAssocType {
    pub name: String,
    pub doc: ParsedDoc,
    pub bounds: Vec<TraitBound>,
    pub default: Option<TypeRef>,
}

#[derive(Debug, Clone)]
pub struct DocAssocConst {
    pub name: String,
    pub doc: ParsedDoc,
    pub ty: TypeRef,
    pub default: Option<String>,
}

