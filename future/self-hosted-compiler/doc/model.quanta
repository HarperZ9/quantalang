}

// ═══════════════════════════════════════════════════════════════════════════════
// GENERICS
// ═══════════════════════════════════════════════════════════════════════════════

/// Generic parameters
#[derive(Debug, Clone, Default)]
pub struct Generics {
    pub params: Vec<GenericParam>,
    pub where_predicates: Vec<WherePredicate>,
}

impl Generics {
    pub fn is_empty(&self) -> bool {
        self.params.is_empty()
    }
    
    pub fn to_string(&self) -> String {
        if self.params.is_empty() {
            return String::new();
        }
        
        let params: Vec<String> = self.params.iter().map(|p| p.to_string()).collect();
        format!("<{}>", params.join(", "))
    }
}

#[derive(Debug, Clone)]
pub enum GenericParam {
    Type(TypeParam),
    Lifetime(LifetimeParam),
    Const(ConstParam),
}

impl GenericParam {
    pub fn to_string(&self) -> String {
        match self {
            GenericParam::Type(t) => t.to_string(),
            GenericParam::Lifetime(l) => format!("'{}", l.name),
            GenericParam::Const(c) => format!("const {}: {}", c.name, c.ty.to_string()),
        }
    }
}

#[derive(Debug, Clone)]
pub struct TypeParam {
    pub name: String,
    pub bounds: Vec<TraitBound>,
    pub default: Option<TypeRef>,
}

impl TypeParam {
    pub fn to_string(&self) -> String {
        let mut s = self.name.clone();
        if !self.bounds.is_empty() {
            s.push_str(": ");
            s.push_str(&self.bounds.iter().map(|b| b.to_string()).collect::<Vec<_>>().join(" + "));
        }
        if let Some(ref default) = self.default {
            s.push_str(" = ");
            s.push_str(&default.to_string());
        }
        s
    }
}

#[derive(Debug, Clone)]
pub struct LifetimeParam {
    pub name: String,
    pub bounds: Vec<String>,
}

#[derive(Debug, Clone)]
pub struct ConstParam {
    pub name: String,
    pub ty: TypeRef,
    pub default: Option<String>,
}

#[derive(Debug, Clone)]
pub struct TraitBound {
    pub path: ItemPath,
    pub generics: Vec<TypeRef>,
    pub is_maybe: bool, // ?Sized
}

impl TraitBound {
    pub fn to_string(&self) -> String {
        let mut s = if self.is_maybe { "?".to_string() } else { String::new() };
        s.push_str(&self.path.to_string());
        if !self.generics.is_empty() {
            s.push('<');
            s.push_str(&self.generics.iter().map(|g| g.to_string()).collect::<Vec<_>>().join(", "));
            s.push('>');
        }
        s
    }
}

#[derive(Debug, Clone)]
pub struct WherePredicate {
    pub subject: String,
    pub bounds: Vec<TraitBound>,
}

// ═══════════════════════════════════════════════════════════════════════════════
// TYPE REFERENCE
// ═══════════════════════════════════════════════════════════════════════════════

/// A type reference
#[derive(Debug, Clone)]
pub enum TypeRef {
    /// Named type (path)
    Path(ItemPath, Vec<TypeRef>),
    /// Reference (&T or &mut T)
    Reference { lifetime: Option<String>, is_mut: bool, ty: Box<TypeRef> },
    /// Pointer (*const T or *mut T)
    Pointer { is_mut: bool, ty: Box<TypeRef> },
    /// Slice [T]
    Slice(Box<TypeRef>),
    /// Array [T; N]
    Array(Box<TypeRef>, String),
    /// Tuple (T1, T2, ...)
    Tuple(Vec<TypeRef>),
    /// Function pointer fn(T) -> R
    FnPointer { params: Vec<TypeRef>, ret: Option<Box<TypeRef>> },
    /// Impl trait
    ImplTrait(Vec<TraitBound>),
    /// Dyn trait
    DynTrait(Vec<TraitBound>),
    /// Inferred type _
    Infer,
    /// Never type !
    Never,
    /// Raw string representation (fallback)
    Raw(String),
}

impl TypeRef {
    pub fn to_string(&self) -> String {
        match self {
            TypeRef::Path(path, generics) => {
                let mut s = path.to_string();
                if !generics.is_empty() {
                    s.push('<');
                    s.push_str(&generics.iter().map(|g| g.to_string()).collect::<Vec<_>>().join(", "));
                    s.push('>');
                }
                s
            }
            TypeRef::Reference { lifetime, is_mut, ty } => {
                let mut s = "&".to_string();
                if let Some(lt) = lifetime {
                    s.push_str(lt);
                    s.push(' ');
                }
                if *is_mut {
                    s.push_str("mut ");
                }
                s.push_str(&ty.to_string());
                s
            }
            TypeRef::Pointer { is_mut, ty } => {
                format!("*{} {}", if *is_mut { "mut" } else { "const" }, ty.to_string())
            }
            TypeRef::Slice(ty) => format!("[{}]", ty.to_string()),
            TypeRef::Array(ty, len) => format!("[{}; {}]", ty.to_string(), len),
            TypeRef::Tuple(types) => {
                format!("({})", types.iter().map(|t| t.to_string()).collect::<Vec<_>>().join(", "))
            }
            TypeRef::FnPointer { params, ret } => {
                let params = params.iter().map(|p| p.to_string()).collect::<Vec<_>>().join(", ");
                match ret {
                    Some(r) => format!("fn({}) -> {}", params, r.to_string()),
                    None => format!("fn({})", params),
                }
            }
            TypeRef::ImplTrait(bounds) => {
                format!("impl {}", bounds.iter().map(|b| b.to_string()).collect::<Vec<_>>().join(" + "))
            }
            TypeRef::DynTrait(bounds) => {
                format!("dyn {}", bounds.iter().map(|b| b.to_string()).collect::<Vec<_>>().join(" + "))
            }
            TypeRef::Infer => "_".to_string(),
            TypeRef::Never => "!".to_string(),
            TypeRef::Raw(s) => s.clone(),
        }
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// TRAITS
// ═══════════════════════════════════════════════════════════════════════════════

/// Trait for items that have documentation
pub trait HasDoc {
    fn doc(&self) -> &ParsedDoc;
    fn name(&self) -> &str;
    fn visibility(&self) -> &Visibility;
}

impl HasDoc for DocFunction {
    fn doc(&self) -> &ParsedDoc { &self.doc }
    fn name(&self) -> &str { &self.name }
    fn visibility(&self) -> &Visibility { &self.visibility }
}

impl HasDoc for DocStruct {
    fn doc(&self) -> &ParsedDoc { &self.doc }
    fn name(&self) -> &str { &self.name }
    fn visibility(&self) -> &Visibility { &self.visibility }
}

impl HasDoc for DocEnum {
    fn doc(&self) -> &ParsedDoc { &self.doc }
    fn name(&self) -> &str { &self.name }
    fn visibility(&self) -> &Visibility { &self.visibility }
}

impl HasDoc for DocTrait {
    fn doc(&self) -> &ParsedDoc { &self.doc }
    fn name(&self) -> &str { &self.name }
    fn visibility(&self) -> &Visibility { &self.visibility }
}

impl HasDoc for DocModule {
    fn doc(&self) -> &ParsedDoc { &self.doc }
    fn name(&self) -> &str { &self.name }
    fn visibility(&self) -> &Visibility { &self.visibility }
}
