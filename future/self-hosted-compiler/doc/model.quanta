module quantalang::doc::model

use alloc::string::String;
use alloc::vec::Vec;
use alloc::collections::BTreeMap;
use crate::doc::parser::{ParsedDoc, DocAttributes, DeprecationInfo};

// ═══════════════════════════════════════════════════════════════════════════════
// VISIBILITY
// ═══════════════════════════════════════════════════════════════════════════════

/// Item visibility
#[derive(Debug, Clone, PartialEq, Eq)]
pub enum Visibility {
    /// pub
    Public,
    /// pub(crate)
    Crate,
    /// pub(super)
    Super,
    /// pub(in path)
    Restricted(String),
    /// Private (no visibility modifier)
    Private,
}

impl Visibility {
    pub fn is_public(&self) -> bool {
        matches!(self, Visibility::Public)
    }
    
    pub fn is_exported(&self) -> bool {
        !matches!(self, Visibility::Private)
    }
}

impl Default for Visibility {
    fn default() -> Self {
        Visibility::Private
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// PATHS
// ═══════════════════════════════════════════════════════════════════════════════

/// A path to an item (e.g., std::collections::Vec)
#[derive(Debug, Clone, PartialEq, Eq, Hash)]
pub struct ItemPath {
    pub segments: Vec<String>,
}

impl ItemPath {
    pub fn new(segments: Vec<String>) -> Self {
        ItemPath { segments }
    }
    
    pub fn from_str(s: &str) -> Self {
        ItemPath {
            segments: s.split("::").map(String::from).collect(),
        }
    }
    
    pub fn root() -> Self {
        ItemPath { segments: Vec::new() }
    }
    
    pub fn push(&mut self, segment: &str) {
        self.segments.push(segment.to_string());
    }
    
    pub fn join(&self, segment: &str) -> Self {
        let mut new = self.clone();
        new.push(segment);
        new
    }
    
    pub fn parent(&self) -> Option<Self> {
        if self.segments.is_empty() {
            None
        } else {
            let mut new = self.clone();
            new.segments.pop();
            Some(new)
        }
    }
    
    pub fn name(&self) -> Option<&str> {
        self.segments.last().map(|s| s.as_str())
    }
    
    pub fn is_root(&self) -> bool {
        self.segments.is_empty()
    }
    
    pub fn to_string(&self) -> String {
        self.segments.join("::")
    }
    
    pub fn to_file_path(&self) -> String {
        self.segments.join("/")
    }
}

impl core::fmt::Display for ItemPath {
    fn fmt(&self, f: &mut core::fmt::Formatter<'_>) -> core::fmt::Result {
        write!(f, "{}", self.segments.join("::"))
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// SOURCE LOCATION
// ═══════════════════════════════════════════════════════════════════════════════

/// Source file location
#[derive(Debug, Clone)]
pub struct SourceLocation {
    /// File path
    pub file: String,
    /// Line number (1-indexed)
    pub line: u32,
    /// Column number (1-indexed)
    pub column: u32,
}

impl SourceLocation {
    pub fn new(file: String, line: u32, column: u32) -> Self {
        SourceLocation { file, line, column }
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// DOCUMENTED CRATE
// ═══════════════════════════════════════════════════════════════════════════════

/// A documented crate
#[derive(Debug, Clone)]
pub struct DocCrate {
    /// Crate name
    pub name: String,
    /// Crate version
    pub version: String,
    /// Crate documentation (from //! comments in lib.rs)
    pub doc: ParsedDoc,
    /// Root module
    pub root_module: DocModule,
    /// All items indexed by path
    pub index: BTreeMap<String, ItemKind>,
    /// External crate dependencies
    pub dependencies: Vec<DependencyInfo>,
    /// Feature flags
    pub features: Vec<FeatureInfo>,
}

impl DocCrate {
    pub fn new(name: String, version: String) -> Self {
        DocCrate {
            name: name.clone(),
            version,
            doc: ParsedDoc::new(),
            root_module: DocModule::new(name),
            index: BTreeMap::new(),
            dependencies: Vec::new(),
            features: Vec::new(),
        }
    }
    
    /// Get an item by path
    pub fn get_item(&self, path: &str) -> Option<&ItemKind> {
        self.index.get(path)
    }
    
    /// Iterate all public items
    pub fn public_items(&self) -> impl Iterator<Item = (&String, &ItemKind)> {
        self.index.iter().filter(|(_, item)| item.is_public())
    }
}

#[derive(Debug, Clone)]
pub struct DependencyInfo {
    pub name: String,
    pub version: String,
    pub features: Vec<String>,
    pub optional: bool,
}

#[derive(Debug, Clone)]
pub struct FeatureInfo {
    pub name: String,
    pub description: Option<String>,
    pub dependencies: Vec<String>,
    pub default: bool,
}

// ═══════════════════════════════════════════════════════════════════════════════
// ITEM KIND
// ═══════════════════════════════════════════════════════════════════════════════

/// Kind of documented item
#[derive(Debug, Clone)]
pub enum ItemKind {
    Module(DocModule),
    Function(DocFunction),
    Struct(DocStruct),
    Enum(DocEnum),
    Trait(DocTrait),
    TypeAlias(DocTypeAlias),
    Constant(DocConstant),
    Static(DocStatic),
    Macro(DocMacro),
    Impl(DocImpl),
    Import(DocImport),
}

impl ItemKind {
    pub fn name(&self) -> &str {
        match self {
            ItemKind::Module(m) => &m.name,
            ItemKind::Function(f) => &f.name,
            ItemKind::Struct(s) => &s.name,
            ItemKind::Enum(e) => &e.name,
            ItemKind::Trait(t) => &t.name,
            ItemKind::TypeAlias(t) => &t.name,
            ItemKind::Constant(c) => &c.name,
            ItemKind::Static(s) => &s.name,
            ItemKind::Macro(m) => &m.name,
            ItemKind::Impl(i) => &i.self_ty,
            ItemKind::Import(i) => &i.name,
        }
    }
    
    pub fn visibility(&self) -> &Visibility {
        match self {
            ItemKind::Module(m) => &m.visibility,
            ItemKind::Function(f) => &f.visibility,
            ItemKind::Struct(s) => &s.visibility,
            ItemKind::Enum(e) => &e.visibility,
            ItemKind::Trait(t) => &t.visibility,
            ItemKind::TypeAlias(t) => &t.visibility,
            ItemKind::Constant(c) => &c.visibility,
            ItemKind::Static(s) => &s.visibility,
            ItemKind::Macro(m) => &m.visibility,
            ItemKind::Impl(_) => &Visibility::Public, // Impls inherit visibility
            ItemKind::Import(i) => &i.visibility,
        }
    }
    
    pub fn is_public(&self) -> bool {
        self.visibility().is_public()
    }
    
    pub fn doc(&self) -> &ParsedDoc {
        match self {
            ItemKind::Module(m) => &m.doc,
            ItemKind::Function(f) => &f.doc,
            ItemKind::Struct(s) => &s.doc,
            ItemKind::Enum(e) => &e.doc,
            ItemKind::Trait(t) => &t.doc,
            ItemKind::TypeAlias(t) => &t.doc,
            ItemKind::Constant(c) => &c.doc,
            ItemKind::Static(s) => &s.doc,
            ItemKind::Macro(m) => &m.doc,
            ItemKind::Impl(i) => &i.doc,
            ItemKind::Import(i) => &i.doc,
        }
    }
    
    pub fn kind_name(&self) -> &'static str {
        match self {
            ItemKind::Module(_) => "Module",
            ItemKind::Function(_) => "Function",
            ItemKind::Struct(_) => "Struct",
            ItemKind::Enum(_) => "Enum",
            ItemKind::Trait(_) => "Trait",
            ItemKind::TypeAlias(_) => "Type Alias",
            ItemKind::Constant(_) => "Constant",
            ItemKind::Static(_) => "Static",
            ItemKind::Macro(_) => "Macro",
            ItemKind::Impl(_) => "Impl",
            ItemKind::Import(_) => "Import",
        }
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// MODULE
// ═══════════════════════════════════════════════════════════════════════════════

/// A documented module
#[derive(Debug, Clone)]
pub struct DocModule {
    pub name: String,
    pub visibility: Visibility,
    pub doc: ParsedDoc,
    pub path: ItemPath,
    pub location: Option<SourceLocation>,
    /// Child modules
    pub modules: Vec<DocModule>,
    /// Functions in this module
    pub functions: Vec<DocFunction>,
    /// Structs
    pub structs: Vec<DocStruct>,
    /// Enums
    pub enums: Vec<DocEnum>,
    /// Traits
    pub traits: Vec<DocTrait>,
    /// Type aliases
    pub type_aliases: Vec<DocTypeAlias>,
    /// Constants
    pub constants: Vec<DocConstant>,
    /// Statics
    pub statics: Vec<DocStatic>,
    /// Macros
    pub macros: Vec<DocMacro>,
    /// Impls
    pub impls: Vec<DocImpl>,
    /// Re-exports
    pub imports: Vec<DocImport>,
}

impl DocModule {
    pub fn new(name: String) -> Self {
        DocModule {
            name: name.clone(),
            visibility: Visibility::Public,
            doc: ParsedDoc::new(),
            path: ItemPath::from_str(&name),
            location: None,
            modules: Vec::new(),
            functions: Vec::new(),
            structs: Vec::new(),
            enums: Vec::new(),
            traits: Vec::new(),
            type_aliases: Vec::new(),
            constants: Vec::new(),
            statics: Vec::new(),
            macros: Vec::new(),
            impls: Vec::new(),
            imports: Vec::new(),
        }
    }
    
    /// Get all public items
    pub fn public_items(&self) -> impl Iterator<Item = &dyn HasDoc> {
        let funcs = self.functions.iter()
            .filter(|f| f.visibility.is_public())
            .map(|f| f as &dyn HasDoc);
        let structs = self.structs.iter()
            .filter(|s| s.visibility.is_public())
            .map(|s| s as &dyn HasDoc);
        let enums = self.enums.iter()
            .filter(|e| e.visibility.is_public())
            .map(|e| e as &dyn HasDoc);
        let traits = self.traits.iter()
            .filter(|t| t.visibility.is_public())
            .map(|t| t as &dyn HasDoc);
        
        funcs.chain(structs).chain(enums).chain(traits)
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// FUNCTION
// ═══════════════════════════════════════════════════════════════════════════════

/// A documented function
#[derive(Debug, Clone)]
pub struct DocFunction {
    pub name: String,
    pub visibility: Visibility,
    pub doc: ParsedDoc,
    pub path: ItemPath,
    pub location: Option<SourceLocation>,
    /// Function signature
    pub signature: FunctionSignature,
    /// Generic parameters
    pub generics: Generics,
    /// Is this async?
    pub is_async: bool,
    /// Is this const?
    pub is_const: bool,
    /// Is this unsafe?
    pub is_unsafe: bool,
    /// ABI (e.g., "C", "system")
    pub abi: Option<String>,
}

#[derive(Debug, Clone)]
pub struct FunctionSignature {
    /// Self parameter
    pub self_param: Option<SelfParam>,
    /// Parameters
    pub params: Vec<FunctionParam>,
    /// Return type
    pub return_type: Option<TypeRef>,
    /// Where clause
    pub where_clause: Option<String>,
}

#[derive(Debug, Clone)]
pub struct SelfParam {
    pub is_ref: bool,
    pub is_mut: bool,
    pub lifetime: Option<String>,
}

#[derive(Debug, Clone)]
pub struct FunctionParam {
    pub name: String,
    pub ty: TypeRef,
    pub default: Option<String>,
}

// ═══════════════════════════════════════════════════════════════════════════════
// STRUCT
// ═══════════════════════════════════════════════════════════════════════════════

/// A documented struct
#[derive(Debug, Clone)]
pub struct DocStruct {
    pub name: String,
    pub visibility: Visibility,
    pub doc: ParsedDoc,
    pub path: ItemPath,
    pub location: Option<SourceLocation>,
    /// Generic parameters
    pub generics: Generics,
    /// Struct kind
    pub kind: StructKind,
    /// Fields
    pub fields: Vec<DocField>,
    /// Implementations
    pub impls: Vec<ImplRef>,
    /// Derived traits
    pub derives: Vec<String>,
}

#[derive(Debug, Clone, PartialEq, Eq)]
pub enum StructKind {
    /// Regular struct with named fields
    Regular,
    /// Tuple struct
    Tuple,
    /// Unit struct
    Unit,
}

#[derive(Debug, Clone)]
pub struct DocField {
    pub name: Option<String>, // None for tuple fields
    pub visibility: Visibility,
    pub doc: ParsedDoc,
    pub ty: TypeRef,
    pub index: usize, // For tuple structs
}

// ═══════════════════════════════════════════════════════════════════════════════
// ENUM
// ═══════════════════════════════════════════════════════════════════════════════

/// A documented enum
#[derive(Debug, Clone)]
pub struct DocEnum {
    pub name: String,
    pub visibility: Visibility,
    pub doc: ParsedDoc,
    pub path: ItemPath,
    pub location: Option<SourceLocation>,
    /// Generic parameters
    pub generics: Generics,
    /// Variants
    pub variants: Vec<DocVariant>,
    /// Implementations
    pub impls: Vec<ImplRef>,
    /// Derived traits
    pub derives: Vec<String>,
}

#[derive(Debug, Clone)]
pub struct DocVariant {
    pub name: String,
    pub doc: ParsedDoc,
    /// Discriminant value
    pub discriminant: Option<String>,
    /// Variant kind
    pub kind: VariantKind,
}

#[derive(Debug, Clone)]
pub enum VariantKind {
    /// Unit variant
    Unit,
    /// Tuple variant
    Tuple(Vec<TypeRef>),
    /// Struct variant
    Struct(Vec<DocField>),
}

