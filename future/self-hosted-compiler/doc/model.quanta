    pub kind: MacroKind,
    /// Example invocations
    pub matchers: Vec<String>,
}

#[derive(Debug, Clone, PartialEq, Eq)]
pub enum MacroKind {
    /// macro_rules!
    DeclarativeMacro,
    /// #[proc_macro]
    ProcMacro,
    /// #[proc_macro_derive]
    DeriveMacro,
    /// #[proc_macro_attribute]
    AttributeMacro,
}

