//
// The QuantaLang Documentation Generator (quantadoc) produces HTML and Markdown
// documentation from QuantaLang source code, similar to Rustdoc.
//
// Features:
// - Extracts documentation from /// and //! comments
// - Parses Markdown-like content with code blocks
// - Generates searchable HTML documentation
// - Generates Markdown for static site generators
// - Supports intra-doc links like [`Type`]
// - Extracts and tests code examples
//
// ═══════════════════════════════════════════════════════════════════════════════

//! # QuantaDoc - Documentation Generator for QuantaLang
//!
//! This crate provides tools for generating documentation from QuantaLang source.
//!
//! ## Quick Start
//!
//! ```quanta
//! use quantalang::doc::{DocGenerator, DocOptions};
//!
//! fn main() {
//!     let opts = DocOptions::default();
//!     let generator = DocGenerator::new(opts);
//!     generator.generate().expect("failed to generate docs");
//! }
//! ```
//!
//! ## Command Line Usage
//!
//! ```bash
//! # Generate HTML documentation
//! quantadoc
//!
//! # Generate Markdown
//! quantadoc --format md
//!
//! # Include private items
//! quantadoc --private
//!
//! # Custom output directory
//! quantadoc --output docs
//! ```
//!
//! ## Modules
//!
//! - [`parser`] - Parses documentation comments from source
//! - [`model`] - Data structures for documentation items
//! - [`html`] - HTML output generator
//! - [`markdown`] - Markdown output generator
//! - [`cli`] - Command-line interface

module quantalang::doc

// Submodules
pub mod parser;
pub mod model;
pub mod html;
pub mod markdown;
pub mod cli;

// Re-exports for convenience
pub use parser::{DocParser, DocContentParser, ParsedDoc, DocComment, DocKind};
pub use model::{
    DocCrate, DocModule, DocFunction, DocStruct, DocEnum, DocTrait,
    DocTypeAlias, DocConstant, DocStatic, DocMacro, DocImpl,
    ItemPath, Visibility, Generics, TypeRef,
};
pub use html::{HtmlRenderer, HtmlConfig, Theme};
pub use markdown::{MarkdownRenderer, MarkdownConfig, LinkStyle};
pub use cli::{DocGenerator, DocOptions, OutputFormat, GenerationResult};

// Version information
pub const VERSION: &str = "1.0.0";
pub const VERSION_MAJOR: u32 = 1;
pub const VERSION_MINOR: u32 = 0;
pub const VERSION_PATCH: u32 = 0;

/// Generate documentation with default options
///
/// # Examples
///
/// ```quanta
/// use quantalang::doc;
///
/// doc::generate_default().expect("failed to generate docs");
/// ```
pub fn generate_default() -> Result<GenerationResult, String> {
    let opts = DocOptions::default();
    let generator = DocGenerator::new(opts);
    generator.generate()
}

/// Generate documentation for a specific source
///
/// # Arguments
///
/// * `source` - Path to source file or directory
/// * `output` - Output directory for generated documentation
///
/// # Examples
///
/// ```quanta
/// use quantalang::doc;
///
/// doc::generate("src/lib.quanta", "target/doc").expect("failed");
/// ```
pub fn generate(source: &str, output: &str) -> Result<GenerationResult, String> {
    let opts = DocOptions {
        source: source.to_string(),
        output: output.to_string(),
        ..DocOptions::default()
    };
    let generator = DocGenerator::new(opts);
    generator.generate()
}

/// Generate Markdown documentation
///
/// # Arguments
///
/// * `source` - Path to source file or directory
/// * `output` - Output directory for generated documentation
///
/// # Examples
///
/// ```quanta
/// use quantalang::doc;
///
/// doc::generate_markdown("src", "docs").expect("failed");
/// ```
pub fn generate_markdown(source: &str, output: &str) -> Result<GenerationResult, String> {
    let opts = DocOptions {
        source: source.to_string(),
        output: output.to_string(),
        format: OutputFormat::Markdown,
        ..DocOptions::default()
    };
    let generator = DocGenerator::new(opts);
    generator.generate()
}

/// Parse documentation from a source string
///
/// # Arguments
///
/// * `source` - Source code string
///
/// # Returns
///
/// Vector of parsed documentation comments
///
/// # Examples
///
/// ```quanta
/// use quantalang::doc;
///
/// let source = "/// This is a doc comment\nfn foo() {}";
/// let comments = doc::parse(source);
/// assert_eq!(comments.len(), 1);
/// ```
pub fn parse(source: &str) -> Vec<DocComment> {
    let mut parser = DocParser::new(source);
    parser.parse_all()
}

/// Parse documentation content into structured form
///
/// # Arguments
///
/// * `content` - Raw documentation content (without /// prefix)
///
/// # Returns
///
/// Parsed documentation with sections
///
/// # Examples
///
/// ```quanta
/// use quantalang::doc;
///
/// let content = "Brief description.\n\n# Examples\n\n```\ncode\n```";
/// let doc = doc::parse_content(content);
/// assert!(doc.brief.is_some());
/// ```
pub fn parse_content(content: &str) -> ParsedDoc {
    DocContentParser::parse(content)
}

// ═══════════════════════════════════════════════════════════════════════════════
// BUILDER API
// ═══════════════════════════════════════════════════════════════════════════════

/// Builder for configuring documentation generation
///
/// # Examples
///
/// ```quanta
/// use quantalang::doc::DocBuilder;
///
/// DocBuilder::new()
///     .source("src")
///     .output("target/doc")
///     .format_html()
///     .include_private()
///     .generate()
///     .expect("failed to generate docs");
/// ```
pub struct DocBuilder {
    opts: DocOptions,
}

impl DocBuilder {
    /// Create a new documentation builder
    pub fn new() -> Self {
        DocBuilder {
            opts: DocOptions::default(),
        }
    }
    
    /// Set the source directory or file
    pub fn source(mut self, source: &str) -> Self {
        self.opts.source = source.to_string();
        self
    }
    
    /// Set the output directory
    pub fn output(mut self, output: &str) -> Self {
        self.opts.output = output.to_string();
        self
    }
    
    /// Use HTML output format
    pub fn format_html(mut self) -> Self {
        self.opts.format = OutputFormat::Html;
        self
    }
    
    /// Use Markdown output format
    pub fn format_markdown(mut self) -> Self {
        self.opts.format = OutputFormat::Markdown;
        self
    }
    
    /// Use JSON output format
    pub fn format_json(mut self) -> Self {
        self.opts.format = OutputFormat::Json;
        self
    }
    
    /// Include private items in documentation
    pub fn include_private(mut self) -> Self {
        self.opts.document_private = true;
        self
    }
    
    /// Exclude source code from documentation
    pub fn no_source(mut self) -> Self {
        self.opts.include_source = false;
        self
    }
    
    /// Generate as a single file
    pub fn single_file(mut self) -> Self {
        self.opts.single_file = true;
        self
    }
    
    /// Disable search functionality
    pub fn no_search(mut self) -> Self {
        self.opts.enable_search = false;
        self
    }
    
    /// Set the theme
    pub fn theme(mut self, theme: Theme) -> Self {
        self.opts.theme = theme;
        self
    }
    
    /// Set custom CSS file
    pub fn custom_css(mut self, path: &str) -> Self {
        self.opts.custom_css = Some(path.to_string());
        self
    }
    
    /// Set logo image
    pub fn logo(mut self, path: &str) -> Self {
        self.opts.logo = Some(path.to_string());
        self
    }
    
    /// Set crate name override
    pub fn crate_name(mut self, name: &str) -> Self {
        self.opts.crate_name = Some(name.to_string());
        self
    }
    
    /// Set crate version override
    pub fn crate_version(mut self, version: &str) -> Self {
        self.opts.crate_version = Some(version.to_string());
        self
    }
    
    /// Enable verbose output
    pub fn verbose(mut self) -> Self {
        self.opts.verbose = true;
        self
    }
    
    /// Enable quiet mode
    pub fn quiet(mut self) -> Self {
        self.opts.quiet = true;
        self
    }
    
    /// Open documentation in browser after generation
    pub fn open(mut self) -> Self {
        self.opts.open = true;
        self
    }
    
    /// Generate the documentation
    pub fn generate(self) -> Result<GenerationResult, String> {
        let generator = DocGenerator::new(self.opts);
        generator.generate()
    }
}

impl Default for DocBuilder {
    fn default() -> Self {
        Self::new()
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// TESTS
// ═══════════════════════════════════════════════════════════════════════════════

#[cfg(test)]
mod tests {
    use super::*;
    
    #[test]
    fn test_parse_doc_comment() {
        let source = r#"
/// This is a function
/// With multiple lines
fn foo() {}
"#;
        
        let comments = parse(source);
        assert_eq!(comments.len(), 2);
        assert!(comments[0].is_outer());
    }
    
    #[test]
    fn test_parse_content() {
        let content = r#"Brief description.

Extended description here.

# Examples

```quanta
let x = 42;
```

# Panics

When x is negative.
"#;
        
        let doc = parse_content(content);
        
        assert_eq!(doc.brief.as_deref(), Some("Brief description."));
        assert!(doc.sections.contains_key(&parser::StandardSection::Examples));
        assert!(doc.sections.contains_key(&parser::StandardSection::Panics));
    }
    
    #[test]
    fn test_builder() {
        let builder = DocBuilder::new()
            .source("src")
            .output("docs")
            .format_markdown()
            .include_private();
        
        assert_eq!(builder.opts.source, "src");
        assert_eq!(builder.opts.output, "docs");
        assert_eq!(builder.opts.format, OutputFormat::Markdown);
        assert!(builder.opts.document_private);
    }
}
