module quantalang::test::cli

use alloc::string::String;
use alloc::vec::Vec;
use core::time::Duration;
use std::path::PathBuf;
use crate::test::config::{
    TestConfig, OutputFormat, ColorChoice, ReportFormat, TestOrder, CaptureMode,
};
use crate::test::discovery::{TestDiscovery, DiscoveryOptions};
use crate::test::executor::TestExecutor;
use crate::test::reporter::{Reporter, create_reporter, create_file_reporter};

// ═══════════════════════════════════════════════════════════════════════════════
// VERSION
// ═══════════════════════════════════════════════════════════════════════════════

pub const VERSION: &str = "1.0.0";

// ═══════════════════════════════════════════════════════════════════════════════
// CLI OPTIONS
// ═══════════════════════════════════════════════════════════════════════════════

/// CLI arguments
#[derive(Debug, Clone)]
pub struct CliArgs {
    /// Test filter (positional)
    pub filter: Option<String>,
    
    /// Run ignored tests
    pub ignored: bool,
    
    /// Include ignored tests
    pub include_ignored: bool,
    
    /// Exact match filter
    pub exact: bool,
    
    /// Test threads
    pub test_threads: Option<usize>,
    
    /// Don't capture output
    pub nocapture: bool,
    
    /// Show output for passing tests
    pub show_output: bool,
    
    /// Output format
    pub format: Option<OutputFormat>,
    
    /// Color output
    pub color: Option<ColorChoice>,
    
    /// Quiet mode
    pub quiet: bool,
    
    /// List tests without running
    pub list: bool,
    
    /// Skip tests matching pattern
    pub skip: Vec<String>,
    
    /// Shuffle tests
    pub shuffle: bool,
    
    /// Shuffle seed
    pub shuffle_seed: Option<u64>,
    
    /// Report file
    pub report: Option<String>,
    
    /// Report format
    pub report_format: Option<ReportFormat>,
    
    /// Ensure test time limit
    pub ensure_time: Option<Duration>,
    
    /// Continue on failure
    pub no_fail_fast: bool,
    
    /// Run benchmarks
    pub bench: bool,
    
    /// Test timeout
    pub timeout: Option<Duration>,
    
    /// Working directory
    pub manifest_path: Option<PathBuf>,
    
    /// Package to test
    pub package: Option<String>,
    
    /// Workspace
    pub workspace: bool,
    
    /// All targets
    pub all_targets: bool,
    
    /// Lib target
    pub lib: bool,
    
    /// Bin targets
    pub bins: bool,
    
    /// Example targets
    pub examples: bool,
    
    /// Test targets
    pub tests: bool,
    
    /// Doc tests
    pub doc: bool,
    
    /// Features
    pub features: Vec<String>,
    
    /// All features
    pub all_features: bool,
    
    /// No default features
    pub no_default_features: bool,
    
    /// Release mode
    pub release: bool,
    
    /// Profile
    pub profile: Option<String>,
    
    /// Target triple
    pub target: Option<String>,
    
    /// Verbose
    pub verbose: bool,
    
    /// Help
    pub help: bool,
    
    /// Version
    pub version: bool,
}

impl Default for CliArgs {
    fn default() -> Self {
        CliArgs {
            filter: None,
            ignored: false,
            include_ignored: false,
            exact: false,
            test_threads: None,
            nocapture: false,
            show_output: false,
            format: None,
            color: None,
            quiet: false,
            list: false,
            skip: Vec::new(),
            shuffle: false,
            shuffle_seed: None,
            report: None,
            report_format: None,
            ensure_time: None,
            no_fail_fast: false,
            bench: false,
            timeout: None,
            manifest_path: None,
            package: None,
            workspace: false,
            all_targets: false,
            lib: false,
            bins: false,
            examples: false,
            tests: false,
            doc: false,
            features: Vec::new(),
            all_features: false,
            no_default_features: false,
            release: false,
            profile: None,
            target: None,
            verbose: false,
            help: false,
            version: false,
        }
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// ARGUMENT PARSING
// ═══════════════════════════════════════════════════════════════════════════════

/// Parse command-line arguments
pub fn parse_args(args: &[String]) -> Result<CliArgs, String> {
    let mut cli = CliArgs::default();
    let mut i = 0;
    let mut after_separator = false;
    
    while i < args.len() {
        let arg = &args[i];
        
        // Handle -- separator
        if arg == "--" {
            after_separator = true;
            i += 1;
            continue;
        }
        
        // After --, treat all as positional
        if after_separator {
            if cli.filter.is_none() {
                cli.filter = Some(arg.clone());
            }
            i += 1;
            continue;
        }
        
        match arg.as_str() {
            "-h" | "--help" => cli.help = true,
            "-V" | "--version" => cli.version = true,
            "-v" | "--verbose" => cli.verbose = true,
            "-q" | "--quiet" => cli.quiet = true,
            "--ignored" => cli.ignored = true,
            "--include-ignored" => cli.include_ignored = true,
            "--exact" => cli.exact = true,
            "--nocapture" => cli.nocapture = true,
            "--show-output" => cli.show_output = true,
            "--list" => cli.list = true,
            "--bench" => cli.bench = true,
            "--no-fail-fast" => cli.no_fail_fast = true,
            "--workspace" | "--all" => cli.workspace = true,
            "--all-targets" => cli.all_targets = true,
            "--lib" => cli.lib = true,
            "--bins" => cli.bins = true,
            "--examples" => cli.examples = true,
            "--tests" => cli.tests = true,
            "--doc" => cli.doc = true,
            "--all-features" => cli.all_features = true,
            "--no-default-features" => cli.no_default_features = true,
            "--release" => cli.release = true,
            "--shuffle" => cli.shuffle = true,
            
            "--test-threads" => {
                i += 1;
                cli.test_threads = Some(
                    args.get(i)
                        .ok_or("missing value for --test-threads")?
                        .parse()
                        .map_err(|_| "invalid thread count")?
                );
            }
            
            "--format" => {
                i += 1;
                cli.format = Some(parse_output_format(
                    args.get(i).ok_or("missing value for --format")?
                )?);
            }
            
            "--color" => {
                i += 1;
                cli.color = Some(parse_color_choice(
                    args.get(i).ok_or("missing value for --color")?
                )?);
            }
            
            "--skip" => {
                i += 1;
                cli.skip.push(
                    args.get(i)
                        .ok_or("missing value for --skip")?
                        .clone()
                );
            }
            
            "--shuffle-seed" => {
                i += 1;
                cli.shuffle_seed = Some(
                    args.get(i)
                        .ok_or("missing value for --shuffle-seed")?
                        .parse()
                        .map_err(|_| "invalid shuffle seed")?
                );
            }
            
            "--report" | "--report-file" => {
                i += 1;
                cli.report = Some(
                    args.get(i)
                        .ok_or("missing value for --report")?
                        .clone()
                );
            }
            
            "--report-format" => {
                i += 1;
                cli.report_format = Some(parse_report_format(
                    args.get(i).ok_or("missing value for --report-format")?
                )?);
            }
            
            "--timeout" => {
                i += 1;
                cli.timeout = Some(parse_duration(
                    args.get(i).ok_or("missing value for --timeout")?
                )?);
            }
            
            "--manifest-path" => {
                i += 1;
                cli.manifest_path = Some(PathBuf::from(
                    args.get(i).ok_or("missing value for --manifest-path")?
                ));
            }
            
            "-p" | "--package" => {
                i += 1;
                cli.package = Some(
                    args.get(i)
                        .ok_or("missing value for --package")?
                        .clone()
                );
            }
            
            "-F" | "--features" => {
                i += 1;
                let features = args.get(i).ok_or("missing value for --features")?;
                cli.features.extend(features.split(',').map(String::from));
            }
            
            "--profile" => {
                i += 1;
                cli.profile = Some(
                    args.get(i)
                        .ok_or("missing value for --profile")?
                        .clone()
                );
            }
            
            "--target" => {
                i += 1;
                cli.target = Some(
                    args.get(i)
                        .ok_or("missing value for --target")?
                        .clone()
                );
            }
            
            _ if arg.starts_with('-') => {
                return Err(format!("unknown option: {}", arg));
            }
            
            _ => {
                // Positional argument (filter)
                if cli.filter.is_none() {
                    cli.filter = Some(arg.clone());
                }
            }
        }
        
        i += 1;
    }
    
    Ok(cli)
}

fn parse_output_format(s: &str) -> Result<OutputFormat, String> {
    match s.to_lowercase().as_str() {
        "pretty" => Ok(OutputFormat::Pretty),
        "terse" => Ok(OutputFormat::Terse),
        "json" => Ok(OutputFormat::Json),
        "junit" => Ok(OutputFormat::Junit),
        _ => Err(format!("unknown format: {}", s)),
    }
}

fn parse_color_choice(s: &str) -> Result<ColorChoice, String> {
    match s.to_lowercase().as_str() {
        "auto" => Ok(ColorChoice::Auto),
        "always" => Ok(ColorChoice::Always),
        "never" => Ok(ColorChoice::Never),
        _ => Err(format!("unknown color choice: {}", s)),
    }
}

fn parse_report_format(s: &str) -> Result<ReportFormat, String> {
    match s.to_lowercase().as_str() {
        "json" => Ok(ReportFormat::Json),
        "junit" | "xml" => Ok(ReportFormat::Junit),
        "html" => Ok(ReportFormat::Html),
        "tap" => Ok(ReportFormat::Tap),
        _ => Err(format!("unknown report format: {}", s)),
    }
}

fn parse_duration(s: &str) -> Result<Duration, String> {
    if s.ends_with("ms") {
        let n: u64 = s[..s.len()-2].parse().map_err(|_| "invalid duration")?;
        Ok(Duration::from_millis(n))
    } else if s.ends_with('s') {
        let n: u64 = s[..s.len()-1].parse().map_err(|_| "invalid duration")?;
        Ok(Duration::from_secs(n))
    } else if s.ends_with('m') {
        let n: u64 = s[..s.len()-1].parse().map_err(|_| "invalid duration")?;
        Ok(Duration::from_secs(n * 60))
    } else {
        let n: u64 = s.parse().map_err(|_| "invalid duration")?;
        Ok(Duration::from_secs(n))
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// HELP
// ═══════════════════════════════════════════════════════════════════════════════

fn print_help() {
    println!(r#"quantatest - QuantaLang Test Runner

USAGE:
    quantatest [OPTIONS] [TESTNAME] [-- <ARGS>...]

ARGS:
    <TESTNAME>    Filter tests by name

OPTIONS:
    -h, --help                   Show this help message
    -V, --version                Show version
    -v, --verbose                Verbose output
    -q, --quiet                  Only show failures
    
TEST SELECTION:
    --ignored                    Run only ignored tests
    --include-ignored            Run ignored and non-ignored tests
    --exact                      Exact match test name
    --skip <FILTER>              Skip tests matching filter
    --lib                        Test library target
    --bins                       Test binary targets
    --tests                      Test targets in tests/
    --examples                   Test examples
    --doc                        Test documentation examples
    --all-targets                Test all targets
    
EXECUTION:
    --test-threads <N>           Number of test threads
    --nocapture                  Don't capture stdout/stderr
    --show-output                Show output for passing tests
    --no-fail-fast               Continue after failures
    --shuffle                    Randomize test order
    --shuffle-seed <SEED>        Seed for shuffling
    --timeout <DURATION>         Test timeout (e.g., 60s)
    --bench                      Run benchmarks
    --list                       List tests without running
    
OUTPUT:
    --format <FORMAT>            Output format (pretty, terse, json, junit)
    --color <WHEN>               Color output (auto, always, never)
    --report <FILE>              Write report to file
    --report-format <FORMAT>     Report format (json, junit, html, tap)
    
PACKAGE SELECTION:
    -p, --package <SPEC>         Package to test
    --workspace                  Test all workspace packages
    --manifest-path <PATH>       Path to Cargo.toml
    
FEATURE FLAGS:
    -F, --features <FEATURES>    Enable features
    --all-features               Enable all features
    --no-default-features        Disable default features
    
COMPILATION:
    --release                    Test in release mode
    --profile <PROFILE>          Build profile
    --target <TRIPLE>            Target triple

EXAMPLES:
    quantatest                       Run all tests
    quantatest test_foo              Run tests matching "test_foo"
    quantatest --ignored             Run ignored tests
    quantatest --format json         JSON output
    quantatest --test-threads 4      Use 4 threads
    quantatest -- --help             Show libtest help
"#);
}

// ═══════════════════════════════════════════════════════════════════════════════
// MAIN EXECUTION
// ═══════════════════════════════════════════════════════════════════════════════

/// Run the test runner
pub fn run(args: &CliArgs) -> Result<i32, String> {
    if args.help {
        print_help();
        return Ok(0);
    }
    
    if args.version {
        println!("quantatest {}", VERSION);
        return Ok(0);
    }
    
    // Build test config
    let config = build_config(args);
    
    // Determine project root
    let root = args.manifest_path
        .as_ref()
        .map(|p| p.parent().unwrap_or(std::path::Path::new(".")).to_path_buf())
        .unwrap_or_else(|| std::env::current_dir().unwrap_or_else(|_| PathBuf::from(".")));
    
    // Discover tests
    let discovery_opts = build_discovery_options(args);
    let mut discovery = TestDiscovery::new(&root).with_options(discovery_opts);
    let suites = discovery.discover()
        .map_err(|e| format!("discovery failed: {}", e))?;
    
    // Collect all tests
    let tests: Vec<_> = suites.iter()
        .flat_map(|s| s.tests.clone())
        .collect();
    
    // List mode
    if args.list {
        for test in &tests {
            if config.should_run(test) {
                println!("{}: test", test.name);
            }
        }
        println!("\n{} tests", tests.len());
        return Ok(0);
    }
    
    // Create reporter
    let mut reporter = create_reporter(&config);
    let mut file_reporter = create_file_reporter(&config);
    
    // Run tests
    let mut executor = TestExecutor::new(config);
    
    reporter.start(tests.len());
    if let Some(ref mut fr) = file_reporter {
        fr.start(tests.len());
    }
    
    // Execute tests with reporting
    let summary = executor.run(tests);
    
    // Report results
    for result in executor.results() {
        reporter.test_end(result);
        if let Some(ref mut fr) = file_reporter {
            fr.test_end(result);
        }
    }
    
    reporter.finish(summary);
    if let Some(ref mut fr) = file_reporter {
        fr.finish(summary);
    }
    
    // Return exit code
    Ok(if summary.is_success() { 0 } else { 1 })
}

fn build_config(args: &CliArgs) -> TestConfig {
    let mut config = TestConfig::default();
    
    config.filter = args.filter.clone();
    config.exact = args.exact;
    config.run_ignored = args.ignored;
    config.include_ignored = args.include_ignored;
    config.skip = args.skip.clone();
    config.no_fail_fast = args.no_fail_fast;
    config.bench = args.bench;
    config.list = args.list;
    config.verbose = args.verbose;
    config.quiet = args.quiet;
    config.show_output = args.show_output;
    
    if let Some(threads) = args.test_threads {
        config.test_threads = threads;
    }
    
    if args.nocapture {
        config.capture = CaptureMode::Disabled;
    }
    
    if let Some(format) = args.format {
        config.format = format;
    }
    
    if let Some(color) = args.color {
        config.color = color;
    }
    
    if args.shuffle {
        config.test_order = TestOrder::Random;
        config.shuffle_seed = args.shuffle_seed;
    }
    
    if let Some(ref path) = args.report {
        config.report_path = Some(path.clone());
    }
    
    if let Some(format) = args.report_format {
        config.report_format = format;
    }
    
    if let Some(timeout) = args.timeout {
        config.default_timeout = timeout;
    }
    
    config.features = args.features.iter().cloned().collect();
    config.all_features = args.all_features;
    config.no_default_features = args.no_default_features;
    
    config
}

fn build_discovery_options(args: &CliArgs) -> DiscoveryOptions {
    let mut opts = DiscoveryOptions::default();
    
    opts.include_doc_tests = args.doc || args.all_targets || (!args.lib && !args.bins && !args.tests && !args.examples);
    opts.include_integration = args.tests || args.all_targets || (!args.lib && !args.bins && !args.doc && !args.examples);
    opts.include_examples = args.examples || args.all_targets;
    opts.include_benches = args.bench;
    
    opts
}

/// Main entry point
pub fn main() -> Result<i32, String> {
    let args: Vec<String> = std::env::args().skip(1).collect();
    let cli = parse_args(&args)?;
    run(&cli)
}

// ═══════════════════════════════════════════════════════════════════════════════
// TESTS
// ═══════════════════════════════════════════════════════════════════════════════

#[cfg(test)]
mod tests {
    use super::*;
    
    #[test]
    fn test_parse_args_empty() {
        let args: Vec<String> = vec![];
        let cli = parse_args(&args).unwrap();
        assert!(cli.filter.is_none());
        assert!(!cli.verbose);
    }
    
    #[test]
    fn test_parse_args_filter() {
        let args = vec!["test_foo".to_string()];
        let cli = parse_args(&args).unwrap();
        assert_eq!(cli.filter, Some("test_foo".to_string()));
    }
    
    #[test]
    fn test_parse_args_options() {
        let args = vec![
            "--verbose".to_string(),
            "--ignored".to_string(),
            "--test-threads".to_string(),
            "4".to_string(),
        ];
        let cli = parse_args(&args).unwrap();
        assert!(cli.verbose);
        assert!(cli.ignored);
        assert_eq!(cli.test_threads, Some(4));
    }
    
    #[test]
    fn test_parse_duration() {
        assert_eq!(parse_duration("5s").unwrap(), Duration::from_secs(5));
        assert_eq!(parse_duration("100ms").unwrap(), Duration::from_millis(100));
        assert_eq!(parse_duration("2m").unwrap(), Duration::from_secs(120));
    }
}
