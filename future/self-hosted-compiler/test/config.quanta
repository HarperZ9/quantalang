module quantalang::test::config

use alloc::string::String;
use alloc::vec::Vec;
use alloc::collections::{BTreeMap, BTreeSet};
use core::time::Duration;
use core::fmt;

// ═══════════════════════════════════════════════════════════════════════════════
// TEST CONFIGURATION
// ═══════════════════════════════════════════════════════════════════════════════

/// Test runner configuration
#[derive(Debug, Clone)]
pub struct TestConfig {
    /// Number of test threads (0 = auto-detect)
    pub test_threads: usize,
    
    /// Run tests in order (not randomized)
    pub test_order: TestOrder,
    
    /// Capture stdout/stderr
    pub capture: CaptureMode,
    
    /// Show output for passing tests
    pub show_output: bool,
    
    /// Continue after first failure
    pub no_fail_fast: bool,
    
    /// Test timeout
    pub timeout: Option<Duration>,
    
    /// Default timeout per test
    pub default_timeout: Duration,
    
    /// Include ignored tests
    pub include_ignored: bool,
    
    /// Run only ignored tests
    pub run_ignored: bool,
    
    /// Run only exact match
    pub exact: bool,
    
    /// Filter by test name pattern
    pub filter: Option<String>,
    
    /// Skip tests matching pattern
    pub skip: Vec<String>,
    
    /// Run benchmarks instead of tests
    pub bench: bool,
    
    /// List tests without running
    pub list: bool,
    
    /// Output format
    pub format: OutputFormat,
    
    /// Color output
    pub color: ColorChoice,
    
    /// Verbose output
    pub verbose: bool,
    
    /// Quiet mode (only failures)
    pub quiet: bool,
    
    /// Report file path
    pub report_path: Option<String>,
    
    /// Report format
    pub report_format: ReportFormat,
    
    /// Enable test coverage
    pub coverage: bool,
    
    /// Coverage output directory
    pub coverage_dir: Option<String>,
    
    /// Shuffle seed (for reproducible randomization)
    pub shuffle_seed: Option<u64>,
    
    /// Environment variables for tests
    pub env: BTreeMap<String, String>,
    
    /// Working directory for tests
    pub working_dir: Option<String>,
    
    /// Features to enable
    pub features: BTreeSet<String>,
    
    /// All features
    pub all_features: bool,
    
    /// No default features
    pub no_default_features: bool,
}

impl Default for TestConfig {
    fn default() -> Self {
        TestConfig {
            test_threads: 0,
            test_order: TestOrder::Random,
            capture: CaptureMode::Enabled,
            show_output: false,
            no_fail_fast: false,
            timeout: None,
            default_timeout: Duration::from_secs(60),
            include_ignored: false,
            run_ignored: false,
            exact: false,
            filter: None,
            skip: Vec::new(),
            bench: false,
            list: false,
            format: OutputFormat::Pretty,
            color: ColorChoice::Auto,
            verbose: false,
            quiet: false,
            report_path: None,
            report_format: ReportFormat::Json,
            coverage: false,
            coverage_dir: None,
            shuffle_seed: None,
            env: BTreeMap::new(),
            working_dir: None,
            features: BTreeSet::new(),
            all_features: false,
            no_default_features: false,
        }
    }
}

impl TestConfig {
    /// Get effective number of threads
    pub fn effective_threads(&self) -> usize {
        if self.test_threads == 0 {
            num_cpus()
        } else {
            self.test_threads
        }
    }
    
    /// Check if test should run based on filters
    pub fn should_run(&self, test: &TestDescriptor) -> bool {
        // Check ignore status
        if test.ignored && !self.include_ignored && !self.run_ignored {
            return false;
        }
        if self.run_ignored && !test.ignored {
            return false;
        }
        
        // Check filter
        if let Some(ref filter) = self.filter {
            if self.exact {
                if test.name != *filter {
                    return false;
                }
            } else if !test.name.contains(filter) {
                return false;
            }
        }
        
        // Check skip patterns
        for skip in &self.skip {
            if test.name.contains(skip) {
                return false;
            }
        }
        
        true
    }
}

#[derive(Debug, Clone, Copy, PartialEq, Eq)]
pub enum TestOrder {
    /// Randomize test order
    Random,
    /// Run in declaration order
    Declaration,
    /// Alphabetical order
    Alphabetical,
}

#[derive(Debug, Clone, Copy, PartialEq, Eq)]
pub enum CaptureMode {
    /// Capture output
    Enabled,
    /// Don't capture (show immediately)
    Disabled,
}

#[derive(Debug, Clone, Copy, PartialEq, Eq)]
pub enum OutputFormat {
    /// Human-readable pretty output
    Pretty,
    /// Terse output (one char per test)
    Terse,
    /// JSON output
    Json,
    /// JUnit XML output
    Junit,
}

#[derive(Debug, Clone, Copy, PartialEq, Eq)]
pub enum ColorChoice {
    Auto,
    Always,
    Never,
}

#[derive(Debug, Clone, Copy, PartialEq, Eq)]
pub enum ReportFormat {
    /// JSON report
    Json,
    /// JUnit XML
    Junit,
    /// HTML report
    Html,
    /// TAP (Test Anything Protocol)
    Tap,
}

/// Get number of CPUs
fn num_cpus() -> usize {
    // Platform-specific CPU detection
    #[cfg(target_os = "linux")]
    {
        std::fs::read_to_string("/proc/cpuinfo")
            .map(|s| s.matches("processor").count())
            .unwrap_or(1)
    }
    
    #[cfg(not(target_os = "linux"))]
    {
        std::thread::available_parallelism()
            .map(|n| n.get())
            .unwrap_or(1)
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// TEST DESCRIPTOR
// ═══════════════════════════════════════════════════════════════════════════════

/// Describes a single test
#[derive(Debug, Clone)]
pub struct TestDescriptor {
    /// Full test name (module::test_name)
    pub name: String,
    
    /// Test function name only
    pub fn_name: String,
    
    /// Module path
    pub module: String,
    
    /// Source file
    pub file: String,
    
    /// Line number
    pub line: usize,
    
    /// Test is ignored (#[ignore])
    pub ignored: bool,
    
    /// Ignore reason
    pub ignore_reason: Option<String>,
    
    /// Test should panic (#[should_panic])
    pub should_panic: Option<ShouldPanic>,
    
    /// Test timeout override
    pub timeout: Option<Duration>,
    
    /// Test is async
    pub is_async: bool,
    
    /// Test kind
    pub kind: TestKind,
    
    /// Test attributes
    pub attributes: Vec<TestAttribute>,
    
    /// Required features
    pub required_features: Vec<String>,
}

impl TestDescriptor {
    pub fn new(name: &str, module: &str, fn_name: &str) -> Self {
        TestDescriptor {
            name: name.to_string(),
            fn_name: fn_name.to_string(),
            module: module.to_string(),
            file: String::new(),
            line: 0,
            ignored: false,
            ignore_reason: None,
            should_panic: None,
            timeout: None,
            is_async: false,
            kind: TestKind::Unit,
            attributes: Vec::new(),
            required_features: Vec::new(),
        }
    }
    
    pub fn with_file(mut self, file: &str, line: usize) -> Self {
        self.file = file.to_string();
        self.line = line;
        self
    }
    
    pub fn ignored(mut self, reason: Option<&str>) -> Self {
        self.ignored = true;
        self.ignore_reason = reason.map(String::from);
        self
    }
    
    pub fn should_panic(mut self, expected: Option<&str>) -> Self {
        self.should_panic = Some(ShouldPanic {
            expected: expected.map(String::from),
        });
        self
    }
    
    pub fn with_timeout(mut self, timeout: Duration) -> Self {
        self.timeout = Some(timeout);
        self
    }
    
    pub fn async_test(mut self) -> Self {
        self.is_async = true;
        self
    }
}

#[derive(Debug, Clone)]
pub struct ShouldPanic {
    /// Expected panic message (substring match)
    pub expected: Option<String>,
}

#[derive(Debug, Clone, Copy, PartialEq, Eq)]
pub enum TestKind {
    /// Unit test (#[test])
    Unit,
    /// Integration test
    Integration,
    /// Doc test
    Doc,
    /// Benchmark (#[bench])
    Bench,
    /// Example
    Example,
}

#[derive(Debug, Clone)]
pub enum TestAttribute {
    /// #[ignore]
    Ignore(Option<String>),
    /// #[should_panic]
    ShouldPanic(Option<String>),
    /// #[timeout(duration)]
    Timeout(Duration),
    /// #[serial]
    Serial,
    /// #[parallel]
    Parallel,
    /// Custom attribute
    Custom(String, Option<String>),
}

// ═══════════════════════════════════════════════════════════════════════════════
// TEST RESULT
// ═══════════════════════════════════════════════════════════════════════════════

/// Result of running a single test
#[derive(Debug, Clone)]
pub struct TestResult {
    /// Test descriptor
    pub test: TestDescriptor,
    
    /// Test outcome
    pub outcome: TestOutcome,
    
    /// Execution duration
    pub duration: Duration,
    
    /// Captured stdout
    pub stdout: String,
    
    /// Captured stderr
    pub stderr: String,
    
    /// Failure message
    pub message: Option<String>,
    
    /// Stack trace (if available)
    pub backtrace: Option<String>,
}

impl TestResult {
    pub fn passed(test: TestDescriptor, duration: Duration) -> Self {
        TestResult {
            test,
            outcome: TestOutcome::Passed,
            duration,
            stdout: String::new(),
            stderr: String::new(),
            message: None,
            backtrace: None,
        }
    }
    
    pub fn failed(test: TestDescriptor, duration: Duration, message: &str) -> Self {
        TestResult {
            test,
            outcome: TestOutcome::Failed,
            duration,
            stdout: String::new(),
            stderr: String::new(),
            message: Some(message.to_string()),
            backtrace: None,
        }
    }
    
    pub fn ignored(test: TestDescriptor) -> Self {
        TestResult {
            test,
            outcome: TestOutcome::Ignored,
            duration: Duration::ZERO,
            stdout: String::new(),
            stderr: String::new(),
            message: None,
            backtrace: None,
        }
    }
    
    pub fn timed_out(test: TestDescriptor, duration: Duration) -> Self {
        TestResult {
            test,
            outcome: TestOutcome::TimedOut,
            duration,
            stdout: String::new(),
            stderr: String::new(),
            message: Some("test timed out".to_string()),
            backtrace: None,
        }
    }
    
    pub fn with_output(mut self, stdout: String, stderr: String) -> Self {
        self.stdout = stdout;
        self.stderr = stderr;
        self
    }
    
    pub fn with_backtrace(mut self, backtrace: String) -> Self {
        self.backtrace = Some(backtrace);
        self
    }
    
    pub fn is_success(&self) -> bool {
        matches!(self.outcome, TestOutcome::Passed | TestOutcome::Ignored)
    }
    
    pub fn is_failure(&self) -> bool {
        matches!(self.outcome, TestOutcome::Failed | TestOutcome::TimedOut)
    }
}

#[derive(Debug, Clone, Copy, PartialEq, Eq)]
pub enum TestOutcome {
    /// Test passed
    Passed,
    /// Test failed
    Failed,
    /// Test was ignored
    Ignored,
    /// Test timed out
    TimedOut,
    /// Test was filtered out
    Filtered,
}

impl fmt::Display for TestOutcome {
    fn fmt(&self, f: &mut fmt::Formatter<'_>) -> fmt::Result {
        match self {
            TestOutcome::Passed => write!(f, "ok"),
            TestOutcome::Failed => write!(f, "FAILED"),
            TestOutcome::Ignored => write!(f, "ignored"),
            TestOutcome::TimedOut => write!(f, "TIMED OUT"),
            TestOutcome::Filtered => write!(f, "filtered"),
        }
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// TEST SUITE
// ═══════════════════════════════════════════════════════════════════════════════

/// Collection of tests from a crate/module
#[derive(Debug, Clone)]
pub struct TestSuite {
    /// Suite name (crate or module)
    pub name: String,
    
    /// Tests in this suite
    pub tests: Vec<TestDescriptor>,
    
    /// Setup function
    pub setup: Option<String>,
    
    /// Teardown function
    pub teardown: Option<String>,
    
    /// Suite-level timeout
    pub timeout: Option<Duration>,
}

impl TestSuite {
    pub fn new(name: &str) -> Self {
        TestSuite {
            name: name.to_string(),
            tests: Vec::new(),
            setup: None,
            teardown: None,
            timeout: None,
        }
    }
    
    pub fn add_test(&mut self, test: TestDescriptor) {
        self.tests.push(test);
    }
    
    pub fn test_count(&self) -> usize {
        self.tests.len()
    }
    
    pub fn ignored_count(&self) -> usize {
        self.tests.iter().filter(|t| t.ignored).count()
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// TEST SUMMARY
// ═══════════════════════════════════════════════════════════════════════════════

/// Summary of test run
#[derive(Debug, Clone, Default)]
pub struct TestSummary {
    /// Total tests discovered
    pub total: usize,
    
    /// Tests that passed
    pub passed: usize,
    
    /// Tests that failed
    pub failed: usize,
    
    /// Tests that were ignored
    pub ignored: usize,
    
    /// Tests that timed out
    pub timed_out: usize,
    
    /// Tests that were filtered
    pub filtered: usize,
    
    /// Total duration
    pub duration: Duration,
    
    /// Failed test names
    pub failures: Vec<String>,
}

impl TestSummary {
    pub fn new() -> Self {
        Self::default()
    }
    
    pub fn record(&mut self, result: &TestResult) {
        self.total += 1;
        
        match result.outcome {
            TestOutcome::Passed => self.passed += 1,
            TestOutcome::Failed => {
                self.failed += 1;
                self.failures.push(result.test.name.clone());
            }
            TestOutcome::Ignored => self.ignored += 1,
            TestOutcome::TimedOut => {
                self.timed_out += 1;
                self.failures.push(result.test.name.clone());
            }
            TestOutcome::Filtered => self.filtered += 1,
        }
    }
    
    pub fn is_success(&self) -> bool {
        self.failed == 0 && self.timed_out == 0
    }
    
    pub fn merge(&mut self, other: &TestSummary) {
        self.total += other.total;
        self.passed += other.passed;
        self.failed += other.failed;
        self.ignored += other.ignored;
        self.timed_out += other.timed_out;
        self.filtered += other.filtered;
        self.failures.extend(other.failures.clone());
    }
}

impl fmt::Display for TestSummary {
    fn fmt(&self, f: &mut fmt::Formatter<'_>) -> fmt::Result {
        write!(
            f,
            "test result: {}. {} passed; {} failed; {} ignored; {} filtered out; finished in {:.2}s",
            if self.is_success() { "ok" } else { "FAILED" },
            self.passed,
            self.failed + self.timed_out,
            self.ignored,
            self.filtered,
            self.duration.as_secs_f64()
        )
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// ASSERTION TYPES
// ═══════════════════════════════════════════════════════════════════════════════

/// Assertion failure information
#[derive(Debug, Clone)]
pub struct AssertionFailure {
    /// Assertion type
    pub kind: AssertionKind,
    
    /// Left value (for comparisons)
    pub left: Option<String>,
    
    /// Right value (for comparisons)
    pub right: Option<String>,
    
    /// Custom message
    pub message: Option<String>,
    
    /// File where assertion failed
    pub file: String,
    
    /// Line number
    pub line: usize,
    
    /// Column number
    pub column: usize,
}

#[derive(Debug, Clone, Copy, PartialEq, Eq)]
pub enum AssertionKind {
    /// assert!(expr)
    Assert,
    /// assert_eq!(left, right)
    AssertEq,
    /// assert_ne!(left, right)
    AssertNe,
    /// assert!(matches!(expr, pattern))
    AssertMatches,
    /// Custom assertion
    Custom,
}

impl fmt::Display for AssertionFailure {
    fn fmt(&self, f: &mut fmt::Formatter<'_>) -> fmt::Result {
        match self.kind {
            AssertionKind::Assert => {
                write!(f, "assertion failed")?;
            }
            AssertionKind::AssertEq => {
                write!(f, "assertion `left == right` failed\n")?;
                if let (Some(left), Some(right)) = (&self.left, &self.right) {
                    write!(f, "  left: {}\n right: {}", left, right)?;
                }
            }
            AssertionKind::AssertNe => {
                write!(f, "assertion `left != right` failed\n")?;
                if let Some(left) = &self.left {
                    write!(f, " both: {}", left)?;
                }
            }
            AssertionKind::AssertMatches => {
                write!(f, "assertion `matches!(...)` failed")?;
            }
            AssertionKind::Custom => {
                if let Some(msg) = &self.message {
                    write!(f, "{}", msg)?;
                } else {
                    write!(f, "assertion failed")?;
                }
            }
        }
        
        if let Some(msg) = &self.message {
            write!(f, ": {}", msg)?;
        }
        
        write!(f, "\n  --> {}:{}:{}", self.file, self.line, self.column)?;
        
        Ok(())
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// TESTS
// ═══════════════════════════════════════════════════════════════════════════════

#[cfg(test)]
mod tests {
    use super::*;
    
    #[test]
    fn test_config_defaults() {
        let config = TestConfig::default();
        assert_eq!(config.test_threads, 0);
        assert!(!config.no_fail_fast);
        assert!(matches!(config.format, OutputFormat::Pretty));
    }
    
    #[test]
    fn test_descriptor() {
        let test = TestDescriptor::new("my_test", "crate::module", "test_foo")
            .with_file("src/lib.quanta", 42)
            .ignored(Some("not implemented"));
        
        assert!(test.ignored);
        assert_eq!(test.ignore_reason, Some("not implemented".to_string()));
    }
    
    #[test]
    fn test_summary() {
        let mut summary = TestSummary::new();
        
        let test = TestDescriptor::new("test1", "", "test1");
        summary.record(&TestResult::passed(test.clone(), Duration::from_millis(10)));
        summary.record(&TestResult::failed(test.clone(), Duration::from_millis(20), "oops"));
        
        assert_eq!(summary.passed, 1);
        assert_eq!(summary.failed, 1);
        assert!(!summary.is_success());
    }
}
