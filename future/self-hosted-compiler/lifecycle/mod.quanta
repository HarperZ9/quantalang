module quantalang::lifecycle

pub mod lts;

pub use lts::{
    // Versions
    Version, VersionError,
    
    // Support
    SupportTier, Release, ReleaseSchedule,
    ReleaseCadence, LtsFrequency,
    
    // Dates
    Date,
    
    // Deprecations
    Deprecation, DeprecationKind, BreakingChange,
    
    // Registry
    ReleaseRegistry, SupportMatrix, SupportMatrixEntry,
};

use alloc::vec::Vec;
use alloc::string::String;

// ═══════════════════════════════════════════════════════════════════════════════
// CURRENT VERSION
// ═══════════════════════════════════════════════════════════════════════════════

/// Current QuantaLang version
pub const CURRENT_VERSION: Version = Version::new(1, 0, 0);

/// Current version string
pub const VERSION_STRING: &str = "1.0.0";

/// Build metadata
pub const BUILD_INFO: BuildInfo = BuildInfo {
    version: CURRENT_VERSION,
    commit: "HEAD",
    build_date: "2025-01-15",
    rustc_version: "1.75.0",
    target: "x86_64-unknown-linux-gnu",
};

/// Build information
#[derive(Debug, Clone)]
pub struct BuildInfo {
    pub version: Version,
    pub commit: &'static str,
    pub build_date: &'static str,
    pub rustc_version: &'static str,
    pub target: &'static str,
}

impl BuildInfo {
    pub fn full_version(&self) -> String {
        format!(
            "{} ({} {}) [{}]",
            self.version,
            self.commit,
            self.build_date,
            self.target
        )
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// OFFICIAL RELEASES
// ═══════════════════════════════════════════════════════════════════════════════

/// Get official release registry
pub fn official_releases() -> ReleaseRegistry {
    let mut registry = ReleaseRegistry::default();
    
    // v1.0.0 - Initial LTS release
    registry.add(
        Release::new(Version::new(1, 0, 0), Date::new(2025, 1, 15))
            .codename("Genesis")
    );
    
    registry
}

// ═══════════════════════════════════════════════════════════════════════════════
// VERSION CHECKING
// ═══════════════════════════════════════════════════════════════════════════════

/// Check if current version is supported
pub fn is_supported() -> bool {
    let registry = official_releases();
    if let Some(release) = registry.get(&CURRENT_VERSION) {
        let today = Date::today();
        release.calculate_tier(&today).has_security_support()
    } else {
        false
    }
}

/// Get current support tier
pub fn current_support_tier() -> SupportTier {
    let registry = official_releases();
    if let Some(release) = registry.get(&CURRENT_VERSION) {
        let today = Date::today();
        release.calculate_tier(&today)
    } else {
        SupportTier::EndOfLife
    }
}

/// Check if upgrade is recommended
pub fn upgrade_recommended() -> Option<Version> {
    let registry = official_releases();
    
    if let Some(current) = registry.current() {
        if current.version > CURRENT_VERSION {
            return Some(current.version.clone());
        }
    }
    
    None
}

// ═══════════════════════════════════════════════════════════════════════════════
// PRELUDE
// ═══════════════════════════════════════════════════════════════════════════════

pub mod prelude {
    pub use super::{
        Version, SupportTier, Release, ReleaseRegistry,
        Date, Deprecation, DeprecationKind,
        CURRENT_VERSION, BUILD_INFO,
        is_supported, current_support_tier, upgrade_recommended,
    };
}

// ═══════════════════════════════════════════════════════════════════════════════
// TESTS
// ═══════════════════════════════════════════════════════════════════════════════

#[cfg(test)]
mod tests {
    use super::*;
    
    #[test]
    fn test_current_version() {
        assert_eq!(CURRENT_VERSION.major, 1);
        assert!(CURRENT_VERSION.is_lts());
    }
    
    #[test]
    fn test_build_info() {
        let info = BUILD_INFO.full_version();
        assert!(info.contains("1.0.0"));
    }
}
