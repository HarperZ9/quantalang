// ═══════════════════════════════════════════════════════════════════════════════
// SOLVER RESULT
// ═══════════════════════════════════════════════════════════════════════════════

/// SMT solver result
#[derive(Debug, Clone)]
pub enum SolverResult {
    /// Formula is satisfiable
    Sat(Model),
    /// Formula is unsatisfiable
    Unsat(Option<UnsatCore>),
    /// Unknown (timeout or resource limit)
    Unknown(String),
    /// Solver error
    Error(String),
}

impl SolverResult {
    pub fn is_sat(&self) -> bool {
        matches!(self, SolverResult::Sat(_))
    }
    
    pub fn is_unsat(&self) -> bool {
        matches!(self, SolverResult::Unsat(_))
    }
    
    pub fn is_unknown(&self) -> bool {
        matches!(self, SolverResult::Unknown(_))
    }
    
    pub fn get_model(&self) -> Option<&Model> {
        match self {
            SolverResult::Sat(model) => Some(model),
            _ => None,
        }
    }
    
    pub fn get_unsat_core(&self) -> Option<&UnsatCore> {
        match self {
            SolverResult::Unsat(Some(core)) => Some(core),
            _ => None,
        }
    }
}

/// Model (satisfying assignment)
#[derive(Debug, Clone, Default)]
pub struct Model {
    /// Variable assignments
    pub assignments: BTreeMap<String, ModelValue>,
    /// Function interpretations
    pub functions: BTreeMap<String, FunctionInterpretation>,
    /// Array interpretations
    pub arrays: BTreeMap<String, ArrayInterpretation>,
}

impl Model {
    pub fn new() -> Self {
        Model::default()
    }
    
    pub fn get(&self, var: &str) -> Option<&ModelValue> {
        self.assignments.get(var)
    }
    
    pub fn get_int(&self, var: &str) -> Option<i128> {
        self.get(var).and_then(|v| match v {
            ModelValue::Int(n) => Some(*n),
            _ => None,
        })
    }
    
    pub fn get_bool(&self, var: &str) -> Option<bool> {
        self.get(var).and_then(|v| match v {
            ModelValue::Bool(b) => Some(*b),
            _ => None,
        })
    }
    
    /// Evaluate a term in the model
    pub fn evaluate(&self, term: &Term) -> Option<ModelValue> {
        match term {
            Term::Var(v) => self.get(v).cloned(),
            Term::IntConst(n) => Some(ModelValue::Int(*n)),
            Term::BoolConst(b) => Some(ModelValue::Bool(*b)),
            Term::RealConst(r) => Some(ModelValue::Real(*r)),
            Term::Add(l, r) => {
                let lv = self.evaluate(l)?.as_int()?;
                let rv = self.evaluate(r)?.as_int()?;
                Some(ModelValue::Int(lv + rv))
            }
            Term::Sub(l, r) => {
                let lv = self.evaluate(l)?.as_int()?;
                let rv = self.evaluate(r)?.as_int()?;
                Some(ModelValue::Int(lv - rv))
            }
            Term::Mul(l, r) => {
                let lv = self.evaluate(l)?.as_int()?;
                let rv = self.evaluate(r)?.as_int()?;
                Some(ModelValue::Int(lv * rv))
            }
            Term::Div(l, r) => {
                let lv = self.evaluate(l)?.as_int()?;
                let rv = self.evaluate(r)?.as_int()?;
                if rv == 0 { None } else { Some(ModelValue::Int(lv / rv)) }
            }
            Term::Neg(t) => {
                let v = self.evaluate(t)?.as_int()?;
                Some(ModelValue::Int(-v))
            }
            Term::Select(arr, idx) => {
                let arr_name = match arr.as_ref() {
                    Term::Var(v) => v.clone(),
                    _ => return None,
                };
                let idx_val = self.evaluate(idx)?;
                self.arrays.get(&arr_name)?.get(&idx_val)
            }
            _ => None,
        }
    }
}

/// Model value
#[derive(Debug, Clone, PartialEq)]
pub enum ModelValue {
    Bool(bool),
    Int(i128),
    Real(f64),
    BitVec(Vec<bool>),
    Array(Box<ArrayInterpretation>),
    Uninterpreted(String),
}

impl ModelValue {
    pub fn as_int(&self) -> Option<i128> {
        match self {
            ModelValue::Int(n) => Some(*n),
            _ => None,
        }
    }
    
    pub fn as_bool(&self) -> Option<bool> {
        match self {
            ModelValue::Bool(b) => Some(*b),
            _ => None,
        }
    }
}

/// Function interpretation
#[derive(Debug, Clone)]
pub struct FunctionInterpretation {
    /// Explicit mappings
    pub mappings: Vec<(Vec<ModelValue>, ModelValue)>,
    /// Default value
    pub default: Option<ModelValue>,
}

impl FunctionInterpretation {
    pub fn new() -> Self {
        FunctionInterpretation {
            mappings: Vec::new(),
            default: None,
        }
    }
    
    pub fn apply(&self, args: &[ModelValue]) -> Option<ModelValue> {
        for (params, result) in &self.mappings {
            if params == args {
                return Some(result.clone());
            }
        }
        self.default.clone()
    }
}

impl Default for FunctionInterpretation {
    fn default() -> Self {
        Self::new()
    }
}

/// Array interpretation
#[derive(Debug, Clone)]
pub struct ArrayInterpretation {
    /// Explicit element mappings
    pub elements: BTreeMap<String, ModelValue>,
    /// Default value
    pub default: Option<ModelValue>,
}

impl ArrayInterpretation {
    pub fn new() -> Self {
        ArrayInterpretation {
            elements: BTreeMap::new(),
            default: None,
        }
    }
    
    pub fn get(&self, index: &ModelValue) -> Option<ModelValue> {
        let key = format!("{:?}", index);
        self.elements.get(&key).cloned().or_else(|| self.default.clone())
    }
}

impl Default for ArrayInterpretation {
    fn default() -> Self {
        Self::new()
    }
}

/// Unsat core
#[derive(Debug, Clone)]
pub struct UnsatCore {
    /// Indices of assertions in the core
    pub assertions: Vec<usize>,
    /// Named assertions
    pub named: Vec<String>,
}

impl UnsatCore {
    pub fn new() -> Self {
        UnsatCore {
            assertions: Vec::new(),
            named: Vec::new(),
        }
    }
}

impl Default for UnsatCore {
    fn default() -> Self {
        Self::new()
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// SOLVER TRAIT
// ═══════════════════════════════════════════════════════════════════════════════

/// SMT solver trait
pub trait Solver: Send + Sync {
    /// Solver name
    fn name(&self) -> &str;
    
    /// Push a new scope
    fn push(&mut self);
    
    /// Pop a scope
    fn pop(&mut self);
    
    /// Assert a formula
    fn assert(&mut self, formula: &Formula);
    
    /// Assert with a name (for unsat cores)
    fn assert_named(&mut self, name: &str, formula: &Formula);
    
    /// Check satisfiability
    fn check_sat(&mut self) -> SolverResult;
    
    /// Check satisfiability with timeout
    fn check_sat_timeout(&mut self, timeout: Duration) -> SolverResult;
    
    /// Get model (after SAT result)
    fn get_model(&self) -> Option<Model>;
    
    /// Get unsat core (after UNSAT result)
    fn get_unsat_core(&self) -> Option<UnsatCore>;
    
    /// Reset solver
    fn reset(&mut self);
    
    /// Set option
    fn set_option(&mut self, name: &str, value: &str);
    
    /// Declare variable
    fn declare(&mut self, name: &str, sort: &Sort);
    
    /// Declare function
    fn declare_fun(&mut self, name: &str, params: &[Sort], result: &Sort);
    
    /// Define function
    fn define_fun(&mut self, name: &str, params: &[(String, Sort)], result: &Sort, body: &Term);
}

// ═══════════════════════════════════════════════════════════════════════════════
// Z3 SOLVER
// ═══════════════════════════════════════════════════════════════════════════════

/// Z3 solver implementation (via SMT-LIB2 interface)
pub struct Z3Solver {
    /// Accumulated assertions
    assertions: Vec<String>,
    /// Named assertions
    named_assertions: BTreeMap<String, String>,
    /// Declarations
    declarations: Vec<String>,
    /// Scope stack
    scope_stack: Vec<usize>,
    /// Options
    options: BTreeMap<String, String>,
    /// Last result
    last_result: Option<SolverResult>,
    /// Z3 path
    z3_path: String,
}

impl Z3Solver {
    pub fn new() -> Self {
        Z3Solver {
            assertions: Vec::new(),
            named_assertions: BTreeMap::new(),
            declarations: Vec::new(),
            scope_stack: Vec::new(),
            options: BTreeMap::new(),
            last_result: None,
            z3_path: "z3".to_string(),
        }
    }
    
    pub fn with_path(mut self, path: impl Into<String>) -> Self {
        self.z3_path = path.into();
        self
    }
    
    fn generate_script(&self) -> String {
        let mut script = String::new();
        
        // Options
        for (name, value) in &self.options {
            script.push_str(&format!("(set-option :{} {})\n", name, value));
        }
        
        script.push_str("(set-logic ALL)\n");
        
        // Declarations
        for decl in &self.declarations {
            script.push_str(decl);
            script.push('\n');
        }
        
        // Assertions
        for assertion in &self.assertions {
            script.push_str(&format!("(assert {})\n", assertion));
        }
        
        script.push_str("(check-sat)\n");
        script.push_str("(get-model)\n");
        
        script
    }
}

impl Default for Z3Solver {
    fn default() -> Self {
        Self::new()
    }
}

impl Solver for Z3Solver {
    fn name(&self) -> &str { "z3" }
    
    fn push(&mut self) {
        self.scope_stack.push(self.assertions.len());
    }
    
    fn pop(&mut self) {
        if let Some(size) = self.scope_stack.pop() {
            self.assertions.truncate(size);
        }
    }
    
    fn assert(&mut self, formula: &Formula) {
        let smt2 = formula_to_smt2(formula);
        self.assertions.push(smt2);
    }
    
    fn assert_named(&mut self, name: &str, formula: &Formula) {
        let smt2 = formula_to_smt2(formula);
        let named = format!("(! {} :named {})", smt2, name);
        self.assertions.push(named.clone());
        self.named_assertions.insert(name.to_string(), named);
    }
    
    fn check_sat(&mut self) -> SolverResult {
        // In a real implementation, this would invoke Z3
        // For now, return Unknown
        let result = SolverResult::Unknown("Z3 not available".to_string());
        self.last_result = Some(result.clone());
        result
    }
    
    fn check_sat_timeout(&mut self, timeout: Duration) -> SolverResult {
        self.set_option("timeout", &timeout.as_millis().to_string());
        self.check_sat()
    }
    
    fn get_model(&self) -> Option<Model> {
        match &self.last_result {
            Some(SolverResult::Sat(model)) => Some(model.clone()),
            _ => None,
        }
    }
    
    fn get_unsat_core(&self) -> Option<UnsatCore> {
        match &self.last_result {
            Some(SolverResult::Unsat(core)) => core.clone(),
            _ => None,
        }
    }
    
    fn reset(&mut self) {
        self.assertions.clear();
        self.named_assertions.clear();
        self.declarations.clear();
        self.scope_stack.clear();
        self.last_result = None;
    }
    
    fn set_option(&mut self, name: &str, value: &str) {
        self.options.insert(name.to_string(), value.to_string());
    }
    
    fn declare(&mut self, name: &str, sort: &Sort) {
        let decl = format!("(declare-const {} {})", name, sort.to_smt2());
        self.declarations.push(decl);
    }
    
    fn declare_fun(&mut self, name: &str, params: &[Sort], result: &Sort) {
        let params_str: Vec<String> = params.iter().map(|s| s.to_smt2()).collect();
        let decl = format!(
            "(declare-fun {} ({}) {})",
            name, params_str.join(" "), result.to_smt2()
        );
        self.declarations.push(decl);
    }
    
    fn define_fun(&mut self, name: &str, params: &[(String, Sort)], result: &Sort, body: &Term) {
        let params_str: Vec<String> = params.iter()
            .map(|(n, s)| format!("({} {})", n, s.to_smt2()))
            .collect();
        let decl = format!(
            "(define-fun {} ({}) {} {})",
            name, params_str.join(" "), result.to_smt2(), term_to_smt2(body)
        );
        self.declarations.push(decl);
    }
}

