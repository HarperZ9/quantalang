// CVC5 SOLVER
// ═══════════════════════════════════════════════════════════════════════════════

/// CVC5 solver implementation
pub struct Cvc5Solver {
    assertions: Vec<String>,
    declarations: Vec<String>,
    scope_stack: Vec<usize>,
    options: BTreeMap<String, String>,
    last_result: Option<SolverResult>,
    cvc5_path: String,
}

impl Cvc5Solver {
    pub fn new() -> Self {
        Cvc5Solver {
            assertions: Vec::new(),
            declarations: Vec::new(),
            scope_stack: Vec::new(),
            options: BTreeMap::new(),
            last_result: None,
            cvc5_path: "cvc5".to_string(),
        }
    }
}

impl Default for Cvc5Solver {
    fn default() -> Self {
        Self::new()
    }
}

impl Solver for Cvc5Solver {
    fn name(&self) -> &str { "cvc5" }
    
    fn push(&mut self) {
        self.scope_stack.push(self.assertions.len());
    }
    
    fn pop(&mut self) {
        if let Some(size) = self.scope_stack.pop() {
            self.assertions.truncate(size);
        }
    }
    
    fn assert(&mut self, formula: &Formula) {
        let smt2 = formula_to_smt2(formula);
        self.assertions.push(smt2);
    }
    
    fn assert_named(&mut self, name: &str, formula: &Formula) {
        let smt2 = formula_to_smt2(formula);
        self.assertions.push(format!("(! {} :named {})", smt2, name));
    }
    
    fn check_sat(&mut self) -> SolverResult {
        SolverResult::Unknown("CVC5 not available".to_string())
    }
    
    fn check_sat_timeout(&mut self, _timeout: Duration) -> SolverResult {
        self.check_sat()
    }
    
    fn get_model(&self) -> Option<Model> { None }
    
    fn get_unsat_core(&self) -> Option<UnsatCore> { None }
    
    fn reset(&mut self) {
        self.assertions.clear();
        self.declarations.clear();
        self.scope_stack.clear();
        self.last_result = None;
    }
    
    fn set_option(&mut self, name: &str, value: &str) {
        self.options.insert(name.to_string(), value.to_string());
    }
    
    fn declare(&mut self, name: &str, sort: &Sort) {
        self.declarations.push(format!("(declare-const {} {})", name, sort.to_smt2()));
    }
    
    fn declare_fun(&mut self, name: &str, params: &[Sort], result: &Sort) {
        let params_str: Vec<String> = params.iter().map(|s| s.to_smt2()).collect();
        self.declarations.push(format!(
            "(declare-fun {} ({}) {})",
            name, params_str.join(" "), result.to_smt2()
        ));
    }
    
    fn define_fun(&mut self, name: &str, params: &[(String, Sort)], result: &Sort, body: &Term) {
        let params_str: Vec<String> = params.iter()
            .map(|(n, s)| format!("({} {})", n, s.to_smt2()))
            .collect();
        self.declarations.push(format!(
            "(define-fun {} ({}) {} {})",
            name, params_str.join(" "), result.to_smt2(), term_to_smt2(body)
        ));
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// SOLVER POOL
// ═══════════════════════════════════════════════════════════════════════════════

/// Solver pool for parallel verification
pub struct SolverPool {
    solvers: Vec<Box<dyn Solver>>,
    strategy: SolverStrategy,
}

#[derive(Debug, Clone, Copy, PartialEq, Eq)]
pub enum SolverStrategy {
    /// Use first solver
    First,
    /// Round-robin
    RoundRobin,
    /// Race all solvers
    Race,
    /// Portfolio (different configurations)
    Portfolio,
}

impl SolverPool {
    pub fn new() -> Self {
        SolverPool {
            solvers: Vec::new(),
            strategy: SolverStrategy::First,
        }
    }
    
    pub fn add_solver(&mut self, solver: Box<dyn Solver>) {
        self.solvers.push(solver);
    }
    
    pub fn with_strategy(mut self, strategy: SolverStrategy) -> Self {
        self.strategy = strategy;
        self
    }
    
    /// Check VC using pool
    pub fn check(&mut self, vc: &VerificationCondition) -> SolverResult {
        if self.solvers.is_empty() {
            return SolverResult::Error("No solvers available".to_string());
        }
        
        match self.strategy {
            SolverStrategy::First => {
                let solver = &mut self.solvers[0];
                solver.reset();
                
                // Add assumptions
                for assumption in &vc.assumptions {
                    solver.assert(assumption);
                }
                
                // Negate goal
                solver.assert(&vc.goal.clone().not());
                
                // Check: if UNSAT, the VC is valid
                match solver.check_sat() {
                    SolverResult::Unsat(core) => SolverResult::Unsat(core),
                    SolverResult::Sat(model) => SolverResult::Sat(model),
                    SolverResult::Unknown(msg) => SolverResult::Unknown(msg),
                    SolverResult::Error(msg) => SolverResult::Error(msg),
                }
            }
            _ => {
                // Other strategies would be implemented similarly
                SolverResult::Unknown("Strategy not implemented".to_string())
            }
        }
    }
}

impl Default for SolverPool {
    fn default() -> Self {
        Self::new()
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// SMT-LIB2 CONVERSION (duplicated from core for independence)
// ═══════════════════════════════════════════════════════════════════════════════

fn formula_to_smt2(formula: &Formula) -> String {
    match formula {
        Formula::True => "true".to_string(),
        Formula::False => "false".to_string(),
        Formula::Var(v) => v.clone(),
        Formula::Eq(l, r) => format!("(= {} {})", term_to_smt2(l), term_to_smt2(r)),
        Formula::Ne(l, r) => format!("(distinct {} {})", term_to_smt2(l), term_to_smt2(r)),
        Formula::Lt(l, r) => format!("(< {} {})", term_to_smt2(l), term_to_smt2(r)),
        Formula::Le(l, r) => format!("(<= {} {})", term_to_smt2(l), term_to_smt2(r)),
        Formula::Gt(l, r) => format!("(> {} {})", term_to_smt2(l), term_to_smt2(r)),
        Formula::Ge(l, r) => format!("(>= {} {})", term_to_smt2(l), term_to_smt2(r)),
        Formula::Not(f) => format!("(not {})", formula_to_smt2(f)),
        Formula::And(l, r) => format!("(and {} {})", formula_to_smt2(l), formula_to_smt2(r)),
        Formula::Or(l, r) => format!("(or {} {})", formula_to_smt2(l), formula_to_smt2(r)),
        Formula::Implies(l, r) => format!("(=> {} {})", formula_to_smt2(l), formula_to_smt2(r)),
        Formula::Iff(l, r) => format!("(= {} {})", formula_to_smt2(l), formula_to_smt2(r)),
        Formula::Forall(v, s, body) => {
            format!("(forall (({} {})) {})", v, s.to_smt2(), formula_to_smt2(body))
        }
        Formula::Exists(v, s, body) => {
            format!("(exists (({} {})) {})", v, s.to_smt2(), formula_to_smt2(body))
        }
        Formula::ArraySelect(arr, idx) => {
            format!("(select {} {})", term_to_smt2(arr), term_to_smt2(idx))
        }
        Formula::InRange(x, lo, hi) => {
            format!("(and (>= {} {}) (< {} {}))",
                term_to_smt2(x), term_to_smt2(lo),
                term_to_smt2(x), term_to_smt2(hi))
        }
        Formula::Divisible(x, y) => {
            format!("(= (mod {} {}) 0)", term_to_smt2(x), term_to_smt2(y))
        }
        Formula::BitAnd(x, y, z) => {
            format!("(= (bvand {} {}) {})",
                term_to_smt2(x), term_to_smt2(y), term_to_smt2(z))
        }
        Formula::App(name, args) => {
            if args.is_empty() {
                name.clone()
            } else {
                let args_str: Vec<String> = args.iter().map(|a| term_to_smt2(a)).collect();
                format!("({} {})", name, args_str.join(" "))
            }
        }
    }
}

fn term_to_smt2(term: &Term) -> String {
    match term {
        Term::Var(v) => v.clone(),
        Term::IntConst(n) => {
            if *n >= 0 {
                n.to_string()
            } else {
                format!("(- {})", -n)
            }
        }
        Term::BoolConst(b) => if *b { "true" } else { "false" }.to_string(),
        Term::RealConst(r) => format!("{:.15}", r),
        Term::Add(l, r) => format!("(+ {} {})", term_to_smt2(l), term_to_smt2(r)),
        Term::Sub(l, r) => format!("(- {} {})", term_to_smt2(l), term_to_smt2(r)),
        Term::Mul(l, r) => format!("(* {} {})", term_to_smt2(l), term_to_smt2(r)),
        Term::Div(l, r) => format!("(div {} {})", term_to_smt2(l), term_to_smt2(r)),
        Term::Mod(l, r) => format!("(mod {} {})", term_to_smt2(l), term_to_smt2(r)),
        Term::Neg(t) => format!("(- {})", term_to_smt2(t)),
        Term::BitAnd(l, r) => format!("(bvand {} {})", term_to_smt2(l), term_to_smt2(r)),
        Term::BitOr(l, r) => format!("(bvor {} {})", term_to_smt2(l), term_to_smt2(r)),
        Term::BitXor(l, r) => format!("(bvxor {} {})", term_to_smt2(l), term_to_smt2(r)),
        Term::BitNot(t) => format!("(bvnot {})", term_to_smt2(t)),
        Term::Shl(l, r) => format!("(bvshl {} {})", term_to_smt2(l), term_to_smt2(r)),
        Term::Shr(l, r) => format!("(bvlshr {} {})", term_to_smt2(l), term_to_smt2(r)),
        Term::Ite(c, t, e) => {
            format!("(ite {} {} {})", formula_to_smt2(c), term_to_smt2(t), term_to_smt2(e))
        }
        Term::Select(arr, idx) => format!("(select {} {})", term_to_smt2(arr), term_to_smt2(idx)),
        Term::Store(arr, idx, val) => {
            format!("(store {} {} {})", term_to_smt2(arr), term_to_smt2(idx), term_to_smt2(val))
        }
        Term::App(name, args) => {
            if args.is_empty() {
                name.clone()
            } else {
                let args_str: Vec<String> = args.iter().map(|a| term_to_smt2(a)).collect();
                format!("({} {})", name, args_str.join(" "))
            }
        }
        Term::Old(t) => format!("old_{}", term_to_smt2(t)),
        Term::Result => "result".to_string(),
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// TESTS
// ═══════════════════════════════════════════════════════════════════════════════

#[cfg(test)]
mod tests {
    use super::*;
    
    #[test]
    fn test_z3_solver_new() {
        let solver = Z3Solver::new();
        assert_eq!(solver.name(), "z3");
    }
    
    #[test]
    fn test_solver_push_pop() {
        let mut solver = Z3Solver::new();
        
        solver.assert(&Formula::True);
        solver.push();
        solver.assert(&Formula::False);
        assert_eq!(solver.assertions.len(), 2);
        
        solver.pop();
        assert_eq!(solver.assertions.len(), 1);
    }
    
    #[test]
    fn test_declare() {
        let mut solver = Z3Solver::new();
        solver.declare("x", &Sort::Int);
        
        assert!(solver.declarations[0].contains("declare-const x Int"));
    }
    
    #[test]
    fn test_model_evaluate() {
        let mut model = Model::new();
        model.assignments.insert("x".to_string(), ModelValue::Int(5));
        model.assignments.insert("y".to_string(), ModelValue::Int(3));
        
        let term = Term::Add(
            Box::new(Term::Var("x".to_string())),
            Box::new(Term::Var("y".to_string())),
        );
        
        let result = model.evaluate(&term);
        assert_eq!(result, Some(ModelValue::Int(8)));
    }
    
    #[test]
    fn test_solver_pool() {
        let mut pool = SolverPool::new();
        pool.add_solver(Box::new(Z3Solver::new()));
        
        assert_eq!(pool.solvers.len(), 1);
    }
}
