module quantalang::build::executor

use alloc::string::String;
use alloc::vec::Vec;
use alloc::sync::Arc;
use alloc::collections::BTreeMap;
use std::path::{Path, PathBuf};
use std::sync::{Mutex, mpsc};
use std::thread;
use std::time::{Duration, Instant};
use std::io;
use crate::build::config::BuildConfig;
use crate::build::graph::{DependencyGraph, Unit, UnitId, CycleError};
use crate::build::cache::{BuildCache, Fingerprint};
use crate::build::compiler::{CompilerInvocation, CompileResult, CompileProcess};

// ═══════════════════════════════════════════════════════════════════════════════
// BUILD EXECUTOR
// ═══════════════════════════════════════════════════════════════════════════════

/// Build execution engine
pub struct BuildExecutor {
    config: BuildConfig,
    cache: BuildCache,
    progress: BuildProgress,
}

impl BuildExecutor {
    /// Create new executor with configuration
    pub fn new(config: BuildConfig, cache_dir: &Path) -> io::Result<Self> {
        Ok(BuildExecutor {
            config,
            cache: BuildCache::new(cache_dir)?,
            progress: BuildProgress::new(),
        })
    }
    
    /// Execute build for dependency graph
    pub fn execute(&mut self, graph: &mut DependencyGraph) -> BuildResult {
        let start = Instant::now();
        
        // Compute build order
        let order = match graph.topological_order() {
            Ok(order) => order.to_vec(),
            Err(e) => {
                return BuildResult {
                    success: false,
                    built: Vec::new(),
                    cached: Vec::new(),
                    failed: Vec::new(),
                    duration: start.elapsed(),
                    errors: vec![BuildError::Cycle(e)],
                };
            }
        };
        
        // Initialize progress
        self.progress.total = order.len();
        self.progress.start_time = Some(Instant::now());
        
        // Determine what needs to be built
        let mut to_build = Vec::new();
        let mut cached = Vec::new();
        let mut fingerprints: BTreeMap<UnitId, u64> = BTreeMap::new();
        
        for id in &order {
            let unit = match graph.get_unit(id) {
                Some(u) => u,
                None => continue,
            };
            
            // Get dependency fingerprints
            let dep_fps: Vec<u64> = unit.dependencies.iter()
                .filter_map(|d| fingerprints.get(d).copied())
                .collect();
            
            // Check if fresh
            if self.cache.is_fresh(unit, &self.config, &dep_fps) {
                // Use cached fingerprint
                if let Some(fp) = self.cache.get_fingerprint(id) {
                    fingerprints.insert(id.clone(), fp.hash);
                    cached.push(id.clone());
                    self.progress.cached += 1;
                    continue;
                }
            }
            
            to_build.push(id.clone());
        }
        
        // Build using parallel or sequential execution
        let (built, failed, errors) = if self.config.jobs > 1 {
            self.execute_parallel(graph, &to_build, &mut fingerprints)
        } else {
            self.execute_sequential(graph, &to_build, &mut fingerprints)
        };
        
        BuildResult {
            success: failed.is_empty() && errors.is_empty(),
            built,
            cached,
            failed,
            duration: start.elapsed(),
            errors,
        }
    }
    
    /// Sequential execution
    fn execute_sequential(
        &mut self,
        graph: &DependencyGraph,
        to_build: &[UnitId],
        fingerprints: &mut BTreeMap<UnitId, u64>,
    ) -> (Vec<UnitId>, Vec<UnitId>, Vec<BuildError>) {
        let mut built = Vec::new();
        let mut failed = Vec::new();
        let mut errors = Vec::new();
        
        for id in to_build {
            let unit = match graph.get_unit(id) {
                Some(u) => u,
                None => continue,
            };
            
            // Report progress
            self.progress.current = built.len() + failed.len() + 1;
            self.progress.current_unit = Some(id.display_name());
            self.report_progress();
            
            // Check if dependencies failed
            let deps_ok = unit.dependencies.iter()
                .all(|d| !failed.contains(d));
            
            if !deps_ok {
                failed.push(id.clone());
                errors.push(BuildError::DependencyFailed(id.clone()));
                continue;
            }
            
            // Build the unit
            match self.build_unit(unit, fingerprints) {
                Ok(fp) => {
                    fingerprints.insert(id.clone(), fp.hash);
                    let _ = self.cache.store_fingerprint(id, fp);
                    built.push(id.clone());
                    self.progress.completed += 1;
                }
                Err(e) => {
                    failed.push(id.clone());
                    errors.push(e);
                    self.progress.failed += 1;
                    
                    // Stop on first failure unless configured otherwise
                    if !self.config.verbose {
                        break;
                    }
                }
            }
        }
        
        (built, failed, errors)
    }
    
    /// Parallel execution
    fn execute_parallel(
        &mut self,
        graph: &DependencyGraph,
        to_build: &[UnitId],
        fingerprints: &mut BTreeMap<UnitId, u64>,
    ) -> (Vec<UnitId>, Vec<UnitId>, Vec<BuildError>) {
        let mut built = Vec::new();
        let mut failed = Vec::new();
        let mut errors = Vec::new();
        
        // Track which units are ready to build
        let mut pending: BTreeMap<UnitId, PendingUnit> = BTreeMap::new();
        let mut in_progress: BTreeMap<UnitId, CompileProcess> = BTreeMap::new();
        
        // Initialize pending set
        for id in to_build {
            if let Some(unit) = graph.get_unit(id) {
                let deps_needed: Vec<_> = unit.dependencies.iter()
                    .filter(|d| to_build.contains(d))
                    .cloned()
                    .collect();
                
                pending.insert(id.clone(), PendingUnit {
                    unit: unit.clone(),
                    deps_remaining: deps_needed,
                });
            }
        }
        
        // Process until everything is done
        while !pending.is_empty() || !in_progress.is_empty() {
            // Start new jobs if slots available
            while in_progress.len() < self.config.jobs && !pending.is_empty() {
                // Find a unit ready to build (no pending deps)
                let ready = pending.iter()
                    .find(|(_, p)| p.deps_remaining.is_empty())
                    .map(|(id, _)| id.clone());
                
                match ready {
                    Some(id) => {
                        let pending_unit = pending.remove(&id).unwrap();
                        
                        // Check if deps failed
                        if pending_unit.deps_remaining.iter().any(|d| failed.contains(d)) {
                            failed.push(id.clone());
                            errors.push(BuildError::DependencyFailed(id));
                            continue;
                        }
                        
                        // Start compilation
                        let inv = CompilerInvocation::from_unit(&pending_unit.unit, &self.config);
                        
                        match inv.spawn() {
                            Ok(process) => {
                                in_progress.insert(id, process);
                            }
                            Err(e) => {
                                failed.push(id.clone());
                                errors.push(BuildError::Spawn(id, e.to_string()));
                            }
                        }
                    }
                    None => break, // No ready units, wait for running ones
                }
            }
            
            // Wait for any process to complete
            if !in_progress.is_empty() {
                // Poll all processes
                let mut completed = Vec::new();
                
                for (id, process) in in_progress.iter_mut() {
                    if let Ok(Some(_)) = process.try_wait() {
                        completed.push(id.clone());
                    }
                }
                
                // Process completed jobs
                for id in completed {
                    let process = in_progress.remove(&id).unwrap();
                    let result = process.wait();
                    
                    if result.success {
                        // Create fingerprint
                        if let Some(unit) = graph.get_unit(&id) {
                            let dep_fps: Vec<u64> = unit.dependencies.iter()
                                .filter_map(|d| fingerprints.get(d).copied())
                                .collect();
                            
                            let fp = Fingerprint::for_unit(unit, &self.config, &dep_fps);
                            fingerprints.insert(id.clone(), fp.hash);
                            let _ = self.cache.store_fingerprint(&id, fp);
                        }
                        
                        built.push(id.clone());
                        self.progress.completed += 1;
                        
                        // Update pending deps
                        for (_, p) in pending.iter_mut() {
                            p.deps_remaining.retain(|d| d != &id);
                        }
                    } else {
                        failed.push(id.clone());
                        errors.push(BuildError::Compilation(id.clone(), result));
                        self.progress.failed += 1;
                    }
                    
                    self.report_progress();
                }
                
                // Small sleep to avoid busy waiting
                if in_progress.len() > 0 {
                    thread::sleep(Duration::from_millis(10));
                }
            }
            
            // Check for deadlock (no progress possible)
            if in_progress.is_empty() && !pending.is_empty() {
                let first = pending.keys().next().unwrap().clone();
                errors.push(BuildError::Deadlock(first));
                break;
            }
        }
        
        (built, failed, errors)
    }
    
    /// Build a single unit
    fn build_unit(
        &self,
        unit: &Unit,
        fingerprints: &BTreeMap<UnitId, u64>,
    ) -> Result<Fingerprint, BuildError> {
        let inv = CompilerInvocation::from_unit(unit, &self.config);
        let result = inv.execute();
        
        if result.success {
            let dep_fps: Vec<u64> = unit.dependencies.iter()
                .filter_map(|d| fingerprints.get(d).copied())
                .collect();
            
            Ok(Fingerprint::for_unit(unit, &self.config, &dep_fps))
        } else {
            Err(BuildError::Compilation(unit.id.clone(), result))
        }
    }
    
    /// Report build progress
    fn report_progress(&self) {
        if let Some(cb) = &self.progress.callback {
            cb(&self.progress);
        }
    }
    
    /// Set progress callback
    pub fn on_progress<F>(&mut self, callback: F)
    where
        F: Fn(&BuildProgress) + Send + Sync + 'static,
    {
        self.progress.callback = Some(Box::new(callback));
    }
    
    /// Get cache statistics
    pub fn cache_stats(&self) -> &crate::build::cache::CacheStats {
        self.cache.stats()
    }
}

struct PendingUnit {
    unit: Unit,
    deps_remaining: Vec<UnitId>,
}

// ═══════════════════════════════════════════════════════════════════════════════
// BUILD RESULT
// ═══════════════════════════════════════════════════════════════════════════════

/// Result of a build execution
#[derive(Debug)]
pub struct BuildResult {
    /// Overall success
    pub success: bool,
    
    /// Units that were built
    pub built: Vec<UnitId>,
    
    /// Units that were cached (not rebuilt)
    pub cached: Vec<UnitId>,
    
    /// Units that failed
    pub failed: Vec<UnitId>,
    
    /// Total duration
    pub duration: Duration,
    
    /// Errors encountered
    pub errors: Vec<BuildError>,
}

impl BuildResult {
    /// Get summary string
    pub fn summary(&self) -> String {
        if self.success {
            format!(
                "Finished in {:.2}s: {} built, {} cached",
                self.duration.as_secs_f64(),
                self.built.len(),
                self.cached.len()
            )
        } else {
            format!(
                "Build failed in {:.2}s: {} errors",
                self.duration.as_secs_f64(),
                self.errors.len()
            )
        }
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// BUILD ERROR
// ═══════════════════════════════════════════════════════════════════════════════

/// Build error types
#[derive(Debug)]
pub enum BuildError {
    /// Dependency cycle detected
    Cycle(CycleError),
    
    /// Compilation failed
    Compilation(UnitId, CompileResult),
    
    /// Dependency failed
    DependencyFailed(UnitId),
    
    /// Failed to spawn compiler
    Spawn(UnitId, String),
    
    /// Deadlock in parallel build
    Deadlock(UnitId),
    
    /// I/O error
    Io(String),
}

impl std::fmt::Display for BuildError {
    fn fmt(&self, f: &mut std::fmt::Formatter<'_>) -> std::fmt::Result {
        match self {
            BuildError::Cycle(e) => write!(f, "{}", e),
            BuildError::Compilation(id, result) => {
                write!(f, "compilation failed: {}\n{}", id.display_name(), result.stderr)
            }
            BuildError::DependencyFailed(id) => {
                write!(f, "dependency failed: {}", id.display_name())
            }
            BuildError::Spawn(id, msg) => {
                write!(f, "failed to spawn compiler for {}: {}", id.display_name(), msg)
            }
            BuildError::Deadlock(id) => {
                write!(f, "deadlock detected at {}", id.display_name())
            }
            BuildError::Io(msg) => write!(f, "I/O error: {}", msg),
        }
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// BUILD PROGRESS
// ═══════════════════════════════════════════════════════════════════════════════

/// Build progress tracking
pub struct BuildProgress {
    /// Total units to build
    pub total: usize,
    
    /// Current unit index
    pub current: usize,
    
    /// Units completed
    pub completed: usize,
    
    /// Units cached
    pub cached: usize,
    
    /// Units failed
    pub failed: usize,
    
    /// Current unit name
    pub current_unit: Option<String>,
    
    /// Start time
    pub start_time: Option<Instant>,
    
    /// Progress callback
    callback: Option<Box<dyn Fn(&BuildProgress) + Send + Sync>>,
}

impl BuildProgress {
    fn new() -> Self {
        BuildProgress {
            total: 0,
            current: 0,
            completed: 0,
            cached: 0,
            failed: 0,
            current_unit: None,
            start_time: None,
            callback: None,
        }
    }
    
    /// Get progress percentage
    pub fn percentage(&self) -> f64 {
        if self.total == 0 {
            100.0
        } else {
            ((self.completed + self.cached + self.failed) as f64 / self.total as f64) * 100.0
        }
    }
    
    /// Get elapsed time
    pub fn elapsed(&self) -> Duration {
        self.start_time
            .map(|t| t.elapsed())
            .unwrap_or(Duration::ZERO)
    }
    
    /// Get estimated remaining time
    pub fn eta(&self) -> Option<Duration> {
        let elapsed = self.elapsed();
        let done = self.completed + self.cached + self.failed;
        
        if done == 0 {
            return None;
        }
        
        let remaining = self.total - done;
        let rate = elapsed.as_secs_f64() / done as f64;
        
        Some(Duration::from_secs_f64(rate * remaining as f64))
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// JOB QUEUE
// ═══════════════════════════════════════════════════════════════════════════════

/// Job queue for parallel builds
pub struct JobQueue {
    pending: Vec<Job>,
    running: Vec<(UnitId, CompileProcess)>,
    max_jobs: usize,
}

impl JobQueue {
    pub fn new(max_jobs: usize) -> Self {
        JobQueue {
            pending: Vec::new(),
            running: Vec::new(),
            max_jobs,
        }
    }
    
    /// Add a job to the queue
    pub fn push(&mut self, job: Job) {
        self.pending.push(job);
    }
    
    /// Get number of running jobs
    pub fn running_count(&self) -> usize {
        self.running.len()
    }
    
    /// Get number of pending jobs
    pub fn pending_count(&self) -> usize {
        self.pending.len()
    }
    
    /// Check if queue is empty
    pub fn is_empty(&self) -> bool {
        self.pending.is_empty() && self.running.is_empty()
    }
    
    /// Can start more jobs
    pub fn can_start(&self) -> bool {
        self.running.len() < self.max_jobs && !self.pending.is_empty()
    }
}

/// A build job
pub struct Job {
    pub id: UnitId,
    pub unit: Unit,
    pub priority: i32,
}

// ═══════════════════════════════════════════════════════════════════════════════
// BUILDER PATTERN
// ═══════════════════════════════════════════════════════════════════════════════

/// Build configuration builder
pub struct BuildExecutorBuilder {
    config: BuildConfig,
    cache_dir: Option<PathBuf>,
}

impl BuildExecutorBuilder {
    pub fn new() -> Self {
        BuildExecutorBuilder {
            config: BuildConfig::default(),
            cache_dir: None,
        }
    }
    
    pub fn config(mut self, config: BuildConfig) -> Self {
        self.config = config;
        self
    }
    
    pub fn jobs(mut self, jobs: usize) -> Self {
        self.config.jobs = jobs;
        self
    }
    
    pub fn cache_dir(mut self, dir: &Path) -> Self {
        self.cache_dir = Some(dir.to_path_buf());
        self
    }
    
    pub fn verbose(mut self, verbose: bool) -> Self {
        self.config.verbose = verbose;
        self
    }
    
    pub fn build(self) -> io::Result<BuildExecutor> {
        let cache_dir = self.cache_dir
            .unwrap_or_else(|| self.config.target_dir.join(".cache"));
        
        BuildExecutor::new(self.config, &cache_dir)
    }
}

impl Default for BuildExecutorBuilder {
    fn default() -> Self {
        Self::new()
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// TESTS
// ═══════════════════════════════════════════════════════════════════════════════

#[cfg(test)]
mod tests {
    use super::*;
    use crate::build::graph::{Unit, UnitKind};
    
    fn make_unit(name: &str) -> Unit {
        let id = UnitId::new(name, "1.0.0", name, UnitKind::Lib, "dev", "x86_64", vec![]);
        Unit::new(id)
    }
    
    #[test]
    fn test_progress() {
        let mut progress = BuildProgress::new();
        progress.total = 10;
        progress.completed = 5;
        
        assert_eq!(progress.percentage(), 50.0);
    }
    
    #[test]
    fn test_job_queue() {
        let mut queue = JobQueue::new(4);
        
        assert!(queue.is_empty());
        assert!(!queue.can_start());
        
        queue.push(Job {
            id: UnitId::new("test", "1.0.0", "test", UnitKind::Lib, "dev", "x86_64", vec![]),
            unit: make_unit("test"),
            priority: 0,
        });
        
        assert!(!queue.is_empty());
        assert!(queue.can_start());
    }
}
