module quantalang::build::config

use alloc::string::String;
use alloc::vec::Vec;
use alloc::collections::{BTreeMap, BTreeSet};
use std::path::PathBuf;
use core::time::Duration;

// ═══════════════════════════════════════════════════════════════════════════════
// BUILD CONFIGURATION
// ═══════════════════════════════════════════════════════════════════════════════

/// Complete build configuration
#[derive(Debug, Clone)]
pub struct BuildConfig {
    /// Build profile
    pub profile: Profile,
    
    /// Target triple
    pub target: TargetTriple,
    
    /// Output directory
    pub target_dir: PathBuf,
    
    /// Number of parallel jobs
    pub jobs: usize,
    
    /// Features to enable
    pub features: BTreeSet<String>,
    
    /// Enable all features
    pub all_features: bool,
    
    /// Disable default features
    pub no_default_features: bool,
    
    /// Verbose output
    pub verbose: bool,
    
    /// Color output
    pub color: ColorChoice,
    
    /// Message format
    pub message_format: MessageFormat,
    
    /// Build timings
    pub timings: bool,
    
    /// Future incompat report
    pub future_incompat_report: bool,
    
    /// Build mode
    pub mode: BuildMode,
    
    /// Incremental compilation
    pub incremental: bool,
    
    /// Codegen units
    pub codegen_units: Option<usize>,
    
    /// Extra compiler flags
    pub extra_flags: Vec<String>,
    
    /// Environment variables
    pub env: BTreeMap<String, String>,
}

impl Default for BuildConfig {
    fn default() -> Self {
        BuildConfig {
            profile: Profile::default(),
            target: TargetTriple::host(),
            target_dir: PathBuf::from("target"),
            jobs: num_cpus(),
            features: BTreeSet::new(),
            all_features: false,
            no_default_features: false,
            verbose: false,
            color: ColorChoice::Auto,
            message_format: MessageFormat::Human,
            timings: false,
            future_incompat_report: false,
            mode: BuildMode::Build,
            incremental: true,
            codegen_units: None,
            extra_flags: Vec::new(),
            env: BTreeMap::new(),
        }
    }
}

impl BuildConfig {
    /// Get output directory for profile
    pub fn output_dir(&self) -> PathBuf {
        let profile_dir = match self.profile.name.as_str() {
            "dev" | "debug" => "debug",
            "release" => "release",
            name => name,
        };
        
        if self.target.is_host() {
            self.target_dir.join(profile_dir)
        } else {
            self.target_dir.join(self.target.triple()).join(profile_dir)
        }
    }
    
    /// Get deps directory
    pub fn deps_dir(&self) -> PathBuf {
        self.output_dir().join("deps")
    }
    
    /// Get incremental directory
    pub fn incremental_dir(&self) -> PathBuf {
        self.output_dir().join("incremental")
    }
    
    /// Get build directory
    pub fn build_dir(&self) -> PathBuf {
        self.output_dir().join("build")
    }
    
    /// Get examples directory
    pub fn examples_dir(&self) -> PathBuf {
        self.output_dir().join("examples")
    }
}

#[derive(Debug, Clone, Copy, PartialEq, Eq)]
pub enum ColorChoice {
    Auto,
    Always,
    Never,
}

#[derive(Debug, Clone, Copy, PartialEq, Eq)]
pub enum MessageFormat {
    Human,
    Short,
    Json,
    JsonDiagnosticShort,
    JsonDiagnosticRendered,
    JsonRenderDiagnostics,
}

#[derive(Debug, Clone, Copy, PartialEq, Eq)]
pub enum BuildMode {
    Build,
    Check,
    Doc,
    Test,
    Bench,
    Run,
    Clippy,
    Fix,
}

// ═══════════════════════════════════════════════════════════════════════════════
// PROFILE
// ═══════════════════════════════════════════════════════════════════════════════

/// Build profile (dev, release, etc.)
#[derive(Debug, Clone)]
pub struct Profile {
    /// Profile name
    pub name: String,
    
    /// Optimization level
    pub opt_level: OptLevel,
    
    /// Debug info level
    pub debug: DebugInfo,
    
    /// Split debug info
    pub split_debuginfo: SplitDebugInfo,
    
    /// Debug assertions
    pub debug_assertions: bool,
    
    /// Overflow checks
    pub overflow_checks: bool,
    
    /// Link-time optimization
    pub lto: Lto,
    
    /// Panic strategy
    pub panic: PanicStrategy,
    
    /// Incremental compilation
    pub incremental: bool,
    
    /// Codegen units
    pub codegen_units: Option<usize>,
    
    /// Runtime library path
    pub rpath: bool,
    
    /// Strip symbols
    pub strip: Strip,
}

impl Default for Profile {
    fn default() -> Self {
        Profile::dev()
    }
}

impl Profile {
    /// Development profile (fast compile, slow run)
    pub fn dev() -> Self {
        Profile {
            name: "dev".to_string(),
            opt_level: OptLevel::O0,
            debug: DebugInfo::Full,
            split_debuginfo: SplitDebugInfo::default_for_platform(),
            debug_assertions: true,
            overflow_checks: true,
            lto: Lto::Off,
            panic: PanicStrategy::Unwind,
            incremental: true,
            codegen_units: Some(256),
            rpath: false,
            strip: Strip::None,
        }
    }
    
    /// Release profile (slow compile, fast run)
    pub fn release() -> Self {
        Profile {
            name: "release".to_string(),
            opt_level: OptLevel::O3,
            debug: DebugInfo::None,
            split_debuginfo: SplitDebugInfo::Off,
            debug_assertions: false,
            overflow_checks: false,
            lto: Lto::Off,
            panic: PanicStrategy::Unwind,
            incremental: false,
            codegen_units: Some(16),
            rpath: false,
            strip: Strip::None,
        }
    }
    
    /// Test profile
    pub fn test() -> Self {
        let mut profile = Self::dev();
        profile.name = "test".to_string();
        profile
    }
    
    /// Bench profile
    pub fn bench() -> Self {
        let mut profile = Self::release();
        profile.name = "bench".to_string();
        profile.debug = DebugInfo::Full;
        profile
    }
    
    /// Custom profile
    pub fn custom(name: &str) -> Self {
        Profile {
            name: name.to_string(),
            ..Self::dev()
        }
    }
}

#[derive(Debug, Clone, Copy, PartialEq, Eq)]
pub enum OptLevel {
    O0,     // No optimization
    O1,     // Basic optimization
    O2,     // Standard optimization
    O3,     // Aggressive optimization
    Os,     // Size optimization
    Oz,     // Aggressive size optimization
}

impl OptLevel {
    pub fn as_str(&self) -> &'static str {
        match self {
            OptLevel::O0 => "0",
            OptLevel::O1 => "1",
            OptLevel::O2 => "2",
            OptLevel::O3 => "3",
            OptLevel::Os => "s",
            OptLevel::Oz => "z",
        }
    }
    
    pub fn from_str(s: &str) -> Option<Self> {
        match s {
            "0" => Some(OptLevel::O0),
            "1" => Some(OptLevel::O1),
            "2" => Some(OptLevel::O2),
            "3" => Some(OptLevel::O3),
            "s" => Some(OptLevel::Os),
            "z" => Some(OptLevel::Oz),
            _ => None,
        }
    }
}

#[derive(Debug, Clone, Copy, PartialEq, Eq)]
pub enum DebugInfo {
    None,
    LineDirectivesOnly,
    LineTablesOnly,
    Limited,
    Full,
}

impl DebugInfo {
    pub fn from_bool(b: bool) -> Self {
        if b { DebugInfo::Full } else { DebugInfo::None }
    }
    
    pub fn from_int(n: u32) -> Self {
        match n {
            0 => DebugInfo::None,
            1 => DebugInfo::Limited,
            2 | _ => DebugInfo::Full,
        }
    }
}

#[derive(Debug, Clone, Copy, PartialEq, Eq)]
pub enum SplitDebugInfo {
    Off,
    Packed,
    Unpacked,
}

impl SplitDebugInfo {
    pub fn default_for_platform() -> Self {
        #[cfg(target_os = "macos")]
        { SplitDebugInfo::Unpacked }
        
        #[cfg(not(target_os = "macos"))]
        { SplitDebugInfo::Off }
    }
}

#[derive(Debug, Clone, Copy, PartialEq, Eq)]
pub enum Lto {
    Off,
    Thin,
    Fat,
}

impl Lto {
    pub fn from_str(s: &str) -> Option<Self> {
        match s.to_lowercase().as_str() {
            "off" | "false" | "no" => Some(Lto::Off),
            "thin" => Some(Lto::Thin),
            "fat" | "true" | "yes" | "on" => Some(Lto::Fat),
            _ => None,
        }
    }
}

#[derive(Debug, Clone, Copy, PartialEq, Eq)]
pub enum PanicStrategy {
    Unwind,
    Abort,
}

impl PanicStrategy {
    pub fn from_str(s: &str) -> Option<Self> {
        match s.to_lowercase().as_str() {
            "unwind" => Some(PanicStrategy::Unwind),
            "abort" => Some(PanicStrategy::Abort),
            _ => None,
        }
    }
}

#[derive(Debug, Clone, Copy, PartialEq, Eq)]
pub enum Strip {
    None,
    Debuginfo,
    Symbols,
}

impl Strip {
    pub fn from_str(s: &str) -> Option<Self> {
        match s.to_lowercase().as_str() {
            "none" | "false" => Some(Strip::None),
            "debuginfo" => Some(Strip::Debuginfo),
            "symbols" | "true" => Some(Strip::Symbols),
            _ => None,
        }
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// TARGET TRIPLE
// ═══════════════════════════════════════════════════════════════════════════════

/// Target triple (arch-vendor-os-env)
#[derive(Debug, Clone, PartialEq, Eq)]
pub struct TargetTriple {
    /// Full triple string
    triple: String,
    
    /// Architecture
    pub arch: Architecture,
    
    /// Vendor
    pub vendor: String,
    
    /// Operating system
    pub os: OperatingSystem,
    
    /// Environment/ABI
    pub env: String,
}

impl TargetTriple {
    /// Get host target
    pub fn host() -> Self {
        #[cfg(all(target_arch = "x86_64", target_os = "linux", target_env = "gnu"))]
        { Self::from_str("x86_64-unknown-linux-gnu").unwrap() }
        
        #[cfg(all(target_arch = "x86_64", target_os = "linux", target_env = "musl"))]
        { Self::from_str("x86_64-unknown-linux-musl").unwrap() }
        
        #[cfg(all(target_arch = "x86_64", target_os = "macos"))]
        { Self::from_str("x86_64-apple-darwin").unwrap() }
        
        #[cfg(all(target_arch = "aarch64", target_os = "macos"))]
        { Self::from_str("aarch64-apple-darwin").unwrap() }
        
        #[cfg(all(target_arch = "x86_64", target_os = "windows", target_env = "msvc"))]
        { Self::from_str("x86_64-pc-windows-msvc").unwrap() }
        
        #[cfg(all(target_arch = "x86_64", target_os = "windows", target_env = "gnu"))]
        { Self::from_str("x86_64-pc-windows-gnu").unwrap() }
        
        #[cfg(all(target_arch = "aarch64", target_os = "linux", target_env = "gnu"))]
        { Self::from_str("aarch64-unknown-linux-gnu").unwrap() }
        
        #[cfg(not(any(
            all(target_arch = "x86_64", target_os = "linux"),
            all(target_arch = "x86_64", target_os = "macos"),
            all(target_arch = "aarch64", target_os = "macos"),
            all(target_arch = "x86_64", target_os = "windows"),
            all(target_arch = "aarch64", target_os = "linux"),
        )))]
        { Self::from_str("x86_64-unknown-linux-gnu").unwrap() }
    }
    
    /// Parse from string
    pub fn from_str(s: &str) -> Option<Self> {
        let parts: Vec<&str> = s.split('-').collect();
        
        if parts.len() < 2 {
            return None;
        }
        
        let arch = Architecture::from_str(parts[0])?;
        let vendor = parts.get(1).unwrap_or(&"unknown").to_string();
        let os_str = parts.get(2).unwrap_or(&"none");
        let os = OperatingSystem::from_str(os_str);
        let env = parts.get(3).unwrap_or(&"").to_string();
        
        Some(TargetTriple {
            triple: s.to_string(),
            arch,
            vendor,
            os,
            env,
        })
    }
    
    /// Get triple string
    pub fn triple(&self) -> &str {
        &self.triple
    }
    
    /// Check if this is the host target
    pub fn is_host(&self) -> bool {
        *self == Self::host()
    }
    
    /// Get pointer width in bits
    pub fn pointer_width(&self) -> u32 {
        match self.arch {
            Architecture::X86_64 | Architecture::Aarch64 | Architecture::Riscv64 => 64,
            Architecture::X86 | Architecture::Arm | Architecture::Riscv32 | Architecture::Wasm32 => 32,
            Architecture::Wasm64 => 64,
        }
    }
    
    /// Get endianness
    pub fn endianness(&self) -> Endianness {
        match self.arch {
            Architecture::X86 | Architecture::X86_64 => Endianness::Little,
            Architecture::Arm | Architecture::Aarch64 => Endianness::Little,
            Architecture::Riscv32 | Architecture::Riscv64 => Endianness::Little,
            Architecture::Wasm32 | Architecture::Wasm64 => Endianness::Little,
        }
    }
    
    /// Is Windows target
    pub fn is_windows(&self) -> bool {
        matches!(self.os, OperatingSystem::Windows)
    }
    
    /// Is Unix-like target
    pub fn is_unix(&self) -> bool {
        matches!(self.os, OperatingSystem::Linux | OperatingSystem::MacOS | 
                         OperatingSystem::FreeBSD | OperatingSystem::NetBSD)
    }
    
    /// Is WASM target
    pub fn is_wasm(&self) -> bool {
        matches!(self.arch, Architecture::Wasm32 | Architecture::Wasm64)
    }
    
    /// Get executable extension
    pub fn exe_extension(&self) -> &'static str {
        match self.os {
            OperatingSystem::Windows => ".exe",
            _ => "",
        }
    }
    
    /// Get static library extension
    pub fn staticlib_extension(&self) -> &'static str {
        match self.os {
            OperatingSystem::Windows => ".lib",
            _ => ".a",
        }
    }
    
    /// Get dynamic library extension
    pub fn dylib_extension(&self) -> &'static str {
        match self.os {
            OperatingSystem::Windows => ".dll",
            OperatingSystem::MacOS => ".dylib",
            _ => ".so",
        }
    }
}

#[derive(Debug, Clone, Copy, PartialEq, Eq)]
pub enum Architecture {
    X86,
    X86_64,
    Arm,
    Aarch64,
    Riscv32,
    Riscv64,
    Wasm32,
    Wasm64,
}

impl Architecture {
    pub fn from_str(s: &str) -> Option<Self> {
        match s {
            "i386" | "i586" | "i686" | "x86" => Some(Architecture::X86),
            "x86_64" | "amd64" => Some(Architecture::X86_64),
            "arm" | "armv7" => Some(Architecture::Arm),
            "aarch64" | "arm64" => Some(Architecture::Aarch64),
            "riscv32" => Some(Architecture::Riscv32),
            "riscv64" => Some(Architecture::Riscv64),
            "wasm32" => Some(Architecture::Wasm32),
            "wasm64" => Some(Architecture::Wasm64),
            _ => None,
        }
    }
    
    pub fn as_str(&self) -> &'static str {
        match self {
            Architecture::X86 => "x86",
            Architecture::X86_64 => "x86_64",
            Architecture::Arm => "arm",
            Architecture::Aarch64 => "aarch64",
            Architecture::Riscv32 => "riscv32",
            Architecture::Riscv64 => "riscv64",
            Architecture::Wasm32 => "wasm32",
            Architecture::Wasm64 => "wasm64",
        }
    }
}

#[derive(Debug, Clone, Copy, PartialEq, Eq)]
pub enum OperatingSystem {
    Linux,
    MacOS,
    Windows,
    FreeBSD,
    NetBSD,
    Wasi,
    None,
}

impl OperatingSystem {
    pub fn from_str(s: &str) -> Self {
        match s.to_lowercase().as_str() {
            "linux" => OperatingSystem::Linux,
            "darwin" | "macos" => OperatingSystem::MacOS,
            "windows" | "win32" => OperatingSystem::Windows,
            "freebsd" => OperatingSystem::FreeBSD,
            "netbsd" => OperatingSystem::NetBSD,
            "wasi" => OperatingSystem::Wasi,
            _ => OperatingSystem::None,
        }
    }
}

#[derive(Debug, Clone, Copy, PartialEq, Eq)]
pub enum Endianness {
    Little,
    Big,
}

// ═══════════════════════════════════════════════════════════════════════════════
// BUILD TARGET
// ═══════════════════════════════════════════════════════════════════════════════

/// A build target (binary, library, etc.)
#[derive(Debug, Clone)]
pub struct BuildTarget {
    /// Target name
    pub name: String,
    
    /// Target kind
    pub kind: TargetKind,
    
    /// Source root
    pub src_path: PathBuf,
    
    /// Crate types (for libraries)
    pub crate_types: Vec<CrateType>,
    
    /// Required features
    pub required_features: Vec<String>,
    
    /// Edition
    pub edition: Edition,
    
    /// Doc tests enabled
    pub doctest: bool,
    
    /// Test harness
    pub harness: bool,
    
    /// For proc macros
    pub proc_macro: bool,
}

impl BuildTarget {
    pub fn binary(name: &str, path: &str) -> Self {
        BuildTarget {
            name: name.to_string(),
            kind: TargetKind::Bin,
            src_path: PathBuf::from(path),
            crate_types: vec![CrateType::Bin],
            required_features: Vec::new(),
            edition: Edition::Edition2025,
            doctest: false,
            harness: true,
            proc_macro: false,
        }
    }
    
    pub fn library(name: &str, path: &str) -> Self {
        BuildTarget {
            name: name.to_string(),
            kind: TargetKind::Lib,
            src_path: PathBuf::from(path),
            crate_types: vec![CrateType::Rlib],
            required_features: Vec::new(),
            edition: Edition::Edition2025,
            doctest: true,
            harness: true,
            proc_macro: false,
        }
    }
    
    pub fn test(name: &str, path: &str) -> Self {
        BuildTarget {
            name: name.to_string(),
            kind: TargetKind::Test,
            src_path: PathBuf::from(path),
            crate_types: vec![CrateType::Bin],
            required_features: Vec::new(),
            edition: Edition::Edition2025,
            doctest: false,
            harness: true,
            proc_macro: false,
        }
    }
    
    pub fn example(name: &str, path: &str) -> Self {
        BuildTarget {
            name: name.to_string(),
            kind: TargetKind::Example,
            src_path: PathBuf::from(path),
            crate_types: vec![CrateType::Bin],
            required_features: Vec::new(),
            edition: Edition::Edition2025,
            doctest: false,
            harness: true,
            proc_macro: false,
        }
    }
    
    pub fn bench(name: &str, path: &str) -> Self {
        BuildTarget {
            name: name.to_string(),
            kind: TargetKind::Bench,
            src_path: PathBuf::from(path),
            crate_types: vec![CrateType::Bin],
            required_features: Vec::new(),
            edition: Edition::Edition2025,
            doctest: false,
            harness: true,
            proc_macro: false,
        }
    }
    
    /// Get output file name
    pub fn output_name(&self, target: &TargetTriple) -> String {
        match self.kind {
            TargetKind::Bin | TargetKind::Example | TargetKind::Test | TargetKind::Bench => {
                format!("{}{}", self.name, target.exe_extension())
            }
            TargetKind::Lib => {
                if self.crate_types.contains(&CrateType::Dylib) {
                    format!("lib{}{}", self.name, target.dylib_extension())
                } else {
                    format!("lib{}{}", self.name, target.staticlib_extension())
                }
            }
            TargetKind::CustomBuild => {
                format!("build-script-{}{}", self.name, target.exe_extension())
            }
            TargetKind::ProcMacro => {
                format!("lib{}{}", self.name, target.dylib_extension())
            }
        }
    }
}

#[derive(Debug, Clone, Copy, PartialEq, Eq)]
pub enum TargetKind {
    Lib,
    Bin,
    Test,
    Bench,
    Example,
    CustomBuild,
    ProcMacro,
}

#[derive(Debug, Clone, Copy, PartialEq, Eq)]
pub enum CrateType {
    Bin,
    Lib,
    Rlib,
    Dylib,
    Cdylib,
    Staticlib,
    ProcMacro,
}

impl CrateType {
    pub fn from_str(s: &str) -> Option<Self> {
        match s {
            "bin" => Some(CrateType::Bin),
            "lib" => Some(CrateType::Lib),
            "rlib" => Some(CrateType::Rlib),
            "dylib" => Some(CrateType::Dylib),
            "cdylib" => Some(CrateType::Cdylib),
            "staticlib" => Some(CrateType::Staticlib),
            "proc-macro" => Some(CrateType::ProcMacro),
            _ => None,
        }
    }
    
    pub fn as_str(&self) -> &'static str {
        match self {
            CrateType::Bin => "bin",
            CrateType::Lib => "lib",
            CrateType::Rlib => "rlib",
            CrateType::Dylib => "dylib",
            CrateType::Cdylib => "cdylib",
            CrateType::Staticlib => "staticlib",
            CrateType::ProcMacro => "proc-macro",
        }
    }
}

#[derive(Debug, Clone, Copy, PartialEq, Eq)]
pub enum Edition {
    Edition2024,
    Edition2025,
}

impl Edition {
    pub fn from_str(s: &str) -> Option<Self> {
        match s {
            "2024" => Some(Edition::Edition2024),
            "2025" => Some(Edition::Edition2025),
            _ => None,
        }
    }
    
    pub fn as_str(&self) -> &'static str {
        match self {
            Edition::Edition2024 => "2024",
            Edition::Edition2025 => "2025",
        }
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// HELPERS
// ═══════════════════════════════════════════════════════════════════════════════

fn num_cpus() -> usize {
    std::thread::available_parallelism()
        .map(|n| n.get())
        .unwrap_or(1)
}

// ═══════════════════════════════════════════════════════════════════════════════
// TESTS
// ═══════════════════════════════════════════════════════════════════════════════

#[cfg(test)]
mod tests {
    use super::*;
    
    #[test]
    fn test_target_triple() {
        let target = TargetTriple::from_str("x86_64-unknown-linux-gnu").unwrap();
        assert_eq!(target.arch, Architecture::X86_64);
        assert_eq!(target.os, OperatingSystem::Linux);
        assert_eq!(target.pointer_width(), 64);
    }
    
    #[test]
    fn test_profile() {
        let dev = Profile::dev();
        assert_eq!(dev.opt_level, OptLevel::O0);
        assert!(dev.debug_assertions);
        
        let release = Profile::release();
        assert_eq!(release.opt_level, OptLevel::O3);
        assert!(!release.debug_assertions);
    }
    
    #[test]
    fn test_build_target() {
        let target = TargetTriple::from_str("x86_64-unknown-linux-gnu").unwrap();
        let bin = BuildTarget::binary("myapp", "src/main.quanta");
        assert_eq!(bin.output_name(&target), "myapp");
    }
}
