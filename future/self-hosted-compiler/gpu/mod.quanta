// ═══════════════════════════════════════════════════════════════════════════════
// TESTS
// ═══════════════════════════════════════════════════════════════════════════════

#[cfg(test)]
mod tests {
    use super::*;
    
    #[test]
    fn test_kernel_builder() {
        let kernel = KernelBuilder::new("test")
            .workgroup_size(64, 1, 1)
            .storage_buffer("input", 0, 0, GpuType::Float32, BufferAccess::ReadOnly)
            .storage_buffer("output", 0, 1, GpuType::Float32, BufferAccess::WriteOnly)
            .build();
        
        assert_eq!(kernel.name, "test");
        assert_eq!(kernel.workgroup_size.total(), 64);
        assert_eq!(kernel.buffers.len(), 2);
    }
    
    #[test]
    fn test_validate_spirv() {
        let valid = vec![
            SPIRV_MAGIC,
            SPIRV_VERSION_1_6,
            0,
            10, // bound
            0,  // reserved
        ];
        
        assert!(validate_spirv(&valid).is_ok());
        
        let invalid_magic = vec![0x12345678, 0, 0, 10, 0];
        assert!(validate_spirv(&invalid_magic).is_err());
    }
    
    #[test]
    fn test_gpu_capabilities() {
        let caps = GpuCapabilities::default();
        assert_eq!(caps.max_workgroup_invocations, 1024);
        assert_eq!(caps.subgroup_size, 32);
    }
}
