// CODE GENERATION PLUGINS
// ═══════════════════════════════════════════════════════════════════════════════

/// Code generation pass
pub trait CodeGenPass: Send + Sync {
    /// Pass name
    fn name(&self) -> &str;
    
    /// Priority (lower runs first)
    fn priority(&self) -> i32 { 0 }
    
    /// Transform MIR
    fn transform_mir(&self, ctx: &mut CodeGenContext, mir: &mut MirModule) -> Result<(), CodeGenError>;
}

/// Code generation context
pub struct CodeGenContext {
    /// Target triple
    pub target: String,
    
    /// Optimization level
    pub opt_level: OptLevel,
    
    /// Debug info
    pub debug_info: bool,
    
    /// Plugin data
    pub data: BTreeMap<String, Box<dyn Any + Send + Sync>>,
}

#[derive(Debug, Clone, Copy)]
pub enum OptLevel {
    O0, O1, O2, O3, Os, Oz,
}

/// MIR module (simplified)
pub struct MirModule {
    pub name: String,
    pub functions: Vec<MirFunction>,
}

pub struct MirFunction {
    pub name: String,
    pub signature: String,
    pub body: Vec<MirBasicBlock>,
}

pub struct MirBasicBlock {
    pub id: u32,
    pub statements: Vec<MirStatement>,
    pub terminator: MirTerminator,
}

pub struct MirStatement {
    pub kind: MirStatementKind,
}

pub enum MirStatementKind {
    Assign { place: String, value: String },
    Call { func: String, args: Vec<String>, dest: Option<String> },
    Nop,
}

pub enum MirTerminator {
    Return,
    Goto(u32),
    SwitchInt { discriminant: String, targets: Vec<(i64, u32)>, otherwise: u32 },
    Unreachable,
}

#[derive(Debug)]
pub struct CodeGenError {
    pub message: String,
    pub pass: String,
}

