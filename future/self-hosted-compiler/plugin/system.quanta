// PLUGIN REGISTRY
// ═══════════════════════════════════════════════════════════════════════════════

/// Plugin registry
pub struct PluginRegistry {
    /// Loaded plugins
    plugins: Vec<Arc<RwLock<dyn Plugin>>>,
    
    /// Derive macros
    derive_macros: BTreeMap<String, Arc<dyn DeriveMacro>>,
    
    /// Attribute macros
    attr_macros: BTreeMap<String, Arc<dyn AttributeMacro>>,
    
    /// Function macros
    fn_macros: BTreeMap<String, Arc<dyn FunctionMacro>>,
    
    /// Lint passes
    lint_passes: Vec<Arc<dyn LintPass>>,
    
    /// Code generation passes
    codegen_passes: Vec<Arc<dyn CodeGenPass>>,
}

impl PluginRegistry {
    pub fn new() -> Self {
        PluginRegistry {
            plugins: Vec::new(),
            derive_macros: BTreeMap::new(),
            attr_macros: BTreeMap::new(),
            fn_macros: BTreeMap::new(),
            lint_passes: Vec::new(),
            codegen_passes: Vec::new(),
        }
    }
    
    /// Register derive macro
    pub fn register_derive(&mut self, mac: Arc<dyn DeriveMacro>) {
        self.derive_macros.insert(mac.name().to_string(), mac);
    }
    
    /// Register attribute macro
    pub fn register_attr(&mut self, mac: Arc<dyn AttributeMacro>) {
        self.attr_macros.insert(mac.name().to_string(), mac);
    }
    
    /// Register function macro
    pub fn register_fn(&mut self, mac: Arc<dyn FunctionMacro>) {
        self.fn_macros.insert(mac.name().to_string(), mac);
    }
    
    /// Register lint pass
    pub fn register_lint(&mut self, lint: Arc<dyn LintPass>) {
        self.lint_passes.push(lint);
    }
    
    /// Register code generation pass
    pub fn register_codegen(&mut self, pass: Arc<dyn CodeGenPass>) {
        self.codegen_passes.push(pass);
        // Sort by priority
        self.codegen_passes.sort_by_key(|p| p.priority());
    }
    
    /// Get derive macro
    pub fn get_derive(&self, name: &str) -> Option<&Arc<dyn DeriveMacro>> {
        self.derive_macros.get(name)
    }
    
    /// Get attribute macro
    pub fn get_attr(&self, name: &str) -> Option<&Arc<dyn AttributeMacro>> {
        self.attr_macros.get(name)
    }
    
    /// Get function macro
    pub fn get_fn(&self, name: &str) -> Option<&Arc<dyn FunctionMacro>> {
        self.fn_macros.get(name)
    }
    
    /// Get all lint passes
    pub fn lint_passes(&self) -> &[Arc<dyn LintPass>] {
        &self.lint_passes
    }
    
    /// Get codegen passes
    pub fn codegen_passes(&self) -> &[Arc<dyn CodeGenPass>] {
        &self.codegen_passes
    }
    
    /// List all registered macros
    pub fn list_macros(&self) -> Vec<MacroInfo> {
        let mut result = Vec::new();
        
        for (name, _) in &self.derive_macros {
            result.push(MacroInfo {
                name: name.clone(),
                kind: MacroKind::Derive,
            });
        }
        
        for (name, _) in &self.attr_macros {
            result.push(MacroInfo {
                name: name.clone(),
                kind: MacroKind::Attribute,
            });
        }
        
        for (name, _) in &self.fn_macros {
            result.push(MacroInfo {
                name: name.clone(),
                kind: MacroKind::Function,
            });
        }
        
        result
    }
}

impl Default for PluginRegistry {
    fn default() -> Self {
        Self::new()
    }
}

/// Macro information
#[derive(Debug, Clone)]
pub struct MacroInfo {
    pub name: String,
    pub kind: MacroKind,
}

#[derive(Debug, Clone, Copy)]
pub enum MacroKind {
    Derive,
    Attribute,
    Function,
}

// ═══════════════════════════════════════════════════════════════════════════════
// PLUGIN LOADER
// ═══════════════════════════════════════════════════════════════════════════════

/// Plugin loader
pub struct PluginLoader {
    /// Search paths
    search_paths: Vec<PathBuf>,
    
    /// Loaded plugin libraries
    loaded: BTreeMap<String, LoadedPlugin>,
    
    /// Registry
    registry: PluginRegistry,
}

struct LoadedPlugin {
    metadata: PluginMetadata,
    path: PathBuf,
}

impl PluginLoader {
    pub fn new() -> Self {
        PluginLoader {
            search_paths: Vec::new(),
            loaded: BTreeMap::new(),
            registry: PluginRegistry::new(),
        }
    }
    
    /// Add search path
    pub fn add_search_path(&mut self, path: PathBuf) {
        self.search_paths.push(path);
    }
    
    /// Load plugin by name
    pub fn load(&mut self, name: &str) -> Result<(), PluginError> {
        if self.loaded.contains_key(name) {
            return Ok(());
        }
        
        // Find plugin
        let plugin_path = self.find_plugin(name)?;
        
        // Load and initialize
        // Real implementation would use libloading
        let metadata = self.load_metadata(&plugin_path)?;
        
        // Check dependencies
        for dep in &metadata.dependencies {
            if !dep.optional {
                self.load(&dep.name)?;
            }
        }
        
        self.loaded.insert(name.to_string(), LoadedPlugin {
            metadata,
            path: plugin_path,
        });
        
        Ok(())
    }
    
    fn find_plugin(&self, name: &str) -> Result<PathBuf, PluginError> {
        for search_path in &self.search_paths {
            let plugin_path = search_path.join(name);
            
            // Try various extensions
            for ext in &["so", "dylib", "dll", "wasm"] {
                let path = plugin_path.with_extension(ext);
                if path.exists() {
                    return Ok(path);
                }
            }
        }
        
        Err(PluginError::NotFound(name.to_string()))
    }
    
    fn load_metadata(&self, _path: &Path) -> Result<PluginMetadata, PluginError> {
        // Real implementation would read from plugin
        Ok(PluginMetadata {
            name: "unknown".to_string(),
            version: PluginVersion::new(0, 0, 1),
            description: String::new(),
            authors: Vec::new(),
            license: "MIT".to_string(),
            repository: None,
            required_compiler: VersionRequirement::Any,
            capabilities: Vec::new(),
            dependencies: Vec::new(),
        })
    }
    
    /// Get registry
    pub fn registry(&self) -> &PluginRegistry {
        &self.registry
    }
    
    /// Get mutable registry
    pub fn registry_mut(&mut self) -> &mut PluginRegistry {
        &mut self.registry
    }
    
    /// List loaded plugins
    pub fn list_loaded(&self) -> Vec<&PluginMetadata> {
        self.loaded.values().map(|p| &p.metadata).collect()
    }
}

impl Default for PluginLoader {
    fn default() -> Self {
        Self::new()
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// ERRORS
// ═══════════════════════════════════════════════════════════════════════════════

#[derive(Debug)]
pub enum PluginError {
    NotFound(String),
    LoadError(String),
    InitError(String),
    VersionMismatch { required: String, found: String },
    DependencyError(String),
    InvalidMetadata(String),
}

impl std::fmt::Display for PluginError {
    fn fmt(&self, f: &mut std::fmt::Formatter<'_>) -> std::fmt::Result {
        match self {
            Self::NotFound(n) => write!(f, "plugin not found: {}", n),
            Self::LoadError(m) => write!(f, "failed to load plugin: {}", m),
            Self::InitError(m) => write!(f, "plugin initialization failed: {}", m),
            Self::VersionMismatch { required, found } => {
                write!(f, "version mismatch: required {}, found {}", required, found)
            }
            Self::DependencyError(m) => write!(f, "dependency error: {}", m),
            Self::InvalidMetadata(m) => write!(f, "invalid plugin metadata: {}", m),
        }
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// TESTS
// ═══════════════════════════════════════════════════════════════════════════════

#[cfg(test)]
mod tests {
    use super::*;
    
    #[test]
    fn test_plugin_version() {
        let v = PluginVersion::new(1, 2, 3);
        assert_eq!(v.to_string(), "1.2.3");
        
        let parsed = PluginVersion::parse("v1.2.3").unwrap();
        assert_eq!(v, parsed);
    }
    
    #[test]
    fn test_version_requirement() {
        let v = PluginVersion::new(1, 5, 0);
        
        assert!(v.satisfies(&VersionRequirement::Caret(PluginVersion::new(1, 0, 0))));
        assert!(!v.satisfies(&VersionRequirement::Caret(PluginVersion::new(2, 0, 0))));
        
        assert!(v.satisfies(&VersionRequirement::Tilde(PluginVersion::new(1, 5, 0))));
        assert!(!v.satisfies(&VersionRequirement::Tilde(PluginVersion::new(1, 4, 0))));
    }
    
    #[test]
    fn test_token_stream() {
        let ts = TokenStream::from_str("foo 42 bar");
        assert_eq!(ts.tokens.len(), 3);
    }
    
    #[test]
    fn test_plugin_registry() {
        let mut registry = PluginRegistry::new();
        
        struct TestDerive;
        impl DeriveMacro for TestDerive {
            fn name(&self) -> &str { "Test" }
            fn derive(&self, _: &DeriveInput) -> Result<TokenStream, MacroError> {
                Ok(TokenStream::new())
            }
        }
        
        registry.register_derive(Arc::new(TestDerive));
        assert!(registry.get_derive("Test").is_some());
        assert!(registry.get_derive("Unknown").is_none());
    }
    
    #[test]
    fn test_macro_info() {
        let mut registry = PluginRegistry::new();
        
        struct TestFn;
        impl FunctionMacro for TestFn {
            fn name(&self) -> &str { "test!" }
            fn expand(&self, _: TokenStream) -> Result<TokenStream, MacroError> {
                Ok(TokenStream::new())
            }
        }
        
        registry.register_fn(Arc::new(TestFn));
        
        let macros = registry.list_macros();
        assert_eq!(macros.len(), 1);
        assert_eq!(macros[0].name, "test!");
    }
}
