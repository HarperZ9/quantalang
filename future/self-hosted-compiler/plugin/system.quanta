// PLUGIN TRAIT
// ═══════════════════════════════════════════════════════════════════════════════

/// Main plugin trait
pub trait Plugin: Send + Sync {
    /// Get plugin metadata
    fn metadata(&self) -> &PluginMetadata;
    
    /// Initialize plugin
    fn initialize(&mut self, ctx: &mut PluginContext) -> Result<(), PluginError>;
    
    /// Finalize plugin
    fn finalize(&mut self, ctx: &mut PluginContext) -> Result<(), PluginError>;
    
    /// Register capabilities with the compiler
    fn register(&self, registry: &mut PluginRegistry) -> Result<(), PluginError>;
    
    /// Get plugin as Any for downcasting
    fn as_any(&self) -> &dyn Any;
    
    /// Get mutable Any reference
    fn as_any_mut(&mut self) -> &mut dyn Any;
}

/// Plugin context for initialization
pub struct PluginContext {
    /// Compiler version
    pub compiler_version: PluginVersion,
    
    /// Plugin directory
    pub plugin_dir: PathBuf,
    
    /// Cache directory
    pub cache_dir: PathBuf,
    
    /// Configuration
    pub config: BTreeMap<String, String>,
    
    /// Logger
    pub logger: Box<dyn PluginLogger>,
}

/// Plugin logging interface
pub trait PluginLogger: Send + Sync {
    fn debug(&self, msg: &str);
    fn info(&self, msg: &str);
    fn warn(&self, msg: &str);
    fn error(&self, msg: &str);
}

/// Default console logger
pub struct ConsoleLogger;

impl PluginLogger for ConsoleLogger {
    fn debug(&self, msg: &str) {
        println!("[DEBUG] {}", msg);
    }
    
    fn info(&self, msg: &str) {
        println!("[INFO] {}", msg);
    }
    
    fn warn(&self, msg: &str) {
        eprintln!("[WARN] {}", msg);
    }
    
    fn error(&self, msg: &str) {
        eprintln!("[ERROR] {}", msg);
    }
}

