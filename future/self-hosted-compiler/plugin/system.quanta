// MACRO PLUGINS
// ═══════════════════════════════════════════════════════════════════════════════

/// Token stream for macro processing
#[derive(Debug, Clone)]
pub struct TokenStream {
    pub tokens: Vec<Token>,
}

/// Token representation
#[derive(Debug, Clone)]
pub enum Token {
    Ident(String),
    Punct(char),
    Literal(Literal),
    Group { delimiter: Delimiter, tokens: TokenStream },
}

#[derive(Debug, Clone)]
pub enum Literal {
    String(String),
    Integer(i64),
    Float(f64),
    Bool(bool),
    Char(char),
}

#[derive(Debug, Clone, Copy, PartialEq, Eq)]
pub enum Delimiter {
    Parenthesis, // ()
    Bracket,     // []
    Brace,       // {}
    None,        // invisible
}

impl TokenStream {
    pub fn new() -> Self {
        TokenStream { tokens: Vec::new() }
    }
    
    pub fn from_str(s: &str) -> Self {
        // Simplified tokenizer
        let mut tokens = Vec::new();
        
        for word in s.split_whitespace() {
            if let Ok(n) = word.parse::<i64>() {
                tokens.push(Token::Literal(Literal::Integer(n)));
            } else if let Ok(f) = word.parse::<f64>() {
                tokens.push(Token::Literal(Literal::Float(f)));
            } else {
                tokens.push(Token::Ident(word.to_string()));
            }
        }
        
        TokenStream { tokens }
    }
    
    pub fn push(&mut self, token: Token) {
        self.tokens.push(token);
    }
    
    pub fn extend(&mut self, other: TokenStream) {
        self.tokens.extend(other.tokens);
    }
    
    pub fn is_empty(&self) -> bool {
        self.tokens.is_empty()
    }
}

impl Default for TokenStream {
    fn default() -> Self {
        Self::new()
    }
}

/// Derive macro trait
pub trait DeriveMacro: Send + Sync {
    /// Macro name
    fn name(&self) -> &str;
    
    /// Process derive
    fn derive(&self, input: &DeriveInput) -> Result<TokenStream, MacroError>;
    
    /// Helper attributes supported
    fn helper_attributes(&self) -> Vec<&str> {
        Vec::new()
    }
}

/// Input to derive macro
#[derive(Debug, Clone)]
pub struct DeriveInput {
    /// Item name
    pub ident: String,
    
    /// Generics
    pub generics: Generics,
    
    /// Item data
    pub data: DeriveData,
    
    /// Attributes
    pub attrs: Vec<Attribute>,
}

#[derive(Debug, Clone)]
pub struct Generics {
    pub params: Vec<GenericParam>,
    pub where_clause: Option<WhereClause>,
}

#[derive(Debug, Clone)]
pub enum GenericParam {
    Type { name: String, bounds: Vec<String> },
    Lifetime { name: String, bounds: Vec<String> },
    Const { name: String, ty: String },
}

#[derive(Debug, Clone)]
pub struct WhereClause {
    pub predicates: Vec<WherePredicate>,
}

#[derive(Debug, Clone)]
pub struct WherePredicate {
    pub bounded_ty: String,
    pub bounds: Vec<String>,
}

#[derive(Debug, Clone)]
pub enum DeriveData {
    Struct(StructData),
    Enum(EnumData),
}

#[derive(Debug, Clone)]
pub struct StructData {
    pub fields: Fields,
}

#[derive(Debug, Clone)]
pub struct EnumData {
    pub variants: Vec<Variant>,
}

#[derive(Debug, Clone)]
pub struct Variant {
    pub ident: String,
    pub fields: Fields,
    pub discriminant: Option<i64>,
}

#[derive(Debug, Clone)]
pub enum Fields {
    Named(Vec<Field>),
    Unnamed(Vec<Field>),
    Unit,
}

#[derive(Debug, Clone)]
pub struct Field {
    pub ident: Option<String>,
    pub ty: String,
    pub attrs: Vec<Attribute>,
}

#[derive(Debug, Clone)]
pub struct Attribute {
    pub path: String,
    pub tokens: TokenStream,
}

/// Attribute macro trait
pub trait AttributeMacro: Send + Sync {
    /// Macro name
    fn name(&self) -> &str;
    
    /// Process attribute
    fn expand(
        &self,
        attr: TokenStream,
        item: TokenStream,
    ) -> Result<TokenStream, MacroError>;
}

/// Function-like macro trait
pub trait FunctionMacro: Send + Sync {
    /// Macro name
    fn name(&self) -> &str;
    
    /// Expand macro
    fn expand(&self, input: TokenStream) -> Result<TokenStream, MacroError>;
}

/// Macro error
#[derive(Debug)]
pub struct MacroError {
    pub message: String,
    pub span: Option<Span>,
    pub help: Option<String>,
}

impl MacroError {
    pub fn new(message: impl Into<String>) -> Self {
        MacroError {
            message: message.into(),
            span: None,
            help: None,
        }
    }
    
    pub fn with_span(mut self, span: Span) -> Self {
        self.span = Some(span);
        self
    }
    
    pub fn with_help(mut self, help: impl Into<String>) -> Self {
        self.help = Some(help.into());
        self
    }
}

/// Source span
#[derive(Debug, Clone, Copy)]
pub struct Span {
    pub start: u32,
    pub end: u32,
}

