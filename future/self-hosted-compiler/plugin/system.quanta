// LINT PLUGINS
// ═══════════════════════════════════════════════════════════════════════════════

/// Custom lint trait
pub trait LintPass: Send + Sync {
    /// Lint name
    fn name(&self) -> &str;
    
    /// Default lint level
    fn default_level(&self) -> LintLevel;
    
    /// Lint description
    fn description(&self) -> &str;
    
    /// Check AST node
    fn check(&self, ctx: &LintContext, node: &dyn Any) -> Vec<LintDiagnostic>;
}

/// Lint severity level
#[derive(Debug, Clone, Copy, PartialEq, Eq)]
pub enum LintLevel {
    Allow,
    Warn,
    Deny,
    Forbid,
}

/// Lint context
pub struct LintContext<'a> {
    /// Source file path
    pub file: &'a Path,
    
    /// Source content
    pub source: &'a str,
    
    /// Lint configuration
    pub config: &'a LintConfig,
}

/// Lint configuration
#[derive(Debug, Clone, Default)]
pub struct LintConfig {
    pub levels: BTreeMap<String, LintLevel>,
}

/// Lint diagnostic
#[derive(Debug, Clone)]
pub struct LintDiagnostic {
    pub lint: String,
    pub level: LintLevel,
    pub message: String,
    pub span: Span,
    pub notes: Vec<String>,
    pub suggestions: Vec<LintSuggestion>,
}

/// Lint suggestion
#[derive(Debug, Clone)]
pub struct LintSuggestion {
    pub message: String,
    pub replacement: String,
    pub span: Span,
    pub applicability: Applicability,
}

#[derive(Debug, Clone, Copy)]
pub enum Applicability {
    MachineApplicable,
    MaybeIncorrect,
    HasPlaceholders,
    Unspecified,
}

