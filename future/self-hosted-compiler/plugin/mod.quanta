/// Unused variable lint
pub struct UnusedVariableLint;

impl LintPass for UnusedVariableLint {
    fn name(&self) -> &str { "unused_variable" }
    
    fn default_level(&self) -> LintLevel { LintLevel::Warn }
    
    fn description(&self) -> &str {
        "Detects variables that are declared but never used"
    }
    
    fn check(&self, _ctx: &LintContext, _node: &dyn std::any::Any) -> Vec<LintDiagnostic> {
        // Real implementation would analyze AST
        Vec::new()
    }
}

/// Unreachable code lint
pub struct UnreachableCodeLint;

impl LintPass for UnreachableCodeLint {
    fn name(&self) -> &str { "unreachable_code" }
    
    fn default_level(&self) -> LintLevel { LintLevel::Warn }
    
    fn description(&self) -> &str {
        "Detects code that can never be executed"
    }
    
    fn check(&self, _ctx: &LintContext, _node: &dyn std::any::Any) -> Vec<LintDiagnostic> {
        Vec::new()
    }
}

/// Dead code lint
pub struct DeadCodeLint;

impl LintPass for DeadCodeLint {
    fn name(&self) -> &str { "dead_code" }
    
    fn default_level(&self) -> LintLevel { LintLevel::Warn }
    
    fn description(&self) -> &str {
        "Detects functions, types, and constants that are never used"
    }
    
    fn check(&self, _ctx: &LintContext, _node: &dyn std::any::Any) -> Vec<LintDiagnostic> {
        Vec::new()
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// REGISTER BUILTINS
// ═══════════════════════════════════════════════════════════════════════════════

/// Register all built-in plugins
pub fn register_builtins(registry: &mut PluginRegistry) {
    // Derive macros
    registry.register_derive(Arc::new(DebugDerive));
    registry.register_derive(Arc::new(CloneDerive));
    registry.register_derive(Arc::new(DefaultDerive));
    
    // Lint passes
    registry.register_lint(Arc::new(UnusedVariableLint));
    registry.register_lint(Arc::new(UnreachableCodeLint));
    registry.register_lint(Arc::new(DeadCodeLint));
}

