//! # Plugin System
//!
//! Extensible compiler plugin architecture:
//!
//! - **Procedural Macros**: Derive, attribute, and function-like macros
//! - **Custom Lints**: User-defined static analysis rules
//! - **Code Generation**: Custom optimization and transformation passes
//! - **Build Hooks**: Integration with build system
//!
//! ## Plugin Development
//!
//! ```quanta
//! use plugin::prelude::*;
//!
//! #[derive_macro]
//! pub fn my_derive(input: DeriveInput) -> TokenStream {
//!     let name = &input.ident;
//!     quote! {
//!         impl MyTrait for #name {
//!             // ...
//!         }
//!     }
//! }
//! ```
//!
//! ## Plugin Manifest
//!
//! ```toml
//! [plugin]
//! name = "my-plugin"
//! version = "1.0.0"
//! capabilities = ["derive-macro", "lint"]
//! 
//! [dependencies]
//! quantalang = "^1.0"
//! ```

module quantalang::plugin

pub mod system;

pub use system::{
    // Metadata
    PluginMetadata, PluginVersion, VersionRequirement,
    PluginCapability, PluginDependency,
    
    // Core trait
    Plugin, PluginContext, PluginLogger, ConsoleLogger,
    
    // Tokens
    TokenStream, Token, Literal, Delimiter, Span,
    
    // Derive macros
    DeriveMacro, DeriveInput, DeriveData,
    Generics, GenericParam, WhereClause, WherePredicate,
    StructData, EnumData, Variant, Fields, Field, Attribute,
    
    // Attribute macros
    AttributeMacro,
    
    // Function macros
    FunctionMacro,
    
    // Macro error
    MacroError,
    
    // Lints
    LintPass, LintLevel, LintContext, LintConfig,
    LintDiagnostic, LintSuggestion, Applicability,
    
    // Code generation
    CodeGenPass, CodeGenContext, OptLevel,
    MirModule, MirFunction, MirBasicBlock,
    MirStatement, MirStatementKind, MirTerminator,
    CodeGenError,
    
    // Registry
    PluginRegistry, MacroInfo, MacroKind,
    
    // Loader
    PluginLoader, PluginError,
};

