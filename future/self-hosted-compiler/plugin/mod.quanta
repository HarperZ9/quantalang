// ═══════════════════════════════════════════════════════════════════════════════
// TESTS
// ═══════════════════════════════════════════════════════════════════════════════

#[cfg(test)]
mod tests {
    use super::*;
    
    #[test]
    fn test_quote_builder() {
        let mut q = Quote::new();
        q.ident("fn").ident("main").group(Delimiter::Parenthesis, TokenStream::new());
        
        let ts = q.build();
        assert!(!ts.is_empty());
    }
    
    #[test]
    fn test_debug_derive() {
        let derive = DebugDerive;
        
        let input = DeriveInput {
            ident: "MyStruct".to_string(),
            generics: Generics {
                params: vec![],
                where_clause: None,
            },
            data: DeriveData::Struct(StructData {
                fields: Fields::Named(vec![
                    Field {
                        ident: Some("x".to_string()),
                        ty: "i32".to_string(),
                        attrs: vec![],
                    },
                ]),
            }),
            attrs: vec![],
        };
        
        let result = derive.derive(&input);
        assert!(result.is_ok());
    }
    
    #[test]
    fn test_register_builtins() {
        let mut registry = PluginRegistry::new();
        register_builtins(&mut registry);
        
        assert!(registry.get_derive("Debug").is_some());
        assert!(registry.get_derive("Clone").is_some());
        assert!(registry.get_derive("Default").is_some());
        
        assert!(!registry.lint_passes().is_empty());
    }
    
    #[test]
    fn test_lint_level() {
        let lint = UnusedVariableLint;
        assert_eq!(lint.default_level(), LintLevel::Warn);
    }
}
