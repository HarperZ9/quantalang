//
// High-performance async runtime for QuantaLang.
//
// Features:
// - Work-stealing thread pool executor
// - Multi-platform I/O (epoll/kqueue/IOCP)
// - Async channels (MPSC, oneshot, broadcast, watch)
// - Async sync primitives (Mutex, RwLock, Semaphore)
// - Timer support with hierarchical timing wheel
//
// ═══════════════════════════════════════════════════════════════════════════════

//! # QuantaLang Async Runtime
//!
//! A high-performance async runtime with work-stealing executor.
//!
//! ## Quick Start
//!
//! ```quanta
//! use quantalang::async::{spawn, sleep};
//! use quantalang::async::time::Duration;
//!
//! async fn main() {
//!     // Spawn a concurrent task
//!     let handle = spawn(async {
//!         sleep(Duration::from_secs(1)).await;
//!         42
//!     });
//!
//!     // Wait for result
//!     let result = handle.await;
//!     println!("Got: {}", result);
//! }
//! ```
//!
//! ## Channels
//!
//! ```quanta
//! use quantalang::async::channel;
//!
//! let (tx, rx) = channel::unbounded();
//!
//! spawn(async move {
//!     tx.send("hello").await.unwrap();
//! });
//!
//! let msg = rx.recv().await.unwrap();
//! ```
//!
//! ## I/O
//!
//! ```quanta
//! use quantalang::async::net::TcpStream;
//!
//! let stream = TcpStream::connect("127.0.0.1:8080").await?;
//! stream.write_all(b"GET / HTTP/1.1\r\n\r\n").await?;
//! ```

