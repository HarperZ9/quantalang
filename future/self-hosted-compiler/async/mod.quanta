// ═══════════════════════════════════════════════════════════════════════════════
// TESTS
// ═══════════════════════════════════════════════════════════════════════════════

#[cfg(test)]
mod tests {
    use super::*;
    
    #[test]
    fn test_yield_now() {
        block_on(async {
            yield_now().await;
        });
    }
    
    #[test]
    fn test_runtime_builder() {
        let builder = RuntimeBuilder::new()
            .worker_threads(4)
            .enable_all();
        
        assert_eq!(builder.config.worker_threads, 4);
    }
    
    #[test]
    fn test_num_cpus() {
        let cpus = num_cpus();
        assert!(cpus >= 1);
    }
    
    #[test]
    fn test_either() {
        let left: Either<i32, &str> = Either::Left(42);
        assert!(matches!(left, Either::Left(42)));
        
        let right: Either<i32, &str> = Either::Right("hello");
        assert!(matches!(right, Either::Right("hello")));
    }
}
