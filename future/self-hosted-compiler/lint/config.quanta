module quantalang::lint::config

use alloc::string::String;
use alloc::vec::Vec;
use alloc::collections::{BTreeMap, BTreeSet};
use std::path::PathBuf;

// ═══════════════════════════════════════════════════════════════════════════════
// LINT CONFIGURATION
// ═══════════════════════════════════════════════════════════════════════════════

/// Linter configuration
#[derive(Debug, Clone)]
pub struct LintConfig {
    /// Enabled lint groups
    pub enabled_groups: BTreeSet<LintGroup>,
    
    /// Disabled lint groups
    pub disabled_groups: BTreeSet<LintGroup>,
    
    /// Per-lint overrides
    pub lint_levels: BTreeMap<String, LintLevel>,
    
    /// Files to exclude
    pub exclude_files: Vec<String>,
    
    /// Directories to exclude
    pub exclude_dirs: Vec<String>,
    
    /// Maximum issues to report (0 = unlimited)
    pub max_issues: usize,
    
    /// Output format
    pub output_format: OutputFormat,
    
    /// Color output
    pub color: ColorChoice,
    
    /// Fix mode (auto-fix applicable lints)
    pub fix: bool,
    
    /// Verbose output
    pub verbose: bool,
    
    /// Quiet mode (only errors)
    pub quiet: bool,
    
    /// Edition
    pub edition: Edition,
    
    /// Custom rules directory
    pub custom_rules_dir: Option<PathBuf>,
    
    /// Report file path
    pub report_path: Option<PathBuf>,
    
    /// Allow specific lints via attributes
    pub respect_allows: bool,
    
    /// Workspace mode
    pub workspace: bool,
}

impl Default for LintConfig {
    fn default() -> Self {
        let mut enabled_groups = BTreeSet::new();
        enabled_groups.insert(LintGroup::Correctness);
        enabled_groups.insert(LintGroup::Suspicious);
        enabled_groups.insert(LintGroup::Style);
        
        LintConfig {
            enabled_groups,
            disabled_groups: BTreeSet::new(),
            lint_levels: BTreeMap::new(),
            exclude_files: Vec::new(),
            exclude_dirs: vec!["target".to_string(), ".git".to_string()],
            max_issues: 0,
            output_format: OutputFormat::Human,
            color: ColorChoice::Auto,
            fix: false,
            verbose: false,
            quiet: false,
            edition: Edition::Edition2025,
            custom_rules_dir: None,
            report_path: None,
            respect_allows: true,
            workspace: false,
        }
    }
}

impl LintConfig {
    /// Create strict configuration (all lints enabled)
    pub fn strict() -> Self {
        let mut config = Self::default();
        config.enabled_groups.insert(LintGroup::Pedantic);
        config.enabled_groups.insert(LintGroup::Perf);
        config.enabled_groups.insert(LintGroup::Complexity);
        config.enabled_groups.insert(LintGroup::Nursery);
        config
    }
    
    /// Create minimal configuration (only errors)
    pub fn minimal() -> Self {
        let mut config = Self::default();
        config.enabled_groups.clear();
        config.enabled_groups.insert(LintGroup::Correctness);
        config
    }
    
    /// Get effective lint level
    pub fn lint_level(&self, lint: &LintRule) -> LintLevel {
        // Check per-lint override
        if let Some(&level) = self.lint_levels.get(&lint.name) {
            return level;
        }
        
        // Check if group is disabled
        if self.disabled_groups.contains(&lint.group) {
            return LintLevel::Allow;
        }
        
        // Check if group is enabled
        if self.enabled_groups.contains(&lint.group) {
            return lint.default_level;
        }
        
        LintLevel::Allow
    }
    
    /// Set lint level
    pub fn set_lint(&mut self, name: &str, level: LintLevel) {
        self.lint_levels.insert(name.to_string(), level);
    }
    
    /// Enable lint group
    pub fn enable_group(&mut self, group: LintGroup) {
        self.enabled_groups.insert(group);
        self.disabled_groups.remove(&group);
    }
    
    /// Disable lint group
    pub fn disable_group(&mut self, group: LintGroup) {
        self.disabled_groups.insert(group);
        self.enabled_groups.remove(&group);
    }
    
    /// Check if file should be linted
    pub fn should_lint_file(&self, path: &str) -> bool {
        // Check exclude patterns
        for pattern in &self.exclude_files {
            if glob_match(pattern, path) {
                return false;
            }
        }
        
        for dir in &self.exclude_dirs {
            if path.starts_with(dir) || path.contains(&format!("/{}/", dir)) {
                return false;
            }
        }
        
        true
    }
    
    /// Parse from TOML
    pub fn from_toml(content: &str) -> Result<Self, ConfigError> {
        let mut config = Self::default();
        
        for line in content.lines() {
            let line = line.trim();
            
            if line.is_empty() || line.starts_with('#') {
                continue;
            }
            
            if let Some((key, value)) = line.split_once('=') {
                let key = key.trim();
                let value = value.trim().trim_matches('"');
                
                match key {
                    "fix" => config.fix = value == "true",
                    "verbose" => config.verbose = value == "true",
                    "quiet" => config.quiet = value == "true",
                    "max_issues" => {
                        config.max_issues = value.parse().unwrap_or(0);
                    }
                    "edition" => {
                        config.edition = Edition::from_str(value)
                            .unwrap_or(Edition::Edition2025);
                    }
                    "output_format" => {
                        config.output_format = OutputFormat::from_str(value)
                            .unwrap_or(OutputFormat::Human);
                    }
                    _ => {
                        // Check for lint level settings (lint_name = "level")
                        if let Some(level) = LintLevel::from_str(value) {
                            config.lint_levels.insert(key.to_string(), level);
                        }
                    }
                }
            }
        }
        
        Ok(config)
    }
    
    /// Serialize to TOML
    pub fn to_toml(&self) -> String {
        let mut output = String::new();
        
        output.push_str("# QuantaLang Linter Configuration\n\n");
        
        output.push_str(&format!("fix = {}\n", self.fix));
        output.push_str(&format!("verbose = {}\n", self.verbose));
        output.push_str(&format!("quiet = {}\n", self.quiet));
        output.push_str(&format!("max_issues = {}\n", self.max_issues));
        output.push_str(&format!("edition = \"{}\"\n", self.edition.as_str()));
        output.push_str(&format!("output_format = \"{}\"\n", self.output_format.as_str()));
        
        if !self.lint_levels.is_empty() {
            output.push_str("\n# Lint levels\n");
            for (lint, level) in &self.lint_levels {
                output.push_str(&format!("{} = \"{}\"\n", lint, level.as_str()));
            }
        }
        
        output
    }
}

#[derive(Debug, Clone, Copy, PartialEq, Eq)]
pub enum ColorChoice {
    Auto,
    Always,
    Never,
}

#[derive(Debug, Clone, Copy, PartialEq, Eq)]
pub enum OutputFormat {
    Human,
    Short,
    Json,
    Sarif,
    Checkstyle,
}

impl OutputFormat {
    pub fn from_str(s: &str) -> Option<Self> {
        match s.to_lowercase().as_str() {
            "human" | "pretty" => Some(OutputFormat::Human),
            "short" => Some(OutputFormat::Short),
            "json" => Some(OutputFormat::Json),
            "sarif" => Some(OutputFormat::Sarif),
            "checkstyle" | "xml" => Some(OutputFormat::Checkstyle),
            _ => None,
        }
    }
    
    pub fn as_str(&self) -> &'static str {
        match self {
            OutputFormat::Human => "human",
            OutputFormat::Short => "short",
            OutputFormat::Json => "json",
            OutputFormat::Sarif => "sarif",
            OutputFormat::Checkstyle => "checkstyle",
        }
    }
}

#[derive(Debug, Clone, Copy, PartialEq, Eq)]
pub enum Edition {
    Edition2024,
    Edition2025,
}

impl Edition {
    pub fn from_str(s: &str) -> Option<Self> {
        match s {
            "2024" => Some(Edition::Edition2024),
            "2025" => Some(Edition::Edition2025),
            _ => None,
        }
    }
    
    pub fn as_str(&self) -> &'static str {
        match self {
            Edition::Edition2024 => "2024",
            Edition::Edition2025 => "2025",
        }
    }
}

#[derive(Debug)]
pub enum ConfigError {
    Parse(String),
    Io(String),
}

// ═══════════════════════════════════════════════════════════════════════════════
// LINT LEVELS
// ═══════════════════════════════════════════════════════════════════════════════

/// Lint severity level
#[derive(Debug, Clone, Copy, PartialEq, Eq, PartialOrd, Ord, Hash)]
pub enum LintLevel {
    /// Lint is completely disabled
    Allow,
    /// Emit a warning
    Warn,
    /// Emit an error (fails build)
    Deny,
    /// Like Deny, but cannot be overridden
    Forbid,
}

impl LintLevel {
    pub fn from_str(s: &str) -> Option<Self> {
        match s.to_lowercase().as_str() {
            "allow" => Some(LintLevel::Allow),
            "warn" | "warning" => Some(LintLevel::Warn),
            "deny" | "error" => Some(LintLevel::Deny),
            "forbid" => Some(LintLevel::Forbid),
            _ => None,
        }
    }
    
    pub fn as_str(&self) -> &'static str {
        match self {
            LintLevel::Allow => "allow",
            LintLevel::Warn => "warn",
            LintLevel::Deny => "deny",
            LintLevel::Forbid => "forbid",
        }
    }
    
    pub fn is_error(&self) -> bool {
        matches!(self, LintLevel::Deny | LintLevel::Forbid)
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// LINT GROUPS
// ═══════════════════════════════════════════════════════════════════════════════

/// Lint category groups
#[derive(Debug, Clone, Copy, PartialEq, Eq, PartialOrd, Ord, Hash)]
pub enum LintGroup {
    /// Definite bugs and correctness issues
    Correctness,
    /// Suspicious code that is likely wrong
    Suspicious,
    /// Stylistic issues
    Style,
    /// Performance issues
    Perf,
    /// Complexity issues
    Complexity,
    /// Pedantic lints (very strict)
    Pedantic,
    /// Security-related lints
    Security,
    /// Documentation lints
    Documentation,
    /// Restriction lints (disallow certain patterns)
    Restriction,
    /// Nursery (experimental lints)
    Nursery,
    /// Deprecated patterns
    Deprecated,
    /// Internal lints
    Internal,
}

impl LintGroup {
    pub fn from_str(s: &str) -> Option<Self> {
        match s.to_lowercase().as_str() {
            "correctness" => Some(LintGroup::Correctness),
            "suspicious" => Some(LintGroup::Suspicious),
            "style" => Some(LintGroup::Style),
            "perf" | "performance" => Some(LintGroup::Perf),
            "complexity" => Some(LintGroup::Complexity),
            "pedantic" => Some(LintGroup::Pedantic),
            "security" => Some(LintGroup::Security),
            "documentation" | "docs" => Some(LintGroup::Documentation),
            "restriction" => Some(LintGroup::Restriction),
            "nursery" => Some(LintGroup::Nursery),
            "deprecated" => Some(LintGroup::Deprecated),
            "internal" => Some(LintGroup::Internal),
            _ => None,
        }
    }
    
    pub fn as_str(&self) -> &'static str {
        match self {
            LintGroup::Correctness => "correctness",
            LintGroup::Suspicious => "suspicious",
            LintGroup::Style => "style",
            LintGroup::Perf => "perf",
            LintGroup::Complexity => "complexity",
            LintGroup::Pedantic => "pedantic",
            LintGroup::Security => "security",
            LintGroup::Documentation => "documentation",
            LintGroup::Restriction => "restriction",
            LintGroup::Nursery => "nursery",
            LintGroup::Deprecated => "deprecated",
            LintGroup::Internal => "internal",
        }
    }
    
    pub fn description(&self) -> &'static str {
        match self {
            LintGroup::Correctness => "Lints that detect definite bugs",
            LintGroup::Suspicious => "Lints that detect suspicious code patterns",
            LintGroup::Style => "Lints that enforce stylistic conventions",
            LintGroup::Perf => "Lints that detect performance issues",
            LintGroup::Complexity => "Lints that detect overly complex code",
            LintGroup::Pedantic => "Very strict lints that may have false positives",
            LintGroup::Security => "Lints that detect security vulnerabilities",
            LintGroup::Documentation => "Lints that check documentation quality",
            LintGroup::Restriction => "Lints that disallow certain patterns",
            LintGroup::Nursery => "Experimental lints under development",
            LintGroup::Deprecated => "Lints about deprecated APIs",
            LintGroup::Internal => "Internal compiler lints",
        }
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// LINT RULE DEFINITION
// ═══════════════════════════════════════════════════════════════════════════════

/// Definition of a lint rule
#[derive(Debug, Clone)]
pub struct LintRule {
    /// Unique lint name
    pub name: String,
    
    /// Human-readable description
    pub description: String,
    
    /// Lint group
    pub group: LintGroup,
    
    /// Default severity level
    pub default_level: LintLevel,
    
    /// Is this lint auto-fixable
    pub fixable: bool,
    
    /// Documentation URL
    pub docs_url: Option<String>,
    
    /// Applicability (machine applicable fix confidence)
    pub applicability: Applicability,
    
    /// Edition this lint applies to
    pub edition: Option<Edition>,
    
    /// Related lints
    pub related: Vec<String>,
    
    /// Example code that triggers this lint
    pub example_bad: Option<String>,
    
    /// Example of correct code
    pub example_good: Option<String>,
}

impl LintRule {
    pub fn new(name: &str, description: &str, group: LintGroup) -> Self {
        LintRule {
            name: name.to_string(),
            description: description.to_string(),
            group,
            default_level: LintLevel::Warn,
            fixable: false,
            docs_url: None,
            applicability: Applicability::Unspecified,
            edition: None,
            related: Vec::new(),
            example_bad: None,
            example_good: None,
        }
    }
    
    pub fn with_level(mut self, level: LintLevel) -> Self {
        self.default_level = level;
        self
    }
    
    pub fn fixable(mut self) -> Self {
        self.fixable = true;
        self.applicability = Applicability::MachineApplicable;
        self
    }
    
    pub fn with_applicability(mut self, applicability: Applicability) -> Self {
        self.applicability = applicability;
        self
    }
    
    pub fn with_docs(mut self, url: &str) -> Self {
        self.docs_url = Some(url.to_string());
        self
    }
    
    pub fn with_example(mut self, bad: &str, good: &str) -> Self {
        self.example_bad = Some(bad.to_string());
        self.example_good = Some(good.to_string());
        self
    }
}

/// Confidence level for automatic fixes
#[derive(Debug, Clone, Copy, PartialEq, Eq)]
pub enum Applicability {
    /// Fix is definitely correct
    MachineApplicable,
    /// Fix might change semantics slightly
    MaybeIncorrect,
    /// Fix has placeholders requiring manual intervention
    HasPlaceholders,
    /// Not specified
    Unspecified,
}

// ═══════════════════════════════════════════════════════════════════════════════
// HELPERS
// ═══════════════════════════════════════════════════════════════════════════════

fn glob_match(pattern: &str, text: &str) -> bool {
    if pattern == "*" {
        return true;
    }
    
    if pattern.starts_with("*.") {
        let ext = &pattern[1..];
        return text.ends_with(ext);
    }
    
    if pattern.ends_with("/*") {
        let prefix = &pattern[..pattern.len()-2];
        return text.starts_with(prefix);
    }
    
    pattern == text
}

// ═══════════════════════════════════════════════════════════════════════════════
// TESTS
// ═══════════════════════════════════════════════════════════════════════════════

#[cfg(test)]
mod tests {
    use super::*;
    
    #[test]
    fn test_lint_level() {
        assert_eq!(LintLevel::from_str("warn"), Some(LintLevel::Warn));
        assert_eq!(LintLevel::from_str("deny"), Some(LintLevel::Deny));
        assert!(LintLevel::Deny.is_error());
        assert!(!LintLevel::Warn.is_error());
    }
    
    #[test]
    fn test_lint_group() {
        assert_eq!(LintGroup::from_str("correctness"), Some(LintGroup::Correctness));
        assert_eq!(LintGroup::from_str("perf"), Some(LintGroup::Perf));
    }
    
    #[test]
    fn test_config_defaults() {
        let config = LintConfig::default();
        assert!(config.enabled_groups.contains(&LintGroup::Correctness));
        assert!(config.enabled_groups.contains(&LintGroup::Style));
    }
    
    #[test]
    fn test_lint_rule() {
        let rule = LintRule::new("unused_variable", "Variable is never used", LintGroup::Correctness)
            .with_level(LintLevel::Warn)
            .fixable();
        
        assert_eq!(rule.name, "unused_variable");
        assert!(rule.fixable);
    }
}
