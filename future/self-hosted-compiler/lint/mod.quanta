//
// The QuantaLang Linter (quantalint) provides static analysis, code quality
// checks, and best practices enforcement.
//
// Features:
// - 80+ built-in lint rules across 12 categories
// - Auto-fix support for applicable lints
// - Multiple output formats (human, JSON, SARIF, Checkstyle)
// - Configurable severity levels
// - IDE integration support
//
// ═══════════════════════════════════════════════════════════════════════════════

//! # QuantaLang Linter
//!
//! Static analysis for QuantaLang source code.
//!
//! ## Quick Start
//!
//! ```bash
//! # Lint current directory
//! quantalint
//!
//! # Lint specific files
//! quantalint src/main.quanta src/lib.quanta
//!
//! # Auto-fix issues
//! quantalint --fix
//!
//! # JSON output for CI
//! quantalint --format json
//!
//! # Deny specific lints
//! quantalint -D unused_variable -D todo
//! ```
//!
//! ## Configuration
//!
//! Create `.quantalint.toml` in your project root:
//!
//! ```toml
//! # Lint levels
//! unused_variable = "warn"
//! todo = "deny"
//! dbg_macro = "deny"
//!
//! # Options
//! fix = false
//! verbose = false
//! max_issues = 100
//! edition = "2025"
//! ```
//!
//! ## Programmatic API
//!
//! ```quanta
//! use quantalang::lint::{Linter, LintConfig};
//!
//! let config = LintConfig::default();
//! let linter = Linter::new(config);
//!
//! let diagnostics = linter.check_file("src/main.quanta")?;
//! for diag in &diagnostics {
//!     println!("{}: {}", diag.severity, diag.message);
//! }
//! ```
//!
//! ## Modules
//!
//! - [`config`] - Lint configuration and rule definitions
//! - [`rules`] - Built-in lint rule registry
//! - [`checker`] - AST visitor and checking logic
//! - [`diagnostic`] - Diagnostic types and output formatting
//! - [`cli`] - Command-line interface

module quantalang::lint

// Submodules
pub mod config;
pub mod rules;
pub mod checker;
pub mod diagnostic;
pub mod cli;

