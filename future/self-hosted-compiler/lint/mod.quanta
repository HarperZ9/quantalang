// ═══════════════════════════════════════════════════════════════════════════════

/// Main entry point for quantalint binary
pub fn main() -> Result<i32, String> {
    cli::main()
}

// ═══════════════════════════════════════════════════════════════════════════════
// TESTS
// ═══════════════════════════════════════════════════════════════════════════════

#[cfg(test)]
mod tests {
    use super::*;
    
    #[test]
    fn test_linter_new() {
        let linter = Linter::new();
        assert!(linter.config().enabled_groups.contains(&LintGroup::Correctness));
    }
    
    #[test]
    fn test_linter_builder() {
        let linter = Linter::new()
            .deny("todo")
            .deny("dbg_macro")
            .enable_group(LintGroup::Perf);
        
        assert_eq!(linter.config().lint_levels.get("todo"), Some(&LintLevel::Deny));
        assert!(linter.config().enabled_groups.contains(&LintGroup::Perf));
    }
    
    #[test]
    fn test_lint_summary() {
        let diagnostics = vec![
            Diagnostic::error("error 1"),
            Diagnostic::warning("warning 1"),
            Diagnostic::warning("warning 2"),
        ];
        
        let summary = LintSummary::from_diagnostics(&diagnostics);
        assert_eq!(summary.error_count, 1);
        assert_eq!(summary.warning_count, 2);
        assert!(!summary.is_success());
    }
    
    #[test]
    fn test_presets() {
        let strict = presets::strict();
        assert!(strict.enabled_groups.contains(&LintGroup::Pedantic));
        
        let minimal = presets::minimal();
        assert!(minimal.enabled_groups.contains(&LintGroup::Correctness));
        assert!(!minimal.enabled_groups.contains(&LintGroup::Style));
    }
}
