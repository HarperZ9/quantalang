}

/// Histogram builder
pub struct HistogramBuilder {
    name: String,
    description: String,
    unit: String,
    boundaries: Vec<f64>,
    meter: Meter,
}

impl HistogramBuilder {
    pub fn with_description(mut self, desc: impl Into<String>) -> Self {
        self.description = desc.into();
        self
    }
    
    pub fn with_unit(mut self, unit: impl Into<String>) -> Self {
        self.unit = unit.into();
        self
    }
    
    pub fn with_boundaries(mut self, boundaries: Vec<f64>) -> Self {
        self.boundaries = boundaries;
        self
    }
    
    pub fn build(self) -> Histogram {
        let histogram = Histogram {
            inner: Arc::new(HistogramInner {
                name: self.name,
                description: self.description,
                unit: self.unit,
                boundaries: self.boundaries,
                values: RwLock::new(BTreeMap::new()),
            }),
        };
        self.meter.inner.histograms.write().unwrap().push(histogram.clone());
        histogram
    }
}

/// ObservableCounter builder
pub struct ObservableCounterBuilder {
    name: String,
    description: String,
    unit: String,
    meter: Meter,
}

impl ObservableCounterBuilder {
    pub fn with_description(mut self, desc: impl Into<String>) -> Self {
        self.description = desc.into();
        self
    }
    
    pub fn with_unit(mut self, unit: impl Into<String>) -> Self {
        self.unit = unit.into();
        self
    }
    
    pub fn build(self) -> ObservableCounter {
        let counter = ObservableCounter {
            inner: Arc::new(ObservableCounterInner {
                name: self.name,
                description: self.description,
                unit: self.unit,
                callback: Mutex::new(None),
            }),
        };
        counter
    }
}

