    pub fn build(self) -> Gauge {
        let gauge = Gauge {
            inner: Arc::new(GaugeInner {
                name: self.name,
                description: self.description,
                unit: self.unit,
                values: RwLock::new(BTreeMap::new()),
            }),
        };
        self.meter.inner.gauges.write().unwrap().push(gauge.clone());
