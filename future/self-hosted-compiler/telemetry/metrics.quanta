// ═══════════════════════════════════════════════════════════════════════════════
// METER PROVIDER
// ═══════════════════════════════════════════════════════════════════════════════

/// Provider for creating meters
pub struct MeterProvider {
    inner: Arc<MeterProviderInner>,
}

struct MeterProviderInner {
    resource: Resource,
    readers: RwLock<Vec<Box<dyn MetricReader>>>,
    shutdown: std::sync::atomic::AtomicBool,
}

impl MeterProvider {
    /// Create a new builder
    pub fn builder() -> MeterProviderBuilder {
        MeterProviderBuilder::default()
    }
    
    /// Get a meter
    pub fn meter(&self, name: impl Into<String>) -> Meter {
        self.meter_with_version(name, "")
    }
    
    /// Get a meter with version
    pub fn meter_with_version(&self, name: impl Into<String>, version: impl Into<String>) -> Meter {
        Meter {
            inner: Arc::new(MeterInner {
                name: name.into(),
                version: version.into(),
                counters: RwLock::new(Vec::new()),
                up_down_counters: RwLock::new(Vec::new()),
                gauges: RwLock::new(Vec::new()),
                histograms: RwLock::new(Vec::new()),
                observable_counters: RwLock::new(Vec::new()),
                observable_gauges: RwLock::new(Vec::new()),
            }),
        }
    }
    
    /// Shutdown the provider
    pub fn shutdown(&self) {
        if !self.inner.shutdown.swap(true, Ordering::AcqRel) {
            for reader in self.inner.readers.read().unwrap().iter() {
                reader.shutdown();
            }
        }
    }
    
    /// Force flush
    pub fn force_flush(&self) {
        for reader in self.inner.readers.read().unwrap().iter() {
            reader.force_flush();
        }
    }
}

impl Drop for MeterProvider {
    fn drop(&mut self) {
        self.shutdown();
    }
}

/// Builder for meter provider
#[derive(Default)]
pub struct MeterProviderBuilder {
    resource: Option<Resource>,
    readers: Vec<Box<dyn MetricReader>>,
}

impl MeterProviderBuilder {
    pub fn with_resource(mut self, resource: Resource) -> Self {
        self.resource = Some(resource);
        self
    }
    
    pub fn with_reader<R: MetricReader + 'static>(mut self, reader: R) -> Self {
        self.readers.push(Box::new(reader));
        self
    }
    
    pub fn build(self) -> MeterProvider {
        MeterProvider {
            inner: Arc::new(MeterProviderInner {
                resource: self.resource.unwrap_or_default(),
                readers: RwLock::new(self.readers),
                shutdown: std::sync::atomic::AtomicBool::new(false),
            }),
        }
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// METRIC READER
// ═══════════════════════════════════════════════════════════════════════════════

/// Metric reader trait
pub trait MetricReader: Send + Sync {
    fn collect(&self) -> Vec<MetricData>;
    fn shutdown(&self);
    fn force_flush(&self);
}

/// Periodic exporting reader
pub struct PeriodicReader {
    exporter: Arc<dyn MetricExporter>,
    interval: Duration,
    shutdown: std::sync::atomic::AtomicBool,
}

impl PeriodicReader {
    pub fn new<E: MetricExporter + 'static>(exporter: E, interval: Duration) -> Self {
        PeriodicReader {
            exporter: Arc::new(exporter),
            interval,
            shutdown: std::sync::atomic::AtomicBool::new(false),
        }
    }
}

impl MetricReader for PeriodicReader {
    fn collect(&self) -> Vec<MetricData> {
        Vec::new()
    }
    
    fn shutdown(&self) {
        self.shutdown.store(true, Ordering::Release);
        self.exporter.shutdown();
    }
    
    fn force_flush(&self) {
        self.exporter.force_flush();
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// METRIC EXPORTER
// ═══════════════════════════════════════════════════════════════════════════════

/// Metric exporter trait
pub trait MetricExporter: Send + Sync {
    fn export(&self, metrics: Vec<MetricData>) -> Result<(), ExportError>;
    fn shutdown(&self);
    fn force_flush(&self);
}

/// Export error
#[derive(Debug)]
pub enum ExportError {
    Shutdown,
    Transport(String),
    Encoding(String),
}

/// Collected metric data
#[derive(Debug, Clone)]
pub struct MetricData {
    pub name: String,
    pub description: String,
    pub unit: String,
    pub kind: InstrumentKind,
    pub temporality: Temporality,
    pub points: Vec<DataPoint>,
}

/// Data point
#[derive(Debug, Clone)]
pub struct DataPoint {
    pub attributes: AttributeSet,
    pub timestamp: SystemTime,
    pub value: DataPointValue,
}

/// Data point value
#[derive(Debug, Clone)]
pub enum DataPointValue {
    U64(u64),
    I64(i64),
    F64(f64),
    Histogram(HistogramSnapshot),
}

/// Aggregation temporality
#[derive(Debug, Clone, Copy, PartialEq, Eq)]
pub enum Temporality {
    /// Delta since last collection
    Delta,
    /// Cumulative since start
    Cumulative,
}

/// Console exporter
pub struct ConsoleExporter;

impl MetricExporter for ConsoleExporter {
    fn export(&self, metrics: Vec<MetricData>) -> Result<(), ExportError> {
        for metric in metrics {
            println!(
                "[METRIC] {} ({:?}) - {} points",
                metric.name,
                metric.kind,
                metric.points.len()
            );
            for point in &metric.points {
                println!("  {:?}: {:?}", point.attributes, point.value);
            }
        }
        Ok(())
    }
    
    fn shutdown(&self) {}
    fn force_flush(&self) {}
}

/// In-memory exporter
pub struct InMemoryExporter {
    metrics: Mutex<Vec<MetricData>>,
}

impl InMemoryExporter {
    pub fn new() -> Self {
        InMemoryExporter { metrics: Mutex::new(Vec::new()) }
    }
    
    pub fn metrics(&self) -> Vec<MetricData> {
        self.metrics.lock().unwrap().clone()
    }
    
    pub fn clear(&self) {
        self.metrics.lock().unwrap().clear();
    }
}

impl MetricExporter for InMemoryExporter {
    fn export(&self, metrics: Vec<MetricData>) -> Result<(), ExportError> {
        self.metrics.lock().unwrap().extend(metrics);
        Ok(())
    }
    
    fn shutdown(&self) {}
    fn force_flush(&self) {}
}

impl Default for InMemoryExporter {
    fn default() -> Self { Self::new() }
}

// ═══════════════════════════════════════════════════════════════════════════════
// VIEWS
// ═══════════════════════════════════════════════════════════════════════════════

/// View for customizing metric collection
#[derive(Debug, Clone)]
pub struct View {
    /// Instrument name pattern
    pub instrument_name: Option<String>,
    /// Instrument kind filter
    pub instrument_kind: Option<InstrumentKind>,
    /// Override name
    pub name: Option<String>,
    /// Override description
    pub description: Option<String>,
    /// Attribute keys to keep
    pub attribute_keys: Option<Vec<String>>,
    /// Custom aggregation
    pub aggregation: Option<AggregationType>,
}

/// Aggregation type
#[derive(Debug, Clone)]
pub enum AggregationType {
    Sum,
    LastValue,
    ExplicitBucketHistogram(Vec<f64>),
    ExponentialHistogram,
    Drop,
}

// ═══════════════════════════════════════════════════════════════════════════════
// TESTS
// ═══════════════════════════════════════════════════════════════════════════════

#[cfg(test)]
mod tests {
    use super::*;
    
    #[test]
    fn test_counter() {
        let provider = MeterProvider::builder().build();
        let meter = provider.meter("test");
        
        let counter = meter.create_counter("requests_total")
            .with_description("Total requests")
            .build();
        
        counter.add(5);
        counter.increment();
        
        assert_eq!(counter.value(&AttributeSet::new()), 6);
    }
    
    #[test]
    fn test_counter_with_attributes() {
        let provider = MeterProvider::builder().build();
        let meter = provider.meter("test");
        let counter = meter.create_counter("requests").build();
        
        let attrs1 = AttributeSet::new().with("method", "GET");
        let attrs2 = AttributeSet::new().with("method", "POST");
        
        counter.add_with_attributes(10, attrs1.clone());
        counter.add_with_attributes(5, attrs2.clone());
        counter.add_with_attributes(3, attrs1.clone());
        
        assert_eq!(counter.value(&attrs1), 13);
        assert_eq!(counter.value(&attrs2), 5);
    }
    
    #[test]
    fn test_histogram() {
        let provider = MeterProvider::builder().build();
        let meter = provider.meter("test");
        
        let histogram = meter.create_histogram("latency")
            .with_unit("ms")
            .build();
        
        histogram.record(0.5);
        histogram.record(1.2);
        histogram.record(2.5);
        histogram.record(10.0);
        
        let data = histogram.data(&AttributeSet::new()).unwrap();
        assert_eq!(data.count, 4);
        assert!((data.sum - 14.2).abs() < 0.001);
    }
    
    #[test]
    fn test_up_down_counter() {
        let provider = MeterProvider::builder().build();
        let meter = provider.meter("test");
        
        let counter = meter.create_up_down_counter("queue_size").build();
        
        counter.add(10);
        counter.add(-3);
        counter.increment();
        counter.decrement();
        
        assert_eq!(counter.value(&AttributeSet::new()), 7);
    }
    
    #[test]
    fn test_gauge() {
        let provider = MeterProvider::builder().build();
        let meter = provider.meter("test");
        
        let gauge = meter.create_gauge("temperature").build();
        
        gauge.record(25.5);
        assert!((gauge.value(&AttributeSet::new()) - 25.5).abs() < 0.001);
        
        gauge.record(30.0);
        assert!((gauge.value(&AttributeSet::new()) - 30.0).abs() < 0.001);
    }
}
