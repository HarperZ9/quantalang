module quantalang::concurrent::lockfree

use alloc::boxed::Box;
use alloc::vec::Vec;
use alloc::sync::Arc;
use core::sync::atomic::{AtomicPtr, AtomicUsize, AtomicBool, Ordering, fence};
use core::ptr::{null_mut, NonNull};
use core::mem::MaybeUninit;
use core::cell::UnsafeCell;

// ═══════════════════════════════════════════════════════════════════════════════
// MICHAEL-SCOTT QUEUE (MPMC)
// ═══════════════════════════════════════════════════════════════════════════════

/// Lock-free multi-producer multi-consumer queue
/// 
/// Based on "Simple, Fast, and Practical Non-Blocking and Blocking
/// Concurrent Queue Algorithms" by Michael and Scott (1996).
pub struct MpMcQueue<T> {
    head: AtomicPtr<Node<T>>,
    tail: AtomicPtr<Node<T>>,
}

struct Node<T> {
    value: MaybeUninit<T>,
    next: AtomicPtr<Node<T>>,
}

impl<T> Node<T> {
    fn new(value: T) -> *mut Self {
        Box::into_raw(Box::new(Node {
            value: MaybeUninit::new(value),
            next: AtomicPtr::new(null_mut()),
        }))
    }
    
    fn sentinel() -> *mut Self {
        Box::into_raw(Box::new(Node {
            value: MaybeUninit::uninit(),
            next: AtomicPtr::new(null_mut()),
        }))
    }
}

unsafe impl<T: Send> Send for MpMcQueue<T> {}
unsafe impl<T: Send> Sync for MpMcQueue<T> {}

impl<T> MpMcQueue<T> {
    /// Create a new empty queue
    pub fn new() -> Self {
        let sentinel = Node::<T>::sentinel();
        MpMcQueue {
            head: AtomicPtr::new(sentinel),
            tail: AtomicPtr::new(sentinel),
        }
    }
    
    /// Push a value onto the queue
    pub fn push(&self, value: T) {
        let new_node = Node::new(value);
        
        loop {
            let tail = self.tail.load(Ordering::Acquire);
            let tail_ref = unsafe { &*tail };
            let next = tail_ref.next.load(Ordering::Acquire);
            
            // Check if tail is still valid
            if tail == self.tail.load(Ordering::Acquire) {
                if next.is_null() {
                    // Try to link new node
                    if tail_ref.next.compare_exchange(
                        null_mut(),
                        new_node,
                        Ordering::Release,
                        Ordering::Relaxed,
                    ).is_ok() {
                        // Try to swing tail (ok if fails, another thread will do it)
                        let _ = self.tail.compare_exchange(
                            tail,
                            new_node,
                            Ordering::Release,
                            Ordering::Relaxed,
                        );
                        return;
                    }
                } else {
                    // Tail is behind, try to advance it
                    let _ = self.tail.compare_exchange(
                        tail,
                        next,
                        Ordering::Release,
                        Ordering::Relaxed,
                    );
                }
            }
        }
    }
    
    /// Pop a value from the queue
    pub fn pop(&self) -> Option<T> {
        loop {
            let head = self.head.load(Ordering::Acquire);
            let tail = self.tail.load(Ordering::Acquire);
            let head_ref = unsafe { &*head };
            let next = head_ref.next.load(Ordering::Acquire);
            
            // Check consistency
            if head == self.head.load(Ordering::Acquire) {
                if head == tail {
                    if next.is_null() {
                        // Queue is empty
                        return None;
                    }
                    // Tail is behind, advance it
                    let _ = self.tail.compare_exchange(
                        tail,
                        next,
                        Ordering::Release,
                        Ordering::Relaxed,
                    );
                } else {
                    // Read value before CAS
                    let value = unsafe { (*next).value.as_ptr().read() };
                    
                    // Try to swing head
                    if self.head.compare_exchange(
                        head,
                        next,
                        Ordering::Release,
                        Ordering::Relaxed,
                    ).is_ok() {
                        // Free old head
                        unsafe { drop(Box::from_raw(head)) };
                        return Some(value);
                    }
                }
            }
        }
    }
    
    /// Check if queue is empty
    pub fn is_empty(&self) -> bool {
        let head = self.head.load(Ordering::Acquire);
        let tail = self.tail.load(Ordering::Acquire);
        let head_ref = unsafe { &*head };
        let next = head_ref.next.load(Ordering::Acquire);
        
        head == tail && next.is_null()
    }
}

impl<T> Default for MpMcQueue<T> {
    fn default() -> Self {
        Self::new()
    }
}

impl<T> Drop for MpMcQueue<T> {
    fn drop(&mut self) {
        while self.pop().is_some() {}
        
        // Free sentinel
        let head = self.head.load(Ordering::Relaxed);
        unsafe { drop(Box::from_raw(head)) };
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// TREIBER STACK (MPMC)
// ═══════════════════════════════════════════════════════════════════════════════

/// Lock-free multi-producer multi-consumer stack
///
/// Based on Treiber's stack algorithm (1986).
pub struct MpMcStack<T> {
    head: AtomicPtr<StackNode<T>>,
}

struct StackNode<T> {
    value: T,
    next: *mut StackNode<T>,
}

unsafe impl<T: Send> Send for MpMcStack<T> {}
unsafe impl<T: Send> Sync for MpMcStack<T> {}

impl<T> MpMcStack<T> {
    /// Create a new empty stack
    pub fn new() -> Self {
        MpMcStack {
            head: AtomicPtr::new(null_mut()),
        }
    }
    
    /// Push a value onto the stack
    pub fn push(&self, value: T) {
        let new_node = Box::into_raw(Box::new(StackNode {
            value,
            next: null_mut(),
        }));
        
        loop {
            let head = self.head.load(Ordering::Acquire);
            unsafe { (*new_node).next = head };
            
            if self.head.compare_exchange_weak(
                head,
                new_node,
                Ordering::Release,
                Ordering::Relaxed,
            ).is_ok() {
                return;
            }
        }
    }
    
    /// Pop a value from the stack
    pub fn pop(&self) -> Option<T> {
        loop {
            let head = self.head.load(Ordering::Acquire);
            
            if head.is_null() {
                return None;
            }
            
            let next = unsafe { (*head).next };
            
            if self.head.compare_exchange_weak(
                head,
                next,
                Ordering::Release,
                Ordering::Relaxed,
            ).is_ok() {
                let node = unsafe { Box::from_raw(head) };
                return Some(node.value);
            }
        }
    }
    
    /// Check if stack is empty
    pub fn is_empty(&self) -> bool {
        self.head.load(Ordering::Acquire).is_null()
    }
    
    /// Peek at top value without removing
    pub fn peek(&self) -> Option<&T> {
        let head = self.head.load(Ordering::Acquire);
        if head.is_null() {
            None
        } else {
            unsafe { Some(&(*head).value) }
        }
    }
}

impl<T> Default for MpMcStack<T> {
    fn default() -> Self {
        Self::new()
    }
}

impl<T> Drop for MpMcStack<T> {
    fn drop(&mut self) {
        while self.pop().is_some() {}
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// WORK-STEALING DEQUE (Chase-Lev)
// ═══════════════════════════════════════════════════════════════════════════════

/// Work-stealing deque for efficient task scheduling
///
/// Based on "Dynamic Circular Work-Stealing Deque" by
/// Chase and Lev (2005).
pub struct WorkStealingDeque<T> {
    buffer: AtomicPtr<Buffer<T>>,
    top: AtomicUsize,
    bottom: AtomicUsize,
}

struct Buffer<T> {
    capacity: usize,
    mask: usize,
    storage: Box<[UnsafeCell<MaybeUninit<T>>]>,
}

impl<T> Buffer<T> {
    fn new(capacity: usize) -> *mut Self {
        let capacity = capacity.next_power_of_two();
        let storage: Vec<_> = (0..capacity)
            .map(|_| UnsafeCell::new(MaybeUninit::uninit()))
            .collect();
        
        Box::into_raw(Box::new(Buffer {
            capacity,
            mask: capacity - 1,
            storage: storage.into_boxed_slice(),
        }))
    }
    
    unsafe fn get(&self, index: usize) -> T {
        let slot = &self.storage[index & self.mask];
        (*slot.get()).as_ptr().read()
    }
    
    unsafe fn put(&self, index: usize, value: T) {
        let slot = &self.storage[index & self.mask];
        (*slot.get()).as_mut_ptr().write(value);
    }
    
    fn resize(&self, bottom: usize, top: usize) -> *mut Self {
        let new_capacity = self.capacity * 2;
        let new_buffer = Buffer::<T>::new(new_capacity);
        
        unsafe {
            let new_ref = &*new_buffer;
            for i in top..bottom {
                new_ref.put(i, self.get(i));
            }
        }
        
        new_buffer
    }
}

unsafe impl<T: Send> Send for WorkStealingDeque<T> {}
unsafe impl<T: Send> Sync for WorkStealingDeque<T> {}

impl<T> WorkStealingDeque<T> {
    /// Create a new deque with given capacity
    pub fn new(capacity: usize) -> Self {
        WorkStealingDeque {
            buffer: AtomicPtr::new(Buffer::new(capacity)),
            top: AtomicUsize::new(0),
            bottom: AtomicUsize::new(0),
        }
    }
    
    /// Push a value to the bottom (owner only)
    pub fn push(&self, value: T) {
        let bottom = self.bottom.load(Ordering::Relaxed);
        let top = self.top.load(Ordering::Acquire);
        let buffer = self.buffer.load(Ordering::Relaxed);
        let buffer_ref = unsafe { &*buffer };
        
        let size = bottom.wrapping_sub(top);
        
        // Check if need to grow
        if size >= buffer_ref.capacity - 1 {
            let new_buffer = buffer_ref.resize(bottom, top);
            self.buffer.store(new_buffer, Ordering::Release);
            // Old buffer leaked for simplicity (would need epoch-based reclamation)
        }
        
        let buffer = self.buffer.load(Ordering::Relaxed);
        unsafe { (*buffer).put(bottom, value) };
        fence(Ordering::Release);
        self.bottom.store(bottom.wrapping_add(1), Ordering::Relaxed);
    }
    
    /// Pop a value from the bottom (owner only)
    pub fn pop(&self) -> Option<T> {
        let bottom = self.bottom.load(Ordering::Relaxed).wrapping_sub(1);
        let buffer = self.buffer.load(Ordering::Relaxed);
        
        self.bottom.store(bottom, Ordering::Relaxed);
        fence(Ordering::SeqCst);
        
        let top = self.top.load(Ordering::Relaxed);
        
        if top <= bottom {
            // Non-empty
            let value = unsafe { (*buffer).get(bottom) };
            
            if top == bottom {
                // Last element, race with steal
                if self.top.compare_exchange(
                    top,
                    top.wrapping_add(1),
                    Ordering::SeqCst,
                    Ordering::Relaxed,
                ).is_err() {
                    // Lost race
                    self.bottom.store(bottom.wrapping_add(1), Ordering::Relaxed);
                    return None;
                }
                self.bottom.store(bottom.wrapping_add(1), Ordering::Relaxed);
            }
            
            Some(value)
        } else {
            // Empty
            self.bottom.store(bottom.wrapping_add(1), Ordering::Relaxed);
            None
        }
    }
    
    /// Steal a value from the top (thieves)
    pub fn steal(&self) -> Steal<T> {
        let top = self.top.load(Ordering::Acquire);
        fence(Ordering::SeqCst);
        let bottom = self.bottom.load(Ordering::Acquire);
        
        if top >= bottom {
            return Steal::Empty;
        }
        
        let buffer = self.buffer.load(Ordering::Acquire);
        let value = unsafe { (*buffer).get(top) };
        
        if self.top.compare_exchange(
            top,
            top.wrapping_add(1),
            Ordering::SeqCst,
            Ordering::Relaxed,
        ).is_ok() {
            Steal::Success(value)
        } else {
            // Failed, another thief got it
            Steal::Retry
        }
    }
    
    /// Check if deque is empty
    pub fn is_empty(&self) -> bool {
        let top = self.top.load(Ordering::Acquire);
        let bottom = self.bottom.load(Ordering::Acquire);
        top >= bottom
    }
    
    /// Get approximate length
    pub fn len(&self) -> usize {
        let top = self.top.load(Ordering::Acquire);
        let bottom = self.bottom.load(Ordering::Acquire);
        bottom.saturating_sub(top)
    }
    
    /// Create a stealer handle
    pub fn stealer(&self) -> Stealer<T> {
        Stealer { deque: self }
    }
}

/// Result of a steal operation
pub enum Steal<T> {
    /// Successfully stolen a value
    Success(T),
    /// Deque was empty
    Empty,
    /// Need to retry (contention)
    Retry,
}

/// Handle for stealing from a deque
pub struct Stealer<'a, T> {
    deque: &'a WorkStealingDeque<T>,
}

impl<'a, T> Stealer<'a, T> {
    /// Steal a value
    pub fn steal(&self) -> Steal<T> {
        self.deque.steal()
    }
    
    /// Check if empty
    pub fn is_empty(&self) -> bool {
        self.deque.is_empty()
    }
}

impl<T> Default for WorkStealingDeque<T> {
    fn default() -> Self {
        Self::new(256)
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// SPSC QUEUE (Single-Producer Single-Consumer)
// ═══════════════════════════════════════════════════════════════════════════════

/// High-performance single-producer single-consumer queue
pub struct SpscQueue<T> {
    buffer: Box<[UnsafeCell<MaybeUninit<T>>]>,
    capacity: usize,
    mask: usize,
    head: AtomicUsize,
    tail: AtomicUsize,
    _marker: std::marker::PhantomData<T>,
}

unsafe impl<T: Send> Send for SpscQueue<T> {}
unsafe impl<T: Send> Sync for SpscQueue<T> {}

impl<T> SpscQueue<T> {
    /// Create a new queue with given capacity
    pub fn new(capacity: usize) -> Self {
        let capacity = capacity.next_power_of_two();
        let buffer: Vec<_> = (0..capacity)
            .map(|_| UnsafeCell::new(MaybeUninit::uninit()))
            .collect();
        
        SpscQueue {
            buffer: buffer.into_boxed_slice(),
            capacity,
            mask: capacity - 1,
            head: AtomicUsize::new(0),
            tail: AtomicUsize::new(0),
            _marker: std::marker::PhantomData,
        }
    }
    
    /// Push a value (producer only)
    pub fn push(&self, value: T) -> Result<(), T> {
        let tail = self.tail.load(Ordering::Relaxed);
        let head = self.head.load(Ordering::Acquire);
        
        if tail.wrapping_sub(head) >= self.capacity {
            return Err(value);
        }
        
        let slot = &self.buffer[tail & self.mask];
        unsafe { (*slot.get()).as_mut_ptr().write(value) };
        
        self.tail.store(tail.wrapping_add(1), Ordering::Release);
        Ok(())
    }
    
    /// Pop a value (consumer only)
    pub fn pop(&self) -> Option<T> {
        let head = self.head.load(Ordering::Relaxed);
        let tail = self.tail.load(Ordering::Acquire);
        
        if head >= tail {
            return None;
        }
        
        let slot = &self.buffer[head & self.mask];
        let value = unsafe { (*slot.get()).as_ptr().read() };
        
        self.head.store(head.wrapping_add(1), Ordering::Release);
        Some(value)
    }
    
    /// Check if empty
    pub fn is_empty(&self) -> bool {
        let head = self.head.load(Ordering::Acquire);
        let tail = self.tail.load(Ordering::Acquire);
        head >= tail
    }
    
    /// Check if full
    pub fn is_full(&self) -> bool {
        let head = self.head.load(Ordering::Acquire);
        let tail = self.tail.load(Ordering::Acquire);
        tail.wrapping_sub(head) >= self.capacity
    }
    
    /// Get length
    pub fn len(&self) -> usize {
        let head = self.head.load(Ordering::Acquire);
        let tail = self.tail.load(Ordering::Acquire);
        tail.wrapping_sub(head)
    }
    
    /// Get capacity
    pub fn capacity(&self) -> usize {
        self.capacity
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// ATOMIC CELL
// ═══════════════════════════════════════════════════════════════════════════════

/// Atomic cell for values that fit in a pointer
pub struct AtomicCell<T: Copy> {
    value: AtomicUsize,
    _marker: std::marker::PhantomData<T>,
}

impl<T: Copy> AtomicCell<T> {
    /// Create a new atomic cell
    pub fn new(value: T) -> Self {
        assert!(std::mem::size_of::<T>() <= std::mem::size_of::<usize>());
        
        let bits = unsafe { std::mem::transmute_copy::<T, usize>(&value) };
        AtomicCell {
            value: AtomicUsize::new(bits),
            _marker: std::marker::PhantomData,
        }
    }
    
    /// Load the value
    pub fn load(&self, order: Ordering) -> T {
        let bits = self.value.load(order);
        unsafe { std::mem::transmute_copy::<usize, T>(&bits) }
    }
    
    /// Store a value
    pub fn store(&self, value: T, order: Ordering) {
        let bits = unsafe { std::mem::transmute_copy::<T, usize>(&value) };
        self.value.store(bits, order);
    }
    
    /// Swap values
    pub fn swap(&self, value: T, order: Ordering) -> T {
        let bits = unsafe { std::mem::transmute_copy::<T, usize>(&value) };
        let old = self.value.swap(bits, order);
        unsafe { std::mem::transmute_copy::<usize, T>(&old) }
    }
    
    /// Compare and exchange
    pub fn compare_exchange(
        &self,
        current: T,
        new: T,
        success: Ordering,
        failure: Ordering,
    ) -> Result<T, T> {
        let current_bits = unsafe { std::mem::transmute_copy::<T, usize>(&current) };
        let new_bits = unsafe { std::mem::transmute_copy::<T, usize>(&new) };
        
        match self.value.compare_exchange(current_bits, new_bits, success, failure) {
            Ok(old) => Ok(unsafe { std::mem::transmute_copy::<usize, T>(&old) }),
            Err(old) => Err(unsafe { std::mem::transmute_copy::<usize, T>(&old) }),
        }
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// SEQUENCE LOCK
// ═══════════════════════════════════════════════════════════════════════════════

/// Sequence lock for read-heavy workloads
pub struct SeqLock<T> {
    seq: AtomicUsize,
    data: UnsafeCell<T>,
}

unsafe impl<T: Send> Send for SeqLock<T> {}
unsafe impl<T: Send + Sync> Sync for SeqLock<T> {}

impl<T: Copy> SeqLock<T> {
    /// Create a new sequence lock
    pub const fn new(value: T) -> Self {
        SeqLock {
            seq: AtomicUsize::new(0),
            data: UnsafeCell::new(value),
        }
    }
    
    /// Read the value (may retry on write contention)
    pub fn read(&self) -> T {
        loop {
            let seq1 = self.seq.load(Ordering::Acquire);
            
            // Odd sequence means write in progress
            if seq1 & 1 != 0 {
                std::hint::spin_loop();
                continue;
            }
            
            let value = unsafe { *self.data.get() };
            fence(Ordering::Acquire);
            
            let seq2 = self.seq.load(Ordering::Relaxed);
            
            if seq1 == seq2 {
                return value;
            }
            
            std::hint::spin_loop();
        }
    }
    
    /// Write a value
    pub fn write(&self, value: T) {
        let seq = self.seq.fetch_add(1, Ordering::Relaxed);
        fence(Ordering::Release);
        
        unsafe { *self.data.get() = value };
        
        fence(Ordering::Release);
        self.seq.store(seq + 2, Ordering::Release);
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// TESTS
// ═══════════════════════════════════════════════════════════════════════════════

#[cfg(test)]
mod tests {
    use super::*;
    
    #[test]
    fn test_mpmc_queue() {
        let queue = MpMcQueue::new();
        queue.push(1);
        queue.push(2);
        queue.push(3);
        
        assert_eq!(queue.pop(), Some(1));
        assert_eq!(queue.pop(), Some(2));
        assert_eq!(queue.pop(), Some(3));
        assert_eq!(queue.pop(), None);
    }
    
    #[test]
    fn test_mpmc_stack() {
        let stack = MpMcStack::new();
        stack.push(1);
        stack.push(2);
        stack.push(3);
        
        assert_eq!(stack.pop(), Some(3));
        assert_eq!(stack.pop(), Some(2));
        assert_eq!(stack.pop(), Some(1));
        assert_eq!(stack.pop(), None);
    }
    
    #[test]
    fn test_work_stealing_deque() {
        let deque = WorkStealingDeque::new(16);
        deque.push(1);
        deque.push(2);
        deque.push(3);
        
        // Pop from bottom (LIFO for owner)
        assert_eq!(deque.pop(), Some(3));
        
        // Steal from top (FIFO for thieves)
        match deque.steal() {
            Steal::Success(v) => assert_eq!(v, 1),
            _ => panic!("expected success"),
        }
    }
    
    #[test]
    fn test_spsc_queue() {
        let queue = SpscQueue::new(4);
        assert!(queue.push(1).is_ok());
        assert!(queue.push(2).is_ok());
        
        assert_eq!(queue.pop(), Some(1));
        assert_eq!(queue.pop(), Some(2));
        assert_eq!(queue.pop(), None);
    }
    
    #[test]
    fn test_atomic_cell() {
        let cell = AtomicCell::new(42u32);
        assert_eq!(cell.load(Ordering::SeqCst), 42);
        
        cell.store(100, Ordering::SeqCst);
        assert_eq!(cell.load(Ordering::SeqCst), 100);
    }
    
    #[test]
    fn test_seqlock() {
        let lock = SeqLock::new(42);
        assert_eq!(lock.read(), 42);
        
        lock.write(100);
        assert_eq!(lock.read(), 100);
    }
}
