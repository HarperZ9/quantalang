//
// High-performance concurrency primitives for QuantaLang.
//
// Features:
// - Lock-free data structures (Queue, Stack, Deque)
// - Work-stealing thread pool
// - Extended atomic operations
// - Parallel iterators (rayon-style)
//
// ═══════════════════════════════════════════════════════════════════════════════

//! # QuantaLang Concurrent
//!
//! High-performance concurrency primitives and parallel execution.
//!
//! ## Quick Start
//!
//! ```quanta
//! use quantalang::concurrent::{spawn, join, par_iter};
//!
//! // Parallel iteration
//! let data: Vec<i32> = (0..1000).collect();
//! let sum: i32 = data.par_iter()
//!     .map(|x| x * 2)
//!     .sum();
//!
//! // Fork-join parallelism
//! let (a, b) = join(
//!     || expensive_computation_a(),
//!     || expensive_computation_b(),
//! );
//! ```
//!
//! ## Lock-Free Structures
//!
//! ```quanta
//! use quantalang::concurrent::lockfree::{MpMcQueue, MpMcStack};
//!
//! let queue = MpMcQueue::new();
//! queue.push(42);
//! assert_eq!(queue.pop(), Some(42));
//! ```
//!
//! ## Thread Pool
//!
//! ```quanta
//! use quantalang::concurrent::pool::ThreadPool;
//!
//! let pool = ThreadPool::with_threads(4);
//! pool.submit(|| println!("Hello from worker!"));
//! pool.shutdown();
//! ```

