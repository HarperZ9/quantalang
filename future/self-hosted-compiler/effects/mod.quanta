// ═══════════════════════════════════════════════════════════════════════════════
// TESTS
// ═══════════════════════════════════════════════════════════════════════════════

#[cfg(test)]
mod tests {
    use super::*;
    
    #[test]
    fn test_effect_checker() {
        let mut checker = EffectChecker::new();
        
        checker.register_effect(Effect {
            id: EffectId::new("IO"),
            operations: vec![
                Operation {
                    name: "print".to_string(),
                    params: vec![Type::String],
                    return_type: Type::Unit,
                    resumable: true,
                    doc: None,
                },
            ],
            type_params: vec![],
            doc: None,
        });
        
        // Test effect inference
        let expr = Expr::Perform(
            EffectId::new("IO"),
            "print".to_string(),
            vec![Expr::Lit(Literal::String("hello".to_string()))],
        );
        
        let effects = checker.infer_effects(&expr).unwrap();
        assert!(effects.contains(&EffectId::new("IO")));
    }
    
    #[test]
    fn test_effect_subset_check() {
        let checker = EffectChecker::new();
        
        let mut declared = EffectSet::new();
        declared.add(EffectId::new("IO"));
        declared.add(EffectId::new("State"));
        
        let mut actual = EffectSet::new();
        actual.add(EffectId::new("IO"));
        
        assert!(checker.check_effects(&declared, &actual).is_ok());
        
        actual.add(EffectId::new("Exception"));
        assert!(checker.check_effects(&declared, &actual).is_err());
    }
    
    #[test]
    fn test_handle_transforms() {
        let body = Expr::Lit(Literal::Unit);
        let handler = Handler {
            effect: EffectId::new("IO"),
            operations: BTreeMap::new(),
            return_clause: None,
            finally_clause: None,
        };
        
        let expr = Expr::Handle(Box::new(body), vec![handler]);
        let transformed = EffectTransform::to_cps(&expr);
        
        // Should still be a handle expression
        assert!(matches!(transformed, Expr::Handle(_, _)));
    }
}
