// ═══════════════════════════════════════════════════════════════════════════════
// OPTIMIZATION LEVELS
// ═══════════════════════════════════════════════════════════════════════════════

/// Optimization level
#[derive(Debug, Clone, Copy, PartialEq, Eq, PartialOrd, Ord)]
pub enum OptLevel {
    /// No optimization
    O0,
    /// Basic optimization
    O1,
    /// Standard optimization
    O2,
    /// Aggressive optimization
    O3,
    /// Size optimization
    Os,
    /// Aggressive size optimization
    Oz,
}

impl OptLevel {
    pub fn from_str(s: &str) -> Option<Self> {
        match s {
            "0" | "O0" => Some(OptLevel::O0),
            "1" | "O1" => Some(OptLevel::O1),
            "2" | "O2" => Some(OptLevel::O2),
            "3" | "O3" => Some(OptLevel::O3),
            "s" | "Os" => Some(OptLevel::Os),
            "z" | "Oz" => Some(OptLevel::Oz),
            _ => None,
        }
    }
    
    pub fn inline_threshold(&self) -> i32 {
        match self {
            OptLevel::O0 => 0,
            OptLevel::O1 => 150,
            OptLevel::O2 => 250,
            OptLevel::O3 => 500,
            OptLevel::Os => 75,
            OptLevel::Oz => 25,
        }
    }
    
    pub fn unroll_threshold(&self) -> u32 {
        match self {
            OptLevel::O0 | OptLevel::Os | OptLevel::Oz => 0,
            OptLevel::O1 => 50,
            OptLevel::O2 => 200,
            OptLevel::O3 => 400,
        }
    }
    
    pub fn vectorize(&self) -> bool {
        matches!(self, OptLevel::O2 | OptLevel::O3)
    }
    
    pub fn lto_mode(&self) -> LtoMode {
        match self {
            OptLevel::O3 => LtoMode::Full,
            OptLevel::O2 | OptLevel::Os => LtoMode::Thin,
            _ => LtoMode::None,
        }
    }
}

#[derive(Debug, Clone, Copy, PartialEq, Eq)]
pub enum LtoMode {
    None,
    Thin,
    Full,
}

// ═══════════════════════════════════════════════════════════════════════════════
// PASS INTERFACE
// ═══════════════════════════════════════════════════════════════════════════════

/// Pass result
#[derive(Debug, Clone)]
pub struct PassResult {
    /// Whether the pass modified the IR
    pub modified: bool,
    /// Number of transformations applied
    pub transformations: u32,
    /// Execution time
    pub duration: Duration,
    /// Pass-specific statistics
    pub stats: BTreeMap<String, u64>,
}

impl PassResult {
    pub fn unchanged() -> Self {
        PassResult {
            modified: false,
            transformations: 0,
            duration: Duration::ZERO,
            stats: BTreeMap::new(),
        }
    }
    
    pub fn changed(transformations: u32) -> Self {
        PassResult {
            modified: true,
            transformations,
            duration: Duration::ZERO,
            stats: BTreeMap::new(),
        }
    }
    
    pub fn with_stat(mut self, name: impl Into<String>, value: u64) -> Self {
        self.stats.insert(name.into(), value);
        self
    }
}

/// Pass trait for function passes
pub trait FunctionPass: Send + Sync {
    /// Pass name
    fn name(&self) -> &str;
    
    /// Run the pass on a function
    fn run(&mut self, func: &mut MirFunction, ctx: &PassContext) -> PassResult;
    
    /// Pass dependencies
    fn dependencies(&self) -> Vec<&str> {
        Vec::new()
    }
    
    /// Passes invalidated by this pass
    fn invalidates(&self) -> Vec<&str> {
        Vec::new()
    }
    
    /// Whether this pass preserves CFG
    fn preserves_cfg(&self) -> bool {
        true
    }
}

/// Pass trait for module passes
pub trait ModulePass: Send + Sync {
    /// Pass name
    fn name(&self) -> &str;
    
    /// Run the pass on a module
    fn run(&mut self, module: &mut MirModule, ctx: &PassContext) -> PassResult;
    
    /// Pass dependencies
    fn dependencies(&self) -> Vec<&str> {
        Vec::new()
    }
    
    /// Passes invalidated by this pass
    fn invalidates(&self) -> Vec<&str> {
        Vec::new()
    }
}

/// Pass context provides shared state for passes
#[derive(Debug)]
pub struct PassContext {
    /// Optimization level
    pub opt_level: OptLevel,
    /// Target information
    pub target: TargetInfo,
    /// Analysis results cache
    analyses: BTreeMap<String, Arc<dyn std::any::Any + Send + Sync>>,
    /// Debug output enabled
    pub debug: bool,
    /// Statistics collection enabled
    pub collect_stats: bool,
}

impl PassContext {
    pub fn new(opt_level: OptLevel, target: TargetInfo) -> Self {
        PassContext {
            opt_level,
            target,
            analyses: BTreeMap::new(),
            debug: false,
            collect_stats: true,
        }
    }
    
    /// Cache an analysis result
    pub fn cache_analysis<T: std::any::Any + Send + Sync>(&mut self, name: &str, analysis: T) {
        self.analyses.insert(name.to_string(), Arc::new(analysis));
    }
    
    /// Get a cached analysis result
    pub fn get_analysis<T: std::any::Any + Send + Sync + Clone>(&self, name: &str) -> Option<T> {
        self.analyses.get(name)
            .and_then(|a| a.downcast_ref::<T>().cloned())
    }
    
    /// Invalidate an analysis
    pub fn invalidate(&mut self, name: &str) {
        self.analyses.remove(name);
    }
    
    /// Invalidate all analyses
    pub fn invalidate_all(&mut self) {
        self.analyses.clear();
    }
}

/// Target information for optimization decisions
#[derive(Debug, Clone)]
pub struct TargetInfo {
    /// Target triple
    pub triple: String,
    /// Pointer size in bytes
    pub pointer_size: u32,
    /// Vector width in bits
    pub vector_width: u32,
    /// Cache line size
    pub cache_line_size: u32,
    /// Has hardware division
    pub has_hw_div: bool,
    /// Has hardware FMA
    pub has_fma: bool,
}

impl Default for TargetInfo {
    fn default() -> Self {
        TargetInfo {
            triple: "x86_64-unknown-linux-gnu".to_string(),
            pointer_size: 8,
            vector_width: 256,
            cache_line_size: 64,
            has_hw_div: true,
            has_fma: true,
        }
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// PASS MANAGER
// ═══════════════════════════════════════════════════════════════════════════════

/// Function pass manager
pub struct FunctionPassManager {
    /// Registered passes
    passes: Vec<Box<dyn FunctionPass>>,
    /// Pass context
    ctx: PassContext,
    /// Statistics
    stats: PipelineStats,
}

impl FunctionPassManager {
    pub fn new(ctx: PassContext) -> Self {
        FunctionPassManager {
            passes: Vec::new(),
            ctx,
            stats: PipelineStats::new(),
        }
    }
    
    /// Add a pass to the pipeline
    pub fn add_pass<P: FunctionPass + 'static>(&mut self, pass: P) {
        self.passes.push(Box::new(pass));
    }
    
    /// Run all passes on a function
    pub fn run(&mut self, func: &mut MirFunction) -> PipelineResult {
        let start = Instant::now();
        let mut total_transformations = 0;
        let mut modified = false;
        
        for pass in &mut self.passes {
            let pass_start = Instant::now();
            
            let result = pass.run(func, &self.ctx);
            
            let duration = pass_start.elapsed();
            
            if result.modified {
                modified = true;
                total_transformations += result.transformations;
                
                // Invalidate analyses affected by this pass
                for inv in pass.invalidates() {
                    self.ctx.invalidate(inv);
                }
                
                if !pass.preserves_cfg() {
                    self.ctx.invalidate("cfg");
                    self.ctx.invalidate("dom_tree");
                    self.ctx.invalidate("loop_info");
                }
            }
            
            self.stats.record_pass(pass.name(), &result, duration);
        }
        
        PipelineResult {
            modified,
            total_transformations,
            total_duration: start.elapsed(),
            pass_results: self.stats.pass_stats.clone(),
        }
    }
    
    /// Run passes until fixed point
    pub fn run_until_fixed_point(&mut self, func: &mut MirFunction, max_iterations: u32) -> PipelineResult {
        let start = Instant::now();
        let mut total_transformations = 0;
        let mut iterations = 0;
        
        loop {
            let mut modified = false;
            
            for pass in &mut self.passes {
                let result = pass.run(func, &self.ctx);
                
                if result.modified {
                    modified = true;
                    total_transformations += result.transformations;
                    
                    for inv in pass.invalidates() {
                        self.ctx.invalidate(inv);
                    }
                }
            }
            
            iterations += 1;
            
            if !modified || iterations >= max_iterations {
                break;
            }
        }
        
        PipelineResult {
            modified: total_transformations > 0,
            total_transformations,
            total_duration: start.elapsed(),
            pass_results: self.stats.pass_stats.clone(),
        }
    }
    
    /// Get statistics
    pub fn stats(&self) -> &PipelineStats {
        &self.stats
    }
}

/// Module pass manager
pub struct ModulePassManager {
    /// Registered passes
    passes: Vec<Box<dyn ModulePass>>,
    /// Function pass manager to run on each function
    function_pm: Option<FunctionPassManager>,
    /// Pass context
    ctx: PassContext,
    /// Statistics
    stats: PipelineStats,
}

impl ModulePassManager {
    pub fn new(ctx: PassContext) -> Self {
        ModulePassManager {
            passes: Vec::new(),
            function_pm: None,
            ctx,
            stats: PipelineStats::new(),
        }
    }
    
    /// Add a module pass
    pub fn add_pass<P: ModulePass + 'static>(&mut self, pass: P) {
        self.passes.push(Box::new(pass));
    }
    
    /// Set function pass manager
    pub fn set_function_pm(&mut self, pm: FunctionPassManager) {
        self.function_pm = Some(pm);
    }
    
    /// Run all passes on a module
    pub fn run(&mut self, module: &mut MirModule) -> PipelineResult {
        let start = Instant::now();
        let mut total_transformations = 0;
        let mut modified = false;
        
        // Run module passes
        for pass in &mut self.passes {
            let pass_start = Instant::now();
            
            let result = pass.run(module, &self.ctx);
            
            let duration = pass_start.elapsed();
            
            if result.modified {
                modified = true;
                total_transformations += result.transformations;
                
                for inv in pass.invalidates() {
                    self.ctx.invalidate(inv);
                }
            }
            
            self.stats.record_pass(pass.name(), &result, duration);
        }
        
        // Run function passes on each function
        if let Some(ref mut fpm) = self.function_pm {
            for func in &mut module.functions {
                let result = fpm.run(func);
                
                if result.modified {
                    modified = true;
                    total_transformations += result.total_transformations;
                }
            }
        }
        
        PipelineResult {
            modified,
            total_transformations,
            total_duration: start.elapsed(),
            pass_results: self.stats.pass_stats.clone(),
        }
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// PIPELINE STATISTICS
// ═══════════════════════════════════════════════════════════════════════════════

/// Pipeline execution result
#[derive(Debug, Clone)]
pub struct PipelineResult {
    /// Whether any pass modified the IR
    pub modified: bool,
    /// Total number of transformations
    pub total_transformations: u32,
    /// Total execution time
    pub total_duration: Duration,
    /// Per-pass results
    pub pass_results: BTreeMap<String, PassStats>,
}

/// Per-pass statistics
#[derive(Debug, Clone, Default)]
pub struct PassStats {
    /// Number of times the pass ran
    pub runs: u32,
    /// Total transformations
    pub transformations: u32,
    /// Total execution time
    pub duration: Duration,
    /// Custom statistics
    pub custom: BTreeMap<String, u64>,
}

/// Pipeline statistics collector
#[derive(Debug, Clone)]
pub struct PipelineStats {
    /// Per-pass statistics
    pub pass_stats: BTreeMap<String, PassStats>,
    /// Total passes run
    pub total_passes: u32,
    /// Total time
    pub total_time: Duration,
}

impl PipelineStats {
    pub fn new() -> Self {
        PipelineStats {
            pass_stats: BTreeMap::new(),
            total_passes: 0,
            total_time: Duration::ZERO,
        }
    }
    
    /// Record a pass execution
    pub fn record_pass(&mut self, name: &str, result: &PassResult, duration: Duration) {
        let stats = self.pass_stats.entry(name.to_string()).or_default();
        
        stats.runs += 1;
        stats.transformations += result.transformations;
        stats.duration += duration;
        
        for (k, v) in &result.stats {
            *stats.custom.entry(k.clone()).or_default() += v;
        }
        
        self.total_passes += 1;
        self.total_time += duration;
    }
    
    /// Print statistics report
    pub fn report(&self) -> String {
        let mut report = String::new();
        
        report.push_str("=== Optimization Pipeline Statistics ===\n\n");
        
        report.push_str(&format!("Total passes run: {}\n", self.total_passes));
        report.push_str(&format!("Total time: {:?}\n\n", self.total_time));
        
        report.push_str("Per-pass breakdown:\n");
        report.push_str("-".repeat(60).as_str());
        report.push('\n');
        
        for (name, stats) in &self.pass_stats {
            report.push_str(&format!(
                "{}: {} runs, {} transforms, {:?}\n",
                name, stats.runs, stats.transformations, stats.duration
            ));
            
            for (key, value) in &stats.custom {
                report.push_str(&format!("  {}: {}\n", key, value));
            }
        }
        
        report
    }
}

impl Default for PipelineStats {
    fn default() -> Self {
        Self::new()
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// STANDARD PIPELINES
// ═══════════════════════════════════════════════════════════════════════════════

/// Build a standard optimization pipeline
pub fn build_standard_pipeline(opt_level: OptLevel, target: TargetInfo) -> ModulePassManager {
    let ctx = PassContext::new(opt_level, target);
    let mut mpm = ModulePassManager::new(ctx.clone());
    let mut fpm = FunctionPassManager::new(ctx);
    
    match opt_level {
        OptLevel::O0 => {
            // Minimal passes for debug builds
            fpm.add_pass(SimplifyCfgPass::new());
        }
        OptLevel::O1 => {
            // Basic optimizations
            fpm.add_pass(SimplifyCfgPass::new());
            fpm.add_pass(ConstantFoldingPass::new());
            fpm.add_pass(DeadCodeEliminationPass::new());
            fpm.add_pass(CopyPropagationPass::new());
        }
        OptLevel::O2 => {
            // Standard optimizations
            fpm.add_pass(SimplifyCfgPass::new());
            fpm.add_pass(ConstantFoldingPass::new());
            fpm.add_pass(ScalarReplacementPass::new());
            fpm.add_pass(GvnPass::new());
            fpm.add_pass(LicmPass::new());
            fpm.add_pass(DeadCodeEliminationPass::new());
            fpm.add_pass(LoopUnrollPass::new(200));
            fpm.add_pass(SimplifyCfgPass::new());
            
            mpm.add_pass(InliningPass::new(250));
            mpm.add_pass(GlobalDcePass::new());
        }
        OptLevel::O3 => {
            // Aggressive optimizations
            fpm.add_pass(SimplifyCfgPass::new());
            fpm.add_pass(ConstantFoldingPass::new());
            fpm.add_pass(ScalarReplacementPass::new());
            fpm.add_pass(GvnPass::new());
            fpm.add_pass(LicmPass::new());
            fpm.add_pass(LoopVectorizePass::new());
            fpm.add_pass(SlpVectorizePass::new());
            fpm.add_pass(DeadCodeEliminationPass::new());
            fpm.add_pass(LoopUnrollPass::new(400));
            fpm.add_pass(SimplifyCfgPass::new());
            
            mpm.add_pass(InliningPass::new(500));
            mpm.add_pass(GlobalDcePass::new());
            mpm.add_pass(ArgumentPromotionPass::new());
            mpm.add_pass(IpConstPropPass::new());
        }
        OptLevel::Os | OptLevel::Oz => {
            // Size optimizations
            fpm.add_pass(SimplifyCfgPass::new());
            fpm.add_pass(ConstantFoldingPass::new());
            fpm.add_pass(DeadCodeEliminationPass::new());
            fpm.add_pass(MergeFunctionsPass::new());
            
            mpm.add_pass(InliningPass::new(if opt_level == OptLevel::Oz { 25 } else { 75 }));
            mpm.add_pass(GlobalDcePass::new());
        }
    }
    
    mpm.set_function_pm(fpm);
    mpm
}

