module quantalang::opt::reassociate

use alloc::vec::Vec;
use alloc::string::String;
use alloc::boxed::Box;
use alloc::collections::{BTreeMap, BTreeSet};

// ═══════════════════════════════════════════════════════════════════════════════
// EXPRESSION RANKS
// ═══════════════════════════════════════════════════════════════════════════════

/// Rank of a value (used for canonical ordering)
#[derive(Debug, Clone, Copy, PartialEq, Eq, PartialOrd, Ord)]
pub struct Rank(pub u32);

impl Rank {
    /// Constant rank (highest priority for folding)
    pub const CONSTANT: Rank = Rank(0);
    
    /// Base rank for variables
    pub const BASE: Rank = Rank(1);
    
    /// Combine ranks
    pub fn combine(a: Rank, b: Rank) -> Rank {
        Rank(a.0.max(b.0) + 1)
    }
}

/// Rank calculator
pub struct RankCalculator {
    /// Ranks for each value
    ranks: BTreeMap<String, Rank>,
    /// Next rank to assign
    next_rank: u32,
}

impl RankCalculator {
    pub fn new() -> Self {
        RankCalculator {
            ranks: BTreeMap::new(),
            next_rank: 2,
        }
    }
    
    /// Compute ranks for a function
    pub fn compute(&mut self, func: &MirFunction) {
        self.ranks.clear();
        self.next_rank = 2;
        
        // Parameters get low ranks (higher priority)
        for (i, param) in func.params.iter().enumerate() {
            self.ranks.insert(param.clone(), Rank(1 + i as u32));
        }
        
        self.next_rank = 1 + func.params.len() as u32;
        
        // Process blocks in RPO
        for block in &func.blocks {
            for stmt in &block.statements {
                if let Some(dest) = self.get_definition(stmt) {
                    let rank = self.compute_rank(stmt);
                    self.ranks.insert(dest.to_string(), rank);
                }
            }
        }
    }
    
    fn compute_rank(&mut self, stmt: &MirStatement) -> Rank {
        match stmt {
            MirStatement::Assign { value, .. } => {
                self.operand_rank(value)
            }
            MirStatement::BinaryOp { lhs, rhs, .. } => {
                let lhs_rank = self.operand_rank(lhs);
                let rhs_rank = self.operand_rank(rhs);
                Rank::combine(lhs_rank, rhs_rank)
            }
            MirStatement::Load { .. } => {
                let rank = Rank(self.next_rank);
                self.next_rank += 1;
                rank
            }
            MirStatement::Call { .. } => {
                let rank = Rank(self.next_rank);
                self.next_rank += 1;
                rank
            }
            _ => Rank::BASE,
        }
    }
    
    fn operand_rank(&self, operand: &MirOperand) -> Rank {
        match operand {
            MirOperand::Constant(_) => Rank::CONSTANT,
            MirOperand::Variable(name) => {
                self.ranks.get(name).copied().unwrap_or(Rank::BASE)
            }
        }
    }
    
    fn get_definition<'a>(&self, stmt: &'a MirStatement) -> Option<&'a str> {
        match stmt {
            MirStatement::Assign { dest, .. } |
            MirStatement::BinaryOp { dest, .. } |
            MirStatement::Load { dest, .. } |
            MirStatement::Phi { dest, .. } => Some(dest.as_str()),
            MirStatement::Call { dest: Some(d), .. } => Some(d.as_str()),
            _ => None,
        }
    }
    
    /// Get rank for a value
    pub fn get_rank(&self, name: &str) -> Rank {
        self.ranks.get(name).copied().unwrap_or(Rank::BASE)
    }
}

impl Default for RankCalculator {
    fn default() -> Self {
        Self::new()
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// EXPRESSION TREE
// ═══════════════════════════════════════════════════════════════════════════════

/// Expression tree node
#[derive(Debug, Clone)]
pub enum ExprTree {
    /// Leaf: operand
    Leaf(MirOperand),
    /// Binary operation
    Binary(BinOp, Box<ExprTree>, Box<ExprTree>),
}

impl ExprTree {
    /// Check if expression is a constant
    pub fn is_constant(&self) -> bool {
        matches!(self, ExprTree::Leaf(MirOperand::Constant(_)))
    }
    
    /// Get constant value if leaf is constant
    pub fn get_constant(&self) -> Option<i64> {
        if let ExprTree::Leaf(MirOperand::Constant(c)) = self {
            Some(*c)
        } else {
            None
        }
    }
    
    /// Linearize expression tree (collect all operands)
    pub fn linearize(&self, op: BinOp) -> Vec<MirOperand> {
        let mut operands = Vec::new();
        self.collect_operands(op, &mut operands);
        operands
    }
    
    fn collect_operands(&self, target_op: BinOp, operands: &mut Vec<MirOperand>) {
        match self {
            ExprTree::Leaf(op) => {
                operands.push(op.clone());
            }
            ExprTree::Binary(op, lhs, rhs) if *op == target_op => {
                lhs.collect_operands(target_op, operands);
                rhs.collect_operands(target_op, operands);
            }
            ExprTree::Binary(_, _, _) => {
                // Different op - treat as leaf
                // In real implementation, would evaluate subtree
            }
        }
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// REASSOCIATION PASS
// ═══════════════════════════════════════════════════════════════════════════════

/// Reassociation optimization pass
pub struct Reassociate {
    /// Rank calculator
    ranks: RankCalculator,
    /// Value numbering for CSE
    value_numbers: BTreeMap<String, u32>,
    /// Next value number
    next_vn: u32,
    /// Statistics
    stats: ReassociateStats,
}

/// Statistics for reassociation
#[derive(Debug, Clone, Default)]
pub struct ReassociateStats {
    /// Expressions linearized
    pub linearized: usize,
    /// Constants folded
    pub constants_folded: usize,
    /// Expressions reordered
    pub reordered: usize,
    /// Common factors extracted
    pub factors_extracted: usize,
}

impl Reassociate {
    pub fn new() -> Self {
        Reassociate {
            ranks: RankCalculator::new(),
            value_numbers: BTreeMap::new(),
            next_vn: 0,
            stats: ReassociateStats::default(),
        }
    }
    
    /// Run reassociation on a function
    pub fn run(&mut self, func: &mut MirFunction) -> &ReassociateStats {
        self.stats = ReassociateStats::default();
        
        // Compute ranks
        self.ranks.compute(func);
        
        // Process each block
        for block in &mut func.blocks {
            self.process_block(block);
        }
        
        &self.stats
    }
    
    fn process_block(&mut self, block: &mut MirBlock) {
        let mut new_statements = Vec::new();
        
        for stmt in &block.statements {
            match stmt {
                MirStatement::BinaryOp { dest, op, lhs, rhs } => {
                    if self.is_associative(*op) {
                        if let Some(new_stmt) = self.reassociate(dest, *op, lhs, rhs) {
                            new_statements.push(new_stmt);
                            continue;
                        }
                    }
                    
                    // Canonicalize operand order
                    let (new_lhs, new_rhs) = self.canonicalize_order(*op, lhs, rhs);
                    
                    if new_lhs != *lhs || new_rhs != *rhs {
                        self.stats.reordered += 1;
                        new_statements.push(MirStatement::BinaryOp {
                            dest: dest.clone(),
                            op: *op,
                            lhs: new_lhs,
                            rhs: new_rhs,
                        });
                    } else {
                        new_statements.push(stmt.clone());
                    }
                }
                _ => {
                    new_statements.push(stmt.clone());
                }
            }
        }
        
        block.statements = new_statements;
    }
    
    fn is_associative(&self, op: BinOp) -> bool {
        matches!(op, BinOp::Add | BinOp::Mul | BinOp::And | BinOp::Or | BinOp::Xor)
    }
    
    fn is_commutative(&self, op: BinOp) -> bool {
        matches!(op, BinOp::Add | BinOp::Mul | BinOp::And | BinOp::Or | BinOp::Xor | BinOp::Eq | BinOp::Ne)
    }
    
    fn reassociate(
        &mut self,
        dest: &str,
        op: BinOp,
        lhs: &MirOperand,
        rhs: &MirOperand,
    ) -> Option<MirStatement> {
        // Collect all operands in the expression
        let mut operands = Vec::new();
        self.collect_operands(op, lhs, &mut operands);
        self.collect_operands(op, rhs, &mut operands);
        
        if operands.len() <= 2 {
            return None;
        }
        
        self.stats.linearized += 1;
        
        // Sort operands by rank (constants first)
        operands.sort_by_key(|op| self.operand_rank(op));
        
        // Fold constants at the front
        let mut constant_value: Option<i64> = None;
        let mut variable_ops = Vec::new();
        
        for operand in operands {
            if let MirOperand::Constant(c) = operand {
                constant_value = Some(self.fold_constant(op, constant_value.unwrap_or(self.identity(op)), c));
            } else {
                variable_ops.push(operand);
            }
        }
        
        if constant_value.is_some() && variable_ops.len() < operands.len() - 1 {
            self.stats.constants_folded += 1;
        }
        
        // Reconstruct expression
        if variable_ops.is_empty() {
            // All constants - just assign the result
            return Some(MirStatement::Assign {
                dest: dest.to_string(),
                value: MirOperand::Constant(constant_value.unwrap_or(self.identity(op))),
            });
        }
        
        // Build right-leaning tree (for better codegen)
        let mut result_ops = variable_ops;
        
        // Add constant back if non-identity
        if let Some(c) = constant_value {
            if c != self.identity(op) {
                result_ops.push(MirOperand::Constant(c));
            }
        }
        
        if result_ops.len() == 1 {
            return Some(MirStatement::Assign {
                dest: dest.to_string(),
                value: result_ops.pop().unwrap(),
            });
        }
        
        // Return the first binary op; the rest would need new temp vars
        // (simplified - real implementation would generate full chain)
        let rhs = result_ops.pop().unwrap();
        let lhs = result_ops.pop().unwrap();
        
        Some(MirStatement::BinaryOp {
            dest: dest.to_string(),
            op,
            lhs,
            rhs,
        })
    }
    
    fn collect_operands(&self, target_op: BinOp, operand: &MirOperand, operands: &mut Vec<MirOperand>) {
        // For now, just add the operand directly
        // In a real implementation, we would look up the definition and recurse
        operands.push(operand.clone());
    }
    
    fn operand_rank(&self, operand: &MirOperand) -> Rank {
        match operand {
            MirOperand::Constant(_) => Rank::CONSTANT,
            MirOperand::Variable(name) => self.ranks.get_rank(name),
        }
    }
    
    fn fold_constant(&self, op: BinOp, a: i64, b: i64) -> i64 {
        match op {
            BinOp::Add => a.wrapping_add(b),
            BinOp::Mul => a.wrapping_mul(b),
            BinOp::And => a & b,
            BinOp::Or => a | b,
            BinOp::Xor => a ^ b,
            _ => b,
        }
    }
    
    fn identity(&self, op: BinOp) -> i64 {
        match op {
            BinOp::Add => 0,
            BinOp::Mul => 1,
            BinOp::And => -1, // All ones
            BinOp::Or => 0,
            BinOp::Xor => 0,
            _ => 0,
        }
    }
    
    fn canonicalize_order(&self, op: BinOp, lhs: &MirOperand, rhs: &MirOperand) -> (MirOperand, MirOperand) {
        if !self.is_commutative(op) {
            return (lhs.clone(), rhs.clone());
        }
        
        let lhs_rank = self.operand_rank(lhs);
        let rhs_rank = self.operand_rank(rhs);
        
        // Put lower rank (constants) on the right for better folding
        if lhs_rank < rhs_rank {
            (rhs.clone(), lhs.clone())
        } else {
            (lhs.clone(), rhs.clone())
        }
    }
    
    /// Get statistics
    pub fn stats(&self) -> &ReassociateStats {
        &self.stats
    }
}

impl Default for Reassociate {
    fn default() -> Self {
        Self::new()
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// FACTORIZATION
// ═══════════════════════════════════════════════════════════════════════════════

/// Factor extraction pass
pub struct FactorExtraction {
    /// Common factors found
    factors: BTreeMap<String, Vec<String>>,
    /// Statistics
    stats: FactorStats,
}

/// Statistics for factor extraction
#[derive(Debug, Clone, Default)]
pub struct FactorStats {
    /// Expressions analyzed
    pub analyzed: usize,
    /// Factors found
    pub factors_found: usize,
    /// Factorizations applied
    pub factorizations: usize,
}

impl FactorExtraction {
    pub fn new() -> Self {
        FactorExtraction {
            factors: BTreeMap::new(),
            stats: FactorStats::default(),
        }
    }
    
    /// Run factor extraction
    pub fn run(&mut self, func: &mut MirFunction) -> &FactorStats {
        self.stats = FactorStats::default();
        
        // Find potential factors
        self.find_factors(func);
        
        // Apply factorizations
        self.apply_factorizations(func);
        
        &self.stats
    }
    
    fn find_factors(&mut self, func: &MirFunction) {
        self.factors.clear();
        
        for block in &func.blocks {
            for stmt in &block.statements {
                self.stats.analyzed += 1;
                
                if let MirStatement::BinaryOp { dest, op: BinOp::Add, lhs, rhs } = stmt {
                    // Look for a*x + a*y = a*(x+y)
                    // This is simplified - real implementation would be more thorough
                }
            }
        }
    }
    
    fn apply_factorizations(&mut self, func: &mut MirFunction) {
        // Apply found factorizations
        for (factor, uses) in &self.factors {
            if uses.len() >= 2 {
                self.stats.factors_found += 1;
                // Would transform expressions here
            }
        }
    }
    
    /// Get statistics
    pub fn stats(&self) -> &FactorStats {
        &self.stats
    }
}

impl Default for FactorExtraction {
    fn default() -> Self {
        Self::new()
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// MIR TYPES
// ═══════════════════════════════════════════════════════════════════════════════

#[derive(Debug, Clone)]
pub struct MirFunction {
    pub name: String,
    pub params: Vec<String>,
    pub blocks: Vec<MirBlock>,
}

#[derive(Debug, Clone)]
pub struct MirBlock {
    pub id: u32,
    pub statements: Vec<MirStatement>,
    pub terminator: MirTerminator,
}

#[derive(Debug, Clone)]
pub enum MirStatement {
    Assign { dest: String, value: MirOperand },
    BinaryOp { dest: String, op: BinOp, lhs: MirOperand, rhs: MirOperand },
    Load { dest: String, ptr: MirOperand },
    Store { ptr: MirOperand, value: MirOperand },
    Call { callee: String, args: Vec<MirOperand>, dest: Option<String> },
    Phi { dest: String, incoming: Vec<(u32, MirOperand)> },
    Nop,
}

#[derive(Debug, Clone, PartialEq)]
pub enum MirOperand {
    Variable(String),
    Constant(i64),
}

#[derive(Debug, Clone, Copy, PartialEq, Eq)]
pub enum BinOp {
    Add, Sub, Mul, Div, Rem,
    And, Or, Xor, Shl, Shr,
    Eq, Ne, Lt, Le, Gt, Ge,
}

#[derive(Debug, Clone)]
pub enum MirTerminator {
    Goto(u32),
    Branch { cond: MirOperand, then_bb: u32, else_bb: u32 },
    Return { value: Option<MirOperand> },
}

// ═══════════════════════════════════════════════════════════════════════════════
// TESTS
// ═══════════════════════════════════════════════════════════════════════════════

#[cfg(test)]
mod tests {
    use super::*;
    
    #[test]
    fn test_rank_ordering() {
        assert!(Rank::CONSTANT < Rank::BASE);
        assert!(Rank::combine(Rank::CONSTANT, Rank::BASE) > Rank::BASE);
    }
    
    #[test]
    fn test_canonicalization() {
        let mut func = MirFunction {
            name: "test".to_string(),
            params: vec!["x".to_string()],
            blocks: vec![
                MirBlock {
                    id: 0,
                    statements: vec![
                        // 1 + x should become x + 1
                        MirStatement::BinaryOp {
                            dest: "y".to_string(),
                            op: BinOp::Add,
                            lhs: MirOperand::Constant(1),
                            rhs: MirOperand::Variable("x".to_string()),
                        },
                    ],
                    terminator: MirTerminator::Return { value: None },
                },
            ],
        };
        
        let mut reassoc = Reassociate::new();
        reassoc.run(&mut func);
        
        // Check that operands were reordered
        if let MirStatement::BinaryOp { lhs, rhs, .. } = &func.blocks[0].statements[0] {
            assert!(matches!(lhs, MirOperand::Variable(_)));
            assert!(matches!(rhs, MirOperand::Constant(1)));
        }
    }
    
    #[test]
    fn test_constant_folding() {
        let reassoc = Reassociate::new();
        
        assert_eq!(reassoc.fold_constant(BinOp::Add, 5, 3), 8);
        assert_eq!(reassoc.fold_constant(BinOp::Mul, 5, 3), 15);
        assert_eq!(reassoc.fold_constant(BinOp::And, 0b1010, 0b1100), 0b1000);
        assert_eq!(reassoc.fold_constant(BinOp::Or, 0b1010, 0b0101), 0b1111);
        assert_eq!(reassoc.fold_constant(BinOp::Xor, 0b1010, 0b1010), 0);
    }
    
    #[test]
    fn test_identity_values() {
        let reassoc = Reassociate::new();
        
        assert_eq!(reassoc.identity(BinOp::Add), 0);
        assert_eq!(reassoc.identity(BinOp::Mul), 1);
        assert_eq!(reassoc.identity(BinOp::Or), 0);
        assert_eq!(reassoc.identity(BinOp::Xor), 0);
    }
}
