// Passes with configuration
#[derive(Clone, Default)]
pub struct InlineConfig {
    pub threshold: u32,
    pub hint_threshold: u32,
    pub cold_threshold: u32,
}

#[derive(Clone, Default)]
pub struct LoopUnrollConfig {
    pub count: u32,
    pub threshold: u32,
    pub allow_partial: bool,
    pub allow_runtime: bool,
}

impl LoopUnrollConfig {
    pub fn aggressive() -> Self {
        LoopUnrollConfig {
            count: 8,
            threshold: 400,
            allow_partial: true,
            allow_runtime: true,
        }
    }
}

impl_pass_with_config!(InlinerPass, InlineConfig);
impl_pass_with_config!(LoopUnrollPass, LoopUnrollConfig);
impl_pass_with_config!(LoopVectorizePass, VectorizationConfig);
impl_pass_with_config!(SlpVectorizePass, VectorizationConfig);
impl_pass_with_config!(PgoInstrumentPass, InstrumentationConfig);
impl_pass_with_config!(CoverageInstrumentPass, CoverageConfig);
impl_pass_with_config!(AsanPass, AsanConfig);
impl_pass_with_config!(MsanPass, MsanConfig);
impl_pass_with_config!(TsanPass, TsanConfig);
impl_pass_with_config!(UbsanPass, UbsanConfig);
impl_pass_with_config!(PgoOptPass, ProfileData);

// ═══════════════════════════════════════════════════════════════════════════════
// LIBRARY VERSION
// ═══════════════════════════════════════════════════════════════════════════════

pub const VERSION: &str = "1.0.0";
pub const VERSION_MAJOR: u32 = 1;
pub const VERSION_MINOR: u32 = 0;
pub const VERSION_PATCH: u32 = 0;

/// Print help information
pub fn print_help() {
    println!("QuantaLang Optimization Library v{}", VERSION);
    println!();
    println!("Modules:");
    println!("  pgo           - Profile-Guided Optimization");
    println!("  lto           - Link-Time Optimization");
    println!("  sanitizers    - Runtime Sanitizers (ASan/MSan/TSan/UBSan)");
    println!("  coverage      - Code Coverage Instrumentation");
    println!("  autovectorize - Auto-Vectorization");
    println!();
    println!("Optimization Levels:");
    println!("  O0 - No optimization");
    println!("  O1 - Basic optimization");
    println!("  O2 - Default optimization");
    println!("  O3 - Aggressive optimization");
    println!("  Os - Size optimization");
    println!("  Oz - Aggressive size optimization");
    println!();
    println!("PGO Workflow:");
    println!("  1. Build with -fprofile-instr-generate");
    println!("  2. Run instrumented binary with representative workload");
    println!("  3. Merge profile data: quantaprof merge *.profraw");
    println!("  4. Rebuild with -fprofile-instr-use=merged.profdata");
    println!();
    println!("LTO Modes:");
    println!("  full - Monolithic LTO");
    println!("  thin - Parallel ThinLTO");
    println!("  fat  - Fat LTO (embed bitcode)");
}

// ═══════════════════════════════════════════════════════════════════════════════
// TESTS
// ═══════════════════════════════════════════════════════════════════════════════

#[cfg(test)]
mod tests {
    use super::*;
    
    #[test]
    fn test_default_config() {
        let config = OptimizationConfig::default();
        
        assert_eq!(config.opt_level, OptLevel::O2);
        assert_eq!(config.size_level, SizeLevel::None);
        assert!(!config.debug_info);
    }
    
    #[test]
    fn test_debug_config() {
        let config = OptimizationConfig::debug();
        
        assert_eq!(config.opt_level, OptLevel::O0);
        assert!(config.debug_info);
    }
    
    #[test]
    fn test_release_config() {
        let config = OptimizationConfig::release();
        
        assert_eq!(config.opt_level, OptLevel::O3);
        assert!(config.lto.is_some());
    }
    
    #[test]
    fn test_pipeline_creation() {
        let config = OptimizationConfig::default();
        let pipeline = OptimizationPipeline::new(config);
        
        assert!(!pipeline.passes.is_empty());
    }
    
    #[test]
    fn test_loop_unroll_config() {
        let config = LoopUnrollConfig::aggressive();
        
        assert_eq!(config.count, 8);
        assert!(config.allow_partial);
    }
}
