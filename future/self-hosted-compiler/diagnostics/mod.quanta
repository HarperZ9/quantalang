// ═══════════════════════════════════════════════════════════════════════════════
// TESTS
// ═══════════════════════════════════════════════════════════════════════════════

#[cfg(test)]
mod tests {
    use super::*;
    use std::path::PathBuf;
    
    fn test_source_map() -> Arc<SourceMap> {
        let map = SourceMap::new();
        map.add_file(
            PathBuf::from("test.quanta"),
            "fn main() {\n    let x = 42;\n    println(x);\n}\n".to_string(),
        );
        map
    }
    
    #[test]
    fn test_version() {
        assert_eq!(VERSION, "1.0.0");
    }
    
    #[test]
    fn test_diagnostic_context() {
        let map = test_source_map();
        let ctx = DiagnosticContext::new(map);
        
        assert_eq!(ctx.error_count(), 0);
        assert!(!ctx.has_errors());
    }
    
    #[test]
    fn test_levenshtein() {
        assert_eq!(levenshtein_distance("hello", "hello"), 0);
        assert_eq!(levenshtein_distance("hello", "helo"), 1);
        assert_eq!(levenshtein_distance("hello", "world"), 4);
    }
    
    #[test]
    fn test_find_similar() {
        let candidates = vec!["println", "print", "panic", "parse"];
        let similar = find_similar_names("printn", &candidates, 2);
        
        assert!(similar.contains(&"println"));
        assert!(similar.contains(&"print"));
    }
    
    #[test]
    fn test_type_mismatch_error() {
        let map = test_source_map();
        let diag = type_mismatch(
            &map,
            Span::new(BytePos(20), BytePos(22)),
            FileId(0),
            "String",
            "i32",
        );
        
        assert!(diag.is_error());
        assert_eq!(diag.code, Some(types::TYPE_MISMATCH));
    }
    
    #[test]
    fn test_undefined_variable_error() {
        let map = test_source_map();
        let diag = undefined_variable(
            &map,
            Span::new(BytePos(40), BytePos(41)),
            FileId(0),
            "y",
            &["x"],
        );
        
        assert!(diag.is_error());
        assert_eq!(diag.code, Some(resolution::UNDEFINED_VARIABLE));
    }
    
    #[test]
    fn test_output_format() {
        assert_eq!(OutputFormat::from_str("terminal"), Some(OutputFormat::Terminal));
        assert_eq!(OutputFormat::from_str("JSON"), Some(OutputFormat::Json));
        assert_eq!(OutputFormat::from_str("gcc"), Some(OutputFormat::Short));
        assert_eq!(OutputFormat::from_str("invalid"), None);
    }
    
    #[test]
    fn test_format_summary() {
        let summary = format_summary(2, 3);
        assert!(summary.contains("2 errors"));
        assert!(summary.contains("3 warnings"));
        
        let summary = format_summary(1, 0);
        assert!(summary.contains("1 error"));
        assert!(!summary.contains("warning"));
    }
}
