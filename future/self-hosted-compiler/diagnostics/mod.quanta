//
// Comprehensive compiler diagnostics system:
// - Rust-style error messages with source snippets
// - Error codes with documentation links
// - Suggestions with auto-fix support
// - Multiple output formats (terminal, JSON, SARIF)
//
// ═══════════════════════════════════════════════════════════════════════════════

//! # QuantaLang Diagnostics
//!
//! Rich compiler error reporting with source highlighting.
//!
//! ## Quick Start
//!
//! ```quanta
//! use quantalang::diagnostics::prelude::*;
//!
//! // Create source map
//! let source_map = SourceMap::new();
//! let file = source_map.add_file("main.quanta", source_code);
//!
//! // Create diagnostic handler
//! let handler = DiagnosticHandler::new(
//!     TerminalRenderer::new(source_map.clone())
//! );
//!
//! // Emit an error
//! handler.struct_error("type mismatch")
//!     .code(types::TYPE_MISMATCH)
//!     .span_label(error_span, file.id, "expected `i32`, found `String`")
//!     .note("cannot convert `String` to `i32`")
//!     .help("consider using `.parse::<i32>()`")
//!     .emit(&handler);
//!
//! // Check for errors
//! handler.abort_if_errors();
//! ```

module quantalang::diagnostics

