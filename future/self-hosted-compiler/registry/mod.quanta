//! # Package Registry
//!
//! Complete package registry implementation for QuantaLang.
//!
//! ## Features
//!
//! - **Publishing**: Publish packages to the registry
//! - **Discovery**: Search and browse packages
//! - **Resolution**: Resolve dependency graphs
//! - **Caching**: Local package caching
//!
//! ## Quick Start
//!
//! ```quanta
//! use quantalang::registry::prelude::*;
//!
//! // Create registry client
//! let client = RegistryClient::default_registry();
//!
//! // Search for packages
//! let results = client.search("json", 10)?;
//!
//! // Download a package
//! let tarball = client.download(
//!     &PackageName::parse("serde")?,
//!     &Version::parse("1.0.0")?,
//! )?;
//! ```

module quantalang::registry

pub mod index;
pub mod client;

// Re-exports
pub use index::{
    PackageName, NameError,
    Version, VersionError, Prerelease, PrereleaseId,
    VersionReq, Comparator, Op,
    PackageMetadata, Dependency, IndexEntry, PackageIndex,
};

pub use client::{
    RegistryConfig, DEFAULT_REGISTRY,
    Credentials, RegistryClient, RegistryError,
    UserInfo, SearchResult, PackageCache,
};

use alloc::vec::Vec;
use alloc::string::String;
use alloc::format;
use alloc::collections::{BTreeMap, BTreeSet};
use std::sync::Arc;

