        PackageName, Version, VersionReq, Prerelease,
        
        // Metadata
        PackageMetadata, Dependency, IndexEntry,
        
        // Client
        RegistryConfig, RegistryClient, Credentials,
        RegistryError, UserInfo, SearchResult,
        
        // Resolution
        Resolver, ResolveError, DependencyGraph, ResolvedPackage,
        
        // Lockfile
        Lockfile, LockedPackage, LockfileError,
        
        // Functions
        default_client, resolve, search,
    };
}

// ═══════════════════════════════════════════════════════════════════════════════
// TESTS
// ═══════════════════════════════════════════════════════════════════════════════

#[cfg(test)]
mod tests {
    use super::*;
    
    #[test]
    fn test_lockfile_serialization() {
        let mut lockfile = Lockfile {
            version: 1,
            packages: vec![
                LockedPackage {
                    name: "serde".to_string(),
                    version: "1.0.0".to_string(),
                    source: "registry+https://registry.quantalang.dev".to_string(),
                    checksum: Some("abc123".to_string()),
                    dependencies: vec!["serde_derive".to_string()],
                },
            ],
            metadata: BTreeMap::new(),
        };
        
        let toml = lockfile.to_toml();
        assert!(toml.contains("[[package]]"));
        assert!(toml.contains("serde"));
        assert!(toml.contains("1.0.0"));
    }
    
    #[test]
    fn test_lockfile_parse() {
        let content = r#"
version = 1

[[package]]
name = "test"
version = "1.0.0"
source = "registry"
"#;
        
        let lockfile = Lockfile::parse(content).unwrap();
        assert_eq!(lockfile.packages.len(), 1);
        assert_eq!(lockfile.packages[0].name, "test");
    }
    
    #[test]
    fn test_dependency_graph() {
        let mut graph = DependencyGraph::new();
        
        let pkg = ResolvedPackage {
            name: PackageName::parse("test").unwrap(),
            version: Version::new(1, 0, 0),
            dependencies: vec![],
            features: vec![],
            checksum: None,
        };
        
        graph.packages.insert("test".to_string(), pkg);
        graph.order.push("test".to_string());
        
        assert_eq!(graph.len(), 1);
        assert!(graph.get("test").is_some());
    }
}
