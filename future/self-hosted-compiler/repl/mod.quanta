//
// The QuantaLang REPL (Read-Eval-Print Loop) provides an interactive environment
// for evaluating QuantaLang expressions, defining functions, and exploring the
// language.
//
// Features:
// - Interactive expression evaluation
// - Variable and function definitions
// - Command history with persistence
// - Tab completion for keywords and identifiers
// - Multi-line input support
// - REPL commands (:help, :type, :env, etc.)
// - Syntax highlighting (when enabled)
//
// ═══════════════════════════════════════════════════════════════════════════════

//! # QuantaLang REPL
//!
//! Interactive Read-Eval-Print Loop for QuantaLang.
//!
//! ## Quick Start
//!
//! ```bash
//! # Start interactive REPL
//! quanta-repl
//!
//! # Evaluate expression
//! quanta-repl -e "2 + 2"
//!
//! # Execute file
//! quanta-repl script.quanta
//! ```
//!
//! ## REPL Commands
//!
//! - `:help` - Show help
//! - `:quit` - Exit REPL
//! - `:type <expr>` - Show expression type
//! - `:env` - Show all bindings
//! - `:history` - Show command history
//! - `:load <file>` - Load and execute file
//! - `:reset` - Reset environment
//!
//! ## Programmatic API
//!
//! ```quanta
//! use quantalang::repl::{Repl, ReplConfig};
//!
//! // Create REPL with defaults
//! let mut repl = Repl::new();
//!
//! // Evaluate expression
//! let result = repl.eval("2 + 2")?;
//! println!("{}", result);  // 4
//!
//! // Define variable
//! repl.eval("let x = 10")?;
//! let result = repl.eval("x * 2")?;
//! println!("{}", result);  // 20
//! ```
//!
//! ## Modules
//!
//! - [`config`] - Configuration and value types
//! - [`eval`] - Expression evaluator
//! - [`readline`] - Line editing and history
//! - [`cli`] - Command-line interface

module quantalang::repl

// Submodules
pub mod config;
pub mod eval;
pub mod readline;
pub mod cli;

// Re-exports
pub use config::{
    ReplConfig, Value, TypeInfo, TypeKind,
};

pub use eval::{
    Evaluator, EvalResult, Environment,
    Binding, FunctionDef, FunctionBody,
};

pub use readline::{
    LineEditor, History, Key,
    Completer, KeywordCompleter,
    enable_raw_mode, disable_raw_mode, read_key,
};

pub use cli::{
    CliArgs, Session, parse_args, run,
    VERSION,
};

// ═══════════════════════════════════════════════════════════════════════════════
// HIGH-LEVEL API
// ═══════════════════════════════════════════════════════════════════════════════

/// High-level REPL interface
///
/// # Examples
///
/// ```quanta
/// use quantalang::repl::Repl;
///
/// let mut repl = Repl::new();
///
/// // Simple evaluation
/// assert_eq!(repl.eval("1 + 2")?, Value::I32(3));
///
/// // Variables
/// repl.eval("let x = 10")?;
/// repl.eval("let y = 20")?;
/// assert_eq!(repl.eval("x + y")?, Value::I32(30));
///
/// // Functions
/// repl.eval("fn double(n) { n * 2 }")?;
/// assert_eq!(repl.eval("double(5)")?, Value::I32(10));
/// ```
pub struct Repl {
    config: ReplConfig,
    evaluator: Evaluator,
}

impl Repl {
    /// Create new REPL with default configuration
    pub fn new() -> Self {
        let config = ReplConfig::default();
        Repl {
            evaluator: Evaluator::new(config.clone()),
            config,
        }
    }
    
    /// Create with custom configuration
    pub fn with_config(config: ReplConfig) -> Self {
        Repl {
            evaluator: Evaluator::new(config.clone()),
            config,
        }
    }
    
    /// Get configuration
    pub fn config(&self) -> &ReplConfig {
        &self.config
    }
    
    /// Get mutable configuration
    pub fn config_mut(&mut self) -> &mut ReplConfig {
        &mut self.config
    }
    
    /// Evaluate expression
    pub fn eval(&mut self, input: &str) -> Result<Value, String> {
        self.evaluator.eval(input).value
    }
    
    /// Evaluate and get full result (with timing)
    pub fn eval_full(&mut self, input: &str) -> EvalResult {
        self.evaluator.eval(input)
    }
    
    /// Get environment
    pub fn env(&self) -> &std::rc::Rc<std::cell::RefCell<Environment>> {
        &self.evaluator.env()
    }
    
    /// Define a variable
    pub fn define(&mut self, name: &str, value: Value) {
        self.evaluator.env().borrow_mut().define(name, value, false);
    }
    
    /// Define a mutable variable
    pub fn define_mut(&mut self, name: &str, value: Value) {
        self.evaluator.env().borrow_mut().define(name, value, true);
    }
    
    /// Get a variable
    pub fn get(&self, name: &str) -> Option<Value> {
        self.evaluator.env().borrow().get(name)
    }
    
    /// Set a variable (must exist and be mutable)
    pub fn set(&mut self, name: &str, value: Value) -> Result<(), String> {
        self.evaluator.env().borrow_mut().set(name, value)
    }
    
    /// Check if variable exists
    pub fn has(&self, name: &str) -> bool {
        self.evaluator.env().borrow().contains(name)
    }
    
    /// List all bindings
    pub fn bindings(&self) -> Vec<(String, String)> {
        self.evaluator.env().borrow().list_bindings()
    }
    
    /// Reset environment
    pub fn reset(&mut self) {
        self.evaluator = Evaluator::new(self.config.clone());
    }
    
    /// Execute file
    pub fn exec_file(&mut self, path: &std::path::Path) -> Result<(), String> {
        let content = std::fs::read_to_string(path)
            .map_err(|e| format!("failed to read file: {}", e))?;
        
        for line in content.lines() {
            let line = line.trim();
            if !line.is_empty() && !line.starts_with("//") {
                self.eval(line)?;
            }
        }
        
        Ok(())
    }
    
    /// Start interactive session
    pub fn interactive(&mut self) -> Result<i32, String> {
        let mut session = Session::new(self.config.clone());
        session.run()
    }
}

impl Default for Repl {
    fn default() -> Self {
        Self::new()
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// CONVENIENCE FUNCTIONS
// ═══════════════════════════════════════════════════════════════════════════════

/// Evaluate a single expression
///
/// # Examples
///
/// ```quanta
/// let result = quantalang::repl::eval("2 + 2")?;
/// assert_eq!(result, Value::I32(4));
/// ```
pub fn eval(expr: &str) -> Result<Value, String> {
    let mut repl = Repl::new();
    repl.eval(expr)
}

/// Evaluate multiple expressions
pub fn eval_all(exprs: &[&str]) -> Result<Vec<Value>, String> {
    let mut repl = Repl::new();
    exprs.iter().map(|e| repl.eval(e)).collect()
}

/// Start interactive REPL with default configuration
pub fn start() -> Result<i32, String> {
    let mut repl = Repl::new();
    repl.interactive()
}

/// Start interactive REPL with custom configuration
pub fn start_with_config(config: ReplConfig) -> Result<i32, String> {
    let mut repl = Repl::with_config(config);
    repl.interactive()
}

// ═══════════════════════════════════════════════════════════════════════════════
// PRELUDE VALUES
// ═══════════════════════════════════════════════════════════════════════════════

/// Initialize REPL with standard prelude
pub fn with_prelude() -> Repl {
    let mut repl = Repl::new();
    
    // Define common constants
    repl.define("PI", Value::F64(std::f64::consts::PI));
    repl.define("E", Value::F64(std::f64::consts::E));
    repl.define("TAU", Value::F64(std::f64::consts::TAU));
    
    // Define max/min values
    repl.define("I32_MAX", Value::I32(i32::MAX));
    repl.define("I32_MIN", Value::I32(i32::MIN));
    repl.define("I64_MAX", Value::I64(i64::MAX));
    repl.define("I64_MIN", Value::I64(i64::MIN));
    
    repl
}

// ═══════════════════════════════════════════════════════════════════════════════
// VALUE CONSTRUCTORS
// ═══════════════════════════════════════════════════════════════════════════════

/// Create integer value
pub fn int(n: i32) -> Value {
    Value::I32(n)
}

/// Create float value
pub fn float(n: f64) -> Value {
    Value::F64(n)
}

/// Create boolean value
pub fn bool(b: bool) -> Value {
    Value::Bool(b)
}

/// Create string value
pub fn string(s: &str) -> Value {
    Value::String(s.to_string())
}

/// Create array value
pub fn array(values: Vec<Value>) -> Value {
    Value::Array(values)
}

/// Create tuple value
pub fn tuple(values: Vec<Value>) -> Value {
    Value::Tuple(values)
}

/// Create None value
pub fn none() -> Value {
    Value::Option(None)
}

/// Create Some value
pub fn some(value: Value) -> Value {
    Value::Option(Some(Box::new(value)))
}

/// Create Ok value
pub fn ok(value: Value) -> Value {
    Value::Result(Ok(Box::new(value)))
}

/// Create Err value
pub fn err(value: Value) -> Value {
    Value::Result(Err(Box::new(value)))
}

// ═══════════════════════════════════════════════════════════════════════════════
