// ═══════════════════════════════════════════════════════════════════════════════

/// Main entry point for quanta-repl binary
pub fn main() -> Result<i32, String> {
    cli::main()
}

// ═══════════════════════════════════════════════════════════════════════════════
// TESTS
// ═══════════════════════════════════════════════════════════════════════════════

#[cfg(test)]
mod tests {
    use super::*;
    
    #[test]
    fn test_repl_new() {
        let repl = Repl::new();
        assert!(repl.config().auto_print);
    }
    
    #[test]
    fn test_repl_eval_literals() {
        let mut repl = Repl::new();
        
        assert_eq!(repl.eval("42").unwrap(), Value::I32(42));
        assert_eq!(repl.eval("true").unwrap(), Value::Bool(true));
        assert_eq!(repl.eval("\"hello\"").unwrap(), Value::String("hello".to_string()));
    }
    
    #[test]
    fn test_repl_eval_arithmetic() {
        let mut repl = Repl::new();
        
        assert_eq!(repl.eval("2 + 3").unwrap(), Value::I32(5));
        assert_eq!(repl.eval("10 - 4").unwrap(), Value::I32(6));
        assert_eq!(repl.eval("3 * 4").unwrap(), Value::I32(12));
        assert_eq!(repl.eval("15 / 3").unwrap(), Value::I32(5));
    }
    
    #[test]
    fn test_repl_variables() {
        let mut repl = Repl::new();
        
        repl.eval("let x = 10").unwrap();
        assert_eq!(repl.eval("x").unwrap(), Value::I32(10));
        assert_eq!(repl.eval("x + 5").unwrap(), Value::I32(15));
    }
    
    #[test]
    fn test_repl_define() {
        let mut repl = Repl::new();
        
        repl.define("answer", Value::I32(42));
        assert_eq!(repl.get("answer"), Some(Value::I32(42)));
    }
    
    #[test]
    fn test_repl_functions() {
        let mut repl = Repl::new();
        
        repl.eval("fn add(a, b) { a + b }").unwrap();
        assert_eq!(repl.eval("add(2, 3)").unwrap(), Value::I32(5));
    }
    
    #[test]
    fn test_convenience_eval() {
        assert_eq!(eval("1 + 1").unwrap(), Value::I32(2));
    }
    
    #[test]
    fn test_value_constructors() {
        assert_eq!(int(42), Value::I32(42));
        assert_eq!(float(3.14), Value::F64(3.14));
        assert_eq!(bool(true), Value::Bool(true));
        assert_eq!(string("hello"), Value::String("hello".to_string()));
    }
    
    #[test]
    fn test_with_prelude() {
        let repl = with_prelude();
        assert!(repl.has("PI"));
        assert!(repl.has("E"));
    }
}
