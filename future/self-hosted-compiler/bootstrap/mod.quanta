// ═══════════════════════════════════════════════════════════════════════════════
// TESTS
// ═══════════════════════════════════════════════════════════════════════════════

#[cfg(test)]
mod tests {
    use super::*;
    
    #[test]
    fn test_bootstrap_config_default() {
        let config = BootstrapConfig::default();
        assert!(config.verify);
        assert_eq!(config.opt_level, OptLevel::O2);
    }
    
    #[test]
    fn test_stage_ordering() {
        assert!(Stage::Stage0 < Stage::Stage1);
        assert!(Stage::Stage1 < Stage::Stage2);
        assert!(Stage::Stage2 < Stage::Stage3);
    }
    
    #[test]
    fn test_sha256_empty() {
        let hash = sha256(b"");
        let expected = "e3b0c44298fc1c149afbf4c8996fb92427ae41e4649b934ca495991b7852b855";
        assert_eq!(hex_encode(&hash), expected);
    }
    
    #[test]
    fn test_hex_encode() {
        let bytes = [0xDE, 0xAD, 0xBE, 0xEF];
        assert_eq!(hex_encode(&bytes), "deadbeef");
    }
    
    #[test]
    fn test_reproducible_config() {
        let config = ReproducibleConfig::default();
        assert!(config.deterministic);
        assert!(config.strip_paths);
    }
}
