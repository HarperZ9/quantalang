// BOOTSTRAP COMMANDS
// ═══════════════════════════════════════════════════════════════════════════════

/// Bootstrap command for CLI
#[derive(Debug, Clone)]
pub enum BootstrapCommand {
    /// Full bootstrap (all stages)
    Full { config: BootstrapConfig },
    /// Build specific stage
    Stage { stage: Stage, config: BootstrapConfig },
    /// Verify existing build
    Verify { build_dir: PathBuf },
    /// Clean build artifacts
    Clean { build_dir: PathBuf, stage: Option<Stage> },
    /// Show status
    Status { build_dir: PathBuf },
    /// Run tests on built compiler
    Test { build_dir: PathBuf, stage: Stage },
}

/// Execute bootstrap command
pub fn execute_command(cmd: BootstrapCommand) -> Result<(), BootstrapError> {
    match cmd {
        BootstrapCommand::Full { config } => {
            let mut bootstrap = Bootstrap::new(config);
            bootstrap.run()?;
            Ok(())
        }
        
        BootstrapCommand::Stage { stage, config } => {
            let mut bootstrap = Bootstrap::new(config);
            build_through_stage(&mut bootstrap, stage)?;
            Ok(())
        }
        
        BootstrapCommand::Verify { build_dir } => {
            verify_build(&build_dir)
        }
        
        BootstrapCommand::Clean { build_dir, stage } => {
            clean_build(&build_dir, stage)
        }
        
        BootstrapCommand::Status { build_dir } => {
            show_status(&build_dir)
        }
        
        BootstrapCommand::Test { build_dir, stage } => {
            run_tests(&build_dir, stage)
        }
    }
}

fn build_through_stage(bootstrap: &mut Bootstrap, target: Stage) -> Result<(), BootstrapError> {
    // Build all stages up to and including target
    let mut current = Stage::Stage0;
    
    loop {
        if current > target {
            break;
        }
        
        // Stage 0 is pre-built, verify it
        if current == Stage::Stage0 {
            // Verification handled in bootstrap.run()
        }
        
        if let Some(next) = current.next() {
            current = next;
        } else {
            break;
        }
    }
    
    Ok(())
}

fn verify_build(build_dir: &Path) -> Result<(), BootstrapError> {
    let stage2_path = build_dir.join("stage2/bin/quantac");
    let stage3_path = build_dir.join("stage3/bin/quantac");
    
    if !stage2_path.exists() {
        return Err(BootstrapError::MissingArtifact(Stage::Stage2));
    }
    
    if !stage3_path.exists() {
        return Err(BootstrapError::MissingArtifact(Stage::Stage3));
    }
    
    let stage2_hash = hash_file(&stage2_path)?;
    let stage3_hash = hash_file(&stage3_path)?;
    
    if stage2_hash != stage3_hash {
        return Err(BootstrapError::VerificationFailed {
            stage2_hash: hex_encode(&stage2_hash),
            stage3_hash: hex_encode(&stage3_hash),
        });
    }
    
    println!("✓ Verification passed");
    println!("  Hash: {}", hex_encode(&stage2_hash));
    
    Ok(())
}

fn clean_build(build_dir: &Path, stage: Option<Stage>) -> Result<(), BootstrapError> {
    match stage {
        Some(s) => {
            let stage_dir = build_dir.join(s.name());
            if stage_dir.exists() {
                fs::remove_dir_all(&stage_dir)
                    .map_err(|e| BootstrapError::IoError(e.to_string()))?;
                println!("Cleaned {}", s.name());
            }
        }
        None => {
            if build_dir.exists() {
                fs::remove_dir_all(build_dir)
                    .map_err(|e| BootstrapError::IoError(e.to_string()))?;
                println!("Cleaned all stages");
            }
        }
    }
    
    Ok(())
}

fn show_status(build_dir: &Path) -> Result<(), BootstrapError> {
    println!("Bootstrap Status");
    println!("================");
    println!();
    
    for stage in [Stage::Stage0, Stage::Stage1, Stage::Stage2, Stage::Stage3] {
        let stage_dir = build_dir.join(stage.name());
        let compiler_path = stage_dir.join("bin/quantac");
        
        print!("{}: ", stage.name());
        
        if compiler_path.exists() {
            let hash = hash_file(&compiler_path)?;
            println!("✓ Built ({})", &hex_encode(&hash)[..16]);
        } else {
            println!("✗ Not built");
        }
    }
    
    // Check verification
    let stage2_path = build_dir.join("stage2/bin/quantac");
    let stage3_path = build_dir.join("stage3/bin/quantac");
    
    if stage2_path.exists() && stage3_path.exists() {
        let stage2_hash = hash_file(&stage2_path)?;
        let stage3_hash = hash_file(&stage3_path)?;
        
        println!();
        if stage2_hash == stage3_hash {
            println!("Verification: ✓ Passed");
        } else {
            println!("Verification: ✗ Failed (hashes differ)");
        }
    }
    
    Ok(())
}

fn run_tests(build_dir: &Path, stage: Stage) -> Result<(), BootstrapError> {
    let compiler_path = build_dir.join(stage.name()).join("bin/quantac");
    
    if !compiler_path.exists() {
        return Err(BootstrapError::MissingArtifact(stage));
    }
    
    println!("Running tests with {} compiler...", stage.name());
    
    // Would run test suite
    // For now, just verify compiler runs
    let output = std::process::Command::new(&compiler_path)
        .arg("--version")
        .output()
        .map_err(|e| BootstrapError::CompilerError(e.to_string()))?;
    
    if !output.status.success() {
        return Err(BootstrapError::CompilerError("version check failed".to_string()));
    }
    
    println!("✓ Compiler responds to --version");
    println!("  {}", String::from_utf8_lossy(&output.stdout).trim());
    
    Ok(())
}

fn hash_file(path: &Path) -> Result<[u8; 32], BootstrapError> {
    let contents = fs::read(path)
        .map_err(|e| BootstrapError::IoError(e.to_string()))?;
    Ok(sha256(&contents))
}

fn hex_encode(bytes: &[u8]) -> String {
    bytes.iter().map(|b| format!("{:02x}", b)).collect()
}

/// SHA-256 hash
fn sha256(data: &[u8]) -> [u8; 32] {
    // Simplified - would use proper implementation
    let mut h: [u32; 8] = [
        0x6a09e667, 0xbb67ae85, 0x3c6ef372, 0xa54ff53a,
        0x510e527f, 0x9b05688c, 0x1f83d9ab, 0x5be0cd19,
    ];
    
    const K: [u32; 64] = [
        0x428a2f98, 0x71374491, 0xb5c0fbcf, 0xe9b5dba5,
        0x3956c25b, 0x59f111f1, 0x923f82a4, 0xab1c5ed5,
        0xd807aa98, 0x12835b01, 0x243185be, 0x550c7dc3,
        0x72be5d74, 0x80deb1fe, 0x9bdc06a7, 0xc19bf174,
        0xe49b69c1, 0xefbe4786, 0x0fc19dc6, 0x240ca1cc,
        0x2de92c6f, 0x4a7484aa, 0x5cb0a9dc, 0x76f988da,
        0x983e5152, 0xa831c66d, 0xb00327c8, 0xbf597fc7,
        0xc6e00bf3, 0xd5a79147, 0x06ca6351, 0x14292967,
        0x27b70a85, 0x2e1b2138, 0x4d2c6dfc, 0x53380d13,
        0x650a7354, 0x766a0abb, 0x81c2c92e, 0x92722c85,
        0xa2bfe8a1, 0xa81a664b, 0xc24b8b70, 0xc76c51a3,
        0xd192e819, 0xd6990624, 0xf40e3585, 0x106aa070,
        0x19a4c116, 0x1e376c08, 0x2748774c, 0x34b0bcb5,
        0x391c0cb3, 0x4ed8aa4a, 0x5b9cca4f, 0x682e6ff3,
        0x748f82ee, 0x78a5636f, 0x84c87814, 0x8cc70208,
        0x90befffa, 0xa4506ceb, 0xbef9a3f7, 0xc67178f2,
    ];
    
    let bit_len = (data.len() as u64) * 8;
    let mut padded = data.to_vec();
    padded.push(0x80);
    while (padded.len() % 64) != 56 {
        padded.push(0);
    }
    padded.extend_from_slice(&bit_len.to_be_bytes());
    
    for chunk in padded.chunks(64) {
        let mut w = [0u32; 64];
        
        for (i, word) in chunk.chunks(4).enumerate() {
            w[i] = u32::from_be_bytes([word[0], word[1], word[2], word[3]]);
        }
        
        for i in 16..64 {
            let s0 = w[i-15].rotate_right(7) ^ w[i-15].rotate_right(18) ^ (w[i-15] >> 3);
            let s1 = w[i-2].rotate_right(17) ^ w[i-2].rotate_right(19) ^ (w[i-2] >> 10);
            w[i] = w[i-16].wrapping_add(s0).wrapping_add(w[i-7]).wrapping_add(s1);
        }
        
        let (mut a, mut b, mut c, mut d, mut e, mut f, mut g, mut hh) = 
            (h[0], h[1], h[2], h[3], h[4], h[5], h[6], h[7]);
        
        for i in 0..64 {
            let s1 = e.rotate_right(6) ^ e.rotate_right(11) ^ e.rotate_right(25);
            let ch = (e & f) ^ ((!e) & g);
            let temp1 = hh.wrapping_add(s1).wrapping_add(ch).wrapping_add(K[i]).wrapping_add(w[i]);
            let s0 = a.rotate_right(2) ^ a.rotate_right(13) ^ a.rotate_right(22);
            let maj = (a & b) ^ (a & c) ^ (b & c);
            let temp2 = s0.wrapping_add(maj);
            
            hh = g; g = f; f = e;
            e = d.wrapping_add(temp1);
            d = c; c = b; b = a;
            a = temp1.wrapping_add(temp2);
        }
        
        h[0] = h[0].wrapping_add(a);
        h[1] = h[1].wrapping_add(b);
        h[2] = h[2].wrapping_add(c);
        h[3] = h[3].wrapping_add(d);
        h[4] = h[4].wrapping_add(e);
        h[5] = h[5].wrapping_add(f);
        h[6] = h[6].wrapping_add(g);
        h[7] = h[7].wrapping_add(hh);
    }
    
    let mut result = [0u8; 32];
    for (i, &val) in h.iter().enumerate() {
        result[i*4..(i+1)*4].copy_from_slice(&val.to_be_bytes());
    }
    result
}

