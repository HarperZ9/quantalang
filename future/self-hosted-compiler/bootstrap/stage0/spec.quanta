//
// Stage 0: Minimal QuantaLang compiler implemented in Rust
// 
// This module documents the SUBSET of QuantaLang that Stage 0 must support
// to bootstrap the full compiler. Stage 0 is intentionally minimal to reduce
// the trusted computing base (TCB).
//
// SUPPORTED FEATURES (Stage 0 Subset):
// ───────────────────────────────────
// - Basic types: bool, i8-i128, u8-u128, f32, f64, char, str, ()
// - Composite types: structs, enums, tuples, arrays, slices
// - References: &T, &mut T
// - Functions with generics
// - Pattern matching (basic)
// - Control flow: if/else, match, loop, while, for
// - Modules and imports
// - Traits (basic, no associated types yet in stage0)
// - Standard macros: vec!, format!, println!, assert!
//
// NOT SUPPORTED IN STAGE 0:
// ─────────────────────────
// - Async/await
// - Closures (implemented as trait objects in stage0)
// - Const generics
// - GATs (Generic Associated Types)
// - Specialization
// - Effect system
// - Procedural macros
//
// ═══════════════════════════════════════════════════════════════════════════════

module quantalang::bootstrap::stage0

use alloc::vec::Vec;
use alloc::string::String;
use alloc::boxed::Box;
use alloc::collections::BTreeMap;
use std::path::PathBuf;

// ═══════════════════════════════════════════════════════════════════════════════
// STAGE 0 SUBSET SPECIFICATION
// ═══════════════════════════════════════════════════════════════════════════════

/// Language features supported in Stage 0
#[derive(Debug, Clone)]
pub struct Stage0Features {
    /// Core language features
    pub core: CoreFeatures,
    
    /// Type system features
    pub types: TypeFeatures,
    
    /// Expression features
    pub expressions: ExprFeatures,
    
    /// Module system features
    pub modules: ModuleFeatures,
}

#[derive(Debug, Clone)]
pub struct CoreFeatures {
    /// Function definitions
    pub functions: bool,
    /// Generic parameters on functions/types
    pub generics: bool,
    /// Where clauses
    pub where_clauses: bool,
    /// Visibility modifiers (pub, pub(crate), etc.)
    pub visibility: bool,
    /// Attributes (#[...])
    pub attributes: bool,
    /// Documentation comments
    pub doc_comments: bool,
}

#[derive(Debug, Clone)]
pub struct TypeFeatures {
    /// Primitive types
    pub primitives: bool,
    /// Struct definitions
    pub structs: bool,
    /// Enum definitions  
    pub enums: bool,
    /// Tuple types
    pub tuples: bool,
    /// Array types [T; N]
    pub arrays: bool,
    /// Slice types [T]
    pub slices: bool,
    /// Reference types &T, &mut T
    pub references: bool,
    /// Box<T>
    pub box_type: bool,
    /// Option<T> / Result<T, E>
    pub option_result: bool,
    /// Trait definitions
    pub traits: bool,
    /// Trait implementations
    pub impls: bool,
    /// Associated types (basic)
    pub associated_types: bool,
    /// Type aliases
    pub type_aliases: bool,
}

#[derive(Debug, Clone)]
pub struct ExprFeatures {
    /// Literals
    pub literals: bool,
    /// Binary operators
    pub binary_ops: bool,
    /// Unary operators
    pub unary_ops: bool,
    /// Function calls
    pub calls: bool,
    /// Method calls
    pub method_calls: bool,
    /// Field access
    pub field_access: bool,
    /// Index access
    pub index_access: bool,
    /// If expressions
    pub if_expr: bool,
    /// Match expressions
    pub match_expr: bool,
    /// Loop expressions
    pub loop_expr: bool,
    /// While loops
    pub while_loop: bool,
    /// For loops
    pub for_loop: bool,
    /// Block expressions
    pub blocks: bool,
    /// Return/break/continue
    pub control_flow: bool,
    /// Let bindings
    pub let_bindings: bool,
    /// Assignment
    pub assignment: bool,
    /// Range expressions
    pub ranges: bool,
    /// Struct literals
    pub struct_literals: bool,
    /// Array/tuple literals
    pub collection_literals: bool,
}

#[derive(Debug, Clone)]
pub struct ModuleFeatures {
    /// Module definitions
    pub modules: bool,
    /// Use imports
    pub imports: bool,
    /// Re-exports (pub use)
    pub reexports: bool,
    /// External crates
    pub extern_crates: bool,
    /// Path resolution
    pub paths: bool,
}

impl Default for Stage0Features {
    fn default() -> Self {
        Stage0Features {
            core: CoreFeatures {
                functions: true,
                generics: true,
                where_clauses: true,
                visibility: true,
                attributes: true,
                doc_comments: true,
            },
            types: TypeFeatures {
                primitives: true,
                structs: true,
                enums: true,
                tuples: true,
                arrays: true,
                slices: true,
                references: true,
                box_type: true,
                option_result: true,
                traits: true,
                impls: true,
                associated_types: true,
                type_aliases: true,
            },
            expressions: ExprFeatures {
                literals: true,
                binary_ops: true,
                unary_ops: true,
                calls: true,
                method_calls: true,
                field_access: true,
                index_access: true,
                if_expr: true,
                match_expr: true,
                loop_expr: true,
                while_loop: true,
                for_loop: true,
                blocks: true,
                control_flow: true,
                let_bindings: true,
                assignment: true,
                ranges: true,
                struct_literals: true,
                collection_literals: true,
            },
            modules: ModuleFeatures {
                modules: true,
                imports: true,
                reexports: true,
                extern_crates: true,
                paths: true,
            },
        }
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// STAGE 0 AST (Subset)
// ═══════════════════════════════════════════════════════════════════════════════

/// Compilation unit for Stage 0
#[derive(Debug, Clone)]
pub struct CompilationUnit {
    pub path: PathBuf,
    pub module: Module,
}

/// Module (Stage 0)
#[derive(Debug, Clone)]
pub struct Module {
    pub name: String,
    pub items: Vec<Item>,
}

/// Item (Stage 0)
#[derive(Debug, Clone)]
pub enum Item {
    /// Function definition
    Function(FunctionDef),
    /// Struct definition
    Struct(StructDef),
    /// Enum definition
    Enum(EnumDef),
    /// Trait definition
    Trait(TraitDef),
    /// Implementation
    Impl(ImplDef),
    /// Type alias
    TypeAlias(TypeAlias),
    /// Module
    Module(Module),
    /// Use import
    Use(UseDef),
    /// Constant
    Const(ConstDef),
    /// Static
    Static(StaticDef),
}

/// Function definition
#[derive(Debug, Clone)]
pub struct FunctionDef {
    pub name: String,
    pub visibility: Visibility,
    pub generics: Generics,
    pub params: Vec<Param>,
    pub return_type: Option<Type>,
    pub where_clause: Option<WhereClause>,
    pub body: Option<Block>,
    pub is_unsafe: bool,
    pub is_const: bool,
    pub attrs: Vec<Attribute>,
}

/// Struct definition
#[derive(Debug, Clone)]
pub struct StructDef {
    pub name: String,
    pub visibility: Visibility,
    pub generics: Generics,
    pub fields: Fields,
    pub where_clause: Option<WhereClause>,
    pub attrs: Vec<Attribute>,
}

/// Enum definition
#[derive(Debug, Clone)]
pub struct EnumDef {
    pub name: String,
    pub visibility: Visibility,
    pub generics: Generics,
    pub variants: Vec<EnumVariant>,
    pub where_clause: Option<WhereClause>,
    pub attrs: Vec<Attribute>,
}

/// Enum variant
#[derive(Debug, Clone)]
pub struct EnumVariant {
    pub name: String,
    pub fields: Fields,
    pub discriminant: Option<Expr>,
    pub attrs: Vec<Attribute>,
}

/// Trait definition
#[derive(Debug, Clone)]
pub struct TraitDef {
    pub name: String,
    pub visibility: Visibility,
    pub generics: Generics,
    pub supertraits: Vec<TraitBound>,
    pub items: Vec<TraitItem>,
    pub where_clause: Option<WhereClause>,
    pub is_unsafe: bool,
    pub attrs: Vec<Attribute>,
}

/// Trait item
#[derive(Debug, Clone)]
pub enum TraitItem {
    /// Associated type
    Type {
        name: String,
        bounds: Vec<TypeBound>,
        default: Option<Type>,
    },
    /// Associated constant
    Const {
        name: String,
        ty: Type,
        default: Option<Expr>,
    },
    /// Method signature (or provided method)
    Method(FunctionDef),
}

/// Implementation
#[derive(Debug, Clone)]
pub struct ImplDef {
    pub generics: Generics,
    pub trait_ref: Option<TraitRef>,
    pub self_ty: Type,
    pub items: Vec<ImplItem>,
    pub where_clause: Option<WhereClause>,
    pub is_unsafe: bool,
    pub is_negative: bool,
    pub attrs: Vec<Attribute>,
}

/// Impl item
#[derive(Debug, Clone)]
pub enum ImplItem {
    Type { name: String, ty: Type },
    Const { name: String, ty: Type, value: Expr },
    Method(FunctionDef),
}

/// Type alias
#[derive(Debug, Clone)]
pub struct TypeAlias {
    pub name: String,
    pub visibility: Visibility,
    pub generics: Generics,
    pub ty: Type,
    pub where_clause: Option<WhereClause>,
    pub attrs: Vec<Attribute>,
}

/// Use declaration
#[derive(Debug, Clone)]
pub struct UseDef {
    pub visibility: Visibility,
    pub tree: UseTree,
    pub attrs: Vec<Attribute>,
}

/// Use tree
#[derive(Debug, Clone)]
pub enum UseTree {
    Simple { path: Path, alias: Option<String> },
    Nested { path: Path, items: Vec<UseTree> },
    Glob { path: Path },
}

/// Constant definition
#[derive(Debug, Clone)]
pub struct ConstDef {
    pub name: String,
    pub visibility: Visibility,
    pub ty: Type,
    pub value: Expr,
    pub attrs: Vec<Attribute>,
}

/// Static definition
#[derive(Debug, Clone)]
pub struct StaticDef {
    pub name: String,
    pub visibility: Visibility,
    pub ty: Type,
    pub value: Expr,
    pub is_mut: bool,
    pub attrs: Vec<Attribute>,
}

// ═══════════════════════════════════════════════════════════════════════════════
// TYPES (Stage 0 Subset)
// ═══════════════════════════════════════════════════════════════════════════════

/// Type (Stage 0)
#[derive(Debug, Clone)]
pub enum Type {
    /// Path type: Vec<T>, Option<T>, etc.
    Path(TypePath),
    /// Reference: &T, &mut T, &'a T
    Reference { lifetime: Option<Lifetime>, mutability: Mutability, ty: Box<Type> },
    /// Tuple: (T1, T2, ...)
    Tuple(Vec<Type>),
    /// Array: [T; N]
    Array { element: Box<Type>, size: usize },
    /// Slice: [T]
    Slice(Box<Type>),
    /// Never: !
    Never,
    /// Inferred: _
    Infer,
    /// Unit: ()
    Unit,
}

/// Type path
#[derive(Debug, Clone)]
pub struct TypePath {
    pub segments: Vec<PathSegment>,
}

/// Path segment
#[derive(Debug, Clone)]
pub struct PathSegment {
    pub ident: String,
    pub args: Option<GenericArgs>,
}

/// Generic arguments
#[derive(Debug, Clone)]
pub struct GenericArgs {
    pub args: Vec<GenericArg>,
}

/// Generic argument
#[derive(Debug, Clone)]
pub enum GenericArg {
    Type(Type),
    Lifetime(Lifetime),
}

/// Lifetime
#[derive(Debug, Clone)]
pub struct Lifetime {
    pub name: String,
}

/// Mutability
#[derive(Debug, Clone, Copy, PartialEq, Eq)]
pub enum Mutability {
    Shared,
    Mutable,
}

/// Visibility
#[derive(Debug, Clone)]
pub enum Visibility {
    Public,
    Crate,
    Super,
    InPath(Path),
    Private,
}

/// Path
#[derive(Debug, Clone)]
pub struct Path {
    pub segments: Vec<String>,
}

/// Generics
#[derive(Debug, Clone, Default)]
pub struct Generics {
    pub params: Vec<GenericParam>,
}

/// Generic parameter
#[derive(Debug, Clone)]
pub enum GenericParam {
    Type { name: String, bounds: Vec<TypeBound> },
    Lifetime { name: String, bounds: Vec<Lifetime> },
}

/// Type bound
#[derive(Debug, Clone)]
pub enum TypeBound {
    Trait(TraitBound),
    Lifetime(Lifetime),
}

/// Trait bound
#[derive(Debug, Clone)]
pub struct TraitBound {
    pub path: TypePath,
}

/// Trait reference
#[derive(Debug, Clone)]
pub struct TraitRef {
    pub path: TypePath,
}

/// Where clause
#[derive(Debug, Clone)]
pub struct WhereClause {
    pub predicates: Vec<WherePredicate>,
}

/// Where predicate
#[derive(Debug, Clone)]
pub enum WherePredicate {
    Type { ty: Type, bounds: Vec<TypeBound> },
    Lifetime { lifetime: Lifetime, bounds: Vec<Lifetime> },
}

/// Fields
#[derive(Debug, Clone)]
pub enum Fields {
    Named(Vec<Field>),
    Unnamed(Vec<Type>),
    Unit,
}

/// Field
#[derive(Debug, Clone)]
pub struct Field {
    pub name: String,
    pub visibility: Visibility,
    pub ty: Type,
    pub attrs: Vec<Attribute>,
}

/// Parameter
#[derive(Debug, Clone)]
pub struct Param {
    pub pattern: Pattern,
    pub ty: Type,
}

/// Attribute
#[derive(Debug, Clone)]
pub struct Attribute {
    pub path: Path,
    pub tokens: Vec<String>,
}

// ═══════════════════════════════════════════════════════════════════════════════
// EXPRESSIONS (Stage 0 Subset)
// ═══════════════════════════════════════════════════════════════════════════════

/// Expression (Stage 0)
#[derive(Debug, Clone)]
pub enum Expr {
    /// Literal
    Literal(Literal),
    /// Variable
    Path(Path),
    /// Binary operation
    Binary { op: BinOp, left: Box<Expr>, right: Box<Expr> },
    /// Unary operation
    Unary { op: UnOp, expr: Box<Expr> },
    /// Function call
    Call { func: Box<Expr>, args: Vec<Expr> },
    /// Method call
    MethodCall { receiver: Box<Expr>, method: String, args: Vec<Expr> },
    /// Field access
    Field { expr: Box<Expr>, field: String },
    /// Index
    Index { expr: Box<Expr>, index: Box<Expr> },
    /// If expression
    If { cond: Box<Expr>, then_branch: Block, else_branch: Option<Box<Expr>> },
    /// Match expression
    Match { expr: Box<Expr>, arms: Vec<MatchArm> },
    /// Loop
    Loop { body: Block, label: Option<String> },
    /// While loop
    While { cond: Box<Expr>, body: Block, label: Option<String> },
    /// For loop
    For { pattern: Pattern, iter: Box<Expr>, body: Block, label: Option<String> },
    /// Block
    Block(Block),
    /// Return
    Return(Option<Box<Expr>>),
    /// Break
    Break { label: Option<String>, value: Option<Box<Expr>> },
    /// Continue
    Continue { label: Option<String> },
    /// Reference
    Ref { mutability: Mutability, expr: Box<Expr> },
    /// Dereference
    Deref(Box<Expr>),
    /// Cast
    Cast { expr: Box<Expr>, ty: Type },
    /// Struct literal
    Struct { path: Path, fields: Vec<(String, Expr)>, rest: Option<Box<Expr>> },
    /// Tuple literal
    Tuple(Vec<Expr>),
    /// Array literal
    Array(Vec<Expr>),
    /// Range
    Range { start: Option<Box<Expr>>, end: Option<Box<Expr>>, inclusive: bool },
    /// Assign
    Assign { target: Box<Expr>, value: Box<Expr> },
    /// Compound assign
    AssignOp { op: BinOp, target: Box<Expr>, value: Box<Expr> },
    /// Try (?)
    Try(Box<Expr>),
}

/// Block
#[derive(Debug, Clone)]
pub struct Block {
    pub stmts: Vec<Stmt>,
    pub expr: Option<Box<Expr>>,
}

/// Statement
#[derive(Debug, Clone)]
pub enum Stmt {
    /// Local binding
    Let { pattern: Pattern, ty: Option<Type>, init: Option<Expr> },
    /// Expression statement
    Expr(Expr),
    /// Item
    Item(Box<Item>),
}

/// Pattern (Stage 0)
#[derive(Debug, Clone)]
pub enum Pattern {
    /// Wildcard
    Wildcard,
    /// Identifier
    Ident { name: String, mutability: Mutability, subpattern: Option<Box<Pattern>> },
    /// Literal
    Literal(Literal),
    /// Struct pattern
    Struct { path: Path, fields: Vec<(String, Pattern)>, rest: bool },
    /// Tuple struct
    TupleStruct { path: Path, patterns: Vec<Pattern> },
    /// Tuple
    Tuple(Vec<Pattern>),
    /// Reference
    Ref { mutability: Mutability, pattern: Box<Pattern> },
    /// Or pattern
    Or(Vec<Pattern>),
    /// Range
    Range { start: Option<Box<Pattern>>, end: Option<Box<Pattern>>, inclusive: bool },
    /// Path
    Path(Path),
}

/// Match arm
#[derive(Debug, Clone)]
pub struct MatchArm {
    pub pattern: Pattern,
    pub guard: Option<Box<Expr>>,
    pub body: Expr,
}

/// Literal
#[derive(Debug, Clone)]
pub enum Literal {
    Bool(bool),
    Char(char),
    Int(i128, Option<IntSuffix>),
    Float(f64, Option<FloatSuffix>),
    Str(String),
    ByteStr(Vec<u8>),
}

#[derive(Debug, Clone, Copy)]
pub enum IntSuffix {
    I8, I16, I32, I64, I128, ISize,
    U8, U16, U32, U64, U128, USize,
}

#[derive(Debug, Clone, Copy)]
pub enum FloatSuffix {
    F32, F64,
}

/// Binary operator
#[derive(Debug, Clone, Copy)]
pub enum BinOp {
    Add, Sub, Mul, Div, Rem,
    And, Or,
    BitAnd, BitOr, BitXor,
    Shl, Shr,
    Eq, Ne, Lt, Le, Gt, Ge,
}

/// Unary operator
#[derive(Debug, Clone, Copy)]
pub enum UnOp {
    Not,
    Neg,
}

// ═══════════════════════════════════════════════════════════════════════════════
// STAGE 0 COMPILER INTERFACE
// ═══════════════════════════════════════════════════════════════════════════════

/// Stage 0 compiler entry point (specification)
pub struct Stage0Compiler {
    /// Compiler configuration
    pub config: Stage0Config,
}

/// Stage 0 configuration
#[derive(Debug, Clone)]
pub struct Stage0Config {
    /// Target triple
    pub target: String,
    /// Optimization level
    pub opt_level: u8,
    /// Debug info
    pub debug_info: bool,
    /// Output path
    pub output: PathBuf,
    /// Library paths
    pub lib_paths: Vec<PathBuf>,
    /// Defines
    pub defines: BTreeMap<String, String>,
}

impl Stage0Compiler {
    /// Create new Stage 0 compiler
    pub fn new(config: Stage0Config) -> Self {
        Stage0Compiler { config }
    }
    
    /// Compile sources to object files
    pub fn compile(&self, sources: &[PathBuf]) -> Result<Vec<PathBuf>, Stage0Error> {
        // Would invoke actual Rust-implemented stage0
        // This is a specification/interface
        Ok(sources.iter().map(|s| s.with_extension("o")).collect())
    }
    
    /// Link object files to executable
    pub fn link(&self, objects: &[PathBuf], output: &PathBuf) -> Result<(), Stage0Error> {
        // Would invoke linker
        Ok(())
    }
}

/// Stage 0 error
#[derive(Debug)]
pub enum Stage0Error {
    ParseError(String),
    TypeError(String),
    CodegenError(String),
    LinkError(String),
    IoError(String),
}

impl std::fmt::Display for Stage0Error {
    fn fmt(&self, f: &mut std::fmt::Formatter<'_>) -> std::fmt::Result {
        match self {
            Self::ParseError(m) => write!(f, "parse error: {}", m),
            Self::TypeError(m) => write!(f, "type error: {}", m),
            Self::CodegenError(m) => write!(f, "codegen error: {}", m),
            Self::LinkError(m) => write!(f, "link error: {}", m),
            Self::IoError(m) => write!(f, "I/O error: {}", m),
        }
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// TESTS
// ═══════════════════════════════════════════════════════════════════════════════

#[cfg(test)]
mod tests {
    use super::*;
    
    #[test]
    fn test_stage0_features() {
        let features = Stage0Features::default();
        assert!(features.core.functions);
        assert!(features.types.structs);
        assert!(features.expressions.match_expr);
        assert!(features.modules.imports);
    }
    
    #[test]
    fn test_type_construction() {
        let ty = Type::Reference {
            lifetime: None,
            mutability: Mutability::Shared,
            ty: Box::new(Type::Path(TypePath {
                segments: vec![PathSegment {
                    ident: "str".to_string(),
                    args: None,
                }],
            })),
        };
        
        assert!(matches!(ty, Type::Reference { .. }));
    }
}
