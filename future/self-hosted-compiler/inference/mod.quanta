// PRELUDE
// ═══════════════════════════════════════════════════════════════════════════════

pub mod prelude {
    pub use super::{
        // Core types
        Ty, TyVar, Scheme, Constraint,
        
        // Environment
        TypeEnv, TypeDef, TypeKind,
        
        // Type checker
        TypeChecker,
        
        // Expressions
        Expr, Literal, BinOp,
        
        // Unification
        Unifier, Substitution, TypeError,
        
        // Utilities
        free_vars_in_type,
    };
}

// ═══════════════════════════════════════════════════════════════════════════════
// TESTS
// ═══════════════════════════════════════════════════════════════════════════════

#[cfg(test)]
mod tests {
    use super::*;
    
    #[test]
    fn test_synth_literal() {
        let mut tc = TypeChecker::new();
        
        let ty = tc.synth(&Expr::Lit(Literal::Bool(true)));
        assert_eq!(ty, Ty::Bool);
    }
    
    #[test]
    fn test_synth_lambda() {
        let mut tc = TypeChecker::new();
        
        // |x| x (identity)
        let expr = Expr::Lambda {
            param: "x".to_string(),
            body: Box::new(Expr::Var("x".to_string())),
        };
        
        let ty = tc.synth(&expr);
        
        // Should be Fun { params: [?0], ret: ?0 }
        assert!(matches!(ty, Ty::Fun { .. }));
    }
    
    #[test]
    fn test_synth_application() {
        let mut tc = TypeChecker::new();
        
        // Add id function to env
        let id_ty = Ty::Forall {
            vars: vec![TyVar(1000)],
            body: Box::new(Ty::Fun {
                params: vec![Ty::Var(TyVar(1000))],
                ret: Box::new(Ty::Var(TyVar(1000))),
                effects: EffectRow::pure(),
            }),
        };
        tc.env.insert("id".to_string(), Scheme {
            vars: vec![TyVar(1000)],
            lifetimes: vec![],
            constraints: vec![],
            ty: Ty::Fun {
                params: vec![Ty::Var(TyVar(1000))],
                ret: Box::new(Ty::Var(TyVar(1000))),
                effects: EffectRow::pure(),
            },
        });
        
        // id true
        let expr = Expr::App {
            func: Box::new(Expr::Var("id".to_string())),
            arg: Box::new(Expr::Lit(Literal::Bool(true))),
        };
        
        let ty = tc.synth(&expr);
        tc.finalize().unwrap();
        
        let final_ty = tc.unifier.substitution().apply(&ty);
        assert_eq!(final_ty, Ty::Bool);
    }
    
    #[test]
    fn test_record_inference() {
        let mut tc = TypeChecker::new();
        
        let expr = Expr::Record {
            fields: vec![
                ("x".to_string(), Expr::Lit(Literal::Int(42))),
                ("y".to_string(), Expr::Lit(Literal::Bool(true))),
            ],
        };
        
        let ty = tc.synth(&expr);
        
        assert!(matches!(ty, Ty::Record(_)));
    }
    
    #[test]
    fn test_generalize() {
        let tc = TypeChecker::new();
        
        // Type with free variable
        let ty = Ty::Fun {
            params: vec![Ty::Var(TyVar(100))],
            ret: Box::new(Ty::Var(TyVar(100))),
            effects: EffectRow::pure(),
        };
        
        let scheme = tc.generalize(&ty);
        
        // Should quantify over TyVar(100)
        assert!(!scheme.vars.is_empty());
    }
}
