// ═══════════════════════════════════════════════════════════════════════════════
// TRACE & SPAN IDs
// ═══════════════════════════════════════════════════════════════════════════════

/// 128-bit trace identifier (W3C Trace Context)
#[derive(Debug, Clone, Copy, PartialEq, Eq, Hash)]
pub struct TraceId([u8; 16]);

impl TraceId {
    /// Create a new random trace ID
    pub fn new() -> Self {
        let mut bytes = [0u8; 16];
        getrandom(&mut bytes);
        TraceId(bytes)
    }
    
    /// Create from bytes
    pub fn from_bytes(bytes: [u8; 16]) -> Self {
        TraceId(bytes)
    }
    
    /// Create from hex string
    pub fn from_hex(s: &str) -> Option<Self> {
        if s.len() != 32 {
            return None;
        }
        let mut bytes = [0u8; 16];
        for i in 0..16 {
            bytes[i] = u8::from_str_radix(&s[i*2..i*2+2], 16).ok()?;
        }
        Some(TraceId(bytes))
    }
    
    /// Convert to hex string
    pub fn to_hex(&self) -> String {
        self.0.iter().map(|b| format!("{:02x}", b)).collect()
    }
    
    /// Check if valid (non-zero)
    pub fn is_valid(&self) -> bool {
        self.0.iter().any(|&b| b != 0)
    }
    
    /// Get bytes
    pub fn as_bytes(&self) -> &[u8; 16] {
        &self.0
    }
}

impl Default for TraceId {
    fn default() -> Self {
        Self::new()
    }
}

/// 64-bit span identifier
#[derive(Debug, Clone, Copy, PartialEq, Eq, Hash)]
pub struct SpanId([u8; 8]);

impl SpanId {
    /// Create a new random span ID
    pub fn new() -> Self {
        let mut bytes = [0u8; 8];
        getrandom(&mut bytes);
        SpanId(bytes)
    }
    
    /// Create from bytes
    pub fn from_bytes(bytes: [u8; 8]) -> Self {
        SpanId(bytes)
    }
    
    /// Create from hex string
    pub fn from_hex(s: &str) -> Option<Self> {
        if s.len() != 16 {
            return None;
        }
        let mut bytes = [0u8; 8];
        for i in 0..8 {
            bytes[i] = u8::from_str_radix(&s[i*2..i*2+2], 16).ok()?;
        }
        Some(SpanId(bytes))
    }
    
    /// Convert to hex string
    pub fn to_hex(&self) -> String {
        self.0.iter().map(|b| format!("{:02x}", b)).collect()
    }
    
    /// Check if valid (non-zero)
    pub fn is_valid(&self) -> bool {
        self.0.iter().any(|&b| b != 0)
    }
    
    /// Invalid span ID
    pub fn invalid() -> Self {
        SpanId([0; 8])
    }
}

impl Default for SpanId {
    fn default() -> Self {
        Self::new()
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// SPAN CONTEXT
// ═══════════════════════════════════════════════════════════════════════════════

/// Context for distributed tracing propagation
#[derive(Debug, Clone)]
pub struct SpanContext {
    /// Trace identifier
    pub trace_id: TraceId,
    
    /// Span identifier
    pub span_id: SpanId,
    
    /// Trace flags
    pub trace_flags: TraceFlags,
    
    /// Trace state (vendor-specific)
    pub trace_state: TraceState,
    
    /// Whether this context is remote
    pub is_remote: bool,
}

impl SpanContext {
    /// Create a new span context
    pub fn new(trace_id: TraceId, span_id: SpanId, trace_flags: TraceFlags) -> Self {
        SpanContext {
            trace_id,
            span_id,
            trace_flags,
            trace_state: TraceState::default(),
            is_remote: false,
        }
    }
    
    /// Create an invalid span context
    pub fn invalid() -> Self {
        SpanContext {
            trace_id: TraceId([0; 16]),
            span_id: SpanId([0; 8]),
            trace_flags: TraceFlags::default(),
            trace_state: TraceState::default(),
            is_remote: false,
        }
    }
    
    /// Check if context is valid
    pub fn is_valid(&self) -> bool {
        self.trace_id.is_valid() && self.span_id.is_valid()
    }
    
    /// Check if sampled
    pub fn is_sampled(&self) -> bool {
        self.trace_flags.is_sampled()
    }
    
    /// Create child context
    pub fn child(&self) -> SpanContext {
        SpanContext {
            trace_id: self.trace_id,
            span_id: SpanId::new(),
            trace_flags: self.trace_flags,
            trace_state: self.trace_state.clone(),
            is_remote: false,
        }
    }
    
    /// Format as W3C traceparent header
    pub fn to_traceparent(&self) -> String {
        format!(
            "00-{}-{}-{:02x}",
            self.trace_id.to_hex(),
            self.span_id.to_hex(),
            self.trace_flags.0
        )
    }
    
    /// Parse from W3C traceparent header
    pub fn from_traceparent(s: &str) -> Option<Self> {
        let parts: Vec<&str> = s.split('-').collect();
        if parts.len() != 4 || parts[0] != "00" {
            return None;
        }
        
        let trace_id = TraceId::from_hex(parts[1])?;
        let span_id = SpanId::from_hex(parts[2])?;
        let flags = u8::from_str_radix(parts[3], 16).ok()?;
        
        Some(SpanContext {
            trace_id,
            span_id,
            trace_flags: TraceFlags(flags),
            trace_state: TraceState::default(),
            is_remote: true,
        })
    }
}

/// Trace flags (W3C)
#[derive(Debug, Clone, Copy, Default)]
pub struct TraceFlags(u8);

impl TraceFlags {
    pub const SAMPLED: u8 = 0x01;
    
    pub fn sampled() -> Self {
        TraceFlags(Self::SAMPLED)
    }
    
    pub fn is_sampled(&self) -> bool {
        self.0 & Self::SAMPLED != 0
    }
    
    pub fn with_sampled(mut self, sampled: bool) -> Self {
        if sampled {
            self.0 |= Self::SAMPLED;
        } else {
            self.0 &= !Self::SAMPLED;
        }
        self
    }
}

/// Trace state (vendor-specific key-value pairs)
#[derive(Debug, Clone, Default)]
pub struct TraceState {
    entries: Vec<(String, String)>,
}

impl TraceState {
    pub fn new() -> Self {
        TraceState { entries: Vec::new() }
    }
    
    pub fn get(&self, key: &str) -> Option<&str> {
        self.entries.iter()
            .find(|(k, _)| k == key)
            .map(|(_, v)| v.as_str())
    }
    
    pub fn insert(&mut self, key: String, value: String) {
        self.entries.retain(|(k, _)| k != &key);
        self.entries.insert(0, (key, value));
    }
    
    pub fn to_header(&self) -> String {
        self.entries.iter()
            .map(|(k, v)| format!("{}={}", k, v))
            .collect::<Vec<_>>()
            .join(",")
    }
    
    pub fn from_header(s: &str) -> Self {
        let entries: Vec<_> = s.split(',')
            .filter_map(|pair| {
                let mut parts = pair.splitn(2, '=');
                let key = parts.next()?.trim().to_string();
                let value = parts.next()?.trim().to_string();
                Some((key, value))
            })
            .collect();
        TraceState { entries }
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// SPAN
// ═══════════════════════════════════════════════════════════════════════════════

/// Span status
#[derive(Debug, Clone, Copy, PartialEq, Eq)]
pub enum SpanStatus {
    Unset,
    Ok,
    Error,
}

impl Default for SpanStatus {
    fn default() -> Self {
        SpanStatus::Unset
    }
}

/// Span kind
#[derive(Debug, Clone, Copy, PartialEq, Eq)]
pub enum SpanKind {
    Internal,
    Server,
    Client,
    Producer,
    Consumer,
}

impl Default for SpanKind {
    fn default() -> Self {
        SpanKind::Internal
    }
}

/// Attribute value
#[derive(Debug, Clone)]
pub enum AttributeValue {
    String(String),
    Bool(bool),
    Int(i64),
    Float(f64),
    StringArray(Vec<String>),
    BoolArray(Vec<bool>),
    IntArray(Vec<i64>),
    FloatArray(Vec<f64>),
}

impl From<&str> for AttributeValue {
    fn from(s: &str) -> Self {
        AttributeValue::String(s.to_string())
    }
}

impl From<String> for AttributeValue {
    fn from(s: String) -> Self {
        AttributeValue::String(s)
    }
}

impl From<bool> for AttributeValue {
    fn from(b: bool) -> Self {
        AttributeValue::Bool(b)
    }
}

impl From<i64> for AttributeValue {
    fn from(i: i64) -> Self {
        AttributeValue::Int(i)
    }
}

impl From<f64> for AttributeValue {
    fn from(f: f64) -> Self {
        AttributeValue::Float(f)
    }
}

/// Span event
#[derive(Debug, Clone)]
pub struct SpanEvent {
    pub name: String,
    pub timestamp: SystemTime,
    pub attributes: Vec<(String, AttributeValue)>,
}

/// Span link
#[derive(Debug, Clone)]
pub struct SpanLink {
    pub context: SpanContext,
    pub attributes: Vec<(String, AttributeValue)>,
}

/// A single span in a trace
pub struct Span {
    /// Span name
    name: String,
    
    /// Span context
    context: SpanContext,
    
    /// Parent span ID
    parent_span_id: Option<SpanId>,
    
    /// Span kind
    kind: SpanKind,
    
    /// Start time
    start_time: SystemTime,
    
    /// End time (set when span ends)
    end_time: Option<SystemTime>,
    
    /// Status
    status: SpanStatus,
    
    /// Status message
    status_message: Option<String>,
    
    /// Attributes
    attributes: Vec<(String, AttributeValue)>,
    
    /// Events
    events: Vec<SpanEvent>,
    
    /// Links
    links: Vec<SpanLink>,
    
    /// Resource
    resource: Option<Arc<Resource>>,
    
    /// Instrumentation scope
    scope: Option<InstrumentationScope>,
    
    /// Whether span is recording
    is_recording: AtomicBool,
    
    /// Span processor
    processor: Option<Arc<dyn SpanProcessor>>,
}

impl Span {
    /// Create a new span
    pub fn new(
        name: impl Into<String>,
        context: SpanContext,
        parent_span_id: Option<SpanId>,
        kind: SpanKind,
    ) -> Self {
        Span {
            name: name.into(),
            context,
            parent_span_id,
            kind,
            start_time: SystemTime::now(),
            end_time: None,
            status: SpanStatus::Unset,
            status_message: None,
            attributes: Vec::new(),
            events: Vec::new(),
            links: Vec::new(),
            resource: None,
            scope: None,
            is_recording: AtomicBool::new(true),
            processor: None,
        }
    }
    
    /// Get span context
    pub fn context(&self) -> &SpanContext {
        &self.context
    }
    
    /// Get span name
    pub fn name(&self) -> &str {
        &self.name
    }
    
    /// Set span name
    pub fn set_name(&mut self, name: impl Into<String>) {
        if self.is_recording() {
            self.name = name.into();
        }
    }
    
    /// Get span kind
    pub fn kind(&self) -> SpanKind {
        self.kind
    }
    
    /// Check if recording
    pub fn is_recording(&self) -> bool {
        self.is_recording.load(Ordering::Acquire)
    }
    
    /// Set attribute
    pub fn set_attribute(&mut self, key: impl Into<String>, value: impl Into<AttributeValue>) {
        if self.is_recording() {
            let key = key.into();
            self.attributes.retain(|(k, _)| k != &key);
            self.attributes.push((key, value.into()));
        }
    }
    
    /// Set multiple attributes
    pub fn set_attributes<I, K, V>(&mut self, attrs: I)
    where
        I: IntoIterator<Item = (K, V)>,
        K: Into<String>,
        V: Into<AttributeValue>,
    {
        for (k, v) in attrs {
            self.set_attribute(k, v);
        }
    }
    
    /// Add event
    pub fn add_event(&mut self, name: impl Into<String>) {
        self.add_event_with_attributes(name, Vec::new());
    }
    
    /// Add event with attributes
    pub fn add_event_with_attributes(
        &mut self,
        name: impl Into<String>,
        attributes: Vec<(String, AttributeValue)>,
    ) {
        if self.is_recording() {
            self.events.push(SpanEvent {
                name: name.into(),
                timestamp: SystemTime::now(),
                attributes,
            });
        }
    }
    
    /// Record exception
    pub fn record_exception(&mut self, error: &dyn std::error::Error) {
        let mut attrs = vec![
            ("exception.type".to_string(), AttributeValue::String(
                std::any::type_name_of_val(error).to_string()
            )),
            ("exception.message".to_string(), AttributeValue::String(
                error.to_string()
            )),
        ];
        
        // Add backtrace if available
        #[cfg(feature = "backtrace")]
        {
            let bt = std::backtrace::Backtrace::capture();
            attrs.push((
                "exception.stacktrace".to_string(),
                AttributeValue::String(bt.to_string()),
            ));
        }
        
        self.add_event_with_attributes("exception", attrs);
        self.set_status(SpanStatus::Error, Some(error.to_string()));
    }
    
    /// Add link
    pub fn add_link(&mut self, context: SpanContext, attributes: Vec<(String, AttributeValue)>) {
        if self.is_recording() {
            self.links.push(SpanLink { context, attributes });
        }
    }
    
    /// Set status
    pub fn set_status(&mut self, status: SpanStatus, message: Option<String>) {
        if self.is_recording() {
            // Only update if current status is Unset or new status is Error
            if self.status == SpanStatus::Unset || status == SpanStatus::Error {
                self.status = status;
                self.status_message = message;
            }
        }
    }
    
    /// End the span
    pub fn end(&mut self) {
        self.end_with_time(SystemTime::now());
    }
    
    /// End with specific timestamp
    pub fn end_with_time(&mut self, timestamp: SystemTime) {
        if self.is_recording.swap(false, Ordering::AcqRel) {
            self.end_time = Some(timestamp);
            
            if let Some(processor) = &self.processor {
                processor.on_end(self);
            }
        }
    }
    
    /// Get span data for export
    pub fn to_span_data(&self) -> SpanData {
        SpanData {
            name: self.name.clone(),
            context: self.context.clone(),
            parent_span_id: self.parent_span_id,
            kind: self.kind,
            start_time: self.start_time,
            end_time: self.end_time.unwrap_or(SystemTime::now()),
            status: self.status,
            status_message: self.status_message.clone(),
            attributes: self.attributes.clone(),
            events: self.events.clone(),
            links: self.links.clone(),
            resource: self.resource.clone(),
            scope: self.scope.clone(),
        }
    }
}

impl Drop for Span {
    fn drop(&mut self) {
        if self.is_recording() {
            self.end();
        }
    }
}

/// Exported span data
#[derive(Debug, Clone)]
pub struct SpanData {
    pub name: String,
    pub context: SpanContext,
    pub parent_span_id: Option<SpanId>,
    pub kind: SpanKind,
    pub start_time: SystemTime,
    pub end_time: SystemTime,
    pub status: SpanStatus,
    pub status_message: Option<String>,
    pub attributes: Vec<(String, AttributeValue)>,
    pub events: Vec<SpanEvent>,
    pub links: Vec<SpanLink>,
    pub resource: Option<Arc<Resource>>,
    pub scope: Option<InstrumentationScope>,
}

// ═══════════════════════════════════════════════════════════════════════════════
// RESOURCE
// ═══════════════════════════════════════════════════════════════════════════════

/// Resource represents the entity producing telemetry
#[derive(Debug, Clone)]
pub struct Resource {
    attributes: Vec<(String, AttributeValue)>,
    schema_url: Option<String>,
}

impl Resource {
    /// Create a new resource
    pub fn new(attributes: Vec<(String, AttributeValue)>) -> Self {
        Resource {
            attributes,
            schema_url: None,
        }
    }
    
    /// Create default resource with service info
    pub fn default_resource(service_name: &str) -> Self {
        Resource::new(vec![
            ("service.name".to_string(), AttributeValue::String(service_name.to_string())),
            ("service.version".to_string(), AttributeValue::String(env!("CARGO_PKG_VERSION").to_string())),
            ("telemetry.sdk.name".to_string(), AttributeValue::String("quantalang".to_string())),
            ("telemetry.sdk.version".to_string(), AttributeValue::String("1.0.0".to_string())),
            ("telemetry.sdk.language".to_string(), AttributeValue::String("quanta".to_string())),
        ])
    }
    
    /// Get attributes
    pub fn attributes(&self) -> &[(String, AttributeValue)] {
        &self.attributes
    }
    
    /// Get attribute value
    pub fn get(&self, key: &str) -> Option<&AttributeValue> {
        self.attributes.iter()
            .find(|(k, _)| k == key)
            .map(|(_, v)| v)
    }
    
    /// Merge with another resource
    pub fn merge(&self, other: &Resource) -> Resource {
        let mut attrs = self.attributes.clone();
        for (key, value) in &other.attributes {
            if !attrs.iter().any(|(k, _)| k == key) {
                attrs.push((key.clone(), value.clone()));
            }
        }
        Resource {
            attributes: attrs,
            schema_url: self.schema_url.clone().or(other.schema_url.clone()),
        }
    }
}

/// Instrumentation scope
#[derive(Debug, Clone)]
pub struct InstrumentationScope {
    pub name: String,
    pub version: Option<String>,
    pub schema_url: Option<String>,
    pub attributes: Vec<(String, AttributeValue)>,
}

// ═══════════════════════════════════════════════════════════════════════════════
// TRACER
// ═══════════════════════════════════════════════════════════════════════════════

/// Tracer for creating spans
pub struct Tracer {
    scope: InstrumentationScope,
    provider: Arc<TracerProvider>,
}

impl Tracer {
    /// Start a new span
    pub fn start(&self, name: impl Into<String>) -> Span {
        self.start_with_options(name, SpanOptions::default())
    }
    
    /// Start a span with options
    pub fn start_with_options(&self, name: impl Into<String>, options: SpanOptions) -> Span {
        let name = name.into();
        
        // Determine parent context
        let parent = options.parent.or_else(|| current_span_context());
        
        // Create span context
        let (trace_id, parent_span_id) = match &parent {
            Some(ctx) if ctx.is_valid() => (ctx.trace_id, Some(ctx.span_id)),
            _ => (TraceId::new(), None),
        };
        
        // Sample decision
        let sampler = self.provider.sampler();
        let sampling_result = sampler.should_sample(
            parent.as_ref(),
            &trace_id,
            &name,
            options.kind,
            &options.attributes,
            &options.links,
        );
        
        let trace_flags = if sampling_result.decision.is_sampled() {
            TraceFlags::sampled()
        } else {
            TraceFlags::default()
        };
        
        let context = SpanContext::new(trace_id, SpanId::new(), trace_flags);
        
        let mut span = Span::new(name, context, parent_span_id, options.kind);
        span.resource = Some(self.provider.resource.clone());
        span.scope = Some(self.scope.clone());
        span.processor = Some(self.provider.processor.clone());
        
        // Add sampling attributes
        for (key, value) in sampling_result.attributes {
            span.set_attribute(key, value);
        }
        
        // Add user attributes
        for (key, value) in options.attributes {
            span.set_attribute(key, value);
        }
        
        // Add links
        for link in options.links {
            span.links.push(link);
        }
        
        // Notify processor
        self.provider.processor.on_start(&span);
        
        span
    }
    
    /// Create a span builder
    pub fn span_builder(&self, name: impl Into<String>) -> SpanBuilder {
        SpanBuilder::new(self, name.into())
    }
    
    /// Execute a closure within a span
    pub fn in_span<F, R>(&self, name: impl Into<String>, f: F) -> R
    where
        F: FnOnce(&mut Span) -> R,
    {
        let mut span = self.start(name);
        let _guard = set_current_span(&span);
        let result = f(&mut span);
        span.end();
        result
    }
}

/// Span creation options
#[derive(Default)]
pub struct SpanOptions {
    pub kind: SpanKind,
    pub parent: Option<SpanContext>,
    pub attributes: Vec<(String, AttributeValue)>,
    pub links: Vec<SpanLink>,
    pub start_time: Option<SystemTime>,
}

/// Span builder for fluent API
pub struct SpanBuilder<'a> {
    tracer: &'a Tracer,
    name: String,
    options: SpanOptions,
}

impl<'a> SpanBuilder<'a> {
    fn new(tracer: &'a Tracer, name: String) -> Self {
        SpanBuilder {
            tracer,
            name,
            options: SpanOptions::default(),
        }
    }
    
    pub fn with_kind(mut self, kind: SpanKind) -> Self {
        self.options.kind = kind;
        self
    }
    
    pub fn with_parent(mut self, parent: SpanContext) -> Self {
        self.options.parent = Some(parent);
        self
    }
    
    pub fn with_attribute(mut self, key: impl Into<String>, value: impl Into<AttributeValue>) -> Self {
        self.options.attributes.push((key.into(), value.into()));
        self
    }
    
    pub fn with_link(mut self, context: SpanContext) -> Self {
        self.options.links.push(SpanLink {
            context,
            attributes: Vec::new(),
        });
        self
    }
    
    pub fn with_start_time(mut self, time: SystemTime) -> Self {
        self.options.start_time = Some(time);
        self
    }
    
    pub fn start(self) -> Span {
        self.tracer.start_with_options(self.name, self.options)
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// TRACER PROVIDER
// ═══════════════════════════════════════════════════════════════════════════════

/// Tracer provider
pub struct TracerProvider {
    resource: Arc<Resource>,
    sampler: Arc<dyn Sampler>,
    processor: Arc<dyn SpanProcessor>,
    tracers: RwLock<Vec<Arc<Tracer>>>,
}

impl TracerProvider {
    /// Create a new tracer provider
    pub fn new(
        resource: Resource,
        sampler: impl Sampler + 'static,
        processor: impl SpanProcessor + 'static,
    ) -> Self {
        TracerProvider {
            resource: Arc::new(resource),
            sampler: Arc::new(sampler),
            processor: Arc::new(processor),
            tracers: RwLock::new(Vec::new()),
        }
    }
    
    /// Create a tracer provider builder
    pub fn builder() -> TracerProviderBuilder {
        TracerProviderBuilder::new()
    }
    
    /// Get a tracer
    pub fn tracer(self: &Arc<Self>, name: &str) -> Arc<Tracer> {
        self.tracer_with_version(name, None)
    }
    
    /// Get a tracer with version
    pub fn tracer_with_version(self: &Arc<Self>, name: &str, version: Option<&str>) -> Arc<Tracer> {
        let scope = InstrumentationScope {
            name: name.to_string(),
            version: version.map(|s| s.to_string()),
            schema_url: None,
            attributes: Vec::new(),
        };
        
        let tracer = Arc::new(Tracer {
            scope,
            provider: self.clone(),
        });
        
        self.tracers.write().unwrap().push(tracer.clone());
        tracer
    }
    
    /// Get sampler
    pub fn sampler(&self) -> &dyn Sampler {
        self.sampler.as_ref()
    }
    
    /// Shutdown the provider
    pub fn shutdown(&self) -> Result<(), TracingError> {
        self.processor.shutdown()
    }
    
    /// Force flush
    pub fn force_flush(&self) -> Result<(), TracingError> {
        self.processor.force_flush()
    }
}

/// Tracer provider builder
pub struct TracerProviderBuilder {
    resource: Option<Resource>,
    sampler: Option<Arc<dyn Sampler>>,
    processors: Vec<Arc<dyn SpanProcessor>>,
}

impl TracerProviderBuilder {
    pub fn new() -> Self {
        TracerProviderBuilder {
            resource: None,
            sampler: None,
            processors: Vec::new(),
        }
    }
    
    pub fn with_resource(mut self, resource: Resource) -> Self {
        self.resource = Some(resource);
        self
    }
    
    pub fn with_sampler(mut self, sampler: impl Sampler + 'static) -> Self {
        self.sampler = Some(Arc::new(sampler));
        self
    }
    
    pub fn with_processor(mut self, processor: impl SpanProcessor + 'static) -> Self {
        self.processors.push(Arc::new(processor));
        self
    }
    
    pub fn build(self) -> Arc<TracerProvider> {
        let resource = self.resource.unwrap_or_else(|| Resource::default_resource("unknown"));
        let sampler = self.sampler.unwrap_or_else(|| Arc::new(AlwaysOnSampler));
        
        let processor: Arc<dyn SpanProcessor> = if self.processors.is_empty() {
            Arc::new(NoopProcessor)
        } else if self.processors.len() == 1 {
            self.processors.into_iter().next().unwrap()
        } else {
            Arc::new(MultiProcessor { processors: self.processors })
        };
        
        Arc::new(TracerProvider {
            resource: Arc::new(resource),
            sampler,
            processor,
            tracers: RwLock::new(Vec::new()),
        })
    }
}

impl Default for TracerProviderBuilder {
    fn default() -> Self {
        Self::new()
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// SAMPLING
// ═══════════════════════════════════════════════════════════════════════════════

/// Sampling decision
#[derive(Debug, Clone, Copy, PartialEq, Eq)]
pub enum SamplingDecision {
    Drop,
    RecordOnly,
    RecordAndSample,
}

impl SamplingDecision {
    pub fn is_sampled(&self) -> bool {
        matches!(self, SamplingDecision::RecordAndSample)
    }
    
    pub fn is_recording(&self) -> bool {
        !matches!(self, SamplingDecision::Drop)
    }
}

/// Sampling result
pub struct SamplingResult {
    pub decision: SamplingDecision,
    pub attributes: Vec<(String, AttributeValue)>,
    pub trace_state: TraceState,
}

/// Sampler trait
pub trait Sampler: Send + Sync {
    fn should_sample(
        &self,
        parent: Option<&SpanContext>,
        trace_id: &TraceId,
        name: &str,
        kind: SpanKind,
        attributes: &[(String, AttributeValue)],
        links: &[SpanLink],
    ) -> SamplingResult;
    
    fn description(&self) -> &str;
}

/// Always sample
pub struct AlwaysOnSampler;

impl Sampler for AlwaysOnSampler {
    fn should_sample(
        &self,
        _parent: Option<&SpanContext>,
        _trace_id: &TraceId,
        _name: &str,
        _kind: SpanKind,
        _attributes: &[(String, AttributeValue)],
        _links: &[SpanLink],
    ) -> SamplingResult {
        SamplingResult {
            decision: SamplingDecision::RecordAndSample,
            attributes: Vec::new(),
            trace_state: TraceState::default(),
        }
    }
    
    fn description(&self) -> &str {
        "AlwaysOnSampler"
    }
}

/// Never sample
pub struct AlwaysOffSampler;

impl Sampler for AlwaysOffSampler {
    fn should_sample(
        &self,
        _parent: Option<&SpanContext>,
        _trace_id: &TraceId,
        _name: &str,
        _kind: SpanKind,
        _attributes: &[(String, AttributeValue)],
        _links: &[SpanLink],
    ) -> SamplingResult {
        SamplingResult {
            decision: SamplingDecision::Drop,
            attributes: Vec::new(),
            trace_state: TraceState::default(),
        }
    }
    
    fn description(&self) -> &str {
        "AlwaysOffSampler"
    }
}

/// Probability-based sampler
pub struct TraceIdRatioSampler {
    ratio: f64,
    threshold: u64,
}

impl TraceIdRatioSampler {
    pub fn new(ratio: f64) -> Self {
        let ratio = ratio.clamp(0.0, 1.0);
        let threshold = (ratio * u64::MAX as f64) as u64;
        TraceIdRatioSampler { ratio, threshold }
    }
}

impl Sampler for TraceIdRatioSampler {
    fn should_sample(
        &self,
        _parent: Option<&SpanContext>,
        trace_id: &TraceId,
        _name: &str,
        _kind: SpanKind,
        _attributes: &[(String, AttributeValue)],
        _links: &[SpanLink],
    ) -> SamplingResult {
        // Use lower 8 bytes of trace ID for consistent sampling
        let bytes = trace_id.as_bytes();
        let value = u64::from_be_bytes([
            bytes[8], bytes[9], bytes[10], bytes[11],
            bytes[12], bytes[13], bytes[14], bytes[15],
        ]);
        
        let decision = if value < self.threshold {
            SamplingDecision::RecordAndSample
        } else {
            SamplingDecision::Drop
        };
        
        SamplingResult {
            decision,
            attributes: Vec::new(),
            trace_state: TraceState::default(),
        }
    }
    
    fn description(&self) -> &str {
        "TraceIdRatioSampler"
    }
}

/// Parent-based sampler
pub struct ParentBasedSampler {
    root: Arc<dyn Sampler>,
    remote_sampled: Arc<dyn Sampler>,
    remote_not_sampled: Arc<dyn Sampler>,
    local_sampled: Arc<dyn Sampler>,
    local_not_sampled: Arc<dyn Sampler>,
}

impl ParentBasedSampler {
    pub fn new(root: impl Sampler + 'static) -> Self {
        ParentBasedSampler {
            root: Arc::new(root),
            remote_sampled: Arc::new(AlwaysOnSampler),
            remote_not_sampled: Arc::new(AlwaysOffSampler),
            local_sampled: Arc::new(AlwaysOnSampler),
            local_not_sampled: Arc::new(AlwaysOffSampler),
        }
    }
}

impl Sampler for ParentBasedSampler {
    fn should_sample(
        &self,
        parent: Option<&SpanContext>,
        trace_id: &TraceId,
        name: &str,
        kind: SpanKind,
        attributes: &[(String, AttributeValue)],
        links: &[SpanLink],
    ) -> SamplingResult {
        let sampler = match parent {
            None => &self.root,
            Some(ctx) if !ctx.is_valid() => &self.root,
            Some(ctx) if ctx.is_remote && ctx.is_sampled() => &self.remote_sampled,
            Some(ctx) if ctx.is_remote => &self.remote_not_sampled,
            Some(ctx) if ctx.is_sampled() => &self.local_sampled,
            Some(_) => &self.local_not_sampled,
        };
        
        sampler.should_sample(parent, trace_id, name, kind, attributes, links)
    }
    
    fn description(&self) -> &str {
        "ParentBasedSampler"
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// SPAN PROCESSOR
// ═══════════════════════════════════════════════════════════════════════════════

/// Span processor trait
pub trait SpanProcessor: Send + Sync {
    fn on_start(&self, span: &Span);
    fn on_end(&self, span: &Span);
    fn shutdown(&self) -> Result<(), TracingError>;
    fn force_flush(&self) -> Result<(), TracingError>;
}

/// No-op processor
pub struct NoopProcessor;

impl SpanProcessor for NoopProcessor {
    fn on_start(&self, _span: &Span) {}
    fn on_end(&self, _span: &Span) {}
    fn shutdown(&self) -> Result<(), TracingError> { Ok(()) }
    fn force_flush(&self) -> Result<(), TracingError> { Ok(()) }
}

/// Multi-processor (chains multiple processors)
struct MultiProcessor {
    processors: Vec<Arc<dyn SpanProcessor>>,
}

impl SpanProcessor for MultiProcessor {
    fn on_start(&self, span: &Span) {
        for p in &self.processors {
            p.on_start(span);
        }
    }
    
    fn on_end(&self, span: &Span) {
        for p in &self.processors {
            p.on_end(span);
        }
    }
    
    fn shutdown(&self) -> Result<(), TracingError> {
        for p in &self.processors {
            p.shutdown()?;
        }
        Ok(())
    }
    
    fn force_flush(&self) -> Result<(), TracingError> {
        for p in &self.processors {
            p.force_flush()?;
        }
        Ok(())
    }
}

/// Simple synchronous processor
pub struct SimpleProcessor {
    exporter: Mutex<Box<dyn SpanExporter>>,
}

impl SimpleProcessor {
    pub fn new(exporter: impl SpanExporter + 'static) -> Self {
        SimpleProcessor {
            exporter: Mutex::new(Box::new(exporter)),
        }
    }
}

impl SpanProcessor for SimpleProcessor {
    fn on_start(&self, _span: &Span) {}
    
    fn on_end(&self, span: &Span) {
        let data = span.to_span_data();
        let _ = self.exporter.lock().unwrap().export(vec![data]);
    }
    
    fn shutdown(&self) -> Result<(), TracingError> {
        self.exporter.lock().unwrap().shutdown()
    }
    
    fn force_flush(&self) -> Result<(), TracingError> {
        Ok(())
    }
}

/// Batch span processor
pub struct BatchProcessor {
    queue: Mutex<Vec<SpanData>>,
    exporter: Mutex<Box<dyn SpanExporter>>,
    config: BatchConfig,
    shutdown: AtomicBool,
}

/// Batch processor configuration
#[derive(Debug, Clone)]
pub struct BatchConfig {
    pub max_queue_size: usize,
    pub max_export_batch_size: usize,
    pub scheduled_delay: Duration,
    pub export_timeout: Duration,
}

impl Default for BatchConfig {
    fn default() -> Self {
        BatchConfig {
            max_queue_size: 2048,
            max_export_batch_size: 512,
            scheduled_delay: Duration::from_secs(5),
            export_timeout: Duration::from_secs(30),
        }
    }
}

impl BatchProcessor {
    pub fn new(exporter: impl SpanExporter + 'static, config: BatchConfig) -> Self {
        BatchProcessor {
            queue: Mutex::new(Vec::with_capacity(config.max_queue_size)),
            exporter: Mutex::new(Box::new(exporter)),
            config,
            shutdown: AtomicBool::new(false),
        }
    }
    
    fn export_batch(&self) -> Result<(), TracingError> {
        let batch: Vec<SpanData> = {
            let mut queue = self.queue.lock().unwrap();
            let count = queue.len().min(self.config.max_export_batch_size);
            queue.drain(..count).collect()
        };
        
        if !batch.is_empty() {
            self.exporter.lock().unwrap().export(batch)?;
        }
        
        Ok(())
    }
}

impl SpanProcessor for BatchProcessor {
    fn on_start(&self, _span: &Span) {}
    
    fn on_end(&self, span: &Span) {
        if self.shutdown.load(Ordering::Acquire) {
            return;
        }
        
        let data = span.to_span_data();
        let mut queue = self.queue.lock().unwrap();
        
        if queue.len() < self.config.max_queue_size {
            queue.push(data);
        }
        
        // Export if batch is full
        if queue.len() >= self.config.max_export_batch_size {
            drop(queue);
            let _ = self.export_batch();
        }
    }
    
    fn shutdown(&self) -> Result<(), TracingError> {
        self.shutdown.store(true, Ordering::Release);
        
        // Export remaining spans
        while !self.queue.lock().unwrap().is_empty() {
            self.export_batch()?;
        }
        
        self.exporter.lock().unwrap().shutdown()
    }
    
    fn force_flush(&self) -> Result<(), TracingError> {
        while !self.queue.lock().unwrap().is_empty() {
            self.export_batch()?;
        }
        Ok(())
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// SPAN EXPORTER
// ═══════════════════════════════════════════════════════════════════════════════

/// Span exporter trait
pub trait SpanExporter: Send {
    fn export(&mut self, spans: Vec<SpanData>) -> Result<(), TracingError>;
    fn shutdown(&mut self) -> Result<(), TracingError>;
}

/// Console exporter for debugging
pub struct ConsoleExporter;

impl SpanExporter for ConsoleExporter {
    fn export(&mut self, spans: Vec<SpanData>) -> Result<(), TracingError> {
        for span in spans {
            println!(
                "[TRACE] {} trace_id={} span_id={} parent={:?} duration={:?}",
                span.name,
                span.context.trace_id.to_hex(),
                span.context.span_id.to_hex(),
                span.parent_span_id.map(|s| s.to_hex()),
                span.end_time.duration_since(span.start_time).ok(),
            );
        }
        Ok(())
    }
    
    fn shutdown(&mut self) -> Result<(), TracingError> {
        Ok(())
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// CONTEXT PROPAGATION
// ═══════════════════════════════════════════════════════════════════════════════

thread_local! {
    static CURRENT_SPAN: std::cell::RefCell<Option<SpanContext>> = std::cell::RefCell::new(None);
}

/// Get current span context
pub fn current_span_context() -> Option<SpanContext> {
    CURRENT_SPAN.with(|ctx| ctx.borrow().clone())
}

/// Set current span context
pub fn set_current_span(span: &Span) -> SpanGuard {
    let prev = CURRENT_SPAN.with(|ctx| ctx.borrow_mut().replace(span.context().clone()));
    SpanGuard { prev }
}

/// Guard that restores previous span on drop
pub struct SpanGuard {
    prev: Option<SpanContext>,
}

impl Drop for SpanGuard {
    fn drop(&mut self) {
        CURRENT_SPAN.with(|ctx| {
            *ctx.borrow_mut() = self.prev.take();
        });
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// ERRORS
// ═══════════════════════════════════════════════════════════════════════════════

#[derive(Debug)]
pub enum TracingError {
    Export(String),
    Shutdown(String),
    InvalidConfig(String),
}

impl std::fmt::Display for TracingError {
    fn fmt(&self, f: &mut std::fmt::Formatter<'_>) -> std::fmt::Result {
        match self {
            Self::Export(e) => write!(f, "export error: {}", e),
            Self::Shutdown(e) => write!(f, "shutdown error: {}", e),
            Self::InvalidConfig(e) => write!(f, "invalid config: {}", e),
        }
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// HELPERS
// ═══════════════════════════════════════════════════════════════════════════════

fn getrandom(buf: &mut [u8]) {
    #[cfg(unix)]
    {
        use std::fs::File;
        use std::io::Read;
        if let Ok(mut f) = File::open("/dev/urandom") {
            let _ = f.read_exact(buf);
        }
    }
    #[cfg(windows)]
    {
        // Would use BCryptGenRandom
        for b in buf.iter_mut() {
            *b = (std::time::SystemTime::now()
                .duration_since(UNIX_EPOCH)
                .unwrap()
                .subsec_nanos() as u8)
                .wrapping_add(*b);
        }
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// TESTS
// ═══════════════════════════════════════════════════════════════════════════════

#[cfg(test)]
mod tests {
    use super::*;
    
    #[test]
    fn test_trace_id() {
        let id = TraceId::new();
        assert!(id.is_valid());
        
        let hex = id.to_hex();
        assert_eq!(hex.len(), 32);
        
        let parsed = TraceId::from_hex(&hex).unwrap();
        assert_eq!(id, parsed);
    }
    
    #[test]
    fn test_span_context() {
        let ctx = SpanContext::new(
            TraceId::new(),
            SpanId::new(),
            TraceFlags::sampled(),
        );
        
        assert!(ctx.is_valid());
        assert!(ctx.is_sampled());
        
        let traceparent = ctx.to_traceparent();
        let parsed = SpanContext::from_traceparent(&traceparent).unwrap();
        
        assert_eq!(ctx.trace_id, parsed.trace_id);
        assert_eq!(ctx.span_id, parsed.span_id);
    }
    
    #[test]
    fn test_span_creation() {
        let ctx = SpanContext::new(TraceId::new(), SpanId::new(), TraceFlags::sampled());
        let mut span = Span::new("test-span", ctx, None, SpanKind::Internal);
        
        span.set_attribute("key", "value");
        span.add_event("event1");
        span.set_status(SpanStatus::Ok, None);
        span.end();
        
        assert!(!span.is_recording());
    }
    
    #[test]
    fn test_samplers() {
        let always_on = AlwaysOnSampler;
        let result = always_on.should_sample(
            None,
            &TraceId::new(),
            "test",
            SpanKind::Internal,
            &[],
            &[],
        );
        assert!(result.decision.is_sampled());
        
        let always_off = AlwaysOffSampler;
        let result = always_off.should_sample(
            None,
            &TraceId::new(),
            "test",
            SpanKind::Internal,
            &[],
            &[],
        );
        assert!(!result.decision.is_sampled());
    }
}
