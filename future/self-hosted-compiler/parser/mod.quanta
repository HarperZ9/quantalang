module quanta::parser

use super::lexer::{Token, TokenKind, Keyword}
use super::ast::*

// ═══════════════════════════════════════════════════════════════════════════════
// PARSER IMPLEMENTATION
// ═══════════════════════════════════════════════════════════════════════════════

pub struct Parser {
    tokens: Vec<Token>,
    pos: usize,
    errors: Vec<ParserError>,
}

impl Parser {
    pub fn new(tokens: Vec<Token>) -> Self {
        Parser {
            tokens,
            pos: 0,
            errors: Vec::new(),
        }
    }
    
    /// Parse the entire token stream into an AST
    pub fn parse(&mut self) -> Result<Module, Vec<ParserError>> {
        let mut items = Vec::new();
        
        while !self.is_at_end() {
            match self.parse_item() {
                Ok(item) => items.push(item),
                Err(e) => {
                    self.errors.push(e);
                    self.synchronize();
                }
            }
        }
        
        if self.errors.is_empty() {
            Ok(Module { items, span: self.span_all() })
        } else {
            Err(self.errors.clone())
        }
    }
    
    /// Parse a single item (top-level declaration)
    fn parse_item(&mut self) -> Result<Item, ParserError> {
        let attrs = self.parse_attributes()?;
        let vis = self.parse_visibility()?;
        
        match self.current_kind() {
            TokenKind::Keyword(Keyword::Fn) => {
                self.parse_function(attrs, vis)
            }
            TokenKind::Keyword(Keyword::Struct) => {
                self.parse_struct(attrs, vis)
            }
            TokenKind::Keyword(Keyword::Enum) => {
                self.parse_enum(attrs, vis)
            }
            TokenKind::Keyword(Keyword::Trait) => {
                self.parse_trait(attrs, vis)
            }
            TokenKind::Keyword(Keyword::Impl) => {
                self.parse_impl(attrs)
            }
            TokenKind::Keyword(Keyword::Type) => {
                self.parse_type_alias(attrs, vis)
            }
            TokenKind::Keyword(Keyword::Const) => {
                self.parse_const(attrs, vis)
            }
            TokenKind::Keyword(Keyword::Static) => {
                self.parse_static(attrs, vis)
            }
            TokenKind::Keyword(Keyword::Mod) => {
                self.parse_module(attrs, vis)
            }
            TokenKind::Keyword(Keyword::Use) => {
                self.parse_use(attrs, vis)
            }
            TokenKind::Keyword(Keyword::Extern) => {
                self.parse_extern_block(attrs)
            }
            TokenKind::Keyword(Keyword::Macro) | 
            TokenKind::Keyword(Keyword::MacroRules) => {
                self.parse_macro(attrs, vis)
            }
            _ => {
                Err(self.error("Expected item declaration"))
            }
        }
    }
    
    /// Parse function declaration
    fn parse_function(&mut self, attrs: Vec<Attribute>, vis: Visibility) -> Result<Item, ParserError> {
        self.expect_keyword(Keyword::Fn)?;
        let name = self.expect_ident()?;
        
        // Generic parameters
        let generics = if self.check(TokenKind::Lt) {
            self.parse_generics()?
        } else {
            Vec::new()
        };
        
        // Parameters
        self.expect(TokenKind::LParen)?;
        let params = self.parse_parameters()?;
        self.expect(TokenKind::RParen)?;
        
        // Return type
        let return_type = if self.check(TokenKind::Arrow) {
            self.advance();
            self.parse_type()?
        } else {
            Type::Primitive(Primitive::Unit)
        };
        
        // Effect annotations
        let effects = if self.check_keyword(Keyword::With) {
            self.advance();
            self.parse_effects()?
        } else {
            Vec::new()
        };
        
        // Where clause
        let where_clause = if self.check_keyword(Keyword::Where) {
            Some(self.parse_where_clause()?)
        } else {
            None
        };
        
        // Body
        let body = if self.check(TokenKind::LBrace) {
            Some(self.parse_block()?)
        } else {
            self.expect(TokenKind::Semi)?;
            None
        };
        
        Ok(Item::Function(FunctionDecl {
            name,
            visibility: vis,
            generics,
            params,
            return_type,
            effects,
            where_clause,
            body,
            attributes: attrs,
            span: self.current_span(),
        }))
    }
    
    /// Parse struct declaration
    fn parse_struct(&mut self, attrs: Vec<Attribute>, vis: Visibility) -> Result<Item, ParserError> {
        self.expect_keyword(Keyword::Struct)?;
        let name = self.expect_ident()?;
        
        let generics = if self.check(TokenKind::Lt) {
            self.parse_generics()?
        } else {
            Vec::new()
        };
        
        let where_clause = if self.check_keyword(Keyword::Where) {
            Some(self.parse_where_clause()?)
        } else {
            None
        };
        
        let fields = if self.check(TokenKind::LBrace) {
            // Named fields
            self.advance();
            let fields = self.parse_named_fields()?;
            self.expect(TokenKind::RBrace)?;
            StructFields::Named(fields)
        } else if self.check(TokenKind::LParen) {
            // Tuple struct
            self.advance();
            let types = self.parse_type_list()?;
            self.expect(TokenKind::RParen)?;
            self.expect(TokenKind::Semi)?;
            StructFields::Tuple(types)
        } else {
            // Unit struct
            self.expect(TokenKind::Semi)?;
            StructFields::Unit
        };
        
        Ok(Item::Struct(StructDecl {
            name,
            visibility: vis,
            generics,
            fields,
            where_clause,
            attributes: attrs,
            span: self.current_span(),
        }))
    }
    
    /// Parse enum declaration
    fn parse_enum(&mut self, attrs: Vec<Attribute>, vis: Visibility) -> Result<Item, ParserError> {
        self.expect_keyword(Keyword::Enum)?;
        let name = self.expect_ident()?;
        
        let generics = if self.check(TokenKind::Lt) {
            self.parse_generics()?
        } else {
            Vec::new()
        };
        
        let where_clause = if self.check_keyword(Keyword::Where) {
            Some(self.parse_where_clause()?)
        } else {
            None
        };
        
        self.expect(TokenKind::LBrace)?;
        let variants = self.parse_enum_variants()?;
        self.expect(TokenKind::RBrace)?;
        
        Ok(Item::Enum(EnumDecl {
            name,
            visibility: vis,
            generics,
            variants,
            where_clause,
            attributes: attrs,
            span: self.current_span(),
        }))
    }
    
    /// Parse trait declaration
    fn parse_trait(&mut self, attrs: Vec<Attribute>, vis: Visibility) -> Result<Item, ParserError> {
        self.expect_keyword(Keyword::Trait)?;
        let name = self.expect_ident()?;
        
        let generics = if self.check(TokenKind::Lt) {
            self.parse_generics()?
        } else {
            Vec::new()
        };
        
        // Supertraits
        let supertraits = if self.check(TokenKind::Colon) {
            self.advance();
            self.parse_type_bounds()?
        } else {
            Vec::new()
        };
        
        let where_clause = if self.check_keyword(Keyword::Where) {
            Some(self.parse_where_clause()?)
        } else {
            None
        };
        
        self.expect(TokenKind::LBrace)?;
        let items = self.parse_trait_items()?;
        self.expect(TokenKind::RBrace)?;
        
        Ok(Item::Trait(TraitDecl {
            name,
            visibility: vis,
            generics,
            supertraits,
            items,
            where_clause,
            attributes: attrs,
            span: self.current_span(),
        }))
    }
    
    /// Parse impl block
    fn parse_impl(&mut self, attrs: Vec<Attribute>) -> Result<Item, ParserError> {
        self.expect_keyword(Keyword::Impl)?;
        
        let generics = if self.check(TokenKind::Lt) {
            self.parse_generics()?
        } else {
            Vec::new()
        };
        
        // Parse type or trait for type
        let first_type = self.parse_type()?;
        
        let (trait_path, self_type) = if self.check_keyword(Keyword::For) {
            self.advance();
            let self_type = self.parse_type()?;
            (Some(type_to_path(&first_type)?), self_type)
        } else {
            (None, first_type)
        };
        
        let where_clause = if self.check_keyword(Keyword::Where) {
            Some(self.parse_where_clause()?)
        } else {
            None
        };
        
        self.expect(TokenKind::LBrace)?;
        let items = self.parse_impl_items()?;
        self.expect(TokenKind::RBrace)?;
        
        Ok(Item::Impl(ImplDecl {
            generics,
            trait_path,
            self_type,
            items,
            where_clause,
            span: self.current_span(),
        }))
    }
    
    // ═══════════════════════════════════════════════════════════════════════════
    // EXPRESSION PARSING (Pratt Parser)
    // ═══════════════════════════════════════════════════════════════════════════
    
    /// Parse expression with precedence climbing
    pub fn parse_expr(&mut self) -> Result<Expr, ParserError> {
        self.parse_expr_bp(0)
    }
    
    /// Parse expression with minimum binding power
    fn parse_expr_bp(&mut self, min_bp: u8) -> Result<Expr, ParserError> {
        let mut lhs = self.parse_prefix()?;
        
        loop {
            // Check for postfix operators
            if let Some(bp) = self.postfix_bp() {
                if bp < min_bp {
                    break;
                }
                lhs = self.parse_postfix(lhs)?;
                continue;
            }
            
            // Check for infix operators
            if let Some((l_bp, r_bp)) = self.infix_bp() {
                if l_bp < min_bp {
                    break;
                }
                let op = self.parse_binary_op()?;
                let rhs = self.parse_expr_bp(r_bp)?;
                lhs = Expr::Binary(Box::new(lhs), op, Box::new(rhs));
                continue;
            }
            
            break;
        }
        
        Ok(lhs)
    }
    
    /// Parse prefix expression
    fn parse_prefix(&mut self) -> Result<Expr, ParserError> {
        match self.current_kind() {
            // Literals
            TokenKind::IntLiteral(n) => {
                self.advance();
                Ok(Expr::Literal(Literal::Int(n, None)))
            }
            TokenKind::FloatLiteral(f) => {
                self.advance();
                Ok(Expr::Literal(Literal::Float(f, None)))
            }
            TokenKind::StringLiteral(s) => {
                self.advance();
                Ok(Expr::Literal(Literal::String(s)))
            }
            TokenKind::CharLiteral(c) => {
                self.advance();
                Ok(Expr::Literal(Literal::Char(c)))
            }
            TokenKind::BoolLiteral(b) => {
                self.advance();
                Ok(Expr::Literal(Literal::Bool(b)))
            }
            
            // Identifiers
            TokenKind::Ident(name) => {
                self.advance();
                Ok(Expr::Ident(name))
            }
            
            // Grouped expression
            TokenKind::LParen => {
                self.advance();
                if self.check(TokenKind::RParen) {
                    self.advance();
                    return Ok(Expr::Tuple(Vec::new())); // Unit
                }
                let expr = self.parse_expr()?;
                if self.check(TokenKind::Comma) {
                    // Tuple
                    self.advance();
                    let mut elements = vec![expr];
                    while !self.check(TokenKind::RParen) {
                        elements.push(self.parse_expr()?);
                        if !self.check(TokenKind::Comma) {
                            break;
                        }
                        self.advance();
                    }
                    self.expect(TokenKind::RParen)?;
                    Ok(Expr::Tuple(elements))
                } else {
                    self.expect(TokenKind::RParen)?;
                    Ok(expr)
                }
            }
            
            // Array literal
            TokenKind::LBracket => {
                self.advance();
                let mut elements = Vec::new();
                while !self.check(TokenKind::RBracket) {
                    elements.push(self.parse_expr()?);
                    if !self.check(TokenKind::Comma) {
                        break;
                    }
                    self.advance();
                }
                self.expect(TokenKind::RBracket)?;
                Ok(Expr::Array(elements))
            }
            
            // Block expression
            TokenKind::LBrace => {
                let block = self.parse_block()?;
                Ok(Expr::Block(block))
            }
            
            // Unary operators
            TokenKind::Minus => {
                self.advance();
                let expr = self.parse_expr_bp(PREFIX_BP)?;
                Ok(Expr::Unary(UnaryOp::Neg, Box::new(expr)))
            }
            TokenKind::Not => {
                self.advance();
                let expr = self.parse_expr_bp(PREFIX_BP)?;
                Ok(Expr::Unary(UnaryOp::Not, Box::new(expr)))
            }
            TokenKind::Star => {
                self.advance();
                let expr = self.parse_expr_bp(PREFIX_BP)?;
                Ok(Expr::Deref(Box::new(expr)))
            }
            TokenKind::And => {
                self.advance();
                let mutability = if self.check_keyword(Keyword::Mut) {
                    self.advance();
                    Mutability::Mutable
                } else {
                    Mutability::Immutable
                };
                let expr = self.parse_expr_bp(PREFIX_BP)?;
                Ok(Expr::Ref(Box::new(expr), mutability))
            }
            
            // Control flow
            TokenKind::Keyword(Keyword::If) => self.parse_if(),
            TokenKind::Keyword(Keyword::Match) => self.parse_match(),
            TokenKind::Keyword(Keyword::Loop) => self.parse_loop(),
            TokenKind::Keyword(Keyword::While) => self.parse_while(),
            TokenKind::Keyword(Keyword::For) => self.parse_for(),
            TokenKind::Keyword(Keyword::Return) => self.parse_return(),
            TokenKind::Keyword(Keyword::Break) => self.parse_break(),
            TokenKind::Keyword(Keyword::Continue) => self.parse_continue(),
            
            // Closures
            TokenKind::OrOr => {
                // || closure with no params
                self.advance();
                let body = self.parse_expr()?;
                Ok(Expr::Closure(Vec::new(), None, Box::new(body)))
            }
            TokenKind::Or => {
                // |params| closure
                self.advance();
                let params = self.parse_closure_params()?;
                self.expect(TokenKind::Or)?;
                let return_type = if self.check(TokenKind::Arrow) {
                    self.advance();
                    Some(self.parse_type()?)
                } else {
                    None
                };
                let body = self.parse_expr()?;
                Ok(Expr::Closure(params, return_type, Box::new(body)))
            }
            
            // Unsafe block
            TokenKind::Keyword(Keyword::Unsafe) => {
                self.advance();
                let block = self.parse_block()?;
                Ok(Expr::Unsafe(block))
            }
            
            // Async block
            TokenKind::Keyword(Keyword::Async) => {
                self.advance();
                let block = self.parse_block()?;
                Ok(Expr::Async(block))
            }
            
            // DSL macros
            TokenKind::DslBlock(name, content) => {
                self.advance();
                Ok(Expr::Macro(MacroInvocation {
                    path: vec![name],
                    delimiter: Delimiter::Brace,
                    tokens: vec![], // DSL content stored as string
                }))
            }
            
            _ => Err(self.error("Expected expression")),
        }
    }
    
    /// Parse postfix expression
    fn parse_postfix(&mut self, lhs: Expr) -> Result<Expr, ParserError> {
        match self.current_kind() {
            // Function call
            TokenKind::LParen => {
                self.advance();
                let args = self.parse_call_args()?;
                self.expect(TokenKind::RParen)?;
                Ok(Expr::Call(Box::new(lhs), args))
            }
            
            // Index
            TokenKind::LBracket => {
                self.advance();
                let index = self.parse_expr()?;
                self.expect(TokenKind::RBracket)?;
                Ok(Expr::Index(Box::new(lhs), Box::new(index)))
            }
            
            // Field access / method call
            TokenKind::Dot => {
                self.advance();
                let name = self.expect_ident()?;
                if self.check(TokenKind::LParen) {
                    // Method call
                    self.advance();
                    let args = self.parse_call_args()?;
                    self.expect(TokenKind::RParen)?;
                    Ok(Expr::MethodCall(Box::new(lhs), name, args))
                } else {
                    // Field access
                    Ok(Expr::Field(Box::new(lhs), name))
                }
            }
            
            // Try operator
            TokenKind::Question => {
                self.advance();
                Ok(Expr::Try(Box::new(lhs)))
            }
            
            // Await
            TokenKind::Keyword(Keyword::Await) => {
                self.advance();
                Ok(Expr::Await(Box::new(lhs)))
            }
            
            // Type cast
            TokenKind::Keyword(Keyword::As) => {
                self.advance();
                let ty = self.parse_type()?;
                Ok(Expr::Cast(Box::new(lhs), ty))
            }
            
            _ => Err(self.error("Expected postfix operator")),
        }
    }
    
    // ═══════════════════════════════════════════════════════════════════════════
    // CONTROL FLOW PARSING
    // ═══════════════════════════════════════════════════════════════════════════
    
    fn parse_if(&mut self) -> Result<Expr, ParserError> {
        self.expect_keyword(Keyword::If)?;
        let condition = self.parse_expr()?;
        let then_block = self.parse_block()?;
        
        let else_expr = if self.check_keyword(Keyword::Else) {
            self.advance();
            if self.check_keyword(Keyword::If) {
                Some(Box::new(self.parse_if()?))
            } else {
                let block = self.parse_block()?;
                Some(Box::new(Expr::Block(block)))
            }
        } else {
            None
        };
        
        Ok(Expr::If(Box::new(condition), then_block, else_expr))
    }
    
    fn parse_match(&mut self) -> Result<Expr, ParserError> {
        self.expect_keyword(Keyword::Match)?;
        let scrutinee = self.parse_expr()?;
        
        self.expect(TokenKind::LBrace)?;
        let mut arms = Vec::new();
        
        while !self.check(TokenKind::RBrace) {
            let pattern = self.parse_pattern()?;
            let guard = if self.check_keyword(Keyword::If) {
                self.advance();
                Some(self.parse_expr()?)
            } else {
                None
            };
            
            self.expect(TokenKind::FatArrow)?;
            let body = self.parse_expr()?;
            
            arms.push(MatchArm { pattern, guard, body });
            
            if !self.check(TokenKind::Comma) && !self.check(TokenKind::RBrace) {
                break;
            }
            if self.check(TokenKind::Comma) {
                self.advance();
            }
        }
        
        self.expect(TokenKind::RBrace)?;
        Ok(Expr::Match(Box::new(scrutinee), arms))
    }
    
    fn parse_loop(&mut self) -> Result<Expr, ParserError> {
        self.expect_keyword(Keyword::Loop)?;
        let block = self.parse_block()?;
        Ok(Expr::Loop(block))
    }
    
    fn parse_while(&mut self) -> Result<Expr, ParserError> {
        self.expect_keyword(Keyword::While)?;
        let condition = self.parse_expr()?;
        let block = self.parse_block()?;
        Ok(Expr::While(Box::new(condition), block))
    }
    
    fn parse_for(&mut self) -> Result<Expr, ParserError> {
        self.expect_keyword(Keyword::For)?;
        let pattern = self.parse_pattern()?;
        self.expect_keyword(Keyword::In)?;
        let iterator = self.parse_expr()?;
        let block = self.parse_block()?;
        Ok(Expr::For(pattern, Box::new(iterator), block))
    }
    
    fn parse_return(&mut self) -> Result<Expr, ParserError> {
        self.expect_keyword(Keyword::Return)?;
        let value = if !self.check(TokenKind::Semi) && !self.check(TokenKind::RBrace) {
            Some(Box::new(self.parse_expr()?))
        } else {
            None
        };
        Ok(Expr::Return(value))
    }
    
    fn parse_break(&mut self) -> Result<Expr, ParserError> {
        self.expect_keyword(Keyword::Break)?;
        let value = if !self.check(TokenKind::Semi) && !self.check(TokenKind::RBrace) {
            Some(Box::new(self.parse_expr()?))
        } else {
            None
        };
        Ok(Expr::Break(value))
    }
    
    fn parse_continue(&mut self) -> Result<Expr, ParserError> {
        self.expect_keyword(Keyword::Continue)?;
        Ok(Expr::Continue)
    }
    
    // ═══════════════════════════════════════════════════════════════════════════
    // PATTERN PARSING
    // ═══════════════════════════════════════════════════════════════════════════
    
    fn parse_pattern(&mut self) -> Result<Pattern, ParserError> {
        match self.current_kind() {
            TokenKind::Ident(name) if name == "_" => {
                self.advance();
                Ok(Pattern::Wildcard)
            }
            TokenKind::Ident(name) => {
                self.advance();
                let mutability = Mutability::Immutable;
                let subpattern = if self.check(TokenKind::At) {
                    self.advance();
                    Some(Box::new(self.parse_pattern()?))
                } else {
                    None
                };
                Ok(Pattern::Ident(name, mutability, subpattern))
            }
            TokenKind::IntLiteral(n) => {
                self.advance();
                Ok(Pattern::Literal(Literal::Int(n, None)))
            }
            TokenKind::StringLiteral(s) => {
                self.advance();
                Ok(Pattern::Literal(Literal::String(s)))
            }
            TokenKind::BoolLiteral(b) => {
                self.advance();
                Ok(Pattern::Literal(Literal::Bool(b)))
            }
            TokenKind::LParen => {
                self.advance();
                let mut patterns = Vec::new();
                while !self.check(TokenKind::RParen) {
                    patterns.push(self.parse_pattern()?);
                    if !self.check(TokenKind::Comma) {
                        break;
                    }
                    self.advance();
                }
                self.expect(TokenKind::RParen)?;
                Ok(Pattern::Tuple(patterns))
            }
            TokenKind::Keyword(Keyword::Ref) => {
                self.advance();
                let mutability = if self.check_keyword(Keyword::Mut) {
                    self.advance();
                    Mutability::Mutable
                } else {
                    Mutability::Immutable
                };
                let inner = self.parse_pattern()?;
                Ok(Pattern::Ref(Box::new(inner), mutability))
            }
            _ => Err(self.error("Expected pattern")),
        }
    }
    
    // ═══════════════════════════════════════════════════════════════════════════
    // TYPE PARSING
    // ═══════════════════════════════════════════════════════════════════════════
    
    fn parse_type(&mut self) -> Result<Type, ParserError> {
        // Handle reference types
        if self.check(TokenKind::And) {
            self.advance();
            let mutability = if self.check_keyword(Keyword::Mut) {
                self.advance();
                Mutability::Mutable
            } else {
                Mutability::Immutable
            };
            let inner = self.parse_type()?;
            return Ok(Type::Reference(Box::new(inner), mutability));
        }
        
        // Handle pointer types
        if self.check(TokenKind::Star) {
            self.advance();
            let mutability = if self.check_keyword(Keyword::Const) {
                self.advance();
                Mutability::Immutable
            } else if self.check_keyword(Keyword::Mut) {
                self.advance();
                Mutability::Mutable
            } else {
                Mutability::Immutable
            };
            let inner = self.parse_type()?;
            return Ok(Type::Pointer(Box::new(inner), mutability));
        }
        
        // Handle array/slice types
        if self.check(TokenKind::LBracket) {
            self.advance();
            let inner = self.parse_type()?;
            if self.check(TokenKind::Semi) {
                // Array with size
                self.advance();
                if let TokenKind::IntLiteral(n) = self.current_kind() {
                    self.advance();
                    self.expect(TokenKind::RBracket)?;
                    return Ok(Type::Array(Box::new(inner), Some(n as usize)));
                }
            }
            self.expect(TokenKind::RBracket)?;
            return Ok(Type::Slice(Box::new(inner)));
        }
        
        // Handle tuple types
        if self.check(TokenKind::LParen) {
            self.advance();
            if self.check(TokenKind::RParen) {
                self.advance();
                return Ok(Type::Primitive(Primitive::Unit));
            }
            let mut types = vec![self.parse_type()?];
            while self.check(TokenKind::Comma) {
                self.advance();
                if self.check(TokenKind::RParen) {
                    break;
                }
                types.push(self.parse_type()?);
            }
            self.expect(TokenKind::RParen)?;
            if types.len() == 1 {
                return Ok(types.pop().unwrap());
            }
            return Ok(Type::Tuple(types));
        }
        
        // Handle function types
        if self.check_keyword(Keyword::Fn) {
            self.advance();
            self.expect(TokenKind::LParen)?;
            let params = self.parse_type_list()?;
            self.expect(TokenKind::RParen)?;
            let return_type = if self.check(TokenKind::Arrow) {
                self.advance();
                self.parse_type()?
            } else {
                Type::Primitive(Primitive::Unit)
            };
            return Ok(Type::Function(params, Box::new(return_type)));
        }
        
        // Handle primitive types
        if let TokenKind::Ident(name) = self.current_kind() {
            if let Some(prim) = primitive_from_str(&name) {
                self.advance();
                return Ok(Type::Primitive(prim));
            }
        }
        
        // Handle user-defined types
        let name = self.expect_ident()?;
        
        // Check for generic parameters
        if self.check(TokenKind::Lt) {
            self.advance();
            let params = self.parse_type_list()?;
            self.expect(TokenKind::Gt)?;
            return Ok(Type::Generic(name, params));
        }
        
        Ok(Type::UserDefined(name))
    }
    
    fn parse_type_list(&mut self) -> Result<Vec<Type>, ParserError> {
        let mut types = Vec::new();
        if !self.check(TokenKind::RParen) && !self.check(TokenKind::Gt) {
            types.push(self.parse_type()?);
            while self.check(TokenKind::Comma) {
                self.advance();
                if self.check(TokenKind::RParen) || self.check(TokenKind::Gt) {
                    break;
                }
                types.push(self.parse_type()?);
            }
        }
        Ok(types)
    }
    
    // ═══════════════════════════════════════════════════════════════════════════
    // BLOCK & STATEMENT PARSING
    // ═══════════════════════════════════════════════════════════════════════════
    
    fn parse_block(&mut self) -> Result<Block, ParserError> {
        self.expect(TokenKind::LBrace)?;
        
        let mut stmts = Vec::new();
        let mut expr = None;
        
        while !self.check(TokenKind::RBrace) {
            if self.check_keyword(Keyword::Let) {
                stmts.push(self.parse_let_stmt()?);
            } else if self.is_item_start() {
                let item = self.parse_item()?;
                stmts.push(Stmt::Item(item));
            } else {
                let e = self.parse_expr()?;
                if self.check(TokenKind::Semi) {
                    self.advance();
                    stmts.push(Stmt::Semi(e));
                } else if self.check(TokenKind::RBrace) {
                    expr = Some(Box::new(e));
                } else {
                    stmts.push(Stmt::Expr(e));
                }
            }
        }
        
        self.expect(TokenKind::RBrace)?;
        Ok(Block { stmts, expr })
    }
    
    fn parse_let_stmt(&mut self) -> Result<Stmt, ParserError> {
        self.expect_keyword(Keyword::Let)?;
        
        let pattern = self.parse_pattern()?;
        
        let ty = if self.check(TokenKind::Colon) {
            self.advance();
            Some(self.parse_type()?)
        } else {
            None
        };
        
        let init = if self.check(TokenKind::Assign) {
            self.advance();
            Some(self.parse_expr()?)
        } else {
            None
        };
        
        self.expect(TokenKind::Semi)?;
        
        Ok(Stmt::Let(LetStmt {
            pattern,
            ty,
            init,
            attributes: Vec::new(),
        }))
    }
    
    // ═══════════════════════════════════════════════════════════════════════════
    // HELPER METHODS
    // ═══════════════════════════════════════════════════════════════════════════
    
    fn is_at_end(&self) -> bool {
        matches!(self.current_kind(), TokenKind::Eof)
    }
    
    fn current(&self) -> &Token {
        &self.tokens[self.pos.min(self.tokens.len() - 1)]
    }
    
    fn current_kind(&self) -> TokenKind {
        self.current().kind.clone()
    }
    
    fn current_span(&self) -> Span {
        self.current().span.clone()
    }
    
    fn advance(&mut self) -> &Token {
        if !self.is_at_end() {
            self.pos += 1;
        }
        &self.tokens[self.pos - 1]
    }
    
    fn check(&self, kind: TokenKind) -> bool {
        self.current_kind() == kind
    }
    
    fn check_keyword(&self, kw: Keyword) -> bool {
        matches!(self.current_kind(), TokenKind::Keyword(k) if k == kw)
    }
    
    fn expect(&mut self, kind: TokenKind) -> Result<&Token, ParserError> {
        if self.check(kind.clone()) {
            Ok(self.advance())
        } else {
            Err(self.error(&format!("Expected {:?}", kind)))
        }
    }
    
    fn expect_keyword(&mut self, kw: Keyword) -> Result<&Token, ParserError> {
        if self.check_keyword(kw) {
            Ok(self.advance())
        } else {
            Err(self.error(&format!("Expected keyword {:?}", kw)))
        }
    }
    
    fn expect_ident(&mut self) -> Result<String, ParserError> {
        if let TokenKind::Ident(name) = self.current_kind() {
            self.advance();
            Ok(name)
        } else {
            Err(self.error("Expected identifier"))
        }
    }
    
    fn error(&self, message: &str) -> ParserError {
        ParserError {
            message: message.to_string(),
            span: self.current_span(),
            kind: ParserErrorKind::UnexpectedToken,
            expected: Vec::new(),
            found: format!("{:?}", self.current_kind()),
        }
    }
    
    fn synchronize(&mut self) {
        self.advance();
        while !self.is_at_end() {
            if matches!(self.tokens[self.pos - 1].kind, TokenKind::Semi) {
                return;
            }
            match self.current_kind() {
                TokenKind::Keyword(Keyword::Fn) |
                TokenKind::Keyword(Keyword::Struct) |
                TokenKind::Keyword(Keyword::Enum) |
                TokenKind::Keyword(Keyword::Trait) |
                TokenKind::Keyword(Keyword::Impl) |
                TokenKind::Keyword(Keyword::Mod) |
                TokenKind::Keyword(Keyword::Use) => return,
                _ => {}
            }
            self.advance();
        }
    }
    
    fn span_all(&self) -> Span {
        if self.tokens.is_empty() {
            Span {
                file: String::new(),
                start: Position { line: 1, column: 1, offset: 0 },
                end: Position { line: 1, column: 1, offset: 0 },
            }
        } else {
            Span {
                file: self.tokens[0].span.file.clone(),
                start: self.tokens[0].span.start.clone(),
                end: self.tokens.last().unwrap().span.end.clone(),
            }
        }
    }
    
    // Additional helper parsing methods omitted for brevity...
    fn parse_attributes(&mut self) -> Result<Vec<Attribute>, ParserError> { Ok(Vec::new()) }
    fn parse_visibility(&mut self) -> Result<Visibility, ParserError> { Ok(Visibility::Private) }
    fn parse_generics(&mut self) -> Result<Vec<GenericParam>, ParserError> { Ok(Vec::new()) }
    fn parse_parameters(&mut self) -> Result<Vec<Parameter>, ParserError> { Ok(Vec::new()) }
    fn parse_effects(&mut self) -> Result<Vec<Effect>, ParserError> { Ok(Vec::new()) }
    fn parse_where_clause(&mut self) -> Result<WhereClause, ParserError> { Ok(WhereClause { predicates: Vec::new() }) }
    fn parse_named_fields(&mut self) -> Result<Vec<FieldDecl>, ParserError> { Ok(Vec::new()) }
    fn parse_enum_variants(&mut self) -> Result<Vec<EnumVariant>, ParserError> { Ok(Vec::new()) }
    fn parse_type_bounds(&mut self) -> Result<Vec<TypeBound>, ParserError> { Ok(Vec::new()) }
    fn parse_trait_items(&mut self) -> Result<Vec<TraitItem>, ParserError> { Ok(Vec::new()) }
    fn parse_impl_items(&mut self) -> Result<Vec<ImplItem>, ParserError> { Ok(Vec::new()) }
    fn parse_call_args(&mut self) -> Result<Vec<Expr>, ParserError> { Ok(Vec::new()) }
    fn parse_closure_params(&mut self) -> Result<Vec<Parameter>, ParserError> { Ok(Vec::new()) }
    fn parse_binary_op(&mut self) -> Result<BinaryOp, ParserError> { Ok(BinaryOp::Add) }
    fn postfix_bp(&self) -> Option<u8> { None }
    fn infix_bp(&self) -> Option<(u8, u8)> { None }
    fn is_item_start(&self) -> bool { false }
    fn parse_type_alias(&mut self, _: Vec<Attribute>, _: Visibility) -> Result<Item, ParserError> { unimplemented!() }
    fn parse_const(&mut self, _: Vec<Attribute>, _: Visibility) -> Result<Item, ParserError> { unimplemented!() }
    fn parse_static(&mut self, _: Vec<Attribute>, _: Visibility) -> Result<Item, ParserError> { unimplemented!() }
    fn parse_module(&mut self, _: Vec<Attribute>, _: Visibility) -> Result<Item, ParserError> { unimplemented!() }
    fn parse_use(&mut self, _: Vec<Attribute>, _: Visibility) -> Result<Item, ParserError> { unimplemented!() }
    fn parse_extern_block(&mut self, _: Vec<Attribute>) -> Result<Item, ParserError> { unimplemented!() }
    fn parse_macro(&mut self, _: Vec<Attribute>, _: Visibility) -> Result<Item, ParserError> { unimplemented!() }
}

// Binding power constants
const PREFIX_BP: u8 = 25;

// Helper functions
fn primitive_from_str(s: &str) -> Option<Primitive> {
    match s {
        "i8" => Some(Primitive::I8),
        "i16" => Some(Primitive::I16),
        "i32" => Some(Primitive::I32),
        "i64" => Some(Primitive::I64),
        "i128" => Some(Primitive::I128),
        "isize" => Some(Primitive::Isize),
        "u8" => Some(Primitive::U8),
        "u16" => Some(Primitive::U16),
        "u32" => Some(Primitive::U32),
        "u64" => Some(Primitive::U64),
        "u128" => Some(Primitive::U128),
        "usize" => Some(Primitive::Usize),
        "f16" => Some(Primitive::F16),
        "f32" => Some(Primitive::F32),
        "f64" => Some(Primitive::F64),
        "bool" => Some(Primitive::Bool),
        "char" => Some(Primitive::Char),
        "str" => Some(Primitive::Str),
        _ => None,
    }
}

fn type_to_path(ty: &Type) -> Result<String, ParserError> {
    match ty {
        Type::UserDefined(name) => Ok(name.clone()),
        Type::Generic(name, _) => Ok(name.clone()),
        _ => Err(ParserError {
            message: "Expected type path".to_string(),
            span: Span {
                file: String::new(),
                start: Position { line: 0, column: 0, offset: 0 },
                end: Position { line: 0, column: 0, offset: 0 },
            },
            kind: ParserErrorKind::InvalidType,
            expected: Vec::new(),
            found: String::new(),
        }),
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// PUBLIC API
// ═══════════════════════════════════════════════════════════════════════════════

/// Parse source code into an AST
pub fn parse(tokens: Vec<Token>) -> Result<Module, Vec<ParserError>> {
    let mut parser = Parser::new(tokens);
    parser.parse()
}

#[cfg(test)]
mod tests {
    use super::*;
    use crate::lexer::tokenize;
    
    #[test]
    fn test_parse_function() {
        let tokens = tokenize("fn main() { }").unwrap();
        let ast = parse(tokens).unwrap();
        assert_eq!(ast.items.len(), 1);
    }
    
    #[test]
    fn test_parse_struct() {
        let tokens = tokenize("struct Point { x: f32, y: f32 }").unwrap();
        let ast = parse(tokens).unwrap();
        assert_eq!(ast.items.len(), 1);
    }
}
