// ENVIRONMENT
// ═══════════════════════════════════════════════════════════════════════════════

/// ABI/Environment
#[derive(Debug, Clone, Copy, PartialEq, Eq, Hash)]
pub enum Environment {
    None,
    Gnu,
    Musl,
    Msvc,
    Sgx,
    Android,
    Eabi,
    EabiHf,
    Macabi,
    Kernel,
    Uclibc,
}

impl Environment {
    pub fn from_str(s: &str) -> Option<Self> {
        match s {
            "" | "none" => Some(Environment::None),
            "gnu" => Some(Environment::Gnu),
            "musl" => Some(Environment::Musl),
            "msvc" => Some(Environment::Msvc),
            "sgx" => Some(Environment::Sgx),
            "android" => Some(Environment::Android),
            "eabi" => Some(Environment::Eabi),
            "eabihf" => Some(Environment::EabiHf),
            "macabi" => Some(Environment::Macabi),
            "kernel" => Some(Environment::Kernel),
            "uclibc" => Some(Environment::Uclibc),
            _ => None,
        }
    }
    
    pub fn as_str(&self) -> &'static str {
        match self {
            Environment::None => "",
            Environment::Gnu => "gnu",
            Environment::Musl => "musl",
            Environment::Msvc => "msvc",
            Environment::Sgx => "sgx",
            Environment::Android => "android",
            Environment::Eabi => "eabi",
            Environment::EabiHf => "eabihf",
            Environment::Macabi => "macabi",
            Environment::Kernel => "kernel",
            Environment::Uclibc => "uclibc",
        }
    }
}

impl std::fmt::Display for Environment {
    fn fmt(&self, f: &mut std::fmt::Formatter<'_>) -> std::fmt::Result {
        write!(f, "{}", self.as_str())
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// DATA LAYOUT
// ═══════════════════════════════════════════════════════════════════════════════

/// Byte order
#[derive(Debug, Clone, Copy, PartialEq, Eq, Hash)]
pub enum Endianness {
    Little,
    Big,
}

/// Data layout specification
#[derive(Debug, Clone, Copy)]
pub struct DataLayout {
    pub endianness: Endianness,
    pub pointer_size: u32,
    pub pointer_align: u32,
    pub i8_align: u32,
    pub i16_align: u32,
    pub i32_align: u32,
    pub i64_align: u32,
    pub i128_align: u32,
    pub f32_align: u32,
    pub f64_align: u32,
    pub aggregate_align: u32,
    pub stack_align: u32,
}

impl DataLayout {
    /// Get alignment for integer of given bit width
    pub fn int_align(&self, bits: u32) -> u32 {
        match bits {
            0..=8 => self.i8_align,
            9..=16 => self.i16_align,
            17..=32 => self.i32_align,
            33..=64 => self.i64_align,
            _ => self.i128_align,
        }
    }
    
    /// Get alignment for float of given bit width
    pub fn float_align(&self, bits: u32) -> u32 {
        match bits {
            0..=32 => self.f32_align,
            _ => self.f64_align,
        }
    }
    
    /// Convert to LLVM data layout string
    pub fn to_llvm_string(&self) -> String {
        let mut s = String::new();
        
        // Endianness
        s.push(if self.endianness == Endianness::Little { 'e' } else { 'E' });
        
        // Mangling
        s.push_str("-m:e");
        
        // Pointer
        s.push_str(&format!("-p:{}:{}:{}", 
            self.pointer_size * 8, 
            self.pointer_align * 8, 
            self.pointer_align * 8
        ));
        
        // Integers
        s.push_str(&format!("-i8:{}:{}", self.i8_align * 8, self.i8_align * 8));
        s.push_str(&format!("-i16:{}:{}", self.i16_align * 8, self.i16_align * 8));
        s.push_str(&format!("-i32:{}:{}", self.i32_align * 8, self.i32_align * 8));
        s.push_str(&format!("-i64:{}:{}", self.i64_align * 8, self.i64_align * 8));
        
        // Floats
        s.push_str(&format!("-f32:{}:{}", self.f32_align * 8, self.f32_align * 8));
        s.push_str(&format!("-f64:{}:{}", self.f64_align * 8, self.f64_align * 8));
        
        // Stack
        s.push_str(&format!("-S{}", self.stack_align * 8));
        
        s
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// TARGET TRIPLE
// ═══════════════════════════════════════════════════════════════════════════════

/// Complete target specification
#[derive(Debug, Clone)]
pub struct TargetTriple {
    pub arch: Architecture,
    pub vendor: Vendor,
    pub os: OperatingSystem,
    pub env: Environment,
}

impl TargetTriple {
    /// Create a new target triple
    pub fn new(arch: Architecture, vendor: Vendor, os: OperatingSystem, env: Environment) -> Self {
        TargetTriple { arch, vendor, os, env }
    }
    
    /// Parse from string (e.g., "x86_64-unknown-linux-gnu")
    pub fn parse(s: &str) -> Option<Self> {
        let parts: Vec<&str> = s.split('-').collect();
        
        if parts.len() < 2 {
            return None;
        }
        
        let arch = Architecture::from_str(parts[0])?;
        
        let (vendor, os, env) = match parts.len() {
            2 => {
                // arch-os (e.g., wasm32-wasi)
                let os = OperatingSystem::from_str(parts[1])?;
                (Vendor::Unknown, os, Environment::None)
            }
            3 => {
                // arch-vendor-os or arch-os-env
                if let Some(vendor) = Vendor::from_str(parts[1]) {
                    let os = OperatingSystem::from_str(parts[2])?;
                    (vendor, os, Environment::None)
                } else {
                    let os = OperatingSystem::from_str(parts[1])?;
                    let env = Environment::from_str(parts[2])?;
                    (Vendor::Unknown, os, env)
                }
            }
            4 => {
                // arch-vendor-os-env
                let vendor = Vendor::from_str(parts[1]).unwrap_or(Vendor::Unknown);
                let os = OperatingSystem::from_str(parts[2])?;
                let env = Environment::from_str(parts[3]).unwrap_or(Environment::None);
                (vendor, os, env)
            }
            _ => return None,
        };
        
        Some(TargetTriple { arch, vendor, os, env })
    }
    
    /// Get native target for current platform
    #[cfg(target_arch = "x86_64")]
    pub fn native() -> Self {
        #[cfg(target_os = "linux")]
        {
            TargetTriple::new(Architecture::X86_64, Vendor::Unknown, OperatingSystem::Linux, Environment::Gnu)
        }
        #[cfg(target_os = "macos")]
        {
            TargetTriple::new(Architecture::X86_64, Vendor::Apple, OperatingSystem::Darwin, Environment::None)
        }
        #[cfg(target_os = "windows")]
        {
            TargetTriple::new(Architecture::X86_64, Vendor::Pc, OperatingSystem::Windows, Environment::Msvc)
        }
        #[cfg(not(any(target_os = "linux", target_os = "macos", target_os = "windows")))]
        {
            TargetTriple::new(Architecture::X86_64, Vendor::Unknown, OperatingSystem::None, Environment::None)
        }
    }
    
    #[cfg(target_arch = "aarch64")]
    pub fn native() -> Self {
        #[cfg(target_os = "linux")]
        {
            TargetTriple::new(Architecture::AArch64, Vendor::Unknown, OperatingSystem::Linux, Environment::Gnu)
        }
        #[cfg(target_os = "macos")]
        {
            TargetTriple::new(Architecture::AArch64, Vendor::Apple, OperatingSystem::Darwin, Environment::None)
        }
        #[cfg(not(any(target_os = "linux", target_os = "macos")))]
        {
            TargetTriple::new(Architecture::AArch64, Vendor::Unknown, OperatingSystem::None, Environment::None)
        }
    }
    
    #[cfg(not(any(target_arch = "x86_64", target_arch = "aarch64")))]
    pub fn native() -> Self {
        TargetTriple::new(Architecture::X86_64, Vendor::Unknown, OperatingSystem::None, Environment::None)
    }
    
    /// Convert to string
    pub fn to_string(&self) -> String {
        let mut s = format!("{}-{}-{}", self.arch, self.vendor, self.os);
        if self.env != Environment::None {
            s.push('-');
            s.push_str(self.env.as_str());
        }
        s
    }
    
    /// Get data layout
    pub fn data_layout(&self) -> DataLayout {
        self.arch.data_layout()
    }
    
    /// Get pointer width
    pub fn pointer_width(&self) -> u32 {
        self.arch.pointer_width()
    }
    
    /// Check if this is a 64-bit target
    pub fn is_64bit(&self) -> bool {
        self.pointer_width() == 64
    }
    
    /// Check if cross-compiling from native
    pub fn is_cross(&self) -> bool {
        *self != Self::native()
    }
    
    /// Get default linker
    pub fn default_linker(&self) -> &'static str {
        match (self.os, self.env) {
            (OperatingSystem::Windows, Environment::Msvc) => "link.exe",
            (OperatingSystem::Windows, Environment::Gnu) => "x86_64-w64-mingw32-gcc",
            (OperatingSystem::Darwin, _) => "ld64.lld",
            (OperatingSystem::Wasi, _) => "wasm-ld",
            (OperatingSystem::Emscripten, _) => "emcc",
            _ => "ld.lld",
        }
    }
    
    /// Get default C compiler
    pub fn default_cc(&self) -> &'static str {
        match (self.os, self.env) {
            (OperatingSystem::Windows, Environment::Msvc) => "cl.exe",
            (OperatingSystem::Darwin, _) => "clang",
            (OperatingSystem::Emscripten, _) => "emcc",
            _ => "clang",
        }
    }
}

impl PartialEq for TargetTriple {
    fn eq(&self, other: &Self) -> bool {
        self.arch == other.arch && 
        self.vendor == other.vendor && 
        self.os == other.os && 
        self.env == other.env
    }
}

impl std::fmt::Display for TargetTriple {
    fn fmt(&self, f: &mut std::fmt::Formatter<'_>) -> std::fmt::Result {
        write!(f, "{}", self.to_string())
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// PREDEFINED TARGETS
// ═══════════════════════════════════════════════════════════════════════════════

/// Common target triples
pub mod targets {
    use super::*;
    
    pub fn x86_64_unknown_linux_gnu() -> TargetTriple {
        TargetTriple::new(Architecture::X86_64, Vendor::Unknown, OperatingSystem::Linux, Environment::Gnu)
    }
    
    pub fn x86_64_unknown_linux_musl() -> TargetTriple {
        TargetTriple::new(Architecture::X86_64, Vendor::Unknown, OperatingSystem::Linux, Environment::Musl)
    }
    
    pub fn x86_64_apple_darwin() -> TargetTriple {
        TargetTriple::new(Architecture::X86_64, Vendor::Apple, OperatingSystem::Darwin, Environment::None)
    }
    
    pub fn x86_64_pc_windows_msvc() -> TargetTriple {
        TargetTriple::new(Architecture::X86_64, Vendor::Pc, OperatingSystem::Windows, Environment::Msvc)
    }
    
    pub fn x86_64_pc_windows_gnu() -> TargetTriple {
        TargetTriple::new(Architecture::X86_64, Vendor::Pc, OperatingSystem::Windows, Environment::Gnu)
    }
    
    pub fn aarch64_unknown_linux_gnu() -> TargetTriple {
        TargetTriple::new(Architecture::AArch64, Vendor::Unknown, OperatingSystem::Linux, Environment::Gnu)
    }
    
    pub fn aarch64_apple_darwin() -> TargetTriple {
        TargetTriple::new(Architecture::AArch64, Vendor::Apple, OperatingSystem::Darwin, Environment::None)
    }
    
    pub fn aarch64_apple_ios() -> TargetTriple {
        TargetTriple::new(Architecture::AArch64, Vendor::Apple, OperatingSystem::Ios, Environment::None)
    }
    
    pub fn wasm32_unknown_unknown() -> TargetTriple {
        TargetTriple::new(Architecture::Wasm32, Vendor::Unknown, OperatingSystem::None, Environment::None)
    }
    
    pub fn wasm32_wasi() -> TargetTriple {
        TargetTriple::new(Architecture::Wasm32, Vendor::Unknown, OperatingSystem::Wasi, Environment::None)
    }
    
    pub fn riscv64gc_unknown_linux_gnu() -> TargetTriple {
        TargetTriple::new(Architecture::RiscV64, Vendor::Unknown, OperatingSystem::Linux, Environment::Gnu)
    }
    
    /// List all built-in targets
    pub fn all() -> Vec<TargetTriple> {
        vec![
            x86_64_unknown_linux_gnu(),
            x86_64_unknown_linux_musl(),
            x86_64_apple_darwin(),
            x86_64_pc_windows_msvc(),
            x86_64_pc_windows_gnu(),
            aarch64_unknown_linux_gnu(),
            aarch64_apple_darwin(),
            aarch64_apple_ios(),
            wasm32_unknown_unknown(),
            wasm32_wasi(),
            riscv64gc_unknown_linux_gnu(),
        ]
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// TESTS
// ═══════════════════════════════════════════════════════════════════════════════

#[cfg(test)]
mod tests {
    use super::*;
    
    #[test]
    fn test_parse_triple() {
        let triple = TargetTriple::parse("x86_64-unknown-linux-gnu").unwrap();
        assert_eq!(triple.arch, Architecture::X86_64);
        assert_eq!(triple.vendor, Vendor::Unknown);
        assert_eq!(triple.os, OperatingSystem::Linux);
        assert_eq!(triple.env, Environment::Gnu);
    }
    
    #[test]
    fn test_parse_short_triple() {
        let triple = TargetTriple::parse("wasm32-wasi").unwrap();
        assert_eq!(triple.arch, Architecture::Wasm32);
        assert_eq!(triple.os, OperatingSystem::Wasi);
    }
    
    #[test]
    fn test_triple_to_string() {
        let triple = targets::x86_64_unknown_linux_gnu();
        assert_eq!(triple.to_string(), "x86_64-unknown-linux-gnu");
    }
    
    #[test]
    fn test_pointer_width() {
        assert_eq!(Architecture::X86_64.pointer_width(), 64);
        assert_eq!(Architecture::X86.pointer_width(), 32);
        assert_eq!(Architecture::Wasm32.pointer_width(), 32);
        assert_eq!(Architecture::AArch64.pointer_width(), 64);
    }
    
    #[test]
    fn test_data_layout() {
        let layout = Architecture::X86_64.data_layout();
        assert_eq!(layout.pointer_size, 8);
        assert_eq!(layout.endianness, Endianness::Little);
    }
}
