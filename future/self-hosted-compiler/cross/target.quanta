module quantalang::cross::target

use alloc::vec::Vec;
use alloc::string::String;
use alloc::format;
use alloc::collections::BTreeMap;
use core::str::FromStr;

// ═══════════════════════════════════════════════════════════════════════════════
// ARCHITECTURE
// ═══════════════════════════════════════════════════════════════════════════════

/// CPU architecture
#[derive(Debug, Clone, Copy, PartialEq, Eq, Hash)]
pub enum Architecture {
    /// x86-64 / AMD64
    X86_64,
    
    /// x86 / i686
    X86,
    
    /// ARM 64-bit (AArch64)
    AArch64,
    
    /// ARM 32-bit
    Arm,
    
    /// RISC-V 64-bit
    RiscV64,
    
    /// RISC-V 32-bit
    RiscV32,
    
    /// WebAssembly 32-bit
    Wasm32,
    
    /// WebAssembly 64-bit
    Wasm64,
    
    /// MIPS 64-bit
    Mips64,
    
    /// PowerPC 64-bit
    PowerPC64,
    
    /// S390x (IBM Z)
    S390x,
}

impl Architecture {
    /// Parse from string
    pub fn from_str(s: &str) -> Option<Self> {
        match s {
            "x86_64" | "amd64" => Some(Architecture::X86_64),
            "x86" | "i686" | "i386" => Some(Architecture::X86),
            "aarch64" | "arm64" => Some(Architecture::AArch64),
            "arm" | "armv7" | "thumbv7" => Some(Architecture::Arm),
            "riscv64" | "riscv64gc" => Some(Architecture::RiscV64),
            "riscv32" | "riscv32gc" => Some(Architecture::RiscV32),
            "wasm32" => Some(Architecture::Wasm32),
            "wasm64" => Some(Architecture::Wasm64),
            "mips64" | "mips64el" => Some(Architecture::Mips64),
            "powerpc64" | "ppc64" | "ppc64le" => Some(Architecture::PowerPC64),
            "s390x" => Some(Architecture::S390x),
            _ => None,
        }
    }
    
    /// Convert to string
    pub fn as_str(&self) -> &'static str {
        match self {
            Architecture::X86_64 => "x86_64",
            Architecture::X86 => "i686",
            Architecture::AArch64 => "aarch64",
            Architecture::Arm => "arm",
            Architecture::RiscV64 => "riscv64",
            Architecture::RiscV32 => "riscv32",
            Architecture::Wasm32 => "wasm32",
            Architecture::Wasm64 => "wasm64",
            Architecture::Mips64 => "mips64",
            Architecture::PowerPC64 => "powerpc64",
            Architecture::S390x => "s390x",
        }
    }
    
    /// Get pointer width in bits
    pub fn pointer_width(&self) -> u32 {
        match self {
            Architecture::X86 | Architecture::Arm | Architecture::RiscV32 | Architecture::Wasm32 => 32,
            _ => 64,
        }
    }
    
    /// Get default data layout
    pub fn data_layout(&self) -> DataLayout {
        match self {
            Architecture::X86_64 => DataLayout {
                endianness: Endianness::Little,
                pointer_size: 8,
                pointer_align: 8,
                i8_align: 1,
                i16_align: 2,
                i32_align: 4,
                i64_align: 8,
                i128_align: 16,
                f32_align: 4,
                f64_align: 8,
                aggregate_align: 8,
                stack_align: 16,
            },
            Architecture::AArch64 => DataLayout {
                endianness: Endianness::Little,
                pointer_size: 8,
                pointer_align: 8,
                i8_align: 1,
                i16_align: 2,
                i32_align: 4,
                i64_align: 8,
                i128_align: 16,
                f32_align: 4,
                f64_align: 8,
                aggregate_align: 8,
                stack_align: 16,
            },
            Architecture::X86 => DataLayout {
                endianness: Endianness::Little,
                pointer_size: 4,
                pointer_align: 4,
                i8_align: 1,
                i16_align: 2,
                i32_align: 4,
                i64_align: 8,
                i128_align: 16,
                f32_align: 4,
                f64_align: 8,
                aggregate_align: 4,
                stack_align: 16,
            },
            Architecture::Wasm32 => DataLayout {
                endianness: Endianness::Little,
                pointer_size: 4,
                pointer_align: 4,
                i8_align: 1,
                i16_align: 2,
                i32_align: 4,
                i64_align: 8,
                i128_align: 16,
                f32_align: 4,
                f64_align: 8,
                aggregate_align: 4,
                stack_align: 16,
            },
            Architecture::Wasm64 => DataLayout {
                endianness: Endianness::Little,
                pointer_size: 8,
                pointer_align: 8,
                i8_align: 1,
                i16_align: 2,
                i32_align: 4,
                i64_align: 8,
                i128_align: 16,
                f32_align: 4,
                f64_align: 8,
                aggregate_align: 8,
                stack_align: 16,
            },
            Architecture::RiscV64 => DataLayout {
                endianness: Endianness::Little,
                pointer_size: 8,
                pointer_align: 8,
                i8_align: 1,
                i16_align: 2,
                i32_align: 4,
                i64_align: 8,
                i128_align: 16,
                f32_align: 4,
                f64_align: 8,
                aggregate_align: 8,
                stack_align: 16,
            },
            Architecture::RiscV32 => DataLayout {
                endianness: Endianness::Little,
                pointer_size: 4,
                pointer_align: 4,
                i8_align: 1,
                i16_align: 2,
                i32_align: 4,
                i64_align: 8,
                i128_align: 16,
                f32_align: 4,
                f64_align: 8,
                aggregate_align: 4,
                stack_align: 16,
            },
            Architecture::Arm => DataLayout {
                endianness: Endianness::Little,
                pointer_size: 4,
                pointer_align: 4,
                i8_align: 1,
                i16_align: 2,
                i32_align: 4,
                i64_align: 8,
                i128_align: 16,
                f32_align: 4,
                f64_align: 8,
                aggregate_align: 4,
                stack_align: 8,
            },
            Architecture::Mips64 | Architecture::S390x => DataLayout {
                endianness: Endianness::Big,
                pointer_size: 8,
                pointer_align: 8,
                i8_align: 1,
                i16_align: 2,
                i32_align: 4,
                i64_align: 8,
                i128_align: 16,
                f32_align: 4,
                f64_align: 8,
                aggregate_align: 8,
                stack_align: 16,
            },
            Architecture::PowerPC64 => DataLayout {
                endianness: Endianness::Little, // PPC64LE default
                pointer_size: 8,
                pointer_align: 8,
                i8_align: 1,
                i16_align: 2,
                i32_align: 4,
                i64_align: 8,
                i128_align: 16,
                f32_align: 4,
                f64_align: 8,
                aggregate_align: 8,
                stack_align: 16,
            },
        }
    }
    
    /// Get number of general-purpose registers
    pub fn gp_register_count(&self) -> u32 {
        match self {
            Architecture::X86_64 => 16,
            Architecture::X86 => 8,
            Architecture::AArch64 => 31,
            Architecture::Arm => 16,
            Architecture::RiscV64 | Architecture::RiscV32 => 32,
            Architecture::Wasm32 | Architecture::Wasm64 => 0, // Stack machine
            Architecture::Mips64 => 32,
            Architecture::PowerPC64 => 32,
            Architecture::S390x => 16,
        }
    }
    
    /// Get number of floating-point registers
    pub fn fp_register_count(&self) -> u32 {
        match self {
            Architecture::X86_64 => 16,
            Architecture::X86 => 8,
            Architecture::AArch64 => 32,
            Architecture::Arm => 32,
            Architecture::RiscV64 | Architecture::RiscV32 => 32,
            Architecture::Wasm32 | Architecture::Wasm64 => 0,
            Architecture::Mips64 => 32,
            Architecture::PowerPC64 => 32,
            Architecture::S390x => 16,
        }
    }
    
    /// Check if SIMD is available
    pub fn has_simd(&self) -> bool {
        !matches!(self, Architecture::Wasm32 | Architecture::Wasm64)
    }
}

impl std::fmt::Display for Architecture {
    fn fmt(&self, f: &mut std::fmt::Formatter<'_>) -> std::fmt::Result {
        write!(f, "{}", self.as_str())
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// VENDOR
// ═══════════════════════════════════════════════════════════════════════════════

/// Target vendor
#[derive(Debug, Clone, Copy, PartialEq, Eq, Hash)]
pub enum Vendor {
    Unknown,
    Apple,
    Pc,
    Riscv,
    Sun,
    Nvidia,
    Ibm,
}

impl Vendor {
    pub fn from_str(s: &str) -> Option<Self> {
        match s {
            "unknown" => Some(Vendor::Unknown),
            "apple" => Some(Vendor::Apple),
            "pc" => Some(Vendor::Pc),
            "riscv" => Some(Vendor::Riscv),
            "sun" => Some(Vendor::Sun),
            "nvidia" => Some(Vendor::Nvidia),
            "ibm" => Some(Vendor::Ibm),
            _ => None,
        }
    }
    
    pub fn as_str(&self) -> &'static str {
        match self {
            Vendor::Unknown => "unknown",
            Vendor::Apple => "apple",
            Vendor::Pc => "pc",
            Vendor::Riscv => "riscv",
            Vendor::Sun => "sun",
            Vendor::Nvidia => "nvidia",
            Vendor::Ibm => "ibm",
        }
    }
}

impl std::fmt::Display for Vendor {
    fn fmt(&self, f: &mut std::fmt::Formatter<'_>) -> std::fmt::Result {
        write!(f, "{}", self.as_str())
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// OPERATING SYSTEM
// ═══════════════════════════════════════════════════════════════════════════════

/// Operating system
#[derive(Debug, Clone, Copy, PartialEq, Eq, Hash)]
pub enum OperatingSystem {
    None,       // Bare metal
    Linux,
    Darwin,     // macOS, iOS
    Windows,
    FreeBSD,
    NetBSD,
    OpenBSD,
    Solaris,
    Fuchsia,
    Android,
    Ios,
    TvOS,
    WatchOS,
    Wasi,
    Emscripten,
    Uefi,
}

impl OperatingSystem {
    pub fn from_str(s: &str) -> Option<Self> {
        match s {
            "none" | "unknown" => Some(OperatingSystem::None),
            "linux" => Some(OperatingSystem::Linux),
            "darwin" | "macos" => Some(OperatingSystem::Darwin),
            "windows" | "win32" => Some(OperatingSystem::Windows),
            "freebsd" => Some(OperatingSystem::FreeBSD),
            "netbsd" => Some(OperatingSystem::NetBSD),
            "openbsd" => Some(OperatingSystem::OpenBSD),
            "solaris" => Some(OperatingSystem::Solaris),
            "fuchsia" => Some(OperatingSystem::Fuchsia),
            "android" => Some(OperatingSystem::Android),
            "ios" => Some(OperatingSystem::Ios),
            "tvos" => Some(OperatingSystem::TvOS),
            "watchos" => Some(OperatingSystem::WatchOS),
            "wasi" => Some(OperatingSystem::Wasi),
            "emscripten" => Some(OperatingSystem::Emscripten),
            "uefi" => Some(OperatingSystem::Uefi),
            _ => None,
        }
    }
    
    pub fn as_str(&self) -> &'static str {
        match self {
            OperatingSystem::None => "none",
            OperatingSystem::Linux => "linux",
            OperatingSystem::Darwin => "darwin",
            OperatingSystem::Windows => "windows",
            OperatingSystem::FreeBSD => "freebsd",
            OperatingSystem::NetBSD => "netbsd",
            OperatingSystem::OpenBSD => "openbsd",
            OperatingSystem::Solaris => "solaris",
            OperatingSystem::Fuchsia => "fuchsia",
            OperatingSystem::Android => "android",
            OperatingSystem::Ios => "ios",
            OperatingSystem::TvOS => "tvos",
            OperatingSystem::WatchOS => "watchos",
            OperatingSystem::Wasi => "wasi",
            OperatingSystem::Emscripten => "emscripten",
            OperatingSystem::Uefi => "uefi",
        }
    }
    
    /// Check if Unix-like
    pub fn is_unix(&self) -> bool {
        matches!(
            self,
            OperatingSystem::Linux
                | OperatingSystem::Darwin
                | OperatingSystem::FreeBSD
                | OperatingSystem::NetBSD
                | OperatingSystem::OpenBSD
                | OperatingSystem::Solaris
                | OperatingSystem::Android
                | OperatingSystem::Ios
        )
    }
    
    /// Check if Windows
    pub fn is_windows(&self) -> bool {
        matches!(self, OperatingSystem::Windows)
    }
    
    /// Check if bare metal
    pub fn is_bare_metal(&self) -> bool {
        matches!(self, OperatingSystem::None | OperatingSystem::Uefi)
    }
    
    /// Get default executable suffix
    pub fn exe_suffix(&self) -> &'static str {
        match self {
            OperatingSystem::Windows => ".exe",
            OperatingSystem::Wasi => ".wasm",
            OperatingSystem::Emscripten => ".js",
            _ => "",
        }
    }
    
    /// Get default shared library suffix
    pub fn dll_suffix(&self) -> &'static str {
        match self {
            OperatingSystem::Windows => ".dll",
            OperatingSystem::Darwin | OperatingSystem::Ios => ".dylib",
            _ => ".so",
        }
    }
    
    /// Get default static library suffix
    pub fn staticlib_suffix(&self) -> &'static str {
        match self {
            OperatingSystem::Windows => ".lib",
            _ => ".a",
        }
    }
}

impl std::fmt::Display for OperatingSystem {
    fn fmt(&self, f: &mut std::fmt::Formatter<'_>) -> std::fmt::Result {
        write!(f, "{}", self.as_str())
    }
}

