// UTILITY FUNCTIONS
// ═══════════════════════════════════════════════════════════════════════════════

/// Validate package name
///
/// Package names must:
/// - Start with a letter or underscore
/// - Contain only alphanumeric characters, hyphens, and underscores
/// - Be non-empty and not exceed 64 characters
/// - Not be a reserved name
pub fn validate_package_name(name: &str) -> Result<(), String> {
    if name.is_empty() {
        return Err("package name cannot be empty".to_string());
    }
    
    if name.len() > 64 {
        return Err("package name cannot exceed 64 characters".to_string());
    }
    
    let first = name.chars().next().unwrap();
    if !first.is_ascii_alphabetic() && first != '_' {
        return Err("package name must start with a letter or underscore".to_string());
    }
    
    for c in name.chars() {
        if !c.is_ascii_alphanumeric() && c != '-' && c != '_' {
            return Err(format!("invalid character in package name: '{}'", c));
        }
    }
    
    // Reserved names
    const RESERVED: &[&str] = &[
        "std", "core", "alloc", "test", "proc_macro",
        "self", "super", "crate", "Self",
    ];
    
    if RESERVED.contains(&name) {
        return Err(format!("'{}' is a reserved name", name));
    }
    
    Ok(())
}

/// Get target directory
pub fn target_dir() -> String {
    std::env::var("QUANTA_TARGET_DIR")
        .unwrap_or_else(|_| "target".to_string())
}

/// Get profile-specific output directory
pub fn output_dir(profile: &str) -> String {
    format!("{}/{}", target_dir(), profile)
}

// ═══════════════════════════════════════════════════════════════════════════════
// MAIN ENTRY POINT
// ═══════════════════════════════════════════════════════════════════════════════

/// Main entry point for the package manager
pub fn main() -> Result<i32, String> {
    let args: Vec<String> = std::env::args().collect();
    let (global, command) = parse_args(&args[1..])?;
    execute(&global, &command)
}

// ═══════════════════════════════════════════════════════════════════════════════
// TESTS
// ═══════════════════════════════════════════════════════════════════════════════

#[cfg(test)]
mod tests {
    use super::*;
    
    #[test]
    fn test_validate_package_name() {
        assert!(validate_package_name("my-crate").is_ok());
        assert!(validate_package_name("my_crate").is_ok());
        assert!(validate_package_name("MyCrate").is_ok());
        assert!(validate_package_name("crate123").is_ok());
        
        assert!(validate_package_name("").is_err());
        assert!(validate_package_name("123crate").is_err());
        assert!(validate_package_name("-crate").is_err());
        assert!(validate_package_name("my.crate").is_err());
        assert!(validate_package_name("std").is_err());
    }
    
    #[test]
    fn test_package_builder() {
        let manifest = PackageBuilder::new("test-crate")
            .version("1.0.0")
            .author("Test Author")
            .dependency("serde", "1.0")
            .feature("default", vec!["std".to_string()])
            .build();
        
        assert_eq!(manifest.package.name, "test-crate");
        assert_eq!(manifest.package.version, "1.0.0");
        assert!(manifest.dependencies.contains_key("serde"));
        assert!(manifest.features.contains_key("default"));
    }
    
    #[test]
    fn test_version_parse() {
        let v = Version::parse("1.2.3").unwrap();
        assert_eq!(v.major, 1);
        assert_eq!(v.minor, 2);
        assert_eq!(v.patch, 3);
        
        let v = Version::parse("1.0.0-alpha.1+build.123").unwrap();
        assert!(v.is_prerelease());
    }
    
    #[test]
    fn test_version_req() {
        let req = VersionReq::parse("^1.2.3").unwrap();
        
        assert!(req.matches(&Version::parse("1.2.3").unwrap()));
        assert!(req.matches(&Version::parse("1.9.9").unwrap()));
        assert!(!req.matches(&Version::parse("2.0.0").unwrap()));
    }
}
