module quantalang::pkg::manifest

use alloc::string::String;
use alloc::vec::Vec;
use alloc::collections::BTreeMap;
use core::fmt;

// ═══════════════════════════════════════════════════════════════════════════════
// MANIFEST STRUCTURE
// ═══════════════════════════════════════════════════════════════════════════════

/// A parsed quanta.toml manifest
#[derive(Debug, Clone)]
pub struct Manifest {
    /// [package] section
    pub package: Package,
    /// [dependencies] section
    pub dependencies: BTreeMap<String, Dependency>,
    /// [dev-dependencies] section
    pub dev_dependencies: BTreeMap<String, Dependency>,
    /// [build-dependencies] section
    pub build_dependencies: BTreeMap<String, Dependency>,
    /// [features] section
    pub features: BTreeMap<String, Vec<String>>,
    /// [[bin]] sections
    pub binaries: Vec<BinaryTarget>,
    /// [[lib]] section
    pub library: Option<LibraryTarget>,
    /// [[test]] sections
    pub tests: Vec<TestTarget>,
    /// [[bench]] sections
    pub benches: Vec<BenchTarget>,
    /// [[example]] sections
    pub examples: Vec<ExampleTarget>,
    /// [workspace] section
    pub workspace: Option<Workspace>,
    /// [profile.*] sections
    pub profiles: BTreeMap<String, Profile>,
    /// [patch.*] sections
    pub patches: BTreeMap<String, BTreeMap<String, Dependency>>,
    /// [replace] section (deprecated)
    pub replace: BTreeMap<String, Dependency>,
    /// [badges] section
    pub badges: BTreeMap<String, BTreeMap<String, String>>,
}

impl Manifest {
    pub fn new(name: &str, version: &str) -> Self {
        Manifest {
            package: Package::new(name, version),
            dependencies: BTreeMap::new(),
            dev_dependencies: BTreeMap::new(),
            build_dependencies: BTreeMap::new(),
            features: BTreeMap::new(),
            binaries: Vec::new(),
            library: None,
            tests: Vec::new(),
            benches: Vec::new(),
            examples: Vec::new(),
            workspace: None,
            profiles: BTreeMap::new(),
            patches: BTreeMap::new(),
            replace: BTreeMap::new(),
            badges: BTreeMap::new(),
        }
    }
    
    /// Add a dependency
    pub fn add_dependency(&mut self, name: &str, dep: Dependency) {
        self.dependencies.insert(name.to_string(), dep);
    }
    
    /// Add a dev dependency
    pub fn add_dev_dependency(&mut self, name: &str, dep: Dependency) {
        self.dev_dependencies.insert(name.to_string(), dep);
    }
    
    /// Add a feature
    pub fn add_feature(&mut self, name: &str, deps: Vec<String>) {
        self.features.insert(name.to_string(), deps);
    }
    
    /// Get all dependencies (including optional based on features)
    pub fn all_dependencies(&self, features: &[String]) -> Vec<(&String, &Dependency)> {
        let mut deps: Vec<_> = self.dependencies.iter().collect();
        
        // Add feature-activated dependencies
        for feature in features {
            if let Some(feature_deps) = self.features.get(feature) {
                for dep_name in feature_deps {
                    if let Some(dep) = self.dependencies.get(dep_name) {
                        if !deps.iter().any(|(n, _)| *n == dep_name) {
                            deps.push((dep_name, dep));
                        }
                    }
                }
            }
        }
        
        deps
    }
    
    /// Check if this is a workspace root
    pub fn is_workspace(&self) -> bool {
        self.workspace.is_some()
    }
    
    /// Serialize to TOML string
    pub fn to_toml(&self) -> String {
        let mut toml = String::new();
        
        // [package]
        toml.push_str("[package]\n");
        toml.push_str(&format!("name = \"{}\"\n", self.package.name));
        toml.push_str(&format!("version = \"{}\"\n", self.package.version));
        
        if let Some(ref edition) = self.package.edition {
            toml.push_str(&format!("edition = \"{}\"\n", edition));
        }
        if let Some(ref desc) = self.package.description {
            toml.push_str(&format!("description = \"{}\"\n", desc));
        }
        if let Some(ref license) = self.package.license {
            toml.push_str(&format!("license = \"{}\"\n", license));
        }
        if !self.package.authors.is_empty() {
            toml.push_str(&format!("authors = [\"{}\"]\n", self.package.authors.join("\", \"")));
        }
        
        // [dependencies]
        if !self.dependencies.is_empty() {
            toml.push_str("\n[dependencies]\n");
            for (name, dep) in &self.dependencies {
                toml.push_str(&format!("{} = {}\n", name, dep.to_toml_value()));
            }
        }
        
        // [dev-dependencies]
        if !self.dev_dependencies.is_empty() {
            toml.push_str("\n[dev-dependencies]\n");
            for (name, dep) in &self.dev_dependencies {
                toml.push_str(&format!("{} = {}\n", name, dep.to_toml_value()));
            }
        }
        
        // [features]
        if !self.features.is_empty() {
            toml.push_str("\n[features]\n");
            for (name, deps) in &self.features {
                toml.push_str(&format!("{} = [\"{}\"]\n", name, deps.join("\", \"")));
            }
        }
        
        toml
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// PACKAGE
// ═══════════════════════════════════════════════════════════════════════════════

/// [package] section
#[derive(Debug, Clone)]
pub struct Package {
    pub name: String,
    pub version: String,
    pub edition: Option<String>,
    pub authors: Vec<String>,
    pub description: Option<String>,
    pub documentation: Option<String>,
    pub readme: Option<String>,
    pub homepage: Option<String>,
    pub repository: Option<String>,
    pub license: Option<String>,
    pub license_file: Option<String>,
    pub keywords: Vec<String>,
    pub categories: Vec<String>,
    pub workspace: Option<String>,
    pub build: Option<String>,
    pub links: Option<String>,
    pub exclude: Vec<String>,
    pub include: Vec<String>,
    pub publish: Option<PublishConfig>,
    pub metadata: BTreeMap<String, TomlValue>,
    pub default_run: Option<String>,
    pub autobins: bool,
    pub autoexamples: bool,
    pub autotests: bool,
    pub autobenches: bool,
    pub resolver: Option<String>,
}

impl Package {
    pub fn new(name: &str, version: &str) -> Self {
        Package {
            name: name.to_string(),
            version: version.to_string(),
            edition: Some("2025".to_string()),
            authors: Vec::new(),
            description: None,
            documentation: None,
            readme: None,
            homepage: None,
            repository: None,
            license: None,
            license_file: None,
            keywords: Vec::new(),
            categories: Vec::new(),
            workspace: None,
            build: None,
            links: None,
            exclude: Vec::new(),
            include: Vec::new(),
            publish: None,
            metadata: BTreeMap::new(),
            default_run: None,
            autobins: true,
            autoexamples: true,
            autotests: true,
            autobenches: true,
            resolver: None,
        }
    }
}

#[derive(Debug, Clone)]
pub enum PublishConfig {
    Bool(bool),
    Registries(Vec<String>),
}

// ═══════════════════════════════════════════════════════════════════════════════
// DEPENDENCY
// ═══════════════════════════════════════════════════════════════════════════════

/// A dependency specification
#[derive(Debug, Clone)]
pub struct Dependency {
    /// Version requirement (e.g., "1.0", "^1.2.3", ">=1.0, <2.0")
    pub version: Option<String>,
    /// Git repository URL
    pub git: Option<String>,
    /// Git branch
    pub branch: Option<String>,
    /// Git tag
    pub tag: Option<String>,
    /// Git revision
    pub rev: Option<String>,
    /// Local path
    pub path: Option<String>,
    /// Registry name
    pub registry: Option<String>,
    /// Features to enable
    pub features: Vec<String>,
    /// Use default features
    pub default_features: bool,
    /// Optional dependency
    pub optional: bool,
    /// Package name (if different from key)
    pub package: Option<String>,
}

impl Dependency {
    /// Create a version-based dependency
    pub fn version(version: &str) -> Self {
        Dependency {
            version: Some(version.to_string()),
            git: None,
            branch: None,
            tag: None,
            rev: None,
            path: None,
            registry: None,
            features: Vec::new(),
            default_features: true,
            optional: false,
            package: None,
        }
    }
    
    /// Create a git-based dependency
    pub fn git(url: &str) -> Self {
        Dependency {
            version: None,
            git: Some(url.to_string()),
            branch: None,
            tag: None,
            rev: None,
            path: None,
            registry: None,
            features: Vec::new(),
            default_features: true,
            optional: false,
            package: None,
        }
    }
    
    /// Create a path-based dependency
    pub fn path(path: &str) -> Self {
        Dependency {
            version: None,
            git: None,
            branch: None,
            tag: None,
            rev: None,
            path: Some(path.to_string()),
            registry: None,
            features: Vec::new(),
            default_features: true,
            optional: false,
            package: None,
        }
    }
    
    /// Set branch for git dependency
    pub fn with_branch(mut self, branch: &str) -> Self {
        self.branch = Some(branch.to_string());
        self
    }
    
    /// Set tag for git dependency
    pub fn with_tag(mut self, tag: &str) -> Self {
        self.tag = Some(tag.to_string());
        self
    }
    
    /// Set revision for git dependency
    pub fn with_rev(mut self, rev: &str) -> Self {
        self.rev = Some(rev.to_string());
        self
    }
    
    /// Enable features
    pub fn with_features(mut self, features: Vec<String>) -> Self {
        self.features = features;
        self
    }
    
    /// Disable default features
    pub fn no_default_features(mut self) -> Self {
        self.default_features = false;
        self
    }
    
    /// Mark as optional
    pub fn optional(mut self) -> Self {
        self.optional = true;
        self
    }
    
    /// Convert to TOML value representation
    pub fn to_toml_value(&self) -> String {
        // Simple version string
        if self.version.is_some() 
            && self.git.is_none() 
            && self.path.is_none()
            && self.features.is_empty()
            && self.default_features
            && !self.optional
        {
            return format!("\"{}\"", self.version.as_ref().unwrap());
        }
        
        // Inline table
        let mut parts = Vec::new();
        
        if let Some(ref v) = self.version {
            parts.push(format!("version = \"{}\"", v));
        }
        if let Some(ref g) = self.git {
            parts.push(format!("git = \"{}\"", g));
        }
        if let Some(ref b) = self.branch {
            parts.push(format!("branch = \"{}\"", b));
        }
        if let Some(ref t) = self.tag {
            parts.push(format!("tag = \"{}\"", t));
        }
        if let Some(ref r) = self.rev {
            parts.push(format!("rev = \"{}\"", r));
        }
        if let Some(ref p) = self.path {
            parts.push(format!("path = \"{}\"", p));
        }
        if !self.features.is_empty() {
            parts.push(format!("features = [\"{}\"]", self.features.join("\", \"")));
        }
        if !self.default_features {
            parts.push("default-features = false".to_string());
        }
        if self.optional {
            parts.push("optional = true".to_string());
        }
        
        format!("{{ {} }}", parts.join(", "))
    }
    
    /// Check if this is a registry dependency
    pub fn is_registry(&self) -> bool {
        self.version.is_some() && self.git.is_none() && self.path.is_none()
    }
    
    /// Check if this is a git dependency
    pub fn is_git(&self) -> bool {
        self.git.is_some()
    }
    
    /// Check if this is a path dependency
    pub fn is_path(&self) -> bool {
        self.path.is_some()
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// TARGETS
// ═══════════════════════════════════════════════════════════════════════════════

/// [[bin]] target
#[derive(Debug, Clone)]
pub struct BinaryTarget {
    pub name: String,
    pub path: Option<String>,
    pub test: bool,
    pub doctest: bool,
    pub bench: bool,
    pub doc: bool,
    pub harness: bool,
    pub edition: Option<String>,
    pub required_features: Vec<String>,
}

impl BinaryTarget {
    pub fn new(name: &str) -> Self {
        BinaryTarget {
            name: name.to_string(),
            path: None,
            test: true,
            doctest: true,
            bench: true,
            doc: true,
            harness: true,
            edition: None,
            required_features: Vec::new(),
        }
    }
}

/// [lib] target
#[derive(Debug, Clone)]
pub struct LibraryTarget {
    pub name: Option<String>,
    pub path: Option<String>,
    pub test: bool,
    pub doctest: bool,
    pub bench: bool,
    pub doc: bool,
    pub harness: bool,
    pub edition: Option<String>,
    pub crate_type: Vec<CrateType>,
    pub proc_macro: bool,
}

impl LibraryTarget {
    pub fn new() -> Self {
        LibraryTarget {
            name: None,
            path: None,
            test: true,
            doctest: true,
            bench: true,
            doc: true,
            harness: true,
            edition: None,
            crate_type: vec![CrateType::Lib],
            proc_macro: false,
        }
    }
}

#[derive(Debug, Clone, PartialEq, Eq)]
pub enum CrateType {
    Lib,
    Rlib,
    Dylib,
    Cdylib,
    Staticlib,
    ProcMacro,
}

impl CrateType {
    pub fn from_str(s: &str) -> Option<Self> {
        match s {
            "lib" => Some(CrateType::Lib),
            "rlib" => Some(CrateType::Rlib),
            "dylib" => Some(CrateType::Dylib),
            "cdylib" => Some(CrateType::Cdylib),
            "staticlib" => Some(CrateType::Staticlib),
            "proc-macro" => Some(CrateType::ProcMacro),
            _ => None,
        }
    }
    
    pub fn as_str(&self) -> &'static str {
        match self {
            CrateType::Lib => "lib",
            CrateType::Rlib => "rlib",
            CrateType::Dylib => "dylib",
            CrateType::Cdylib => "cdylib",
            CrateType::Staticlib => "staticlib",
            CrateType::ProcMacro => "proc-macro",
        }
    }
}

/// [[test]] target
#[derive(Debug, Clone)]
pub struct TestTarget {
    pub name: String,
    pub path: Option<String>,
    pub harness: bool,
    pub edition: Option<String>,
    pub required_features: Vec<String>,
}

/// [[bench]] target
#[derive(Debug, Clone)]
pub struct BenchTarget {
    pub name: String,
    pub path: Option<String>,
    pub harness: bool,
    pub edition: Option<String>,
    pub required_features: Vec<String>,
}

/// [[example]] target
#[derive(Debug, Clone)]
pub struct ExampleTarget {
    pub name: String,
    pub path: Option<String>,
    pub test: bool,
    pub doc: bool,
    pub harness: bool,
    pub edition: Option<String>,
    pub crate_type: Vec<CrateType>,
    pub required_features: Vec<String>,
}

// ═══════════════════════════════════════════════════════════════════════════════
// WORKSPACE
// ═══════════════════════════════════════════════════════════════════════════════

/// [workspace] section
#[derive(Debug, Clone)]
pub struct Workspace {
    pub members: Vec<String>,
    pub exclude: Vec<String>,
    pub default_members: Vec<String>,
    pub resolver: Option<String>,
    pub package: Option<WorkspacePackage>,
    pub dependencies: BTreeMap<String, Dependency>,
}

impl Workspace {
    pub fn new() -> Self {
        Workspace {
            members: Vec::new(),
            exclude: Vec::new(),
            default_members: Vec::new(),
            resolver: None,
            package: None,
            dependencies: BTreeMap::new(),
        }
    }
}

/// [workspace.package] for shared package metadata
#[derive(Debug, Clone, Default)]
pub struct WorkspacePackage {
    pub version: Option<String>,
    pub authors: Vec<String>,
    pub edition: Option<String>,
    pub description: Option<String>,
    pub documentation: Option<String>,
    pub readme: Option<String>,
    pub homepage: Option<String>,
    pub repository: Option<String>,
    pub license: Option<String>,
    pub keywords: Vec<String>,
    pub categories: Vec<String>,
    pub publish: Option<PublishConfig>,
}

// ═══════════════════════════════════════════════════════════════════════════════
// PROFILE
// ═══════════════════════════════════════════════════════════════════════════════

/// [profile.*] section
#[derive(Debug, Clone)]
pub struct Profile {
    pub opt_level: Option<OptLevel>,
    pub debug: Option<DebugInfo>,
    pub split_debuginfo: Option<String>,
    pub debug_assertions: Option<bool>,
    pub overflow_checks: Option<bool>,
    pub lto: Option<Lto>,
    pub panic: Option<PanicStrategy>,
    pub incremental: Option<bool>,
    pub codegen_units: Option<u32>,
    pub rpath: Option<bool>,
    pub strip: Option<Strip>,
    /// Per-package overrides
    pub package: BTreeMap<String, Profile>,
    /// Build override
    pub build_override: Option<Box<Profile>>,
    /// Inherits from another profile
    pub inherits: Option<String>,
}

impl Profile {
    pub fn dev() -> Self {
        Profile {
            opt_level: Some(OptLevel::O0),
            debug: Some(DebugInfo::Full),
            split_debuginfo: None,
            debug_assertions: Some(true),
            overflow_checks: Some(true),
            lto: Some(Lto::Off),
            panic: Some(PanicStrategy::Unwind),
            incremental: Some(true),
            codegen_units: Some(256),
            rpath: Some(false),
            strip: Some(Strip::None),
            package: BTreeMap::new(),
            build_override: None,
            inherits: None,
        }
    }
    
    pub fn release() -> Self {
        Profile {
            opt_level: Some(OptLevel::O3),
            debug: Some(DebugInfo::None),
            split_debuginfo: None,
            debug_assertions: Some(false),
            overflow_checks: Some(false),
            lto: Some(Lto::Off),
            panic: Some(PanicStrategy::Unwind),
            incremental: Some(false),
            codegen_units: Some(16),
            rpath: Some(false),
            strip: Some(Strip::None),
            package: BTreeMap::new(),
            build_override: None,
            inherits: None,
        }
    }
    
    pub fn test() -> Self {
        let mut p = Self::dev();
        p.inherits = Some("dev".to_string());
        p
    }
    
    pub fn bench() -> Self {
        let mut p = Self::release();
        p.inherits = Some("release".to_string());
        p
    }
}

#[derive(Debug, Clone, Copy, PartialEq, Eq)]
pub enum OptLevel {
    O0,
    O1,
    O2,
    O3,
    Os,
    Oz,
}

impl OptLevel {
    pub fn from_str(s: &str) -> Option<Self> {
        match s {
            "0" => Some(OptLevel::O0),
            "1" => Some(OptLevel::O1),
            "2" => Some(OptLevel::O2),
            "3" => Some(OptLevel::O3),
            "s" => Some(OptLevel::Os),
            "z" => Some(OptLevel::Oz),
            _ => None,
        }
    }
}

#[derive(Debug, Clone, Copy, PartialEq, Eq)]
pub enum DebugInfo {
    None,
    Line,
    Limited,
    Full,
}

#[derive(Debug, Clone, PartialEq, Eq)]
pub enum Lto {
    Off,
    Thin,
    Fat,
    Bool(bool),
}

#[derive(Debug, Clone, Copy, PartialEq, Eq)]
pub enum PanicStrategy {
    Unwind,
    Abort,
}

#[derive(Debug, Clone, Copy, PartialEq, Eq)]
pub enum Strip {
    None,
    Debuginfo,
    Symbols,
}

// ═══════════════════════════════════════════════════════════════════════════════
// TOML VALUE
// ═══════════════════════════════════════════════════════════════════════════════

/// Generic TOML value for metadata
#[derive(Debug, Clone)]
pub enum TomlValue {
    String(String),
    Integer(i64),
    Float(f64),
    Boolean(bool),
    Array(Vec<TomlValue>),
    Table(BTreeMap<String, TomlValue>),
}

// ═══════════════════════════════════════════════════════════════════════════════
// PARSER
// ═══════════════════════════════════════════════════════════════════════════════

/// Parse a quanta.toml manifest
pub fn parse_manifest(content: &str) -> Result<Manifest, ParseError> {
    let mut parser = ManifestParser::new(content);
    parser.parse()
}

#[derive(Debug)]
pub struct ParseError {
    pub message: String,
    pub line: usize,
    pub column: usize,
}

impl fmt::Display for ParseError {
    fn fmt(&self, f: &mut fmt::Formatter<'_>) -> fmt::Result {
        write!(f, "{}:{}: {}", self.line, self.column, self.message)
    }
}

struct ManifestParser<'a> {
    content: &'a str,
    pos: usize,
    line: usize,
    column: usize,
}

impl<'a> ManifestParser<'a> {
    fn new(content: &'a str) -> Self {
        ManifestParser {
            content,
            pos: 0,
            line: 1,
            column: 1,
        }
    }
    
    fn parse(&mut self) -> Result<Manifest, ParseError> {
        let mut manifest = Manifest::new("unknown", "0.0.0");
        let mut current_section = String::new();
        let mut current_array_section: Option<String> = None;
        
        while self.pos < self.content.len() {
            self.skip_whitespace_and_comments();
            
            if self.pos >= self.content.len() {
                break;
            }
            
            // Check for section header
            if self.peek() == Some('[') {
                if self.peek_at(1) == Some('[') {
                    // Array of tables [[section]]
                    self.advance(); // [
                    self.advance(); // [
                    let section = self.read_until(']')?;
                    self.expect(']')?;
                    self.expect(']')?;
                    current_array_section = Some(section.clone());
                    current_section = section;
                    
                    // Initialize array entry
                    match current_section.as_str() {
                        "bin" => manifest.binaries.push(BinaryTarget::new("")),
                        "test" => manifest.tests.push(TestTarget {
                            name: String::new(),
                            path: None,
                            harness: true,
                            edition: None,
                            required_features: Vec::new(),
                        }),
                        "bench" => manifest.benches.push(BenchTarget {
                            name: String::new(),
                            path: None,
                            harness: true,
                            edition: None,
                            required_features: Vec::new(),
                        }),
                        "example" => manifest.examples.push(ExampleTarget {
                            name: String::new(),
                            path: None,
                            test: false,
                            doc: false,
                            harness: true,
                            edition: None,
                            crate_type: vec![CrateType::Lib],
                            required_features: Vec::new(),
                        }),
                        _ => {}
                    }
                } else {
                    // Regular section [section]
                    self.advance(); // [
                    current_section = self.read_until(']')?;
                    self.expect(']')?;
                    current_array_section = None;
                }
                continue;
            }
            
            // Parse key-value pair
            let key = self.read_key()?;
            self.skip_whitespace();
            self.expect('=')?;
            self.skip_whitespace();
            let value = self.read_value()?;
            
            // Store value in appropriate section
            self.store_value(&mut manifest, &current_section, &current_array_section, &key, value)?;
        }
        
        Ok(manifest)
    }
    
    fn skip_whitespace(&mut self) {
        while let Some(c) = self.peek() {
            if c == ' ' || c == '\t' {
                self.advance();
            } else if c == '\n' {
                self.advance();
                self.line += 1;
                self.column = 1;
            } else if c == '\r' {
                self.advance();
            } else {
                break;
            }
        }
    }
    
    fn skip_whitespace_and_comments(&mut self) {
        loop {
            self.skip_whitespace();
            
            if self.peek() == Some('#') {
                // Skip comment
                while let Some(c) = self.peek() {
                    self.advance();
                    if c == '\n' {
                        self.line += 1;
                        self.column = 1;
                        break;
                    }
                }
            } else {
                break;
            }
        }
    }
    
    fn peek(&self) -> Option<char> {
        self.content[self.pos..].chars().next()
    }
    
    fn peek_at(&self, offset: usize) -> Option<char> {
        self.content[self.pos..].chars().nth(offset)
    }
    
    fn advance(&mut self) -> Option<char> {
        let c = self.peek()?;
        self.pos += c.len_utf8();
        self.column += 1;
        Some(c)
    }
    
    fn expect(&mut self, expected: char) -> Result<(), ParseError> {
        match self.advance() {
            Some(c) if c == expected => Ok(()),
            Some(c) => Err(ParseError {
                message: format!("expected '{}', found '{}'", expected, c),
                line: self.line,
                column: self.column,
            }),
            None => Err(ParseError {
                message: format!("expected '{}', found EOF", expected),
                line: self.line,
                column: self.column,
            }),
        }
    }
    
    fn read_until(&mut self, end: char) -> Result<String, ParseError> {
        let mut s = String::new();
        while let Some(c) = self.peek() {
            if c == end {
                break;
            }
            s.push(c);
            self.advance();
        }
        Ok(s.trim().to_string())
    }
    
    fn read_key(&mut self) -> Result<String, ParseError> {
        let mut key = String::new();
        
        while let Some(c) = self.peek() {
            if c.is_alphanumeric() || c == '_' || c == '-' || c == '.' {
                key.push(c);
                self.advance();
            } else {
                break;
            }
        }
        
        if key.is_empty() {
            return Err(ParseError {
                message: "expected key".to_string(),
                line: self.line,
                column: self.column,
            });
        }
        
        Ok(key)
    }
    
    fn read_value(&mut self) -> Result<TomlValue, ParseError> {
        match self.peek() {
            Some('"') => self.read_string(),
            Some('\'') => self.read_literal_string(),
            Some('[') => self.read_array(),
            Some('{') => self.read_inline_table(),
            Some(c) if c.is_ascii_digit() || c == '-' || c == '+' => self.read_number(),
            Some('t') | Some('f') => self.read_boolean(),
            _ => Err(ParseError {
                message: "expected value".to_string(),
                line: self.line,
                column: self.column,
            }),
        }
    }
    
    fn read_string(&mut self) -> Result<TomlValue, ParseError> {
        self.expect('"')?;
        let mut s = String::new();
        
        while let Some(c) = self.peek() {
            if c == '"' {
                self.advance();
                break;
            } else if c == '\\' {
                self.advance();
                match self.advance() {
                    Some('n') => s.push('\n'),
                    Some('t') => s.push('\t'),
                    Some('r') => s.push('\r'),
                    Some('\\') => s.push('\\'),
                    Some('"') => s.push('"'),
                    Some(c) => s.push(c),
                    None => break,
                }
            } else {
                s.push(c);
                self.advance();
            }
        }
        
        Ok(TomlValue::String(s))
    }
    
    fn read_literal_string(&mut self) -> Result<TomlValue, ParseError> {
        self.expect('\'')?;
        let mut s = String::new();
        
        while let Some(c) = self.peek() {
            if c == '\'' {
                self.advance();
                break;
            }
            s.push(c);
            self.advance();
        }
        
        Ok(TomlValue::String(s))
    }
    
    fn read_array(&mut self) -> Result<TomlValue, ParseError> {
        self.expect('[')?;
        let mut arr = Vec::new();
        
        self.skip_whitespace_and_comments();
        
        while self.peek() != Some(']') {
            let value = self.read_value()?;
            arr.push(value);
            
            self.skip_whitespace_and_comments();
            
            if self.peek() == Some(',') {
                self.advance();
                self.skip_whitespace_and_comments();
            }
        }
        
        self.expect(']')?;
        Ok(TomlValue::Array(arr))
    }
    
    fn read_inline_table(&mut self) -> Result<TomlValue, ParseError> {
        self.expect('{')?;
        let mut table = BTreeMap::new();
        
        self.skip_whitespace();
        
        while self.peek() != Some('}') {
            let key = self.read_key()?;
            self.skip_whitespace();
            self.expect('=')?;
            self.skip_whitespace();
            let value = self.read_value()?;
            
            table.insert(key, value);
            
            self.skip_whitespace();
            if self.peek() == Some(',') {
                self.advance();
                self.skip_whitespace();
            }
        }
        
        self.expect('}')?;
        Ok(TomlValue::Table(table))
    }
    
    fn read_number(&mut self) -> Result<TomlValue, ParseError> {
        let mut s = String::new();
        let mut is_float = false;
        
        while let Some(c) = self.peek() {
            if c.is_ascii_digit() || c == '-' || c == '+' || c == '_' {
                if c != '_' {
                    s.push(c);
                }
                self.advance();
            } else if c == '.' || c == 'e' || c == 'E' {
                is_float = true;
                s.push(c);
                self.advance();
            } else {
                break;
            }
        }
        
        if is_float {
            s.parse::<f64>()
                .map(TomlValue::Float)
                .map_err(|_| ParseError {
                    message: "invalid float".to_string(),
                    line: self.line,
                    column: self.column,
                })
        } else {
            s.parse::<i64>()
                .map(TomlValue::Integer)
                .map_err(|_| ParseError {
                    message: "invalid integer".to_string(),
                    line: self.line,
                    column: self.column,
                })
        }
    }
    
    fn read_boolean(&mut self) -> Result<TomlValue, ParseError> {
        if self.content[self.pos..].starts_with("true") {
            self.pos += 4;
            self.column += 4;
            Ok(TomlValue::Boolean(true))
        } else if self.content[self.pos..].starts_with("false") {
            self.pos += 5;
            self.column += 5;
            Ok(TomlValue::Boolean(false))
        } else {
            Err(ParseError {
                message: "expected boolean".to_string(),
                line: self.line,
                column: self.column,
            })
        }
    }
    
    fn store_value(
        &self,
        manifest: &mut Manifest,
        section: &str,
        array_section: &Option<String>,
        key: &str,
        value: TomlValue,
    ) -> Result<(), ParseError> {
        match section {
            "package" => self.store_package_value(&mut manifest.package, key, value),
            "dependencies" => self.store_dependency(&mut manifest.dependencies, key, value),
            "dev-dependencies" => self.store_dependency(&mut manifest.dev_dependencies, key, value),
            "build-dependencies" => self.store_dependency(&mut manifest.build_dependencies, key, value),
            "features" => self.store_feature(&mut manifest.features, key, value),
            "workspace" => {
                if manifest.workspace.is_none() {
                    manifest.workspace = Some(Workspace::new());
                }
                self.store_workspace_value(manifest.workspace.as_mut().unwrap(), key, value)
            }
            "lib" => {
                if manifest.library.is_none() {
                    manifest.library = Some(LibraryTarget::new());
                }
                self.store_lib_value(manifest.library.as_mut().unwrap(), key, value)
            }
            s if s.starts_with("profile.") => {
                let profile_name = &s[8..];
                if !manifest.profiles.contains_key(profile_name) {
                    manifest.profiles.insert(profile_name.to_string(), Profile::dev());
                }
                self.store_profile_value(manifest.profiles.get_mut(profile_name).unwrap(), key, value)
            }
            _ if array_section.is_some() => {
                match array_section.as_ref().unwrap().as_str() {
                    "bin" => self.store_bin_value(manifest.binaries.last_mut().unwrap(), key, value),
                    _ => Ok(()),
                }
            }
            _ => Ok(()),
        }
    }
    
    fn store_package_value(&self, package: &mut Package, key: &str, value: TomlValue) -> Result<(), ParseError> {
        match key {
            "name" => {
                if let TomlValue::String(s) = value {
                    package.name = s;
                }
            }
            "version" => {
                if let TomlValue::String(s) = value {
                    package.version = s;
                }
            }
            "edition" => {
                if let TomlValue::String(s) = value {
                    package.edition = Some(s);
                }
            }
            "authors" => {
                if let TomlValue::Array(arr) = value {
                    package.authors = arr.into_iter()
                        .filter_map(|v| if let TomlValue::String(s) = v { Some(s) } else { None })
                        .collect();
                }
            }
            "description" => {
                if let TomlValue::String(s) = value {
                    package.description = Some(s);
                }
            }
            "license" => {
                if let TomlValue::String(s) = value {
                    package.license = Some(s);
                }
            }
            "repository" => {
                if let TomlValue::String(s) = value {
                    package.repository = Some(s);
                }
            }
            "keywords" => {
                if let TomlValue::Array(arr) = value {
                    package.keywords = arr.into_iter()
                        .filter_map(|v| if let TomlValue::String(s) = v { Some(s) } else { None })
                        .collect();
                }
            }
            _ => {}
        }
        Ok(())
    }
    
    fn store_dependency(&self, deps: &mut BTreeMap<String, Dependency>, key: &str, value: TomlValue) -> Result<(), ParseError> {
        let dep = match value {
            TomlValue::String(version) => Dependency::version(&version),
            TomlValue::Table(table) => {
                let mut dep = Dependency::version("");
                
                for (k, v) in table {
                    match (k.as_str(), v) {
                        ("version", TomlValue::String(s)) => dep.version = Some(s),
                        ("git", TomlValue::String(s)) => dep.git = Some(s),
                        ("branch", TomlValue::String(s)) => dep.branch = Some(s),
                        ("tag", TomlValue::String(s)) => dep.tag = Some(s),
                        ("rev", TomlValue::String(s)) => dep.rev = Some(s),
                        ("path", TomlValue::String(s)) => dep.path = Some(s),
                        ("features", TomlValue::Array(arr)) => {
                            dep.features = arr.into_iter()
                                .filter_map(|v| if let TomlValue::String(s) = v { Some(s) } else { None })
                                .collect();
                        }
                        ("default-features", TomlValue::Boolean(b)) => dep.default_features = b,
                        ("optional", TomlValue::Boolean(b)) => dep.optional = b,
                        ("package", TomlValue::String(s)) => dep.package = Some(s),
                        _ => {}
                    }
                }
                
                dep
            }
            _ => return Ok(()),
        };
        
        deps.insert(key.to_string(), dep);
        Ok(())
    }
    
    fn store_feature(&self, features: &mut BTreeMap<String, Vec<String>>, key: &str, value: TomlValue) -> Result<(), ParseError> {
        if let TomlValue::Array(arr) = value {
            let deps: Vec<String> = arr.into_iter()
                .filter_map(|v| if let TomlValue::String(s) = v { Some(s) } else { None })
                .collect();
            features.insert(key.to_string(), deps);
        }
        Ok(())
    }
    
    fn store_workspace_value(&self, workspace: &mut Workspace, key: &str, value: TomlValue) -> Result<(), ParseError> {
        match key {
            "members" => {
                if let TomlValue::Array(arr) = value {
                    workspace.members = arr.into_iter()
                        .filter_map(|v| if let TomlValue::String(s) = v { Some(s) } else { None })
                        .collect();
                }
            }
            "exclude" => {
                if let TomlValue::Array(arr) = value {
                    workspace.exclude = arr.into_iter()
                        .filter_map(|v| if let TomlValue::String(s) = v { Some(s) } else { None })
                        .collect();
                }
            }
            _ => {}
        }
        Ok(())
    }
    
    fn store_lib_value(&self, lib: &mut LibraryTarget, key: &str, value: TomlValue) -> Result<(), ParseError> {
        match key {
            "name" => {
                if let TomlValue::String(s) = value {
                    lib.name = Some(s);
                }
            }
            "path" => {
                if let TomlValue::String(s) = value {
                    lib.path = Some(s);
                }
            }
            "proc-macro" => {
                if let TomlValue::Boolean(b) = value {
                    lib.proc_macro = b;
                }
            }
            _ => {}
        }
        Ok(())
    }
    
    fn store_profile_value(&self, profile: &mut Profile, key: &str, value: TomlValue) -> Result<(), ParseError> {
        match key {
            "opt-level" => {
                match value {
                    TomlValue::Integer(i) => {
                        profile.opt_level = match i {
                            0 => Some(OptLevel::O0),
                            1 => Some(OptLevel::O1),
                            2 => Some(OptLevel::O2),
                            3 => Some(OptLevel::O3),
                            _ => None,
                        };
                    }
                    TomlValue::String(s) => {
                        profile.opt_level = OptLevel::from_str(&s);
                    }
                    _ => {}
                }
            }
            "debug" => {
                match value {
                    TomlValue::Boolean(b) => {
                        profile.debug = if b { Some(DebugInfo::Full) } else { Some(DebugInfo::None) };
                    }
                    TomlValue::Integer(i) => {
                        profile.debug = match i {
                            0 => Some(DebugInfo::None),
                            1 => Some(DebugInfo::Limited),
                            2 => Some(DebugInfo::Full),
                            _ => None,
                        };
                    }
                    _ => {}
                }
            }
            "lto" => {
                match value {
                    TomlValue::Boolean(b) => profile.lto = Some(Lto::Bool(b)),
                    TomlValue::String(s) => {
                        profile.lto = match s.as_str() {
                            "thin" => Some(Lto::Thin),
                            "fat" | "true" => Some(Lto::Fat),
                            "off" | "false" => Some(Lto::Off),
                            _ => None,
                        };
                    }
                    _ => {}
                }
            }
            "panic" => {
                if let TomlValue::String(s) = value {
                    profile.panic = match s.as_str() {
                        "unwind" => Some(PanicStrategy::Unwind),
                        "abort" => Some(PanicStrategy::Abort),
                        _ => None,
                    };
                }
            }
            "incremental" => {
                if let TomlValue::Boolean(b) = value {
                    profile.incremental = Some(b);
                }
            }
            "codegen-units" => {
                if let TomlValue::Integer(i) = value {
                    profile.codegen_units = Some(i as u32);
                }
            }
            _ => {}
        }
        Ok(())
    }
    
    fn store_bin_value(&self, bin: &mut BinaryTarget, key: &str, value: TomlValue) -> Result<(), ParseError> {
        match key {
            "name" => {
                if let TomlValue::String(s) = value {
                    bin.name = s;
                }
            }
            "path" => {
                if let TomlValue::String(s) = value {
                    bin.path = Some(s);
                }
            }
            "test" => {
                if let TomlValue::Boolean(b) = value {
                    bin.test = b;
                }
            }
            _ => {}
        }
        Ok(())
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// TESTS
// ═══════════════════════════════════════════════════════════════════════════════

#[cfg(test)]
mod tests {
    use super::*;
    
    #[test]
    fn test_parse_basic_manifest() {
        let content = r#"
[package]
name = "my-crate"
version = "1.0.0"
edition = "2025"

[dependencies]
serde = "1.0"
tokio = { version = "1.0", features = ["full"] }

[dev-dependencies]
pretty_assertions = "1.0"

[features]
default = ["std"]
std = []
"#;
        
        let manifest = parse_manifest(content).unwrap();
        
        assert_eq!(manifest.package.name, "my-crate");
        assert_eq!(manifest.package.version, "1.0.0");
        assert!(manifest.dependencies.contains_key("serde"));
        assert!(manifest.dependencies.contains_key("tokio"));
        assert!(manifest.dev_dependencies.contains_key("pretty_assertions"));
        assert!(manifest.features.contains_key("default"));
    }
    
    #[test]
    fn test_dependency_to_toml() {
        let simple = Dependency::version("1.0");
        assert_eq!(simple.to_toml_value(), "\"1.0\"");
        
        let complex = Dependency::git("https://github.com/example/repo")
            .with_branch("main")
            .with_features(vec!["foo".to_string()]);
        assert!(complex.to_toml_value().contains("git"));
        assert!(complex.to_toml_value().contains("branch"));
    }
}
