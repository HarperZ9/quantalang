/// CLI command
#[derive(Debug, Clone)]
pub enum Command {
    New(NewOptions),
    Init(InitOptions),
    Build(BuildOptions),
    Run(RunOptions),
    Test(TestOptions),
    Bench(BenchOptions),
    Check(CheckOptions),
    Clean(CleanOptions),
    Doc(DocOptions),
    Publish(PublishOptions),
    Install(InstallOptions),
    Uninstall(UninstallOptions),
    Search(SearchOptions),
    Update(UpdateOptions),
    Add(AddOptions),
    Remove(RemoveOptions),
    Tree(TreeOptions),
    Fetch(FetchOptions),
    Login(LoginOptions),
    Logout(LogoutOptions),
    Help(Option<String>),
    Version,
}

