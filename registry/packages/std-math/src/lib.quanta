/// Mathematical constant: ratio of a circle's circumference to its diameter.
const PI: f64 = 3.141592653589793;

/// Mathematical constant: Euler's number, base of natural logarithm.
const E: f64 = 2.718281828459045;

/// Mathematical constant: TAU = 2 * PI, a full turn in radians.
const TAU: f64 = 6.283185307179586;

/// Convert degrees to radians.
fn deg_to_rad(degrees: f64) -> f64 {
    degrees * PI / 180.0
}

/// Convert radians to degrees.
fn rad_to_deg(radians: f64) -> f64 {
    radians * 180.0 / PI
}

/// Linearly interpolate between two values.
///   lerp(a, b, 0.0) == a
///   lerp(a, b, 1.0) == b
fn lerp(a: f64, b: f64, t: f64) -> f64 {
    a + (b - a) * t
}

/// Clamp a value to the [0, 1] range.
fn clamp01(x: f64) -> f64 {
    if x < 0.0 {
        0.0
    } else if x > 1.0 {
        1.0
    } else {
        x
    }
}
