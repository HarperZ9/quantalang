// Test: closures and higher-order functions

fn apply(x: f64, f: fn(f64) -> f64) -> f64 {
    f(x)
}

fn square(x: f64) -> f64 {
    x * x
}

fn cube(x: f64) -> f64 {
    x * x * x
}

fn map_pair(a: f64, b: f64, f: fn(f64) -> f64) -> f64 {
    f(a) + f(b)
}

fn main() {
    // Function pointers as arguments
    let s = apply(5.0, square);
    println!("{}", s);

    let c = apply(3.0, cube);
    println!("{}", c);

    // Pass to a function that uses it twice
    let sum = map_pair(2.0, 3.0, square);
    println!("{}", sum);
}
