// Self-hosting test: generic functions, methods, closures
// Tests what the compiler can handle for stdlib development

// --- Generic function (monomorphization) ---
fn identity<T>(x: T) -> T {
    x
}

// --- Struct with methods ---
struct Vec2 {
    x: f64,
    y: f64,
}

impl Vec2 {
    fn new(x: f64, y: f64) -> Vec2 {
        Vec2 { x: x, y: y }
    }

    fn length(self) -> f64 {
        sqrt(self.x * self.x + self.y * self.y)
    }

    fn dot(self, other: Vec2) -> f64 {
        self.x * other.x + self.y * other.y
    }

    fn scale(self, factor: f64) -> Vec2 {
        Vec2 { x: self.x * factor, y: self.y * factor }
    }
}

// --- Higher-order function ---
fn apply_twice(x: f64, f: fn(f64) -> f64) -> f64 {
    f(f(x))
}

fn double(x: f64) -> f64 {
    x * 2.0
}

fn main() {
    // Test generics
    let a = identity(42);
    let b = identity(3.14);
    println!("{}", a);
    println!("{}", b);

    // Test struct methods
    let v = Vec2::new(3.0, 4.0);
    let len = v.length();
    println!("{}", len);

    let v2 = Vec2::new(1.0, 0.0);
    let d = v.dot(v2);
    println!("{}", d);

    let v3 = v.scale(2.0);
    println!("{}", v3.x);
    println!("{}", v3.y);

    // Test higher-order function
    let result = apply_twice(5.0, double);
    println!("{}", result);
}
