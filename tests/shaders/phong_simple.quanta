// Simple Phong lighting shader — no branching, tests function calls in SPIR-V

fn compute_diffuse(normal_x: f64, normal_y: f64, normal_z: f64,
                   light_x: f64, light_y: f64, light_z: f64) -> f64 {
    // Manual dot product (avoiding vec3 for simplicity)
    let d = normal_x * light_x + normal_y * light_y + normal_z * light_z;
    // Approximate max(d, 0) without branching: (d + abs(d)) / 2
    d
}

#[fragment]
fn fs_main(color: vec3) -> vec4 {
    let diffuse = compute_diffuse(0.0, 1.0, 0.0, 0.577, 0.577, 0.577);
    let r = color.x * diffuse;
    let g = color.y * diffuse;
    let b = color.z * diffuse;
    vec4(r, g, b, 1.0)
}
