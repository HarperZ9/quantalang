// ============================================================================
// QUANTALANG DUAL-TARGET PROOF
// ============================================================================
//
// This SINGLE FILE compiles to BOTH:
//   quantac dual_target.quanta -o dual_target.c    # CPU (testable)
//   quantac dual_target.quanta -o dual_target.spv  # GPU (Vulkan SPIR-V)
//
// The SAME aces_tonemap function runs on CPU for testing AND on GPU
// for real-time rendering. No other language can do this.
// ============================================================================

// Industry-standard ACES filmic tone mapping curve
// Used in Unreal Engine, Unity, and most AAA games
fn aces_tonemap(x: f64) -> f64 {
    let a = 2.51;
    let b = 0.03;
    let c = 2.43;
    let d = 0.59;
    let e = 0.14;
    let num = x * (a * x + b);
    let den = x * (c * x + d) + e;
    clamp(num / den, 0.0, 1.0)
}

// Fresnel-Schlick approximation (PBR rendering)
fn fresnel(cos_theta: f64, f0: f64) -> f64 {
    f0 + (1.0 - f0) * pow(clamp(1.0 - cos_theta, 0.0, 1.0), 5.0)
}

// GPU entry point — compiles to SPIR-V fragment shader
#[fragment]
fn fs_postprocess(hdr_color: vec3) -> vec4 {
    // Apply ACES tone mapping to each channel
    let r = aces_tonemap(hdr_color.x);
    let g = aces_tonemap(hdr_color.y);
    let b = aces_tonemap(hdr_color.z);
    vec4(r, g, b, 1.0)
}

// CPU entry point — for testing and verification
fn main() {
    // Test ACES tone mapping with known values
    let dark = aces_tonemap(0.0);
    let mid = aces_tonemap(1.0);
    let bright = aces_tonemap(5.0);
    let over = aces_tonemap(100.0);

    println!("=== QuantaLang Dual-Target Proof ===");
    println!("ACES(0.0) = {} (should be ~0.0)", dark);
    println!("ACES(1.0) = {} (should be ~0.80)", mid);
    println!("ACES(5.0) = {} (should be ~0.98)", bright);
    println!("ACES(100) = {} (should be 1.0)", over);

    // Test Fresnel
    let f_head_on = fresnel(1.0, 0.04);
    let f_grazing = fresnel(0.0, 0.04);
    println!("Fresnel(1.0, 0.04) = {} (head-on, should be ~0.04)", f_head_on);
    println!("Fresnel(0.0, 0.04) = {} (grazing, should be 1.0)", f_grazing);
    println!("=== Same functions compile to Vulkan SPIR-V ===");
}
