// Shader math builtins — all compile to GLSL.std.450 extended instructions
// Tests: sqrt, sin, cos, pow, abs, floor, ceil, clamp, smoothstep, mix

fn fresnel_schlick(cos_theta: f64, f0: f64) -> f64 {
    f0 + (1.0 - f0) * pow(1.0 - cos_theta, 5.0)
}

fn fog_factor(distance: f64, density: f64) -> f64 {
    let exponent = distance * density;
    clamp(1.0 - pow(2.718281828, 0.0 - exponent * exponent), 0.0, 1.0)
}

#[fragment]
fn fs_main(uv: vec3) -> vec4 {
    let x = uv.x;
    let y = uv.y;

    // Use multiple GLSL builtins
    let s = sin(x * 3.14159);
    let c = cos(y * 3.14159);
    let r = sqrt(x * x + y * y);
    let f = floor(x * 10.0);
    let brightness = abs(s * c);
    let fresnel = fresnel_schlick(clamp(r, 0.0, 1.0), 0.04);
    let fog = fog_factor(r * 10.0, 0.1);

    vec4(brightness, fresnel, fog, 1.0)
}
