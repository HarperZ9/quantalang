// Test: simple if/else branching in SPIR-V shaders

fn select_bright(x: f64) -> f64 {
    if x > 0.5 {
        1.0
    } else {
        0.0
    }
}

#[fragment]
fn fs_main(color: vec3) -> vec4 {
    let r = select_bright(color.x);
    let g = select_bright(color.y);
    let b = select_bright(color.z);
    vec4(r, g, b, 1.0)
}
