// ACES Filmic Tone Mapping with clamp — uses GLSL.std.450 builtins in SPIR-V
// This same function works on CPU (C backend) AND GPU (SPIR-V backend)

fn aces_channel(x: f64) -> f64 {
    let a = 2.51;
    let b = 0.03;
    let c = 2.43;
    let d = 0.59;
    let e = 0.14;

    let num = x * (a * x + b);
    let den = x * (c * x + d) + e;
    let result = num / den;

    // clamp → GLSL.std.450 FClamp (opcode 43) in SPIR-V
    clamp(result, 0.0, 1.0)
}

#[fragment]
fn fs_tonemap(hdr_color: vec3) -> vec4 {
    let r = aces_channel(hdr_color.x);
    let g = aces_channel(hdr_color.y);
    let b = aces_channel(hdr_color.z);
    vec4(r, g, b, 1.0)
}
