// Test nested if/else branching in SPIR-V shaders

fn saturate(x: f64) -> f64 {
    if x > 1.0 {
        1.0
    } else {
        if x < 0.0 {
            0.0
        } else {
            x
        }
    }
}

#[fragment]
fn fs_main(color: vec3) -> vec4 {
    let r = saturate(color.x);
    let g = saturate(color.y);
    let b = saturate(color.z);
    vec4(r, g, b, 1.0)
}
