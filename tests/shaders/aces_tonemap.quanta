// ACES Filmic Tone Mapping — compiled to SPIR-V for GPU post-processing
// The SAME aces_channel function compiles to BOTH C (CPU) and SPIR-V (GPU)

fn aces_channel(x: f64) -> f64 {
    let a = 2.51;
    let b = 0.03;
    let c = 2.43;
    let d = 0.59;
    let e = 0.14;

    let num = x * (a * x + b);
    let den = x * (c * x + d) + e;
    num / den
}

#[fragment]
fn fs_tonemap(hdr_color: vec3) -> vec4 {
    let r = aces_channel(hdr_color.x);
    let g = aces_channel(hdr_color.y);
    let b = aces_channel(hdr_color.z);
    vec4(r, g, b, 1.0)
}
