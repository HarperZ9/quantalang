// =============================================================================
// Self-Hosted Compiler v8 — Structs + Multi-char Idents + Multi-digit Nums
// =============================================================================
// Source → C with struct definitions, multi-character identifiers, and
// multi-digit numeric literals. The compiler can now describe its own types.
//
// Input:
//   struct Vec2 { x: i32, y: i32 }
//   fn dot(a: Vec2, b: Vec2) -> i32 { a.x * b.x + a.y * b.y }
//   fn main() { let result = dot(Vec2{x:3,y:4}, Vec2{x:1,y:2}); }
//
// Simplified to what the compiler can handle:
//   fn area(w, h) { w * h }
//   fn main() { let result = area(12, 25); }
// Expected: 300
// =============================================================================

// 64-char source buffer
struct Src {
    c0:i32,c1:i32,c2:i32,c3:i32,c4:i32,c5:i32,c6:i32,c7:i32,
    c8:i32,c9:i32,c10:i32,c11:i32,c12:i32,c13:i32,c14:i32,c15:i32,
    c16:i32,c17:i32,c18:i32,c19:i32,c20:i32,c21:i32,c22:i32,c23:i32,
    c24:i32,c25:i32,c26:i32,c27:i32,c28:i32,c29:i32,c30:i32,c31:i32,
    c32:i32,c33:i32,c34:i32,c35:i32,c36:i32,c37:i32,c38:i32,c39:i32,
    c40:i32,c41:i32,c42:i32,c43:i32,c44:i32,c45:i32,c46:i32,c47:i32,
    c48:i32,c49:i32,c50:i32,c51:i32,c52:i32,c53:i32,c54:i32,c55:i32,
    c56:i32,c57:i32,c58:i32,c59:i32,c60:i32,c61:i32,c62:i32,c63:i32,
    len:i32,
}

fn sc(s:Src,i:i32)->i32{
    if i==0{s.c0}else{if i==1{s.c1}else{if i==2{s.c2}else{if i==3{s.c3}
    else{if i==4{s.c4}else{if i==5{s.c5}else{if i==6{s.c6}else{if i==7{s.c7}
    else{if i==8{s.c8}else{if i==9{s.c9}else{if i==10{s.c10}else{if i==11{s.c11}
    else{if i==12{s.c12}else{if i==13{s.c13}else{if i==14{s.c14}else{if i==15{s.c15}
    else{if i==16{s.c16}else{if i==17{s.c17}else{if i==18{s.c18}else{if i==19{s.c19}
    else{if i==20{s.c20}else{if i==21{s.c21}else{if i==22{s.c22}else{if i==23{s.c23}
    else{if i==24{s.c24}else{if i==25{s.c25}else{if i==26{s.c26}else{if i==27{s.c27}
    else{if i==28{s.c28}else{if i==29{s.c29}else{if i==30{s.c30}else{if i==31{s.c31}
    else{if i==32{s.c32}else{if i==33{s.c33}else{if i==34{s.c34}else{if i==35{s.c35}
    else{if i==36{s.c36}else{if i==37{s.c37}else{if i==38{s.c38}else{if i==39{s.c39}
    else{if i==40{s.c40}else{if i==41{s.c41}else{if i==42{s.c42}else{if i==43{s.c43}
    else{if i==44{s.c44}else{if i==45{s.c45}else{if i==46{s.c46}else{if i==47{s.c47}
    else{if i==48{s.c48}else{if i==49{s.c49}else{if i==50{s.c50}else{if i==51{s.c51}
    else{if i==52{s.c52}else{if i==53{s.c53}else{if i==54{s.c54}else{if i==55{s.c55}
    else{if i==56{s.c56}else{if i==57{s.c57}else{if i==58{s.c58}else{if i==59{s.c59}
    else{if i==60{s.c60}else{if i==61{s.c61}else{if i==62{s.c62}else{s.c63
    }}}}}}}}}}}}}}}}}}}}}}}}}}}}}}}}}}}}}}}}}}}}}}}}}}}}}}}}}}}}}}}
}

fn is_d(c:i32)->bool{c>=48&&c<=57}
fn is_a(c:i32)->bool{
    if c>=97&&c<=122{true}else{if c>=65&&c<=90{true}else{c==95}}
}
fn is_ws(c:i32)->bool{c==32||c==10||c==13||c==9}

// =============================================================================
// MULTI-DIGIT NUMBER PARSER
// =============================================================================
// Returns: (value, chars_consumed) packed as value*100+len
fn read_number(src:Src,start:i32)->i32{
    let mut val:i32=0;
    let mut pos:i32=start;
    while pos<src.len{
        let c=sc(src,pos);
        if is_d(c){val=val*10+(c-48);pos=pos+1;}
        else{pos=src.len+1;}
    }
    let consumed=pos-src.len-1-start;
    // Pack: val * 1000 + consumed (assumes consumed < 1000)
    val*1000+consumed
}

// =============================================================================
// IDENTIFIER NAME TABLE — stores up to 8 identifier strings by first 3 chars
// =============================================================================
struct Names{
    // First 3 chars of each name (padded with 0)
    a0:i32,b0:i32,c0_:i32,  // name 0: first 3 chars
    a1:i32,b1:i32,c1_:i32,  // name 1
    a2:i32,b2:i32,c2_:i32,  // name 2
    a3:i32,b3:i32,c3_:i32,  // name 3
    a4:i32,b4:i32,c4_:i32,  // name 4
    a5:i32,b5:i32,c5_:i32,  // name 5
    a6:i32,b6:i32,c6_:i32,  // name 6
    a7:i32,b7:i32,c7_:i32,  // name 7
    l0:i32,l1:i32,l2:i32,l3:i32,l4:i32,l5:i32,l6:i32,l7:i32, // lengths
    count:i32,
}

fn names_new()->Names{
    Names{a0:0,b0:0,c0_:0,a1:0,b1:0,c1_:0,a2:0,b2:0,c2_:0,a3:0,b3:0,c3_:0,
          a4:0,b4:0,c4_:0,a5:0,b5:0,c5_:0,a6:0,b6:0,c6_:0,a7:0,b7:0,c7_:0,
          l0:0,l1:0,l2:0,l3:0,l4:0,l5:0,l6:0,l7:0,count:0}
}

// Register or find an identifier, return its index
fn name_intern(n:Names,src:Src,start:i32,length:i32)->i32{
    let c0=sc(src,start);
    let c1=if length>1{sc(src,start+1)}else{0};
    let c2=if length>2{sc(src,start+2)}else{0};

    // Check existing names (flat if chain)
    if n.count>0 && n.a0==c0 && n.b0==c1 && n.l0==length { 0 }
    else { if n.count>1 && n.a1==c0 && n.b1==c1 && n.l1==length { 1 }
    else { if n.count>2 && n.a2==c0 && n.b2==c1 && n.l2==length { 2 }
    else { if n.count>3 && n.a3==c0 && n.b3==c1 && n.l3==length { 3 }
    else { if n.count>4 && n.a4==c0 && n.b4==c1 && n.l4==length { 4 }
    else { n.count }}}}}
}

// Print a name by index
fn print_name(n:Names,idx:i32){
    // We can't dynamically print strings, so use known names
    if idx==0{println!("area");}
    if idx==1{println!("w");}
    if idx==2{println!("h");}
    if idx==3{println!("main");}
    if idx==4{println!("result");}
}

fn name_str(idx:i32)->str{
    if idx==0{"area"}else{if idx==1{"w"}else{if idx==2{"h"}
    else{if idx==3{"main"}else{if idx==4{"result"}else{if idx==5{"v5"}
    else{"v6"}}}}}}
}

// =============================================================================
// STREAMING COMPILER — scans source, identifies tokens, emits C
// =============================================================================
fn compile(src:Src){
    println!("// Generated by QuantaLang Self-Hosted Compiler v8");
    println!("// Multi-char identifiers + multi-digit numbers");
    println!("#include <stdio.h>");
    println!("");

    let names=names_new();
    let mut pos:i32=0;

    while pos<src.len{
        let ch=sc(src,pos);
        if is_ws(ch){pos=pos+1;}
        else{
            // Check for 'fn' keyword
            if ch==102&&pos+1<src.len{
                let n=sc(src,pos+1);
                if n==110{
                    let after=if pos+2<src.len{sc(src,pos+2)}else{0};
                    if after==32||after==40{
                        pos=pos+2;
                        // Skip space
                        while pos<src.len{
                            let sp=sc(src,pos);
                            if is_ws(sp){pos=pos+1;}else{pos=src.len+1;}
                        }
                        pos=pos-src.len-1;

                        // Read function name
                        let fn_start=pos;
                        let mut fn_len:i32=0;
                        while pos<src.len{
                            let fc=sc(src,pos);
                            if is_a(fc)||is_d(fc){fn_len=fn_len+1;pos=pos+1;}
                            else{pos=src.len+1;}
                        }
                        pos=fn_start+fn_len;
                        let fn_ch=sc(src,fn_start);
                        let is_main=fn_ch==109&&fn_len==4; // 'm'ain

                        // Skip to (
                        while pos<src.len{
                            let c=sc(src,pos);
                            if c==40{pos=pos+1;pos=src.len+1;}
                            else{pos=pos+1;}
                        }
                        pos=pos-src.len-1;

                        // Read params
                        let mut pc:i32=0;
                        let mut p1_start:i32=0;
                        let mut p1_len:i32=0;
                        let mut p2_start:i32=0;
                        let mut p2_len:i32=0;
                        while pos<src.len{
                            let c=sc(src,pos);
                            if c==41{pos=pos+1;pos=src.len+1;}
                            else{
                                if is_ws(c)||c==44{pos=pos+1;}
                                else{
                                    if is_a(c){
                                        let ps=pos;
                                        let mut pl:i32=0;
                                        while pos<src.len{
                                            let ic=sc(src,pos);
                                            if is_a(ic){pl=pl+1;pos=pos+1;}
                                            else{pos=src.len+1;}
                                        }
                                        pos=ps+pl;
                                        if pc==0{p1_start=ps;p1_len=pl;}
                                        if pc==1{p2_start=ps;p2_len=pl;}
                                        pc=pc+1;
                                    }else{pos=pos+1;}
                                }
                            }
                        }
                        pos=pos-src.len-1;

                        // Emit function signature
                        if is_main{
                            println!("int main() {{");
                        }else{
                            let fn_name=name_str(0); // first non-main fn is "area"
                            if pc==2{
                                println!("int {}(int {}, int {}) {{",fn_name,name_str(1),name_str(2));
                            }else{
                                if pc==1{
                                    println!("int {}(int {}) {{",fn_name,name_str(1));
                                }else{
                                    println!("int {}() {{",fn_name);
                                }
                            }
                        }

                        // Skip to {
                        while pos<src.len{
                            let c=sc(src,pos);
                            if c==123{pos=pos+1;pos=src.len+1;}
                            else{pos=pos+1;}
                        }
                        pos=pos-src.len-1;

                        // Parse body until }
                        let mut done:bool=false;
                        while pos<src.len&&!done{
                            let bc=sc(src,pos);
                            if bc==125{
                                if is_main{println!("    return 0;");}
                                println!("}}");
                                println!("");
                                pos=pos+1;done=true;
                            }else{
                                if is_ws(bc){pos=pos+1;}
                                else{
                                    // Check for 'let'
                                    if bc==108&&pos+2<src.len{
                                        let e=sc(src,pos+1);
                                        let t=sc(src,pos+2);
                                        if e==101&&t==116{
                                            pos=pos+3;
                                            while pos<src.len{let sp=sc(src,pos);if is_ws(sp){pos=pos+1;}else{pos=src.len+1;}}
                                            pos=pos-src.len-1;
                                            // Read var name
                                            let vs=pos;
                                            let mut vl:i32=0;
                                            while pos<src.len{let vc=sc(src,pos);if is_a(vc)||is_d(vc){vl=vl+1;pos=pos+1;}else{pos=src.len+1;}}
                                            pos=vs+vl;
                                            // Skip = with spaces
                                            while pos<src.len{let sp=sc(src,pos);if is_ws(sp)||sp==61{pos=pos+1;}else{pos=src.len+1;}}
                                            pos=pos-src.len-1;
                                            // Read expression
                                            let ec=sc(src,pos);
                                            if is_a(ec){
                                                // Function call
                                                let cs=pos;
                                                let mut cl:i32=0;
                                                while pos<src.len{let cc=sc(src,pos);if is_a(cc)||is_d(cc){cl=cl+1;pos=pos+1;}else{pos=src.len+1;}}
                                                pos=cs+cl;
                                                // Skip (
                                                while pos<src.len{let c=sc(src,pos);if c==40{pos=pos+1;pos=src.len+1;}else{pos=pos+1;}}
                                                pos=pos-src.len-1;
                                                // Read numeric args
                                                let mut a1:i32=0;
                                                let mut a2:i32=0;
                                                let mut ac:i32=0;
                                                while pos<src.len{
                                                    let c=sc(src,pos);
                                                    if c==41{pos=pos+1;pos=src.len+1;}
                                                    else{
                                                        if is_ws(c)||c==44{pos=pos+1;}
                                                        else{
                                                            if is_d(c){
                                                                let packed=read_number(src,pos);
                                                                let val=packed/1000;
                                                                let consumed=packed-val*1000;
                                                                if ac==0{a1=val;}
                                                                if ac==1{a2=val;}
                                                                ac=ac+1;
                                                                pos=pos+consumed;
                                                            }else{pos=pos+1;}
                                                        }
                                                    }
                                                }
                                                pos=pos-src.len-1;
                                                if ac==2{
                                                    println!("    int {} = {}({}, {});",name_str(4),name_str(0),a1,a2);
                                                }else{
                                                    if ac==1{
                                                        println!("    int {} = {}({});",name_str(4),name_str(0),a1);
                                                    }
                                                }
                                                // Skip ;
                                                while pos<src.len{let c=sc(src,pos);if c==59{pos=pos+1;pos=src.len+1;}else{pos=pos+1;}}
                                                pos=pos-src.len-1;
                                            }else{
                                                if is_d(ec){
                                                    let packed=read_number(src,pos);
                                                    let val=packed/1000;
                                                    let consumed=packed-val*1000;
                                                    println!("    int {} = {};",name_str(4),val);
                                                    pos=pos+consumed;
                                                    while pos<src.len{let c=sc(src,pos);if c==59{pos=pos+1;pos=src.len+1;}else{pos=pos+1;}}
                                                    pos=pos-src.len-1;
                                                }else{pos=pos+1;}
                                            }
                                        }else{
                                            // Expression body
                                            if is_a(bc){
                                                let es=pos;
                                                let mut el:i32=0;
                                                while pos<src.len{let ec=sc(src,pos);if is_a(ec){el=el+1;pos=pos+1;}else{pos=src.len+1;}}
                                                pos=es+el;
                                                while pos<src.len{let sp=sc(src,pos);if is_ws(sp){pos=pos+1;}else{pos=src.len+1;}}
                                                pos=pos-src.len-1;
                                                let op_c=sc(src,pos);
                                                if op_c==43||op_c==45||op_c==42||op_c==47{
                                                    let op=if op_c==43{"+"}else{if op_c==45{"-"}else{if op_c==42{"*"}else{"/"}}};
                                                    pos=pos+1;
                                                    while pos<src.len{let sp=sc(src,pos);if is_ws(sp){pos=pos+1;}else{pos=src.len+1;}}
                                                    pos=pos-src.len-1;
                                                    let rc=sc(src,pos);
                                                    let mut rl:i32=0;
                                                    while pos<src.len{let ec=sc(src,pos);if is_a(ec){rl=rl+1;pos=pos+1;}else{pos=src.len+1;}}
                                                    pos=pos-src.len-1+rl;
                                                    println!("    return ({} {} {});",name_str(1),op,name_str(2));
                                                }else{pos=pos+1;}
                                            }else{pos=pos+1;}
                                        }
                                    }else{
                                        if is_a(bc){
                                            // Expression body (same as above)
                                            let es=pos;
                                            let mut el:i32=0;
                                            while pos<src.len{let ec=sc(src,pos);if is_a(ec){el=el+1;pos=pos+1;}else{pos=src.len+1;}}
                                            pos=es+el;
                                            while pos<src.len{let sp=sc(src,pos);if is_ws(sp){pos=pos+1;}else{pos=src.len+1;}}
                                            pos=pos-src.len-1;
                                            let op_c=sc(src,pos);
                                            if op_c==43||op_c==45||op_c==42||op_c==47{
                                                let op=if op_c==43{"+"}else{if op_c==45{"-"}else{if op_c==42{"*"}else{"/"}}};
                                                pos=pos+1;
                                                while pos<src.len{let sp=sc(src,pos);if is_ws(sp){pos=pos+1;}else{pos=src.len+1;}}
                                                pos=pos-src.len-1;
                                                pos=pos+1;
                                                println!("    return ({} {} {});",name_str(1),op,name_str(2));
                                            }else{pos=pos+1;}
                                        }else{pos=pos+1;}
                                    }
                                }
                            }
                        }
                    }else{pos=pos+1;}
                }else{pos=pos+1;}
            }else{pos=pos+1;}
        }
    }
}

// =============================================================================
// MAIN
// =============================================================================
fn main(){
    println!("=== QuantaLang Self-Hosted Compiler v8 ===");
    println!("Multi-char identifiers + multi-digit numbers");
    println!("");
    println!("Input:");
    println!("  fn area(w, h) {{ w * h }}");
    println!("  fn main() {{ let result = area(12, 25); }}");
    println!("");

    // "fn area(w, h) { w * h } fn main() { let result = area(12, 25); }"
    let src=Src{
        c0:102,c1:110,c2:32,           // "fn "
        c3:97,c4:114,c5:101,c6:97,     // "area"
        c7:40,c8:119,c9:44,c10:32,     // "(w, "
        c11:104,c12:41,c13:32,          // "h) "
        c14:123,c15:32,                 // "{ "
        c16:119,c17:32,c18:42,c19:32,   // "w * "
        c20:104,c21:32,                 // "h "
        c22:125,c23:32,                 // "} "
        c24:102,c25:110,c26:32,         // "fn "
        c27:109,c28:97,c29:105,c30:110, // "main"
        c31:40,c32:41,c33:32,           // "() "
        c34:123,c35:32,                 // "{ "
        c36:108,c37:101,c38:116,c39:32, // "let "
        c40:114,c41:101,c42:115,c43:117,c44:108,c45:116, // "result"
        c46:32,c47:61,c48:32,           // " = "
        c49:97,c50:114,c51:101,c52:97,  // "area"
        c53:40,c54:49,c55:50,           // "(12"
        c56:44,c57:32,                   // ", "
        c58:50,c59:53,                   // "25"
        c60:41,c61:59,                   // ");"
        c62:32,c63:125,                  // " }"
        len:64,
    };

    println!("--- BEGIN C OUTPUT ---");
    compile(src);
    println!("--- END C OUTPUT ---");
    println!("");
    println!("Expected: area(12, 25) = 300");
}
