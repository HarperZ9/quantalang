// =============================================================================
// Self-Hosted Compiler v4 — Token-Driven Parser
// =============================================================================
// The first version where the parser READS tokens from the lexer output
// and builds the AST dynamically. Previous versions hardcoded the AST.
//
// Pipeline: Source chars → Lexer → Tokens → Parser → AST → Type Check → C
//
// Compiles: "let x = 3 + 4; let y = x * 2;"
// Output: int x = (3 + 4); int y = (x * 2);
// =============================================================================

// Token kinds: 0=NUM 1=IDENT 2=PLUS 3=MINUS 4=STAR 5=SLASH
// 11=SEMI 12=EQUALS 13=EOF 21=KW_LET
// AST kinds: 0=INT_LIT 1=IDENT_REF 2=BINOP 3=LET_STMT

// --- Compact token buffer (24 tokens) ---
struct Toks {
    k0:i32,k1:i32,k2:i32,k3:i32,k4:i32,k5:i32,k6:i32,k7:i32,
    k8:i32,k9:i32,k10:i32,k11:i32,k12:i32,k13:i32,k14:i32,k15:i32,
    k16:i32,k17:i32,k18:i32,k19:i32,k20:i32,k21:i32,k22:i32,k23:i32,
    v0:i32,v1:i32,v2:i32,v3:i32,v4:i32,v5:i32,v6:i32,v7:i32,
    v8:i32,v9:i32,v10:i32,v11:i32,v12:i32,v13:i32,v14:i32,v15:i32,
    v16:i32,v17:i32,v18:i32,v19:i32,v20:i32,v21:i32,v22:i32,v23:i32,
    count:i32,
}

fn toks_new() -> Toks {
    Toks {
        k0:0,k1:0,k2:0,k3:0,k4:0,k5:0,k6:0,k7:0,
        k8:0,k9:0,k10:0,k11:0,k12:0,k13:0,k14:0,k15:0,
        k16:0,k17:0,k18:0,k19:0,k20:0,k21:0,k22:0,k23:0,
        v0:0,v1:0,v2:0,v3:0,v4:0,v5:0,v6:0,v7:0,
        v8:0,v9:0,v10:0,v11:0,v12:0,v13:0,v14:0,v15:0,
        v16:0,v17:0,v18:0,v19:0,v20:0,v21:0,v22:0,v23:0,
        count:0,
    }
}

fn tg_k(t:Toks,i:i32)->i32{
    if i==0{t.k0}else{if i==1{t.k1}else{if i==2{t.k2}else{if i==3{t.k3}
    else{if i==4{t.k4}else{if i==5{t.k5}else{if i==6{t.k6}else{if i==7{t.k7}
    else{if i==8{t.k8}else{if i==9{t.k9}else{if i==10{t.k10}else{if i==11{t.k11}
    else{if i==12{t.k12}else{if i==13{t.k13}else{if i==14{t.k14}else{if i==15{t.k15}
    else{if i==16{t.k16}else{if i==17{t.k17}else{if i==18{t.k18}else{if i==19{t.k19}
    else{if i==20{t.k20}else{if i==21{t.k21}else{if i==22{t.k22}else{t.k23
    }}}}}}}}}}}}}}}}}}}}}}}
}
fn tg_v(t:Toks,i:i32)->i32{
    if i==0{t.v0}else{if i==1{t.v1}else{if i==2{t.v2}else{if i==3{t.v3}
    else{if i==4{t.v4}else{if i==5{t.v5}else{if i==6{t.v6}else{if i==7{t.v7}
    else{if i==8{t.v8}else{if i==9{t.v9}else{if i==10{t.v10}else{if i==11{t.v11}
    else{if i==12{t.v12}else{if i==13{t.v13}else{if i==14{t.v14}else{if i==15{t.v15}
    else{if i==16{t.v16}else{if i==17{t.v17}else{if i==18{t.v18}else{if i==19{t.v19}
    else{if i==20{t.v20}else{if i==21{t.v21}else{if i==22{t.v22}else{t.v23
    }}}}}}}}}}}}}}}}}}}}}}}
}
fn ts(t:Toks,i:i32,k:i32,v:i32)->Toks{
    let mut o=t;
    if i==0{o.k0=k;o.v0=v;}
    if i==1{o.k1=k;o.v1=v;}
    if i==2{o.k2=k;o.v2=v;}
    if i==3{o.k3=k;o.v3=v;}
    if i==4{o.k4=k;o.v4=v;}
    if i==5{o.k5=k;o.v5=v;}
    if i==6{o.k6=k;o.v6=v;}
    if i==7{o.k7=k;o.v7=v;}
    if i==8{o.k8=k;o.v8=v;}
    if i==9{o.k9=k;o.v9=v;}
    if i==10{o.k10=k;o.v10=v;}
    if i==11{o.k11=k;o.v11=v;}
    if i==12{o.k12=k;o.v12=v;}
    if i==13{o.k13=k;o.v13=v;}
    if i==14{o.k14=k;o.v14=v;}
    if i==15{o.k15=k;o.v15=v;}
    if i==16{o.k16=k;o.v16=v;}
    if i==17{o.k17=k;o.v17=v;}
    if i==18{o.k18=k;o.v18=v;}
    if i==19{o.k19=k;o.v19=v;}
    if i==20{o.k20=k;o.v20=v;}
    if i==21{o.k21=k;o.v21=v;}
    if i==22{o.k22=k;o.v22=v;}
    if i==23{o.k23=k;o.v23=v;}
    o.count=if i>=o.count{i+1}else{o.count};
    o
}

// --- AST (16 nodes with kind, val, left, right) ---
struct AST {
    k0:i32,k1:i32,k2:i32,k3:i32,k4:i32,k5:i32,k6:i32,k7:i32,
    k8:i32,k9:i32,k10:i32,k11:i32,k12:i32,k13:i32,k14:i32,k15:i32,
    v0:i32,v1:i32,v2:i32,v3:i32,v4:i32,v5:i32,v6:i32,v7:i32,
    v8:i32,v9:i32,v10:i32,v11:i32,v12:i32,v13:i32,v14:i32,v15:i32,
    l0:i32,l1:i32,l2:i32,l3:i32,l4:i32,l5:i32,l6:i32,l7:i32,
    l8:i32,l9:i32,l10:i32,l11:i32,l12:i32,l13:i32,l14:i32,l15:i32,
    r0:i32,r1:i32,r2:i32,r3:i32,r4:i32,r5:i32,r6:i32,r7:i32,
    r8:i32,r9:i32,r10:i32,r11:i32,r12:i32,r13:i32,r14:i32,r15:i32,
    count:i32,
}
fn ast_new()->AST{
    AST{k0:0,k1:0,k2:0,k3:0,k4:0,k5:0,k6:0,k7:0,
        k8:0,k9:0,k10:0,k11:0,k12:0,k13:0,k14:0,k15:0,
        v0:0,v1:0,v2:0,v3:0,v4:0,v5:0,v6:0,v7:0,
        v8:0,v9:0,v10:0,v11:0,v12:0,v13:0,v14:0,v15:0,
        l0:-1,l1:-1,l2:-1,l3:-1,l4:-1,l5:-1,l6:-1,l7:-1,
        l8:-1,l9:-1,l10:-1,l11:-1,l12:-1,l13:-1,l14:-1,l15:-1,
        r0:-1,r1:-1,r2:-1,r3:-1,r4:-1,r5:-1,r6:-1,r7:-1,
        r8:-1,r9:-1,r10:-1,r11:-1,r12:-1,r13:-1,r14:-1,r15:-1,
        count:0}
}
fn ag_k(a:AST,i:i32)->i32{
    if i==0{a.k0}else{if i==1{a.k1}else{if i==2{a.k2}else{if i==3{a.k3}
    else{if i==4{a.k4}else{if i==5{a.k5}else{if i==6{a.k6}else{if i==7{a.k7}
    else{if i==8{a.k8}else{if i==9{a.k9}else{if i==10{a.k10}else{if i==11{a.k11}
    else{if i==12{a.k12}else{if i==13{a.k13}else{if i==14{a.k14}else{a.k15
    }}}}}}}}}}}}}}}
}
fn ag_v(a:AST,i:i32)->i32{
    if i==0{a.v0}else{if i==1{a.v1}else{if i==2{a.v2}else{if i==3{a.v3}
    else{if i==4{a.v4}else{if i==5{a.v5}else{if i==6{a.v6}else{if i==7{a.v7}
    else{if i==8{a.v8}else{if i==9{a.v9}else{if i==10{a.v10}else{if i==11{a.v11}
    else{if i==12{a.v12}else{if i==13{a.v13}else{if i==14{a.v14}else{a.v15
    }}}}}}}}}}}}}}}
}
fn ag_l(a:AST,i:i32)->i32{
    if i==0{a.l0}else{if i==1{a.l1}else{if i==2{a.l2}else{if i==3{a.l3}
    else{if i==4{a.l4}else{if i==5{a.l5}else{if i==6{a.l6}else{if i==7{a.l7}
    else{if i==8{a.l8}else{if i==9{a.l9}else{if i==10{a.l10}else{if i==11{a.l11}
    else{if i==12{a.l12}else{if i==13{a.l13}else{if i==14{a.l14}else{a.l15
    }}}}}}}}}}}}}}}
}
fn ag_r(a:AST,i:i32)->i32{
    if i==0{a.r0}else{if i==1{a.r1}else{if i==2{a.r2}else{if i==3{a.r3}
    else{if i==4{a.r4}else{if i==5{a.r5}else{if i==6{a.r6}else{if i==7{a.r7}
    else{if i==8{a.r8}else{if i==9{a.r9}else{if i==10{a.r10}else{if i==11{a.r11}
    else{if i==12{a.r12}else{if i==13{a.r13}else{if i==14{a.r14}else{a.r15
    }}}}}}}}}}}}}}}
}
fn as_n(a:AST,i:i32,k:i32,v:i32,l:i32,r:i32)->AST{
    let mut o=a;
    if i==0{o.k0=k;o.v0=v;o.l0=l;o.r0=r;}
    if i==1{o.k1=k;o.v1=v;o.l1=l;o.r1=r;}
    if i==2{o.k2=k;o.v2=v;o.l2=l;o.r2=r;}
    if i==3{o.k3=k;o.v3=v;o.l3=l;o.r3=r;}
    if i==4{o.k4=k;o.v4=v;o.l4=l;o.r4=r;}
    if i==5{o.k5=k;o.v5=v;o.l5=l;o.r5=r;}
    if i==6{o.k6=k;o.v6=v;o.l6=l;o.r6=r;}
    if i==7{o.k7=k;o.v7=v;o.l7=l;o.r7=r;}
    if i==8{o.k8=k;o.v8=v;o.l8=l;o.r8=r;}
    if i==9{o.k9=k;o.v9=v;o.l9=l;o.r9=r;}
    if i==10{o.k10=k;o.v10=v;o.l10=l;o.r10=r;}
    if i==11{o.k11=k;o.v11=v;o.l11=l;o.r11=r;}
    if i==12{o.k12=k;o.v12=v;o.l12=l;o.r12=r;}
    if i==13{o.k13=k;o.v13=v;o.l13=l;o.r13=r;}
    if i==14{o.k14=k;o.v14=v;o.l14=l;o.r14=r;}
    if i==15{o.k15=k;o.v15=v;o.l15=l;o.r15=r;}
    o.count=if i>=o.count{i+1}else{o.count};
    o
}

// =============================================================================
// LEXER — tokenizes "let x = 3 + 4; let y = x * 2;"
// =============================================================================
fn is_d(c:i32)->bool{c>=48&&c<=57}
fn is_a(c:i32)->bool{if c>=97&&c<=122{true}else{if c>=65&&c<=90{true}else{c==95}}}

// Source buffer: "let x = 3 + 4; let y = x * 2;"
struct Src{
    c0:i32,c1:i32,c2:i32,c3:i32,c4:i32,c5:i32,c6:i32,c7:i32,
    c8:i32,c9:i32,c10:i32,c11:i32,c12:i32,c13:i32,c14:i32,c15:i32,
    c16:i32,c17:i32,c18:i32,c19:i32,c20:i32,c21:i32,c22:i32,c23:i32,
    c24:i32,c25:i32,c26:i32,c27:i32,c28:i32,c29:i32,
    len:i32,
}
fn sg(s:Src,i:i32)->i32{
    if i==0{s.c0}else{if i==1{s.c1}else{if i==2{s.c2}else{if i==3{s.c3}
    else{if i==4{s.c4}else{if i==5{s.c5}else{if i==6{s.c6}else{if i==7{s.c7}
    else{if i==8{s.c8}else{if i==9{s.c9}else{if i==10{s.c10}else{if i==11{s.c11}
    else{if i==12{s.c12}else{if i==13{s.c13}else{if i==14{s.c14}else{if i==15{s.c15}
    else{if i==16{s.c16}else{if i==17{s.c17}else{if i==18{s.c18}else{if i==19{s.c19}
    else{if i==20{s.c20}else{if i==21{s.c21}else{if i==22{s.c22}else{if i==23{s.c23}
    else{if i==24{s.c24}else{if i==25{s.c25}else{if i==26{s.c26}else{if i==27{s.c27}
    else{if i==28{s.c28}else{s.c29}}}}}}}}}}}}}}}}}}}}}}}}}}}}}
}

fn lex() -> Toks {
    // "let x = 3 + 4; let y = x * 2;"
    // l=108 e=101 t=116 space=32 x=120 space=32 ==61 space=32
    // 3=51 space=32 +=43 space=32 4=52 ;=59 space=32
    // l=108 e=101 t=116 space=32 y=121 space=32 ==61 space=32
    // x=120 space=32 *=42 space=32 2=50 ;=59
    let src = Src{
        c0:108,c1:101,c2:116,c3:32,c4:120,c5:32,c6:61,c7:32,
        c8:51,c9:32,c10:43,c11:32,c12:52,c13:59,c14:32,
        c15:108,c16:101,c17:116,c18:32,c19:121,c20:32,c21:61,c22:32,
        c23:120,c24:32,c25:42,c26:32,c27:50,c28:59,c29:0,
        len:29,
    };

    let mut t = toks_new();
    let mut pos:i32 = 0;
    let mut ti:i32 = 0;

    while pos < src.len {
        let ch = sg(src, pos);
        if ch==32||ch==9||ch==10{
            pos=pos+1;
        } else {
            if is_d(ch) {
                let val = ch - 48;
                t = ts(t, ti, 0, val);
                ti=ti+1; pos=pos+1;
            } else {
                if is_a(ch) {
                    // Check for "let" keyword: 108,101,116
                    if ch==108 && pos+2<src.len {
                        let c1=sg(src,pos+1);
                        let c2=sg(src,pos+2);
                        if c1==101 && c2==116 {
                            t=ts(t,ti,21,0); ti=ti+1; pos=pos+3;
                        } else {
                            // Single letter ident: map x=0, y=1
                            let idx = if ch==120{0}else{if ch==121{1}else{2}};
                            t=ts(t,ti,1,idx); ti=ti+1; pos=pos+1;
                        }
                    } else {
                        let idx = if ch==120{0}else{if ch==121{1}else{2}};
                        t=ts(t,ti,1,idx); ti=ti+1; pos=pos+1;
                    }
                } else {
                    // Operators and punctuation
                    let kind = if ch==43{2}else{if ch==45{3}else{if ch==42{4}
                    else{if ch==47{5}else{if ch==59{11}else{if ch==61{12}else{99}}}}}};
                    t=ts(t,ti,kind,ch); ti=ti+1; pos=pos+1;
                }
            }
        }
    }
    t=ts(t,ti,13,0); // EOF
    t
}

// =============================================================================
// PARSER — reads tokens and builds AST
// =============================================================================
// Parser state: current token position
struct Parser {
    pos: i32,
}

// Parse a primary expression (number or identifier)
fn parse_primary(toks: Toks, p: Parser, ast: AST) -> AST {
    let kind = tg_k(toks, p.pos);
    let val = tg_v(toks, p.pos);
    let ni = ast.count;
    if kind == 0 {
        // Number literal
        as_n(ast, ni, 0, val, -1, -1)
    } else {
        if kind == 1 {
            // Identifier
            as_n(ast, ni, 1, val, -1, -1)
        } else {
            ast // error: unexpected token
        }
    }
}

// Parse a binary expression: primary (op primary)?
fn parse_expr(toks: Toks, pos: i32, ast: AST) -> AST {
    // Parse left operand
    let lk = tg_k(toks, pos);
    let lv = tg_v(toks, pos);
    let li = ast.count;
    let mut a = ast;
    let left_kind = if lk == 0 { 0 } else { 1 };
    a = as_n(a, li, left_kind, lv, -1, -1);

    // Check for binary operator
    let op_kind = tg_k(toks, pos + 1);
    if op_kind >= 2 && op_kind <= 5 {
        // Parse right operand
        let rk = tg_k(toks, pos + 2);
        let rv = tg_v(toks, pos + 2);
        let ri = a.count;
        let right_kind = if rk == 0 { 0 } else { 1 };
        a = as_n(a, ri, right_kind, rv, -1, -1);

        // Create binary op node
        let op_ascii = if op_kind==2{43}else{if op_kind==3{45}
                       else{if op_kind==4{42}else{47}}};
        let bi = a.count;
        a = as_n(a, bi, 2, op_ascii, li, ri);
        a
    } else {
        a
    }
}

// Parse a let statement: KW_LET IDENT EQUALS expr SEMI
fn parse_let(toks: Toks, pos: i32, ast: AST) -> AST {
    // pos+0 = LET, pos+1 = IDENT(var), pos+2 = EQUALS
    let var_idx = tg_v(toks, pos + 1);

    // Parse the initializer expression starting at pos+3
    let a = parse_expr(toks, pos + 3, ast);

    // The expression's root is the last node added
    let expr_root = a.count - 1;

    // Create let statement node
    let si = a.count;
    as_n(a, si, 3, var_idx, expr_root, -1)
}

// Parse the full program: sequence of let statements
fn parse_program(toks: Toks) -> AST {
    let mut ast = ast_new();
    let mut pos: i32 = 0;

    while pos < toks.count {
        let kind = tg_k(toks, pos);
        if kind == 21 {
            // LET statement
            // Count tokens: LET IDENT EQ expr(1 or 3 tokens) SEMI
            let expr_start = pos + 3;
            let after_expr_kind = tg_k(toks, expr_start + 1);

            if after_expr_kind >= 2 && after_expr_kind <= 5 {
                // Binary expression: 3 tokens (left op right)
                ast = parse_let(toks, pos, ast);
                pos = pos + 7; // LET IDENT EQ left OP right SEMI
            } else {
                // Simple expression: 1 token
                ast = parse_let(toks, pos, ast);
                pos = pos + 5; // LET IDENT EQ value SEMI
            }
        } else {
            if kind == 13 {
                pos = toks.count; // EOF — stop
            } else {
                pos = pos + 1; // skip unknown
            }
        }
    }
    ast
}

// =============================================================================
// C CODE GENERATOR — reads AST and emits C
// =============================================================================
fn var_nm(i:i32)->str{if i==0{"x"}else{if i==1{"y"}else{"z"}}}
fn op_ch(c:i32)->str{if c==43{"+"}else{if c==45{"-"}else{if c==42{"*"}else{"/"}}}}

fn codegen_v4(ast: AST) {
    println!("// Generated by QuantaLang Self-Hosted Compiler v4");
    println!("// First token-driven parser: source → lex → parse → AST → C");
    println!("#include <stdio.h>");
    println!("int main() {{");

    let mut i: i32 = 0;
    while i < ast.count {
        let k = ag_k(ast, i);
        if k == 3 {
            // LET statement
            let var = ag_v(ast, i);
            let init = ag_l(ast, i);
            let ik = ag_k(ast, init);

            if ik == 0 {
                // Simple int literal
                println!("    int {} = {};", var_nm(var), ag_v(ast, init));
            }
            if ik == 1 {
                // Simple ident
                println!("    int {} = {};", var_nm(var), var_nm(ag_v(ast, init)));
            }
            if ik == 2 {
                // Binary expression
                let left = ag_l(ast, init);
                let right = ag_r(ast, init);
                let lk = ag_k(ast, left);
                let rk = ag_k(ast, right);
                let op = op_ch(ag_v(ast, init));

                if lk==0 && rk==0 {
                    println!("    int {} = ({} {} {});",
                        var_nm(var), ag_v(ast,left), op, ag_v(ast,right));
                }
                if lk==1 && rk==0 {
                    println!("    int {} = ({} {} {});",
                        var_nm(var), var_nm(ag_v(ast,left)), op, ag_v(ast,right));
                }
                if lk==0 && rk==1 {
                    println!("    int {} = ({} {} {});",
                        var_nm(var), ag_v(ast,left), op, var_nm(ag_v(ast,right)));
                }
                if lk==1 && rk==1 {
                    println!("    int {} = ({} {} {});",
                        var_nm(var), var_nm(ag_v(ast,left)), op, var_nm(ag_v(ast,right)));
                }
            }
        }
        i = i + 1;
    }

    println!("    printf(\"x = %d, y = %d\\n\", x, y);");
    println!("    return 0;");
    println!("}}");
}

// =============================================================================
// MAIN
// =============================================================================
fn main() {
    println!("=== QuantaLang Self-Hosted Compiler v4 ===");
    println!("FIRST TOKEN-DRIVEN PARSER");
    println!("Source: let x = 3 + 4; let y = x * 2;");
    println!("");

    // Stage 1: Lex
    println!("[1/4] Lexing...");
    let toks = lex();
    println!("  {} tokens", toks.count);

    // Print tokens
    let mut i:i32=0;
    while i<toks.count{
        let k=tg_k(toks,i);
        let v=tg_v(toks,i);
        let name = if k==0{"NUM"}else{if k==1{"ID"}else{if k==2{"+"}
        else{if k==4{"*"}else{if k==11{";"}else{if k==12{"="}
        else{if k==21{"LET"}else{if k==13{"EOF"}else{"?"}}}}}}}};
        if k==0{println!("  [{}] {} ({})",i,name,v);}
        else{if k==1{println!("  [{}] {} ({})",i,name,var_nm(v));}
        else{println!("  [{}] {}",i,name);}}
        i=i+1;
    }

    // Stage 2: Parse
    println!("");
    println!("[2/4] Parsing tokens into AST...");
    let ast = parse_program(toks);
    println!("  {} AST nodes", ast.count);

    // Print AST
    let mut j:i32=0;
    while j<ast.count{
        let k=ag_k(ast,j);
        let v=ag_v(ast,j);
        let l=ag_l(ast,j);
        let r=ag_r(ast,j);
        let name=if k==0{"INT"}else{if k==1{"ID"}else{if k==2{"BINOP"}
        else{if k==3{"LET"}else{"?"}}}};
        println!("  [{}] {} val={} left={} right={}",j,name,v,l,r);
        j=j+1;
    }

    // Stage 3: Type check
    println!("");
    println!("[3/4] Type checking...");
    let mut errors:i32=0;
    let mut tc:i32=0;
    while tc<ast.count{
        let k=ag_k(ast,tc);
        if k==2{if ag_l(ast,tc)<0||ag_r(ast,tc)<0{errors=errors+1;}}
        if k==3{if ag_l(ast,tc)<0{errors=errors+1;}}
        tc=tc+1;
    }
    if errors==0{println!("  PASSED");}
    else{println!("  {} errors",errors);}

    // Stage 4: Codegen
    println!("");
    println!("[4/4] Generating C...");
    println!("");
    println!("--- BEGIN C OUTPUT ---");
    codegen_v4(ast);
    println!("--- END C OUTPUT ---");
    println!("");
    println!("Expected: x = 7, y = 14");
}
