// =============================================================================
// Self-hosted Lexer in QuantaLang
// =============================================================================
// A minimal lexer (tokenizer) written in QuantaLang itself.
// Demonstrates: structs, impl blocks, enums, match, while loops,
// state-machine character classification, and method chaining.
//
// Since QuantaLang doesn't yet have string indexing, we work with
// arrays of i32 character codes and classify them via ASCII ranges.
// =============================================================================

// ---------------------------------------------------------------------------
// Token kind constants (using i32 since we need simple integer comparison)
// ---------------------------------------------------------------------------
//   0 = NUMBER      (sequence of digits)
//   1 = IDENT       (sequence of letters/underscores)
//   2 = PLUS        (+)
//   3 = MINUS       (-)
//   4 = STAR        (*)
//   5 = SLASH       (/)
//   6 = LPAREN      (()
//   7 = RPAREN      ())
//   8 = WHITESPACE  (space/tab)
//   9 = EOF         (end of input)
//  10 = UNKNOWN     (unrecognised character)

// ---------------------------------------------------------------------------
// Token struct: records the kind and position of each token
// ---------------------------------------------------------------------------
struct Token {
    kind: i32,
    start: i32,
    length: i32,
}

// ---------------------------------------------------------------------------
// Lexer struct: holds position and the length of the input
// ---------------------------------------------------------------------------
struct Lexer {
    pos: i32,
    len: i32,
}

impl Lexer {
    fn at_end(self) -> bool {
        self.pos >= self.len
    }
}

// ---------------------------------------------------------------------------
// Character classification helpers (free functions, ASCII code ranges)
// ---------------------------------------------------------------------------
fn is_digit(ch: i32) -> bool {
    ch >= 48 && ch <= 57
}

fn is_alpha(ch: i32) -> bool {
    if ch >= 65 && ch <= 90 {
        true
    } else {
        if ch >= 97 && ch <= 122 {
            true
        } else {
            ch == 95
        }
    }
}

fn is_whitespace(ch: i32) -> bool {
    ch == 32 || ch == 9
}

// ---------------------------------------------------------------------------
// Token kind name lookup (returns a string description)
// ---------------------------------------------------------------------------
fn kind_name(kind: i32) -> str {
    if kind == 0 {
        "NUMBER"
    } else {
        if kind == 1 {
            "IDENT"
        } else {
            if kind == 2 {
                "PLUS"
            } else {
                if kind == 3 {
                    "MINUS"
                } else {
                    if kind == 4 {
                        "STAR"
                    } else {
                        if kind == 5 {
                            "SLASH"
                        } else {
                            if kind == 6 {
                                "LPAREN"
                            } else {
                                if kind == 7 {
                                    "RPAREN"
                                } else {
                                    if kind == 8 {
                                        "WHITESPACE"
                                    } else {
                                        if kind == 9 {
                                            "EOF"
                                        } else {
                                            "UNKNOWN"
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }
    }
}

// ---------------------------------------------------------------------------
// classify_single: determine the token kind for a single-char operator/punct
// ---------------------------------------------------------------------------
fn classify_single(ch: i32) -> i32 {
    if ch == 43 {
        2
    } else {
        if ch == 45 {
            3
        } else {
            if ch == 42 {
                4
            } else {
                if ch == 47 {
                    5
                } else {
                    if ch == 40 {
                        6
                    } else {
                        if ch == 41 {
                            7
                        } else {
                            10
                        }
                    }
                }
            }
        }
    }
}

// ---------------------------------------------------------------------------
// get_char: simulate array indexing into our hardcoded 10-character input
// ---------------------------------------------------------------------------
fn get_char(pos: i32, c0: i32, c1: i32, c2: i32, c3: i32, c4: i32, c5: i32, c6: i32, c7: i32, c8: i32, c9: i32) -> i32 {
    if pos == 0 {
        c0
    } else {
        if pos == 1 {
            c1
        } else {
            if pos == 2 {
                c2
            } else {
                if pos == 3 {
                    c3
                } else {
                    if pos == 4 {
                        c4
                    } else {
                        if pos == 5 {
                            c5
                        } else {
                            if pos == 6 {
                                c6
                            } else {
                                if pos == 7 {
                                    c7
                                } else {
                                    if pos == 8 {
                                        c8
                                    } else {
                                        c9
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }
    }
}

// ---------------------------------------------------------------------------
// Main: hardcoded test input processed as an array of char codes
// ---------------------------------------------------------------------------
fn main() {
    // Test input: "x + 42 * y"
    // ASCII codes:  x=120 space=32 +=43 space=32 4=52 2=50 space=32 *=42 space=32 y=121
    // We simulate this as 10 character codes processed in order.

    // Character codes for "x + 42 * y"
    let c0: i32 = 120;   // 'x'
    let c1: i32 = 32;    // ' '
    let c2: i32 = 43;    // '+'
    let c3: i32 = 32;    // ' '
    let c4: i32 = 52;    // '4'
    let c5: i32 = 50;    // '2'
    let c6: i32 = 32;    // ' '
    let c7: i32 = 42;    // '*'
    let c8: i32 = 32;    // ' '
    let c9: i32 = 121;   // 'y'

    let input_len: i32 = 10;

    let lex = Lexer { pos: 0, len: input_len };

    println!("=== QuantaLang Self-Hosted Lexer ===");
    println!("Input: x + 42 * y");
    println!("---");

    // State machine: iterate through the character codes
    let mut pos: i32 = 0;
    let mut token_count: i32 = 0;

    while pos < input_len {
        // Get the character at the current position
        let ch: i32 = get_char(pos, c0, c1, c2, c3, c4, c5, c6, c7, c8, c9);

        // Classify the character
        if is_whitespace(ch) {
            // Skip whitespace
            pos = pos + 1;
        } else {
            if is_digit(ch) {
                // Scan a multi-digit number
                let num_start: i32 = pos;
                let mut num_len: i32 = 0;
                let mut scan_pos: i32 = pos;
                while scan_pos < input_len {
                    let scan_ch: i32 = get_char(scan_pos, c0, c1, c2, c3, c4, c5, c6, c7, c8, c9);
                    if is_digit(scan_ch) {
                        num_len = num_len + 1;
                        scan_pos = scan_pos + 1;
                    } else {
                        // Break out by setting scan_pos past end
                        scan_pos = input_len;
                    }
                }
                let tok = Token { kind: 0, start: num_start, length: num_len };
                println!("Token: {} at pos {} len {}", kind_name(tok.kind), tok.start, tok.length);
                token_count = token_count + 1;
                pos = num_start + num_len;
            } else {
                if is_alpha(ch) {
                    // Scan an identifier
                    let id_start: i32 = pos;
                    let mut id_len: i32 = 0;
                    let mut scan_pos: i32 = pos;
                    while scan_pos < input_len {
                        let scan_ch: i32 = get_char(scan_pos, c0, c1, c2, c3, c4, c5, c6, c7, c8, c9);
                        if is_alpha(scan_ch) {
                            id_len = id_len + 1;
                            scan_pos = scan_pos + 1;
                        } else {
                            scan_pos = input_len;
                        }
                    }
                    let tok = Token { kind: 1, start: id_start, length: id_len };
                    println!("Token: {} at pos {} len {}", kind_name(tok.kind), tok.start, tok.length);
                    token_count = token_count + 1;
                    pos = id_start + id_len;
                } else {
                    // Single-character operator or unknown
                    let kind: i32 = classify_single(ch);
                    let tok = Token { kind: kind, start: pos, length: 1 };
                    println!("Token: {} at pos {} len {}", kind_name(tok.kind), tok.start, tok.length);
                    token_count = token_count + 1;
                    pos = pos + 1;
                }
            }
        }
    }

    // Emit EOF token
    let eof = Token { kind: 9, start: pos, length: 0 };
    println!("Token: {} at pos {} len {}", kind_name(eof.kind), eof.start, eof.length);
    token_count = token_count + 1;

    println!("---");
    println!("Total tokens: {}", token_count);

    // Test the Lexer struct method
    println!("Lexer at_end: {}", lex.at_end());

    // Verify expected output:
    // IDENT(x), PLUS, NUMBER(42), STAR, IDENT(y), EOF = 6 tokens
    if token_count == 6 {
        println!("PASS: token count matches expected (6)");
    } else {
        println!("FAIL: expected 6 tokens");
    }
}
