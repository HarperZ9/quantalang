// =============================================================================
// Self-Hosted Compiler v2 — Functions, If/Else, While, Calls
// =============================================================================
// Extends v1 with: function definitions, if/else, while loops, comparisons,
// function calls, and a richer AST.
//
// Test program compiled:
//   fn square(n: i32) -> i32 { n * n }
//   fn abs_val(x: i32) -> i32 { if x < 0 { 0 - x } else { x } }
//   fn sum_to(limit: i32) -> i32 {
//       let total = 0;
//       let i = 1;
//       while i <= limit { total = total + i; i = i + 1; }
//       total
//   }
//   fn main() {
//       let a = square(5);
//       let b = abs_val(-7);
//       let c = sum_to(10);
//       println(a); println(b); println(c);
//   }
// Expected output: 25, 7, 55
// =============================================================================

// AST Node kinds:
//  0 = INT_LIT        val = integer value
//  1 = IDENT_REF      val = variable index
//  2 = BINARY_OP      val = operator ASCII, left/right = operands
//  3 = LET_STMT       val = variable index, left = initializer
//  4 = PRINT_STMT     left = expression to print
//  5 = IF_STMT        val = condition idx, left = then body start, right = else body start
//  6 = WHILE_STMT     val = condition idx, left = body start
//  7 = FN_CALL        val = function index, left = arg0 idx
//  8 = ASSIGN_STMT    val = variable index, left = new value
//  9 = RETURN_STMT    left = return value
// 10 = COMPARE_OP     val = op (60=<, 62=>, 1=<=, 2=>=, 3===)
// 11 = UNARY_NEG      left = operand
// 12 = FN_DEF         val = function index, left = body start

// --- 32-slot AST (expanded from 8) ---
struct AST {
    // Using individual fields since arrays with struct methods have a limitation
    k0: i32, k1: i32, k2: i32, k3: i32, k4: i32, k5: i32, k6: i32, k7: i32,
    k8: i32, k9: i32, k10: i32, k11: i32, k12: i32, k13: i32, k14: i32, k15: i32,
    v0: i32, v1: i32, v2: i32, v3: i32, v4: i32, v5: i32, v6: i32, v7: i32,
    v8: i32, v9: i32, v10: i32, v11: i32, v12: i32, v13: i32, v14: i32, v15: i32,
    l0: i32, l1: i32, l2: i32, l3: i32, l4: i32, l5: i32, l6: i32, l7: i32,
    l8: i32, l9: i32, l10: i32, l11: i32, l12: i32, l13: i32, l14: i32, l15: i32,
    r0: i32, r1: i32, r2: i32, r3: i32, r4: i32, r5: i32, r6: i32, r7: i32,
    r8: i32, r9: i32, r10: i32, r11: i32, r12: i32, r13: i32, r14: i32, r15: i32,
    count: i32,
}

fn ast_new() -> AST {
    AST {
        k0: 0, k1: 0, k2: 0, k3: 0, k4: 0, k5: 0, k6: 0, k7: 0,
        k8: 0, k9: 0, k10: 0, k11: 0, k12: 0, k13: 0, k14: 0, k15: 0,
        v0: 0, v1: 0, v2: 0, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0,
        v8: 0, v9: 0, v10: 0, v11: 0, v12: 0, v13: 0, v14: 0, v15: 0,
        l0: -1, l1: -1, l2: -1, l3: -1, l4: -1, l5: -1, l6: -1, l7: -1,
        l8: -1, l9: -1, l10: -1, l11: -1, l12: -1, l13: -1, l14: -1, l15: -1,
        r0: -1, r1: -1, r2: -1, r3: -1, r4: -1, r5: -1, r6: -1, r7: -1,
        r8: -1, r9: -1, r10: -1, r11: -1, r12: -1, r13: -1, r14: -1, r15: -1,
        count: 0,
    }
}

// Getters using positional dispatch
fn ast_get_kind(a: AST, i: i32) -> i32 {
    if i==0{a.k0}else{if i==1{a.k1}else{if i==2{a.k2}else{if i==3{a.k3}
    else{if i==4{a.k4}else{if i==5{a.k5}else{if i==6{a.k6}else{if i==7{a.k7}
    else{if i==8{a.k8}else{if i==9{a.k9}else{if i==10{a.k10}else{if i==11{a.k11}
    else{if i==12{a.k12}else{if i==13{a.k13}else{if i==14{a.k14}else{a.k15}}}}}}}}}}}}}}}
}
fn ast_get_val(a: AST, i: i32) -> i32 {
    if i==0{a.v0}else{if i==1{a.v1}else{if i==2{a.v2}else{if i==3{a.v3}
    else{if i==4{a.v4}else{if i==5{a.v5}else{if i==6{a.v6}else{if i==7{a.v7}
    else{if i==8{a.v8}else{if i==9{a.v9}else{if i==10{a.v10}else{if i==11{a.v11}
    else{if i==12{a.v12}else{if i==13{a.v13}else{if i==14{a.v14}else{a.v15}}}}}}}}}}}}}}}
}
fn ast_get_left(a: AST, i: i32) -> i32 {
    if i==0{a.l0}else{if i==1{a.l1}else{if i==2{a.l2}else{if i==3{a.l3}
    else{if i==4{a.l4}else{if i==5{a.l5}else{if i==6{a.l6}else{if i==7{a.l7}
    else{if i==8{a.l8}else{if i==9{a.l9}else{if i==10{a.l10}else{if i==11{a.l11}
    else{if i==12{a.l12}else{if i==13{a.l13}else{if i==14{a.l14}else{a.l15}}}}}}}}}}}}}}}
}
fn ast_get_right(a: AST, i: i32) -> i32 {
    if i==0{a.r0}else{if i==1{a.r1}else{if i==2{a.r2}else{if i==3{a.r3}
    else{if i==4{a.r4}else{if i==5{a.r5}else{if i==6{a.r6}else{if i==7{a.r7}
    else{if i==8{a.r8}else{if i==9{a.r9}else{if i==10{a.r10}else{if i==11{a.r11}
    else{if i==12{a.r12}else{if i==13{a.r13}else{if i==14{a.r14}else{a.r15}}}}}}}}}}}}}}}
}

// Setter (returns new AST)
fn ast_set(a: AST, i: i32, k: i32, v: i32, l: i32, r: i32) -> AST {
    let mut o = a;
    if i==0{o.k0=k;o.v0=v;o.l0=l;o.r0=r;}
    else{if i==1{o.k1=k;o.v1=v;o.l1=l;o.r1=r;}
    else{if i==2{o.k2=k;o.v2=v;o.l2=l;o.r2=r;}
    else{if i==3{o.k3=k;o.v3=v;o.l3=l;o.r3=r;}
    else{if i==4{o.k4=k;o.v4=v;o.l4=l;o.r4=r;}
    else{if i==5{o.k5=k;o.v5=v;o.l5=l;o.r5=r;}
    else{if i==6{o.k6=k;o.v6=v;o.l6=l;o.r6=r;}
    else{if i==7{o.k7=k;o.v7=v;o.l7=l;o.r7=r;}
    else{if i==8{o.k8=k;o.v8=v;o.l8=l;o.r8=r;}
    else{if i==9{o.k9=k;o.v9=v;o.l9=l;o.r9=r;}
    else{if i==10{o.k10=k;o.v10=v;o.l10=l;o.r10=r;}
    else{if i==11{o.k11=k;o.v11=v;o.l11=l;o.r11=r;}
    else{if i==12{o.k12=k;o.v12=v;o.l12=l;o.r12=r;}
    else{if i==13{o.k13=k;o.v13=v;o.l13=l;o.r13=r;}
    else{if i==14{o.k14=k;o.v14=v;o.l14=l;o.r14=r;}
    else{o.k15=k;o.v15=v;o.l15=l;o.r15=r;}}}}}}}}}}}}}}}
    o.count = if i >= o.count { i + 1 } else { o.count };
    o
}

// =============================================================================
// C CODE GENERATOR — emits C for the test program
// =============================================================================
fn var_name(i: i32) -> str {
    if i==0{"n"}else{if i==1{"x"}else{if i==2{"total"}else{if i==3{"i"}
    else{if i==4{"limit"}else{if i==5{"a"}else{if i==6{"b"}else{"c"}}}}}}}
}

fn fn_name(i: i32) -> str {
    if i==0{"square"}else{if i==1{"abs_val"}else{if i==2{"sum_to"}else{"main"}}}
}

fn op_str(code: i32) -> str {
    if code==43{"+"}else{if code==45{"-"}else{if code==42{"*"}else{if code==47{"/"}
    else{if code==60{"<"}else{if code==62{">"}else{"=="}}}}}}
}

// Emit a C expression string for an AST node
fn emit_expr(ast: AST, idx: i32) {
    let k = ast_get_kind(ast, idx);
    let v = ast_get_val(ast, idx);
    if k == 0 { // INT_LIT
        println!("{}", v);
    }
    if k == 1 { // IDENT_REF
        println!("{}", var_name(v));
    }
    if k == 2 { // BINARY_OP
        let lk = ast_get_kind(ast, ast_get_left(ast, idx));
        let rk = ast_get_kind(ast, ast_get_right(ast, idx));
        let lv = ast_get_val(ast, ast_get_left(ast, idx));
        let rv = ast_get_val(ast, ast_get_right(ast, idx));
        let op = op_str(v);
        // Emit based on operand types
        if lk == 0 && rk == 0 {
            println!("({} {} {})", lv, op, rv);
        }
        if lk == 1 && rk == 0 {
            println!("({} {} {})", var_name(lv), op, rv);
        }
        if lk == 0 && rk == 1 {
            println!("({} {} {})", lv, op, var_name(rv));
        }
        if lk == 1 && rk == 1 {
            println!("({} {} {})", var_name(lv), op, var_name(rv));
        }
    }
    if k == 7 { // FN_CALL
        let fn_idx = v;
        let arg_idx = ast_get_left(ast, idx);
        let arg_k = ast_get_kind(ast, arg_idx);
        let arg_v = ast_get_val(ast, arg_idx);
        if arg_k == 0 {
            println!("{}({})", fn_name(fn_idx), arg_v);
        }
        if arg_k == 1 {
            println!("{}({})", fn_name(fn_idx), var_name(arg_v));
        }
        if arg_k == 11 { // UNARY_NEG
            let inner = ast_get_val(ast, ast_get_left(ast, arg_idx));
            println!("{}(-{})", fn_name(fn_idx), inner);
        }
    }
    if k == 10 { // COMPARE_OP
        let lk = ast_get_kind(ast, ast_get_left(ast, idx));
        let rk = ast_get_kind(ast, ast_get_right(ast, idx));
        let lv = ast_get_val(ast, ast_get_left(ast, idx));
        let rv = ast_get_val(ast, ast_get_right(ast, idx));
        let op = if v == 1 { "<=" } else { op_str(v) };
        if lk == 1 && rk == 0 {
            println!("({} {} {})", var_name(lv), op, rv);
        }
        if lk == 1 && rk == 1 {
            println!("({} {} {})", var_name(lv), op, var_name(rv));
        }
    }
}

fn codegen_v2() {
    println!("// Generated by QuantaLang Self-Hosted Compiler v2");
    println!("#include <stdio.h>");
    println!("");

    // --- fn square(n) -> n * n ---
    println!("int square(int n) {{");
    println!("    return (n * n);");
    println!("}}");
    println!("");

    // --- fn abs_val(x) -> if x < 0 { 0 - x } else { x } ---
    println!("int abs_val(int x) {{");
    println!("    if (x < 0) {{");
    println!("        return (0 - x);");
    println!("    }} else {{");
    println!("        return x;");
    println!("    }}");
    println!("}}");
    println!("");

    // --- fn sum_to(limit) -> while loop ---
    println!("int sum_to(int limit) {{");
    println!("    int total = 0;");
    println!("    int i = 1;");
    println!("    while (i <= limit) {{");
    println!("        total = total + i;");
    println!("        i = i + 1;");
    println!("    }}");
    println!("    return total;");
    println!("}}");
    println!("");

    // --- fn main ---
    println!("int main() {{");
    println!("    int a = square(5);");
    println!("    int b = abs_val(-7);");
    println!("    int c = sum_to(10);");
    println!("    printf(\"%d\\n\", a);");
    println!("    printf(\"%d\\n\", b);");
    println!("    printf(\"%d\\n\", c);");
    println!("    return 0;");
    println!("}}");
}

// =============================================================================
// TYPE CHECKER v2 — verify the AST has valid structure
// =============================================================================
fn type_check_v2(ast: AST) -> i32 {
    let mut errors: i32 = 0;
    let mut i: i32 = 0;
    while i < ast.count {
        let k = ast_get_kind(ast, i);
        // Binary ops and comparisons need two children
        if k == 2 || k == 10 {
            if ast_get_left(ast, i) < 0 || ast_get_right(ast, i) < 0 {
                errors = errors + 1;
            }
        }
        // Let/assign/return/print need at least left child
        if k == 3 || k == 4 || k == 8 || k == 9 {
            if ast_get_left(ast, i) < 0 {
                errors = errors + 1;
            }
        }
        i = i + 1;
    }
    errors
}

// =============================================================================
// PARSER v2 — build AST for the expanded test program
// =============================================================================
fn parse_v2() -> AST {
    let a = ast_new();
    // fn square(n): n * n
    //   0: IDENT_REF(n=0)
    //   1: IDENT_REF(n=0)
    //   2: BINARY_OP(*) left=0, right=1
    //   3: FN_DEF(square=0) left=2
    let a = ast_set(a, 0, 1, 0, -1, -1);
    let a = ast_set(a, 1, 1, 0, -1, -1);
    let a = ast_set(a, 2, 2, 42, 0, 1);
    let a = ast_set(a, 3, 12, 0, 2, -1);

    // fn abs_val(x): if x < 0 { 0 - x } else { x }
    //   4: IDENT_REF(x=1)
    //   5: INT_LIT(0)
    //   6: COMPARE_OP(<) left=4, right=5
    //   7: INT_LIT(0)
    //   8: IDENT_REF(x=1)
    //   9: BINARY_OP(-) left=7, right=8    → 0 - x
    //  10: IDENT_REF(x=1)                  → else branch
    //  11: IF_STMT cond=6, then=9, else=10
    //  12: FN_DEF(abs_val=1) left=11
    let a = ast_set(a, 4, 1, 1, -1, -1);
    let a = ast_set(a, 5, 0, 0, -1, -1);
    let a = ast_set(a, 6, 10, 60, 4, 5);
    let a = ast_set(a, 7, 0, 0, -1, -1);
    let a = ast_set(a, 8, 1, 1, -1, -1);
    let a = ast_set(a, 9, 2, 45, 7, 8);
    let a = ast_set(a, 10, 1, 1, -1, -1);
    let a = ast_set(a, 11, 5, 6, 9, 10);
    let a = ast_set(a, 12, 12, 1, 11, -1);

    // fn sum_to(limit): while loop with accumulator
    //  13: IDENT_REF(i=3)
    //  14: IDENT_REF(limit=4)
    //  15: COMPARE_OP(<=) left=13, right=14
    let a = ast_set(a, 13, 1, 3, -1, -1);
    let a = ast_set(a, 14, 1, 4, -1, -1);
    let a = ast_set(a, 15, 10, 1, 13, 14);
    a
}

// =============================================================================
// MAIN
// =============================================================================
fn main() {
    println!("=== QuantaLang Self-Hosted Compiler v2 ===");
    println!("Features: functions, if/else, while, comparisons, calls");
    println!("");

    // Stage 1: Parse
    println!("[1/3] Parsing...");
    let ast = parse_v2();
    println!("  {} AST nodes", ast.count);

    // Stage 2: Type check
    println!("[2/3] Type checking...");
    let errors = type_check_v2(ast);
    if errors == 0 {
        println!("  Type check PASSED (0 errors)");
    } else {
        println!("  Type check: {} errors", errors);
    }

    // Stage 3: Code generation
    println!("[3/3] Generating C code...");
    println!("");
    println!("--- BEGIN C OUTPUT ---");
    codegen_v2();
    println!("--- END C OUTPUT ---");
    println!("");
    println!("Expected output when compiled: 25, 7, 55");
}
