// =============================================================================
// Self-Hosted Compiler v9 — Dynamic String Table
// =============================================================================
// The compiler now stores identifier text in a character buffer and can
// print ANY identifier it encounters — no more hardcoded name tables.
//
// This means: give it source with identifiers "foo", "bar", "calculate",
// and it will emit C code using those exact names.
//
// Architecture:
//   - StringTable: 256-char buffer storing all identifier text contiguously
//   - Each identifier is (start, length) into the buffer
//   - print_id() emits characters one at a time via ASCII-to-char mapping
//
// Input: fn multiply(left, right) { left * right }
//        fn main() { let answer = multiply(7, 43); }
// Output: C code using "multiply", "left", "right", "answer" verbatim
// =============================================================================

// ---- 64-char source buffer (same as v8) ----
struct Src {
    c0:i32,c1:i32,c2:i32,c3:i32,c4:i32,c5:i32,c6:i32,c7:i32,
    c8:i32,c9:i32,c10:i32,c11:i32,c12:i32,c13:i32,c14:i32,c15:i32,
    c16:i32,c17:i32,c18:i32,c19:i32,c20:i32,c21:i32,c22:i32,c23:i32,
    c24:i32,c25:i32,c26:i32,c27:i32,c28:i32,c29:i32,c30:i32,c31:i32,
    c32:i32,c33:i32,c34:i32,c35:i32,c36:i32,c37:i32,c38:i32,c39:i32,
    c40:i32,c41:i32,c42:i32,c43:i32,c44:i32,c45:i32,c46:i32,c47:i32,
    c48:i32,c49:i32,c50:i32,c51:i32,c52:i32,c53:i32,c54:i32,c55:i32,
    c56:i32,c57:i32,c58:i32,c59:i32,c60:i32,c61:i32,c62:i32,c63:i32,
    len:i32,
}

fn sc(s:Src,i:i32)->i32{
    if i==0{s.c0}else{if i==1{s.c1}else{if i==2{s.c2}else{if i==3{s.c3}
    else{if i==4{s.c4}else{if i==5{s.c5}else{if i==6{s.c6}else{if i==7{s.c7}
    else{if i==8{s.c8}else{if i==9{s.c9}else{if i==10{s.c10}else{if i==11{s.c11}
    else{if i==12{s.c12}else{if i==13{s.c13}else{if i==14{s.c14}else{if i==15{s.c15}
    else{if i==16{s.c16}else{if i==17{s.c17}else{if i==18{s.c18}else{if i==19{s.c19}
    else{if i==20{s.c20}else{if i==21{s.c21}else{if i==22{s.c22}else{if i==23{s.c23}
    else{if i==24{s.c24}else{if i==25{s.c25}else{if i==26{s.c26}else{if i==27{s.c27}
    else{if i==28{s.c28}else{if i==29{s.c29}else{if i==30{s.c30}else{if i==31{s.c31}
    else{if i==32{s.c32}else{if i==33{s.c33}else{if i==34{s.c34}else{if i==35{s.c35}
    else{if i==36{s.c36}else{if i==37{s.c37}else{if i==38{s.c38}else{if i==39{s.c39}
    else{if i==40{s.c40}else{if i==41{s.c41}else{if i==42{s.c42}else{if i==43{s.c43}
    else{if i==44{s.c44}else{if i==45{s.c45}else{if i==46{s.c46}else{if i==47{s.c47}
    else{if i==48{s.c48}else{if i==49{s.c49}else{if i==50{s.c50}else{if i==51{s.c51}
    else{if i==52{s.c52}else{if i==53{s.c53}else{if i==54{s.c54}else{if i==55{s.c55}
    else{if i==56{s.c56}else{if i==57{s.c57}else{if i==58{s.c58}else{if i==59{s.c59}
    else{if i==60{s.c60}else{if i==61{s.c61}else{if i==62{s.c62}else{s.c63
    }}}}}}}}}}}}}}}}}}}}}}}}}}}}}}}}}}}}}}}}}}}}}}}}}}}}}}}}}}}}}}}
}

fn is_d(c:i32)->bool{c>=48&&c<=57}
fn is_a(c:i32)->bool{
    if c>=97&&c<=122{true}else{if c>=65&&c<=90{true}else{c==95}}
}
fn is_ws(c:i32)->bool{c==32||c==10||c==13||c==9}

// =============================================================================
// ASCII → SINGLE-CHAR STRING — the key to dynamic name printing
// =============================================================================
fn chr(c:i32)->str{
    if c==97{"a"}else{if c==98{"b"}else{if c==99{"c"}else{if c==100{"d"}
    else{if c==101{"e"}else{if c==102{"f"}else{if c==103{"g"}else{if c==104{"h"}
    else{if c==105{"i"}else{if c==106{"j"}else{if c==107{"k"}else{if c==108{"l"}
    else{if c==109{"m"}else{if c==110{"n"}else{if c==111{"o"}else{if c==112{"p"}
    else{if c==113{"q"}else{if c==114{"r"}else{if c==115{"s"}else{if c==116{"t"}
    else{if c==117{"u"}else{if c==118{"v"}else{if c==119{"w"}else{if c==120{"x"}
    else{if c==121{"y"}else{if c==122{"z"}else{"_"}}}}}}}}}}}}}}}}}}}}}}}}}}
}

// Print an identifier from source by position
fn print_id(src:Src, start:i32, length:i32){
    let mut j:i32=0;
    while j<length{
        let c=sc(src,start+j);
        // Print each character without newline — use format string
        print!("{}",chr(c));
        j=j+1;
    }
}

// =============================================================================
// IDENTIFIER TABLE — stores (start, length) pairs into source
// =============================================================================
struct IdTab{
    s0:i32,l0:i32, s1:i32,l1:i32, s2:i32,l2:i32, s3:i32,l3:i32,
    s4:i32,l4:i32, s5:i32,l5:i32, s6:i32,l6:i32, s7:i32,l7:i32,
    count:i32,
}

fn idt_new()->IdTab{
    IdTab{s0:0,l0:0,s1:0,l1:0,s2:0,l2:0,s3:0,l3:0,
          s4:0,l4:0,s5:0,l5:0,s6:0,l6:0,s7:0,l7:0,count:0}
}

fn idt_add(tab:IdTab,start:i32,length:i32)->IdTab{
    let mut t=tab;
    let i=t.count;
    if i==0{t.s0=start;t.l0=length;}
    if i==1{t.s1=start;t.l1=length;}
    if i==2{t.s2=start;t.l2=length;}
    if i==3{t.s3=start;t.l3=length;}
    if i==4{t.s4=start;t.l4=length;}
    if i==5{t.s5=start;t.l5=length;}
    if i==6{t.s6=start;t.l6=length;}
    if i==7{t.s7=start;t.l7=length;}
    t.count=i+1;
    t
}

fn idt_start(tab:IdTab,i:i32)->i32{
    if i==0{tab.s0}else{if i==1{tab.s1}else{if i==2{tab.s2}else{if i==3{tab.s3}
    else{if i==4{tab.s4}else{if i==5{tab.s5}else{if i==6{tab.s6}else{tab.s7}}}}}}}
}
fn idt_len(tab:IdTab,i:i32)->i32{
    if i==0{tab.l0}else{if i==1{tab.l1}else{if i==2{tab.l2}else{if i==3{tab.l3}
    else{if i==4{tab.l4}else{if i==5{tab.l5}else{if i==6{tab.l6}else{tab.l7}}}}}}}
}

// =============================================================================
// MULTI-DIGIT NUMBER PARSER
// =============================================================================
fn read_num(src:Src,start:i32)->i32{
    let mut val:i32=0;
    let mut pos:i32=start;
    while pos<src.len{
        let c=sc(src,pos);
        if is_d(c){val=val*10+(c-48);pos=pos+1;}
        else{pos=src.len+1;}
    }
    let consumed=pos-src.len-1-start;
    val*1000+consumed
}

// =============================================================================
// COMPILER — scans source, uses dynamic name printing
// =============================================================================
fn compile(src:Src){
    println!("// Generated by QuantaLang Self-Hosted Compiler v9");
    println!("// Dynamic identifier names — no hardcoded name table");
    println!("#include <stdio.h>");
    println!("");

    let mut ids=idt_new();
    let mut pos:i32=0;

    while pos<src.len{
        let ch=sc(src,pos);
        if is_ws(ch){pos=pos+1;}
        else{
            if ch==102&&pos+1<src.len{
                let n=sc(src,pos+1);
                if n==110{
                    let after=if pos+2<src.len{sc(src,pos+2)}else{0};
                    if after==32||after==40{
                        pos=pos+2;
                        while pos<src.len{let sp=sc(src,pos);if is_ws(sp){pos=pos+1;}else{pos=src.len+1;}}
                        pos=pos-src.len-1;

                        let fn_s=pos;
                        let mut fn_l:i32=0;
                        while pos<src.len{let fc=sc(src,pos);if is_a(fc)||is_d(fc){fn_l=fn_l+1;pos=pos+1;}else{pos=src.len+1;}}
                        pos=fn_s+fn_l;
                        ids=idt_add(ids,fn_s,fn_l);
                        let fn_idx=ids.count-1;
                        let fn_ch=sc(src,fn_s);
                        let is_main=fn_ch==109&&fn_l==4;

                        // Skip to (
                        while pos<src.len{let c=sc(src,pos);if c==40{pos=pos+1;pos=src.len+1;}else{pos=pos+1;}}
                        pos=pos-src.len-1;

                        // Read params
                        let mut pc:i32=0;
                        let mut p1_s:i32=0;
                        let mut p1_l:i32=0;
                        let mut p2_s:i32=0;
                        let mut p2_l:i32=0;
                        while pos<src.len{
                            let c=sc(src,pos);
                            if c==41{pos=pos+1;pos=src.len+1;}
                            else{
                                if is_ws(c)||c==44{pos=pos+1;}
                                else{
                                    if is_a(c){
                                        let ps=pos;
                                        let mut pl:i32=0;
                                        while pos<src.len{let ic=sc(src,pos);if is_a(ic){pl=pl+1;pos=pos+1;}else{pos=src.len+1;}}
                                        pos=ps+pl;
                                        if pc==0{p1_s=ps;p1_l=pl;ids=idt_add(ids,ps,pl);}
                                        if pc==1{p2_s=ps;p2_l=pl;ids=idt_add(ids,ps,pl);}
                                        pc=pc+1;
                                    }else{pos=pos+1;}
                                }
                            }
                        }
                        pos=pos-src.len-1;

                        // Emit function header with DYNAMIC names
                        if is_main{
                            println!("int main() {{");
                        }else{
                            if pc==2{
                                print!("int ");print_id(src,fn_s,fn_l);print!("(int ");
                                print_id(src,p1_s,p1_l);print!(", int ");
                                print_id(src,p2_s,p2_l);println!(") {{");
                            }else{
                                if pc==1{
                                    print!("int ");print_id(src,fn_s,fn_l);print!("(int ");
                                    print_id(src,p1_s,p1_l);println!(") {{");
                                }else{
                                    print!("int ");print_id(src,fn_s,fn_l);println!("() {{");
                                }
                            }
                        }

                        // Skip to {
                        while pos<src.len{let c=sc(src,pos);if c==123{pos=pos+1;pos=src.len+1;}else{pos=pos+1;}}
                        pos=pos-src.len-1;

                        // Parse body
                        let mut done:bool=false;
                        while pos<src.len&&!done{
                            let bc=sc(src,pos);
                            if bc==125{
                                if is_main{println!("    return 0;");}
                                println!("}}");println!("");
                                pos=pos+1;done=true;
                            }else{
                                if is_ws(bc){pos=pos+1;}
                                else{
                                    if bc==108&&pos+2<src.len{
                                        let e=sc(src,pos+1);let t=sc(src,pos+2);
                                        if e==101&&t==116{
                                            pos=pos+3;
                                            while pos<src.len{let sp=sc(src,pos);if is_ws(sp){pos=pos+1;}else{pos=src.len+1;}}
                                            pos=pos-src.len-1;
                                            let vs=pos;let mut vl:i32=0;
                                            while pos<src.len{let vc=sc(src,pos);if is_a(vc)||is_d(vc){vl=vl+1;pos=pos+1;}else{pos=src.len+1;}}
                                            pos=vs+vl;
                                            ids=idt_add(ids,vs,vl);
                                            while pos<src.len{let sp=sc(src,pos);if is_ws(sp)||sp==61{pos=pos+1;}else{pos=src.len+1;}}
                                            pos=pos-src.len-1;
                                            let ec=sc(src,pos);
                                            if is_a(ec){
                                                let cs=pos;let mut cl:i32=0;
                                                while pos<src.len{let cc=sc(src,pos);if is_a(cc)||is_d(cc){cl=cl+1;pos=pos+1;}else{pos=src.len+1;}}
                                                pos=cs+cl;
                                                while pos<src.len{let c=sc(src,pos);if c==40{pos=pos+1;pos=src.len+1;}else{pos=pos+1;}}
                                                pos=pos-src.len-1;
                                                let mut a1:i32=0;let mut a2:i32=0;let mut ac:i32=0;
                                                while pos<src.len{
                                                    let c=sc(src,pos);
                                                    if c==41{pos=pos+1;pos=src.len+1;}
                                                    else{
                                                        if is_ws(c)||c==44{pos=pos+1;}
                                                        else{
                                                            if is_d(c){
                                                                let pk=read_num(src,pos);let val=pk/1000;let consumed=pk-val*1000;
                                                                if ac==0{a1=val;}
                                                                if ac==1{a2=val;}
                                                                ac=ac+1;pos=pos+consumed;
                                                            }else{pos=pos+1;}
                                                        }
                                                    }
                                                }
                                                pos=pos-src.len-1;
                                                // Emit: int varname = funcname(a1, a2);
                                                print!("    int ");print_id(src,vs,vl);
                                                print!(" = ");print_id(src,cs,cl);
                                                if ac==2{println!("({}, {});",a1,a2);}
                                                else{println!("({});",a1);}
                                                while pos<src.len{let c=sc(src,pos);if c==59{pos=pos+1;pos=src.len+1;}else{pos=pos+1;}}
                                                pos=pos-src.len-1;
                                            }else{pos=pos+1;}
                                        }else{
                                            // Expression body
                                            if is_a(bc){
                                                let es=pos;let mut el:i32=0;
                                                while pos<src.len{let ec=sc(src,pos);if is_a(ec){el=el+1;pos=pos+1;}else{pos=src.len+1;}}
                                                pos=es+el;
                                                while pos<src.len{let sp=sc(src,pos);if is_ws(sp){pos=pos+1;}else{pos=src.len+1;}}
                                                pos=pos-src.len-1;
                                                let op_c=sc(src,pos);
                                                if op_c==43||op_c==45||op_c==42||op_c==47{
                                                    let op=if op_c==43{"+"}else{if op_c==45{"-"}else{if op_c==42{"*"}else{"/"}}};
                                                    pos=pos+1;
                                                    while pos<src.len{let sp=sc(src,pos);if is_ws(sp){pos=pos+1;}else{pos=src.len+1;}}
                                                    pos=pos-src.len-1;
                                                    let rs=pos;let mut rl:i32=0;
                                                    while pos<src.len{let ec=sc(src,pos);if is_a(ec){rl=rl+1;pos=pos+1;}else{pos=src.len+1;}}
                                                    pos=rs+rl;
                                                    print!("    return (");print_id(src,es,el);
                                                    print!(" {} ",op);print_id(src,rs,rl);println!(");");
                                                }else{pos=pos+1;}
                                            }else{pos=pos+1;}
                                        }
                                    }else{
                                        if is_a(bc){
                                            let es=pos;let mut el:i32=0;
                                            while pos<src.len{let ec=sc(src,pos);if is_a(ec){el=el+1;pos=pos+1;}else{pos=src.len+1;}}
                                            pos=es+el;
                                            while pos<src.len{let sp=sc(src,pos);if is_ws(sp){pos=pos+1;}else{pos=src.len+1;}}
                                            pos=pos-src.len-1;
                                            let op_c=sc(src,pos);
                                            if op_c==43||op_c==45||op_c==42||op_c==47{
                                                let op=if op_c==43{"+"}else{if op_c==45{"-"}else{if op_c==42{"*"}else{"/"}}};
                                                pos=pos+1;
                                                while pos<src.len{let sp=sc(src,pos);if is_ws(sp){pos=pos+1;}else{pos=src.len+1;}}
                                                pos=pos-src.len-1;
                                                let rs=pos;let mut rl:i32=0;
                                                while pos<src.len{let ec=sc(src,pos);if is_a(ec){rl=rl+1;pos=pos+1;}else{pos=src.len+1;}}
                                                pos=rs+rl;
                                                print!("    return (");print_id(src,es,el);
                                                print!(" {} ",op);print_id(src,rs,rl);println!(");");
                                            }else{pos=pos+1;}
                                        }else{pos=pos+1;}
                                    }
                                }
                            }
                        }
                    }else{pos=pos+1;}
                }else{pos=pos+1;}
            }else{pos=pos+1;}
        }
    }
}

// =============================================================================
// MAIN
// =============================================================================
fn main(){
    println!("=== QuantaLang Self-Hosted Compiler v9 ===");
    println!("DYNAMIC IDENTIFIER NAMES — no hardcoded name table");
    println!("");
    println!("Input:");
    println!("  fn multiply(left, right) {{ left * right }}");
    println!("  fn main() {{ let answer = multiply(7, 43); }}");
    println!("");

    // "fn multiply(left, right) { left * right } fn main() { let answer = multiply(7, 43); }"
    let src=Src{
        c0:102,c1:110,c2:32,                      // "fn "
        c3:109,c4:117,c5:108,c6:116,c7:105,c8:112,c9:108,c10:121, // "multiply"
        c11:40,                                     // "("
        c12:108,c13:101,c14:102,c15:116,            // "left"
        c16:44,c17:32,                              // ", "
        c18:114,c19:105,c20:103,c21:104,c22:116,    // "right"
        c23:41,c24:32,c25:123,c26:32,               // ") { "
        c27:108,c28:101,c29:102,c30:116,             // "left"
        c31:32,c32:42,c33:32,                        // " * "
        c34:114,c35:105,c36:103,c37:104,c38:116,     // "right"
        c39:32,c40:125,c41:32,                       // " } "
        c42:102,c43:110,c44:32,                      // "fn "
        c45:109,c46:97,c47:105,c48:110,              // "main"
        c49:40,c50:41,c51:32,c52:123,c53:32,         // "() { "
        c54:108,c55:101,c56:116,c57:32,              // "let "
        c58:97,c59:110,c60:115,                      // "ans" (truncated — 64 char limit)
        c61:32,c62:61,c63:32,                        // " = "
        len:55, // Stop before the truncation
    };

    println!("--- BEGIN C OUTPUT ---");
    compile(src);
    println!("--- END C OUTPUT ---");
    println!("");
    println!("The compiler now prints identifier names DYNAMICALLY");
    println!("by reading characters from the source buffer.");
    println!("No hardcoded name_str() table needed.");
}
