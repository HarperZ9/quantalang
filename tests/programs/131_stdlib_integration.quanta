// Phase 2 Integration Test: Standard Library
// Uses 2 stdlib modules (core + math) from any directory via automatic
// stdlib path resolution. Verifies imports, compilation, correct output.

mod core;
mod math;

fn main() {
    // --- core: integer utilities ---
    let a = i32_min(10, 3);
    let b = i32_max(10, 3);
    let c = i32_abs(-7);
    let d = i32_clamp(150, 0, 100);
    println!("{} {} {} {}", a, b, c, d);

    // --- core: float utilities ---
    let x = f64_min(3.14, 2.71);
    let y = f64_max(3.14, 2.71);
    let z = f64_clamp(1.5, 0.0, 1.0);
    println!("{} {} {}", x, y, z);

    // --- core: constants ---
    let p = pi();
    println!("{}", p);

    // --- math: interpolation ---
    let mid = lerp_f64(0.0, 100.0, 0.5);
    let mapped = map_range(5.0, 0.0, 10.0, 0.0, 100.0);
    println!("{} {}", mid, mapped);

    // --- math: angle conversion ---
    let rad = degrees_to_radians(90.0);
    println!("{}", rad);

    // --- math: distance ---
    let dsq = distance_2d_squared(0.0, 0.0, 3.0, 4.0);
    println!("{}", dsq);

    // --- combined: core + math together ---
    let val = f64_clamp(lerp_f64(0.0, dsq, 0.5), 0.0, 20.0);
    println!("{}", val);

    println!("stdlib: OK");
}
