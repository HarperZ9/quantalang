// Test 74: Multi-module dependency chain
// main -> photon_render -> spectrum_core (3 levels)

mod spectrum_core;
mod photon_render;

fn main() {
    // Direct call to level-1 module
    let linear = spectrum_core::srgb_to_linear(0.5);
    println!("srgb_to_linear(0.5): {}", linear);

    // Call to level-2 module
    let graded = photon_render::grade_color(0.5, 1.0);
    println!("grade_color(0.5, exp=1.0): {}", graded);

    // Tone mapping
    let hdr_val = 4.0;
    let ldr = photon_render::tonemap_reinhard(hdr_val);
    println!("tonemap(4.0): {}", ldr);

    // Exposure
    let exposed = photon_render::apply_exposure(0.18, 2.0);
    println!("expose(0.18, +2EV): {}", exposed);

    // Luminance from spectrum_core
    let lum = spectrum_core::luminance(0.5, 0.5, 0.5);
    println!("luminance(0.5,0.5,0.5): {}", lum);
}
