// Color Science — the math behind every display and camera

fn linear_to_srgb(c: f64) -> f64 {
    if c <= 0.0031308 { c * 12.92 }
    else { 1.055 * pow(c, 1.0 / 2.4) - 0.055 }
}

fn srgb_to_linear(c: f64) -> f64 {
    if c <= 0.04045 { c / 12.92 }
    else { pow((c + 0.055) / 1.055, 2.4) }
}

fn luminance_bt709(r: f64, g: f64, b: f64) -> f64 {
    r * 0.2126 + g * 0.7152 + b * 0.0722
}

fn luminance_bt601(r: f64, g: f64, b: f64) -> f64 {
    r * 0.299 + g * 0.587 + b * 0.114
}

// HSV to RGB conversion
fn hsv_to_rgb_channel(h: f64, s: f64, v: f64, n: f64) -> f64 {
    let k_raw = n + h / 60.0;
    let k = k_raw - floor(k_raw / 6.0) * 6.0;
    let t1 = if k < 4.0 - k { k } else { 4.0 - k };
    let t2 = if t1 < 1.0 { t1 } else { 1.0 };
    let t3 = if 0.0 > t2 { 0.0 } else { t2 };
    v - v * s * t3
}

fn main() {
    // sRGB roundtrip
    let linear = 0.5;
    let srgb = linear_to_srgb(linear);
    let back = srgb_to_linear(srgb);
    println!("Linear: {}", linear);
    println!("sRGB: {}", srgb);
    println!("Roundtrip: {}", back);

    // Luminance
    let luma_709 = luminance_bt709(1.0, 0.5, 0.2);
    let luma_601 = luminance_bt601(1.0, 0.5, 0.2);
    println!("BT.709 luminance: {}", luma_709);
    println!("BT.601 luminance: {}", luma_601);

    // HSV — standard n values: R=5, G=3, B=1
    let r = hsv_to_rgb_channel(0.0, 1.0, 1.0, 5.0);
    let g = hsv_to_rgb_channel(0.0, 1.0, 1.0, 3.0);
    let b = hsv_to_rgb_channel(0.0, 1.0, 1.0, 1.0);
    println!("HSV(0, 1, 1) = RGB({}, {}, {})", r, g, b);
}
