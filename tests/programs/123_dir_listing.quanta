fn main() {
    let nargs = args_count();
    let path = ".";
    if nargs > 1 {
        let path = args_get(1);
    }
    let files = list_dir(path);
    let count = vec_len(files);
    println!("Files in current dir: {}", count);
    let mut i: i64 = 0;
    while i < count {
        let name = vec_get_str(files, i);
        println!("  {}", name);
        i += 1;
    }
}
