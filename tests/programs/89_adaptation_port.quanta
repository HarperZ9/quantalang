// Test 89: quanta-color port — Chromatic adaptation
// Ported from APPS/quanta-color/quanta_color/adaptation.py
// Bradford chromatic adaptation transform

struct XYZ { x: f64, y: f64, z: f64, }

// Bradford cone response matrix (3x3)
fn bradford_forward_r(xyz: XYZ) -> f64 {  0.8951 * xyz.x + 0.2664 * xyz.y - 0.1614 * xyz.z }
fn bradford_forward_g(xyz: XYZ) -> f64 { -0.7502 * xyz.x + 1.7135 * xyz.y + 0.0367 * xyz.z }
fn bradford_forward_b(xyz: XYZ) -> f64 {  0.0389 * xyz.x - 0.0685 * xyz.y + 1.0296 * xyz.z }

// Bradford inverse
fn bradford_inverse_x(r: f64, g: f64, b: f64) -> f64 {  0.9870 * r - 0.1471 * g + 0.1600 * b }
fn bradford_inverse_y(r: f64, g: f64, b: f64) -> f64 {  0.4323 * r + 0.5184 * g + 0.0493 * b }
fn bradford_inverse_z(r: f64, g: f64, b: f64) -> f64 { -0.0085 * r + 0.0400 * g + 0.9685 * b }

// Standard illuminants (XYZ with Y=1)
fn d65_x() -> f64 { 0.95047 }
fn d65_y() -> f64 { 1.0 }
fn d65_z() -> f64 { 1.08883 }

fn d50_x() -> f64 { 0.96422 }
fn d50_y() -> f64 { 1.0 }
fn d50_z() -> f64 { 0.82521 }

// Bradford adaptation: adapt XYZ from source illuminant to target
fn adapt_bradford(xyz: XYZ, src: XYZ, dst: XYZ) -> XYZ {
    // Source cone response
    let src_r = bradford_forward_r(src);
    let src_g = bradford_forward_g(src);
    let src_b = bradford_forward_b(src);

    // Destination cone response
    let dst_r = bradford_forward_r(dst);
    let dst_g = bradford_forward_g(dst);
    let dst_b = bradford_forward_b(dst);

    // Input cone response
    let in_r = bradford_forward_r(xyz);
    let in_g = bradford_forward_g(xyz);
    let in_b = bradford_forward_b(xyz);

    // Scale by ratio
    let adapted_r = in_r * (dst_r / src_r);
    let adapted_g = in_g * (dst_g / src_g);
    let adapted_b = in_b * (dst_b / src_b);

    // Back to XYZ
    XYZ {
        x: bradford_inverse_x(adapted_r, adapted_g, adapted_b),
        y: bradford_inverse_y(adapted_r, adapted_g, adapted_b),
        z: bradford_inverse_z(adapted_r, adapted_g, adapted_b),
    }
}

fn main() {
    let d65 = XYZ { x: d65_x(), y: d65_y(), z: d65_z() };
    let d50 = XYZ { x: d50_x(), y: d50_y(), z: d50_z() };

    // Adapt D65 white to D50 — should give D50 white
    let adapted = adapt_bradford(d65, d65, d50);
    println!("D65→D50 x: {}", adapted.x);
    println!("D65→D50 y: {}", adapted.y);
    println!("D65→D50 z: {}", adapted.z);

    // Identity: adapt D65 to D65 should be unchanged
    let identity = adapt_bradford(d65, d65, d65);
    println!("identity x: {}", identity.x);
    println!("identity y: {}", identity.y);

    // Adapt a color sample from D65 to D50
    let sample = XYZ { x: 0.4124, y: 0.2126, z: 0.0193 };
    let adapted_sample = adapt_bradford(sample, d65, d50);
    println!("sample D50 x: {}", adapted_sample.x);
    println!("sample D50 y: {}", adapted_sample.y);
}
