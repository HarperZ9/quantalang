// Test 83: VCGT gamma ramp and .cube LUT generation
// Port of vcgt.py — Video Card Gamma Table

// Generate a gamma correction ramp value
fn vcgt_ramp(input: f64, gamma: f64, min_val: f64, max_val: f64) -> f64 {
    let normalized = pow(input, gamma);
    min_val + (max_val - min_val) * normalized
}

// Per-channel correction for warm/cool white point
fn correct_rgb(r: f64, g: f64, b: f64, r_gamma: f64, g_gamma: f64, b_gamma: f64) -> f64 {
    // Return corrected red channel (simplified for test)
    vcgt_ramp(r, r_gamma, 0.0, 1.0)
}

// Write a minimal .cube LUT header
fn write_cube_header(size: i32) -> i32 {
    let wrote = write_file("/tmp/quanta_test_83.cube",
        "# QuantaLang Generated LUT\nTITLE \"Calibration LUT\"\nLUT_3D_SIZE 17\n");
    if wrote { size } else { 0 }
}

fn main() {
    // VCGT ramp at key points
    let v0 = vcgt_ramp(0.0, 2.2, 0.0, 1.0);
    let v25 = vcgt_ramp(0.25, 2.2, 0.0, 1.0);
    let v50 = vcgt_ramp(0.5, 2.2, 0.0, 1.0);
    let v75 = vcgt_ramp(0.75, 2.2, 0.0, 1.0);
    let v100 = vcgt_ramp(1.0, 2.2, 0.0, 1.0);

    println!("ramp[0.00]: {}", v0);
    println!("ramp[0.25]: {}", v25);
    println!("ramp[0.50]: {}", v50);
    println!("ramp[0.75]: {}", v75);
    println!("ramp[1.00]: {}", v100);

    // With min/max range (simulates display black/white point)
    let v_ranged = vcgt_ramp(0.5, 2.2, 0.05, 0.95);
    println!("ranged[0.50]: {}", v_ranged);

    // Write .cube file
    let lut_size = write_cube_header(17);
    println!("cube size: {}", lut_size);

    // Verify file exists
    let exists = file_exists("/tmp/quanta_test_83.cube");
    println!("cube exists: {}", exists);

    // Per-channel correction
    let r_corrected = correct_rgb(0.8, 0.8, 0.8, 2.0, 2.2, 2.4);
    println!("r_corrected: {}", r_corrected);
}
