// Test 51: Full dynamic dispatch — trait object construction + vtable calls
// This is what makes polymorphic rendering architectures possible

trait Material {
    fn shade(self) -> f64;
}

struct Plastic {
    roughness: f64,
}

struct Metal {
    metallic: f64,
}

impl Material for Plastic {
    fn shade(self) -> f64 {
        // Diffuse-heavy shading
        0.8 * (1.0 - self.roughness * 0.5)
    }
}

impl Material for Metal {
    fn shade(self) -> f64 {
        // Specular-heavy shading
        0.95 * self.metallic
    }
}

// This function takes a trait object — it doesn't know the concrete type
fn render_material(mat: dyn Material) -> f64 {
    mat.shade()
}

fn main() {
    let plastic = Plastic { roughness: 0.4 };
    let metal = Metal { metallic: 0.9 };

    // Static dispatch (already works)
    println!("Plastic shade: {}", plastic.shade());
    println!("Metal shade: {}", metal.shade());

    // Dynamic dispatch through trait objects
    let dyn_plastic = plastic as dyn Material;
    let dyn_metal = metal as dyn Material;

    println!("Dyn plastic: {}", render_material(dyn_plastic));
    println!("Dyn metal: {}", render_material(dyn_metal));
}
