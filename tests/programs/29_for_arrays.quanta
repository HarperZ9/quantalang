fn main() {
    let arr = [10, 20, 30, 40, 50];
    let mut sum: i32 = 0;
    let mut i: i32 = 0;
    while i < 5 {
        sum = sum + arr[i];
        i = i + 1;
    }

    let mut product: i32 = 1;
    let mut j: i32 = 0;
    while j < 5 {
        product = product * arr[j];
        j = j + 1;
    }

    println!("Sum: {}", sum);
    println!("Product: {}", product);
}
