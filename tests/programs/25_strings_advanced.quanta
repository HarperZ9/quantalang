// Test 25: Advanced string operations
// Demonstrates string concatenation, equality comparison, and string functions

fn repeat_str(s: str, n: i32) -> str {
    let mut result: str = "";
    let mut i: i32 = 0;
    while i < n {
        result = result + s;
        i = i + 1;
    }
    result
}

fn main() {
    // String concatenation
    let hello: str = "Hello";
    let world: str = "World";
    let greeting: str = hello + ", " + world + "!";
    println!("{}", greeting);

    // String equality
    let empty: str = "";
    let not_empty: str = "content";

    if empty == "" {
        println!("empty is empty");
    }

    // Use if/else with == to test non-empty (avoid != which has a codegen issue)
    if not_empty == "" {
        println!("not_empty is empty");
    } else {
        println!("not_empty has content");
    }

    // String repeat function
    let stars = repeat_str("*", 5);
    println!("{}", stars);

    let dashes = repeat_str("-", 3);
    println!("{}", dashes);

    // Empty repeat
    let none = repeat_str("x", 0);
    if none == "" {
        println!("zero repeat is empty");
    }
}
