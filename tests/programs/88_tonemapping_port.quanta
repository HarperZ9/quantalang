// Test 88: quanta-color port — Tone mapping operators
// Ported from APPS/quanta-color/quanta_color/tonemap.py

fn clamp01(x: f64) -> f64 {
    if x < 0.0 { 0.0 } else { if x > 1.0 { 1.0 } else { x } }
}

// Reinhard (simple)
fn reinhard(x: f64) -> f64 { x / (1.0 + x) }

// Reinhard extended with white point
fn reinhard_extended(x: f64, white: f64) -> f64 {
    let num = x * (1.0 + x / (white * white));
    num / (1.0 + x)
}

// ACES filmic (Narkowicz 2015)
fn aces_filmic(x: f64) -> f64 {
    let a = 2.51;
    let b = 0.03;
    let c = 2.43;
    let d = 0.59;
    let e = 0.14;
    clamp01((x * (a * x + b)) / (x * (c * x + d) + e))
}

// ACES Hill (Stephen Hill 2016, improved fit)
fn aces_hill(x: f64) -> f64 {
    let a = 0.0245786;
    let b = 0.000090537;
    let c = 0.983729;
    let d = 0.4329510;
    let e = 0.238081;
    clamp01((x * (x + a) - b) / (x * (c * x + d) + e))
}

// Uncharted 2 / Hable
fn hable_partial(x: f64) -> f64 {
    let a = 0.15;
    let b = 0.50;
    let c = 0.10;
    let d = 0.20;
    let e = 0.02;
    let f = 0.30;
    ((x * (a * x + c * b) + d * e) / (x * (a * x + b) + d * f)) - e / f
}

fn hable(x: f64) -> f64 {
    let exposure_bias = 2.0;
    let curr = hable_partial(x * exposure_bias);
    let w = hable_partial(11.2);
    curr / w
}

// AgX base (Troy Sobotka)
fn agx_default(x: f64) -> f64 {
    let x_clamped = if x < 0.0 { 0.0 } else { x };
    let lx = if x_clamped > 0.0 { log(x_clamped) / log(2.0) } else { -14.0 };
    let val = (lx - (-12.47393)) / (4.026069 - (-12.47393));
    clamp01(val)
}

fn main() {
    // Reinhard
    println!("reinhard(0.0): {}", reinhard(0.0));
    println!("reinhard(0.18): {}", reinhard(0.18));
    println!("reinhard(1.0): {}", reinhard(1.0));
    println!("reinhard(10.0): {}", reinhard(10.0));

    // ACES
    println!("aces(0.18): {}", aces_filmic(0.18));
    println!("aces(1.0): {}", aces_filmic(1.0));

    // Hable
    println!("hable(0.18): {}", hable(0.18));
    println!("hable(1.0): {}", hable(1.0));

    // Verify monotonic and bounded for all operators
    let v0 = aces_filmic(0.1);
    let v1 = aces_filmic(1.0);
    let v2 = aces_filmic(10.0);
    if v0 < v1 {
        if v1 < v2 {
            if v2 <= 1.0 {
                println!("aces bounded monotonic: true");
            } else { println!("aces bounded monotonic: false"); }
        } else { println!("aces bounded monotonic: false"); }
    } else { println!("aces bounded monotonic: false"); }
}
