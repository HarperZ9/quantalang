fn main() {
    let t: bool = true;
    let f: bool = false;

    if t && f {
        println!("t && f = true");
    } else {
        println!("t && f = false");
    }

    if t || f {
        println!("t || f = true");
    } else {
        println!("t || f = false");
    }

    if !f {
        println!("!f = true");
    } else {
        println!("!f = false");
    }
}
