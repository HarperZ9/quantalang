// Test 71: Color space structs with operator overloading
// RGB color math using operator overloading for +/-

struct RGB {
    r: f64,
    g: f64,
    b: f64,
}

impl RGB {
    fn add(self, other: RGB) -> RGB {
        RGB { r: self.r + other.r, g: self.g + other.g, b: self.b + other.b }
    }

    fn sub(self, other: RGB) -> RGB {
        RGB { r: self.r - other.r, g: self.g - other.g, b: self.b - other.b }
    }

    fn mul(self, other: RGB) -> RGB {
        RGB { r: self.r * other.r, g: self.g * other.g, b: self.b * other.b }
    }
}

fn rgb_scale(c: RGB, factor: f64) -> RGB {
    RGB { r: c.r * factor, g: c.g * factor, b: c.b * factor }
}

fn rgb_luminance(c: RGB) -> f64 {
    0.2126 * c.r + 0.7152 * c.g + 0.0722 * c.b
}

fn srgb_to_linear(c: f64) -> f64 {
    if c <= 0.04045 {
        c / 12.92
    } else {
        pow((c + 0.055) / 1.055, 2.4)
    }
}

fn main() {
    // Color addition via operator overloading
    let red = RGB { r: 1.0, g: 0.0, b: 0.0 };
    let green = RGB { r: 0.0, g: 1.0, b: 0.0 };
    let yellow = red + green;
    println!("yellow: ({}, {}, {})", yellow.r, yellow.g, yellow.b);

    // Luminance
    let white = RGB { r: 1.0, g: 1.0, b: 1.0 };
    println!("white lum: {}", rgb_luminance(white));

    // Scale
    let white2 = RGB { r: 1.0, g: 1.0, b: 1.0 };
    let half = rgb_scale(white2, 0.5);
    println!("half: ({}, {}, {})", half.r, half.g, half.b);

    // Color subtraction
    let bright = RGB { r: 0.8, g: 0.6, b: 0.4 };
    let dim = RGB { r: 0.3, g: 0.2, b: 0.1 };
    let diff = bright - dim;
    println!("diff: ({}, {}, {})", diff.r, diff.g, diff.b);

    // sRGB to linear
    let linear_mid = srgb_to_linear(0.5);
    println!("linear(0.5): {}", linear_mid);
}
