fn main() {
    let a = vec3(1.0, 2.0, 3.0);
    let b = vec3(4.0, 5.0, 6.0);

    let sum = a + b;
    println!("sum: ({}, {}, {})", sum.x, sum.y, sum.z);

    let d = dot(a, b);
    println!("dot: {}", d);

    let c = cross(a, b);
    println!("cross: ({}, {}, {})", c.x, c.y, c.z);

    let n = normalize(a);
    println!("length of normalized: {}", length(n));

    let scaled = a * b;
    println!("component mul: ({}, {}, {})", scaled.x, scaled.y, scaled.z);
}
