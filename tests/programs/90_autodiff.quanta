// Test 90: quanta-oracle port — Automatic Differentiation
// Dual numbers with operator overloading for forward-mode AD
// Ported from APPS/quanta-oracle/quanta_oracle/autodiff.py

struct Dual {
    val: f64,
    deriv: f64,
}

impl Dual {
    fn add(self, other: Dual) -> Dual {
        Dual { val: self.val + other.val, deriv: self.deriv + other.deriv }
    }
    fn sub(self, other: Dual) -> Dual {
        Dual { val: self.val - other.val, deriv: self.deriv - other.deriv }
    }
    fn mul(self, other: Dual) -> Dual {
        // Product rule: (fg)' = f'g + fg'
        Dual {
            val: self.val * other.val,
            deriv: self.deriv * other.val + self.val * other.deriv,
        }
    }
    fn div(self, other: Dual) -> Dual {
        // Quotient rule: (f/g)' = (f'g - fg') / g^2
        Dual {
            val: self.val / other.val,
            deriv: (self.deriv * other.val - self.val * other.deriv) / (other.val * other.val),
        }
    }
}

fn dual_var(x: f64) -> Dual { Dual { val: x, deriv: 1.0 } }
fn dual_const(x: f64) -> Dual { Dual { val: x, deriv: 0.0 } }

fn dual_sin(d: Dual) -> Dual {
    Dual { val: sin(d.val), deriv: d.deriv * cos(d.val) }
}
fn dual_cos(d: Dual) -> Dual {
    Dual { val: cos(d.val), deriv: 0.0 - d.deriv * sin(d.val) }
}
fn dual_pow2(d: Dual) -> Dual {
    // d^2 derivative = 2*d*d'
    Dual { val: d.val * d.val, deriv: 2.0 * d.val * d.deriv }
}

fn main() {
    // f(x) = x^2 at x=3: f(3)=9, f'(3)=6
    let x = dual_var(3.0);
    let f1 = dual_pow2(x);
    println!("x^2 val: {}", f1.val);
    println!("x^2 deriv: {}", f1.deriv);

    // f(x) = x^2 + sin(x) at x=3: f'(3) = 2*3 + cos(3)
    let x2 = dual_var(3.0);
    let f2 = dual_pow2(x2) + dual_sin(x2);
    println!("x^2+sin(x) val: {}", f2.val);
    println!("x^2+sin(x) deriv: {}", f2.deriv);

    // f(x) = 3x + 2 at x=5: f'(5) = 3
    let x3 = dual_var(5.0);
    let f3 = dual_const(3.0) * x3 + dual_const(2.0);
    println!("3x+2 val: {}", f3.val);
    println!("3x+2 deriv: {}", f3.deriv);

    // f(x) = x / (1+x) at x=2: f'(x) = 1/(1+x)^2 = 1/9
    let x4 = dual_var(2.0);
    let f4 = x4 / (dual_const(1.0) + x4);
    println!("x/(1+x) val: {}", f4.val);
    println!("x/(1+x) deriv: {}", f4.deriv);

    // Chain: f(x) = sin(x^2) at x=1: f'(1) = cos(1)*2*1 = 2*cos(1)
    let x5 = dual_var(1.0);
    let f5 = dual_sin(dual_pow2(x5));
    println!("sin(x^2) deriv: {}", f5.deriv);
}
