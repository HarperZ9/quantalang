// Test 87: quanta-color port — Delta-E metrics
// Ported from APPS/quanta-color/quanta_color/difference.py
// CIE76, CIE94, and CIEDE2000

struct Lab { l: f64, a: f64, b: f64, }

// CIE76: simple Euclidean in Lab
fn delta_e_76(a: Lab, b: Lab) -> f64 {
    let dl = a.l - b.l;
    let da = a.a - b.a;
    let db = a.b - b.b;
    sqrt(dl * dl + da * da + db * db)
}

// CIE94 (graphic arts application)
fn delta_e_94(a: Lab, b: Lab) -> f64 {
    let dl = a.l - b.l;
    let c1 = sqrt(a.a * a.a + a.b * a.b);
    let c2 = sqrt(b.a * b.a + b.b * b.b);
    let dc = c1 - c2;
    let da = a.a - b.a;
    let db = a.b - b.b;
    let dh_sq = da * da + db * db - dc * dc;
    let dh_sq_safe = if dh_sq > 0.0 { dh_sq } else { 0.0 };

    let sl = 1.0;
    let sc = 1.0 + 0.045 * c1;
    let sh = 1.0 + 0.015 * c1;

    sqrt((dl / sl) * (dl / sl) + (dc / sc) * (dc / sc) + dh_sq_safe / (sh * sh))
}

// Simplified CIEDE2000 (scalar version)
fn delta_e_2000(lab1: Lab, lab2: Lab) -> f64 {
    let l1 = lab1.l;
    let a1 = lab1.a;
    let b1 = lab1.b;
    let l2 = lab2.l;
    let a2 = lab2.a;
    let b2 = lab2.b;

    let c1 = sqrt(a1 * a1 + b1 * b1);
    let c2 = sqrt(a2 * a2 + b2 * b2);
    let c_avg = (c1 + c2) / 2.0;
    let c_avg7 = pow(c_avg, 7.0);
    let g = 0.5 * (1.0 - sqrt(c_avg7 / (c_avg7 + pow(25.0, 7.0))));

    let a1p = a1 * (1.0 + g);
    let a2p = a2 * (1.0 + g);
    let c1p = sqrt(a1p * a1p + b1 * b1);
    let c2p = sqrt(a2p * a2p + b2 * b2);

    let dl = l2 - l1;
    let dc = c2p - c1p;

    let l_avg = (l1 + l2) / 2.0;
    let c_avg_p = (c1p + c2p) / 2.0;

    let sl = 1.0 + 0.015 * (l_avg - 50.0) * (l_avg - 50.0) / sqrt(20.0 + (l_avg - 50.0) * (l_avg - 50.0));
    let sc = 1.0 + 0.045 * c_avg_p;
    let sh = 1.0 + 0.015 * c_avg_p;

    sqrt((dl / sl) * (dl / sl) + (dc / sc) * (dc / sc))
}

fn main() {
    // Identical colors
    let a = Lab { l: 50.0, a: 0.0, b: 0.0 };
    let b = Lab { l: 50.0, a: 0.0, b: 0.0 };
    println!("identical dE76: {}", delta_e_76(a, b));

    // JND (just noticeable difference)
    let c = Lab { l: 50.0, a: 0.0, b: 0.0 };
    let d = Lab { l: 51.0, a: 0.0, b: 0.0 };
    println!("JND dE76: {}", delta_e_76(c, d));

    // Large difference (red vs blue)
    let red = Lab { l: 53.23, a: 80.11, b: 67.22 };
    let blue = Lab { l: 32.30, a: 79.20, b: -107.86 };
    println!("red-blue dE76: {}", delta_e_76(red, blue));

    // CIE94
    let e = Lab { l: 50.0, a: 2.5, b: 0.0 };
    let f = Lab { l: 50.0, a: 0.0, b: 0.0 };
    println!("small dE94: {}", delta_e_94(e, f));

    // CIEDE2000
    let g = Lab { l: 50.0, a: 2.5, b: 0.0 };
    let h = Lab { l: 50.0, a: 0.0, b: 0.0 };
    println!("small dE2000: {}", delta_e_2000(g, h));

    // Verify dE2000 < dE76 for same pair (perceptual weighting)
    let de76 = delta_e_76(g, h);
    let de2000 = delta_e_2000(g, h);
    if de2000 <= de76 {
        println!("dE2000 <= dE76: true");
    } else {
        println!("dE2000 <= dE76: false");
    }
}
