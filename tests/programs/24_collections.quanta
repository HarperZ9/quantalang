// Test 24: Collection patterns using arrays and helper functions
// Demonstrates array iteration, aggregation, and search operations

fn sum_array(arr: [i32; 5], len: i32) -> i32 {
    let mut total: i32 = 0;
    let mut i: i32 = 0;
    while i < len {
        total = total + arr[i];
        i = i + 1;
    }
    total
}

fn find_max(arr: [i32; 5], len: i32) -> i32 {
    let mut max_val: i32 = arr[0];
    let mut i: i32 = 1;
    while i < len {
        if arr[i] > max_val {
            max_val = arr[i];
        }
        i = i + 1;
    }
    max_val
}

fn find_min(arr: [i32; 5], len: i32) -> i32 {
    let mut min_val: i32 = arr[0];
    let mut i: i32 = 1;
    while i < len {
        if arr[i] < min_val {
            min_val = arr[i];
        }
        i = i + 1;
    }
    min_val
}

fn contains(arr: [i32; 5], len: i32, target: i32) -> bool {
    let mut i: i32 = 0;
    while i < len {
        if arr[i] == target {
            return true;
        }
        i = i + 1;
    }
    false
}

fn count_above(arr: [i32; 5], len: i32, threshold: i32) -> i32 {
    let mut count: i32 = 0;
    let mut i: i32 = 0;
    while i < len {
        if arr[i] > threshold {
            count = count + 1;
        }
        i = i + 1;
    }
    count
}

fn main() {
    let data = [10, 20, 30, 40, 50];
    let len: i32 = 5;

    let total = sum_array(data, len);
    println!("Sum: {}", total);
    println!("Count: {}", len);
    println!("Average: {}", total / len);
    println!("Max: {}", find_max(data, len));
    println!("Min: {}", find_min(data, len));

    if contains(data, len, 30) {
        println!("Contains 30: true");
    } else {
        println!("Contains 30: false");
    }

    if contains(data, len, 25) {
        println!("Contains 25: true");
    } else {
        println!("Contains 25: false");
    }

    println!("Above 25: {}", count_above(data, len, 25));
}
