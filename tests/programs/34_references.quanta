fn add_to(x: &mut i32, amount: i32) {
    *x = *x + amount;
}

fn read_value(x: &i32) -> i32 {
    *x
}

fn main() {
    let mut n: i32 = 10;
    add_to(&mut n, 5);
    println!("After add: {}", n);

    let val = read_value(&n);
    println!("Read: {}", val);

    add_to(&mut n, 100);
    println!("Final: {}", n);
}
