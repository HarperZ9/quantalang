// Test 93: quanta-oracle port — Classical time series decomposition
// Additive: data = trend + seasonal + residual
// Ported from APPS/quanta-oracle/quanta_oracle/decompose.py

// Simple moving average for trend extraction
fn moving_average_at6(data: [f64; 12]) -> f64 {
    // Compute centered moving average at position 6 (window=5)
    let sum = data[4] + data[5] + data[6] + data[7] + data[8];
    sum / 5.0
}

fn main() {
    // Monthly data with trend + seasonal pattern
    // Trend: ~10 + 0.5*month
    // Seasonal: +2 in summer (months 5-8), -2 in winter (months 11,12,1,2)
    let data = [8.5, 9.0, 10.5, 11.0, 13.5, 14.0, 14.5, 15.0, 12.5, 13.0, 11.5, 10.0];

    // Compute overall mean
    let mut mean = 0.0;
    let mut i = 0;
    while i < 12 { mean = mean + data[i]; i = i + 1; }
    mean = mean / 12.0;
    println!("mean: {}", mean);

    // Trend at midpoint (moving average, window=5)
    let trend = moving_average_at6(data);
    println!("trend(mid): {}", trend);

    // Seasonal component at each position: data - trend estimate
    // For simplicity, compute seasonal indices for Q1-Q4
    let q1 = (data[0] + data[1] + data[2]) / 3.0;
    let q2 = (data[3] + data[4] + data[5]) / 3.0;
    let q3 = (data[6] + data[7] + data[8]) / 3.0;
    let q4 = (data[9] + data[10] + data[11]) / 3.0;
    println!("Q1 avg: {}", q1);
    println!("Q2 avg: {}", q2);
    println!("Q3 avg: {}", q3);
    println!("Q4 avg: {}", q4);

    // Seasonal indices (deviation from mean)
    let s1 = q1 - mean;
    let s2 = q2 - mean;
    let s3 = q3 - mean;
    let s4 = q4 - mean;
    println!("seasonal Q1: {}", s1);
    println!("seasonal Q2: {}", s2);

    // Verify: Q2 (spring/summer) should be above mean
    if s2 > 0.0 {
        println!("Q2 above mean: true");
    } else {
        println!("Q2 above mean: false");
    }

    // Verify: Q1 (winter) should be below mean
    if s1 < 0.0 {
        println!("Q1 below mean: true");
    } else {
        println!("Q1 below mean: false");
    }
}
