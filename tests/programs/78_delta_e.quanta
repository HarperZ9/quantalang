// Test 78: CIE76 Delta-E color difference
// Port of color_math.py delta-E calculations in QuantaLang

// Lab color space (perceptually uniform)
struct Lab {
    l: f64,
    a: f64,
    b: f64,
}

// sRGB to linear
fn srgb_to_linear(c: f64) -> f64 {
    if c <= 0.04045 {
        c / 12.92
    } else {
        pow((c + 0.055) / 1.055, 2.4)
    }
}

// sRGB to XYZ (D65 illuminant)
fn srgb_to_xyz_y(r: f64, g: f64, b: f64) -> f64 {
    let rl = srgb_to_linear(r);
    let gl = srgb_to_linear(g);
    let bl = srgb_to_linear(b);
    0.2126 * rl + 0.7152 * gl + 0.0722 * bl
}

// Simplified sRGB to Lab L* component
fn srgb_to_lab_l(r: f64, g: f64, b: f64) -> f64 {
    let y = srgb_to_xyz_y(r, g, b);
    if y > 0.008856 {
        116.0 * pow(y, 1.0 / 3.0) - 16.0
    } else {
        903.3 * y
    }
}

// CIE76 Delta-E: Euclidean distance in Lab space
fn delta_e_76(lab1: Lab, lab2: Lab) -> f64 {
    let dl = lab1.l - lab2.l;
    let da = lab1.a - lab2.a;
    let db = lab1.b - lab2.b;
    sqrt(dl * dl + da * da + db * db)
}

fn main() {
    // Test 1: Identical colors have delta-E = 0
    let white1 = Lab { l: 100.0, a: 0.0, b: 0.0 };
    let white2 = Lab { l: 100.0, a: 0.0, b: 0.0 };
    let de0 = delta_e_76(white1, white2);
    println!("identical: {}", de0);

    // Test 2: Just noticeable difference (~1.0)
    let ref_color = Lab { l: 50.0, a: 0.0, b: 0.0 };
    let jnd = Lab { l: 51.0, a: 0.0, b: 0.0 };
    let de1 = delta_e_76(ref_color, jnd);
    println!("JND: {}", de1);

    // Test 3: Large difference
    let red_lab = Lab { l: 53.23, a: 80.11, b: 67.22 };
    let blue_lab = Lab { l: 32.30, a: 79.20, b: -107.86 };
    let de_large = delta_e_76(red_lab, blue_lab);
    println!("red-blue: {}", de_large);

    // Test 4: Lab L* from sRGB
    let l_white = srgb_to_lab_l(1.0, 1.0, 1.0);
    println!("L*(white): {}", l_white);

    let l_mid = srgb_to_lab_l(0.5, 0.5, 0.5);
    println!("L*(mid): {}", l_mid);

    // Test 5: Perceptually similar (delta-E < 2)
    let sample1 = Lab { l: 50.0, a: 2.5, b: 0.0 };
    let sample2 = Lab { l: 50.0, a: 0.0, b: 0.0 };
    let de_similar = delta_e_76(sample1, sample2);
    if de_similar < 3.0 {
        println!("similar: true");
    } else {
        println!("similar: false");
    }
}
