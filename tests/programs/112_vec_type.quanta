fn main() {
    // vec![] literal
    let mut v = vec![1, 2, 3];
    assert(vec_len(v) == 3);
    assert(vec_get(v, 0) == 1);
    assert(vec_get(v, 2) == 3);

    // push
    vec_push(v, 4);
    assert(vec_len(v) == 4);
    assert(vec_get(v, 3) == 4);

    // vec![val; count] repeat
    let zeros = vec![0; 5];
    assert(vec_len(zeros) == 5);
    assert(vec_get(zeros, 0) == 0);
    assert(vec_get(zeros, 4) == 0);

    // f64 vec literal (uses f64 runtime variants)
    let fv = vec![1.0, 2.0, 3.0];
    assert(vec_len(fv) == 3);

    // f64 vec repeat
    let fzeros = vec![0.0; 4];
    assert(vec_len(fzeros) == 4);

    println!("Vec type tests passed!");
}
