// Test 70: Operator overloading via impl methods
// a + b resolves to a.add(b) for custom types

struct Vec2 {
    x: f64,
    y: f64,
}

impl Vec2 {
    fn add(self, other: Vec2) -> Vec2 {
        Vec2 { x: self.x + other.x, y: self.y + other.y }
    }

    fn sub(self, other: Vec2) -> Vec2 {
        Vec2 { x: self.x - other.x, y: self.y - other.y }
    }

    fn mul(self, other: Vec2) -> Vec2 {
        Vec2 { x: self.x * other.x, y: self.y * other.y }
    }
}

fn main() {
    let a = Vec2 { x: 1.0, y: 2.0 };
    let b = Vec2 { x: 3.0, y: 4.0 };

    // Operator overloading: + calls Vec2_add
    let c = a + b;
    println!("add: ({}, {})", c.x, c.y);

    let d = Vec2 { x: 10.0, y: 20.0 };
    let e = Vec2 { x: 3.0, y: 5.0 };

    // Subtraction
    let f = d - e;
    println!("sub: ({}, {})", f.x, f.y);

    // Multiplication
    let g = Vec2 { x: 2.0, y: 3.0 };
    let h = Vec2 { x: 4.0, y: 5.0 };
    let i = g * h;
    println!("mul: ({}, {})", i.x, i.y);
}
