// Test 94: quanta-finance port — Technical indicators
// SMA, EMA, RSI on price data

fn sma5(data: [f64; 10]) -> f64 {
    // SMA over last 5 values
    (data[5] + data[6] + data[7] + data[8] + data[9]) / 5.0
}

fn sma3_at4(data: [f64; 10]) -> f64 {
    (data[2] + data[3] + data[4]) / 3.0
}

fn sma3_last(data: [f64; 10]) -> f64 {
    (data[7] + data[8] + data[9]) / 3.0
}

// EMA(5) iterative
fn ema5(data: [f64; 10]) -> f64 {
    let alpha = 2.0 / 6.0; // 2/(5+1)
    // Seed: SMA of first 5
    let mut result = (data[0] + data[1] + data[2] + data[3] + data[4]) / 5.0;
    let mut i = 5;
    while i < 10 {
        result = alpha * data[i] + (1.0 - alpha) * result;
        i = i + 1;
    }
    result
}

// RSI(5) — Wilder smoothing
fn rsi5(data: [f64; 10]) -> f64 {
    let mut avg_gain = 0.0;
    let mut avg_loss = 0.0;

    // Initial: first 5 changes
    let mut i = 1;
    while i <= 5 {
        let change = data[i] - data[i - 1];
        if change > 0.0 { avg_gain = avg_gain + change; }
        else { avg_loss = avg_loss - change; }
        i = i + 1;
    }
    avg_gain = avg_gain / 5.0;
    avg_loss = avg_loss / 5.0;

    // Smooth remaining
    while i < 10 {
        let change = data[i] - data[i - 1];
        if change > 0.0 {
            avg_gain = (avg_gain * 4.0 + change) / 5.0;
            avg_loss = (avg_loss * 4.0) / 5.0;
        } else {
            avg_gain = (avg_gain * 4.0) / 5.0;
            avg_loss = (avg_loss * 4.0 - change) / 5.0;
        }
        i = i + 1;
    }

    if avg_loss < 0.0001 { 100.0 }
    else {
        let rs = avg_gain / avg_loss;
        100.0 - 100.0 / (1.0 + rs)
    }
}

fn main() {
    let prices = [100.0, 102.0, 104.0, 103.0, 105.0, 107.0, 106.0, 108.0, 110.0, 109.0];

    println!("SMA(5): {}", sma5(prices));
    println!("SMA(3)@4: {}", sma3_at4(prices));
    println!("EMA(5): {}", ema5(prices));

    let r = rsi5(prices);
    println!("RSI(5): {}", r);

    if r > 50.0 {
        println!("uptrend confirmed: true");
    } else {
        println!("uptrend confirmed: false");
    }

    let s3 = sma3_last(prices);
    let s5 = sma5(prices);
    if s3 > s5 {
        println!("bullish crossover: true");
    } else {
        println!("bullish crossover: false");
    }
}
