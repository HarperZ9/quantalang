// Test 89: ACES tone mapping — the first real-world QuantaLang program
// Verifies that the ACES filmic tone curve produces correct output.

const RRT_A: f64 = 2.51;
const RRT_B: f64 = 0.03;
const RRT_C: f64 = 2.43;
const RRT_D: f64 = 0.59;
const RRT_E: f64 = 0.14;

pub fn aces_tonemap(x: f64) -> f64 {
    let num = x * (RRT_A * x + RRT_B);
    let den = x * (RRT_C * x + RRT_D) + RRT_E;
    num / den
}

pub fn tonemap_reinhard(x: f64) -> f64 {
    x / (1.0 + x)
}

struct Color3 { r: f64, g: f64, b: f64 }

impl Color3 {
    fn new(r: f64, g: f64, b: f64) -> Self { Self { r: r, g: g, b: b } }
}

pub fn rrt(scene: Color3) -> Color3 {
    Color3::new(aces_tonemap(scene.r), aces_tonemap(scene.g), aces_tonemap(scene.b))
}

fn main() {
    // Test tone mapping at various input levels
    println!("ACES(0.1): {}", aces_tonemap(0.1));
    println!("ACES(0.5): {}", aces_tonemap(0.5));
    println!("ACES(1.0): {}", aces_tonemap(1.0));
    println!("ACES(3.0): {}", aces_tonemap(3.0));
    println!("Reinhard(3.0): {}", tonemap_reinhard(3.0));

    // Test on a color
    let scene = Color3::new(2.5, 1.8, 0.6);
    let mapped = rrt(scene);
    println!("RRT R: {}", mapped.r);
    println!("RRT G: {}", mapped.g);
    println!("RRT B: {}", mapped.b);
}
