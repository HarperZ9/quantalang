// Test 56: Methods on generic types
// impl<T> Option<T> with unwrap_or, is_some, is_none

enum Option<T> {
    Some(T),
    None,
}

impl<T> Option<T> {
    fn unwrap_or(self, fallback: T) -> T {
        match self {
            Option::Some(val) => val,
            Option::None => fallback,
        }
    }

    fn is_some(self) -> i32 {
        match self {
            Option::Some(val) => 1,
            Option::None => 0,
        }
    }
}

struct Pair<T> {
    first: T,
    second: T,
}

impl<T> Pair<T> {
    fn get_first(self) -> T {
        self.first
    }

    fn get_second(self) -> T {
        self.second
    }
}

fn main() {
    let some_val = Option::Some(42);
    let none_val = Option::None;

    println!("unwrap Some: {}", some_val.unwrap_or(0));
    println!("unwrap None: {}", none_val.unwrap_or(99));

    let another = Option::Some(7);
    println!("is_some: {}", another.is_some());

    let p = Pair { first: 10, second: 20 };
    println!("first: {}", p.get_first());

    let p2 = Pair { first: 100, second: 200 };
    println!("second: {}", p2.get_second());
}
