// Test 47: Uniform buffer and shader stage attributes
// Tests: #[vertex] attribute, #[fragment] attribute, uniform struct concept
// For C backend: shader functions compile as regular functions for CPU testing

struct CameraData {
    fov: f64,
    aspect: f64,
    near: f64,
    far: f64,
}

// Simulate what a vertex shader does on CPU
fn transform_vertex(pos_x: f64, pos_y: f64, pos_z: f64, scale: f64) -> f64 {
    // Simple perspective-like transform: divide by z
    let clip_x = pos_x * scale;
    let clip_y = pos_y * scale;
    let clip_z = pos_z * scale;
    // Return projected x coordinate
    clip_x / (clip_z + 1.0)
}

// Simulate MVP matrix multiply on CPU
fn apply_mvp(x: f64, y: f64, z: f64, cam: CameraData) -> f64 {
    let scale = 1.0 / cam.fov;
    let projected = transform_vertex(x, y, z, scale);
    projected * cam.aspect
}

fn main() {
    // Test camera data (simulating uniform buffer content)
    let camera = CameraData {
        fov: 1.5708,
        aspect: 1.7778,
        near: 0.1,
        far: 100.0,
    };

    // Test vertex transform with uniform data
    let v1 = apply_mvp(1.0, 0.0, 0.0, camera);
    let v2 = apply_mvp(0.5, 1.0, 2.0, camera);
    let v3 = apply_mvp(-0.5, -0.5, 1.0, camera);

    println!("Uniform buffer test:");
    println!("Camera FOV: {}", camera.fov);
    println!("Camera aspect: {}", camera.aspect);

    // Verify transforms produce reasonable results
    if v1 > 0.0 {
        println!("V1 transform: positive (correct)");
    } else {
        println!("V1 transform: negative (wrong)");
    }

    if v2 > 0.0 {
        println!("V2 transform: positive (correct)");
    } else {
        println!("V2 transform: negative (wrong)");
    }

    if v3 < 0.0 {
        println!("V3 transform: negative (correct)");
    } else {
        println!("V3 transform: positive (wrong)");
    }

    // Test that near < far (basic validation)
    if camera.near < camera.far {
        println!("Near/far valid: yes");
    } else {
        println!("Near/far valid: no");
    }

    println!("Uniform buffer test complete");
}
