// Test 59: Multi-module imports
// Two modules loaded, functions called via module::function paths

mod math_helpers;
mod string_utils;

fn main() {
    // Call function from first module
    let sum = math_helpers::add(10, 20);
    println!("add: {}", sum);

    // Call functions from second module
    let g = string_utils::greet(5);
    println!("greet: {}", g);

    let d = string_utils::double(7);
    println!("double: {}", d);

    // Use results together
    let combined = math_helpers::add(g, d);
    println!("combined: {}", combined);
}
