// Test 76: Color grading pipeline
// Exposure, tone mapping (Reinhard, ACES filmic), contrast, saturation

fn apply_exposure(color: f64, ev: f64) -> f64 {
    color * pow(2.0, ev)
}

fn tonemap_reinhard(x: f64) -> f64 {
    x / (1.0 + x)
}

fn tonemap_aces(x: f64) -> f64 {
    // Simplified ACES filmic curve
    let a = 2.51;
    let b = 0.03;
    let c = 2.43;
    let d = 0.59;
    let e = 0.14;
    let num = x * (a * x + b);
    let den = x * (c * x + d) + e;
    let result = num / den;
    // Clamp to [0, 1]
    if result < 0.0 {
        0.0
    } else {
        if result > 1.0 {
            1.0
        } else {
            result
        }
    }
}

fn adjust_contrast(color: f64, contrast: f64) -> f64 {
    (color - 0.5) * contrast + 0.5
}

fn adjust_saturation(r: f64, g: f64, b: f64, sat: f64) -> f64 {
    let lum = 0.2126 * r + 0.7152 * g + 0.0722 * b;
    lum + (r - lum) * sat
}

fn main() {
    // Exposure: +2 EV doubles twice
    let exposed = apply_exposure(0.18, 2.0);
    println!("expose +2EV: {}", exposed);

    // Reinhard tone mapping
    let ldr = tonemap_reinhard(4.0);
    println!("reinhard(4.0): {}", ldr);

    // ACES filmic
    let aces = tonemap_aces(1.0);
    println!("aces(1.0): {}", aces);

    // HDR pipeline: expose -> tonemap
    let hdr = 0.18;
    let pipeline = tonemap_aces(apply_exposure(hdr, 3.0));
    println!("pipeline(0.18, +3EV): {}", pipeline);

    // Contrast
    let mid = adjust_contrast(0.5, 1.5);
    println!("contrast(0.5, 1.5): {}", mid);

    // Dark value with contrast
    let dark = adjust_contrast(0.2, 1.5);
    println!("contrast(0.2, 1.5): {}", dark);

    // Saturation
    let sat_r = adjust_saturation(0.8, 0.2, 0.1, 1.5);
    println!("saturation boost: {}", sat_r);
}
