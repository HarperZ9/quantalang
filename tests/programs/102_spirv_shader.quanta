// Test 102: Compile a real shader function to SPIR-V
// This is the Pillar 1A proof: QuantaLang source → valid SPIR-V binary
// Uses the PBR BRDF functions from test 75

#[fragment]
fn shade_fragment(uv_x: f64, uv_y: f64) -> f64 {
    // Fresnel-Schlick approximation
    let f0 = 0.04;
    let cos_theta = uv_x;
    let base = 1.0 - cos_theta;
    let base2 = base * base;
    let base5 = base2 * base2 * base;
    let fresnel = f0 + (1.0 - f0) * base5;

    // Simple GGX NDF
    let roughness = uv_y;
    let a = roughness * roughness;
    let a2 = a * a;
    let n_dot_h = 0.9;
    let denom = n_dot_h * n_dot_h * (a2 - 1.0) + 1.0;
    let ndf = a2 / (3.14159 * denom * denom);

    fresnel * ndf
}

fn main() {
    // CPU-side test: verify the shader math produces correct values
    let f = shade_fragment(0.5, 0.3);
    println!("shade(0.5, 0.3): {}", f);

    // Verify Fresnel at normal incidence
    let f0 = shade_fragment(1.0, 0.3);
    println!("shade(1.0, 0.3): {}", f0);
}
