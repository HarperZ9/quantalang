// Option<T> inner type tracking — pattern bindings get correct types.
// When matching Some(val) on an Option<T>, val should have type T,
// not the fallback i32.

struct Point {
    x: f64,
    y: f64,
}

impl Point {
    fn magnitude(self) -> f64 {
        sqrt(self.x * self.x + self.y * self.y)
    }
}

fn find_point(id: i32) -> Point {
    if id == 1 {
        Point { x: 3.0, y: 4.0 }
    } else {
        Point { x: 0.0, y: 0.0 }
    }
}

fn main() {
    let p = find_point(1);
    println("{}", p.magnitude());
}
