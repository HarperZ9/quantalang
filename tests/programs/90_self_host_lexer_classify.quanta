// Test 90: Self-hosting lexer character classification
// This is the core logic that a self-hosted lexer needs: classify
// characters into categories using range patterns, then build tokens.

struct Lexer {
    source: i64,
    pos: i64,
    len: i64,
}

impl Lexer {
    fn new(len: i64) -> Self {
        Self { source: 0, pos: 0, len: len }
    }

    fn peek(self: &Self) -> i64 {
        self.pos
    }

    fn advance(self: &mut Self) {
        self.pos = self.pos + 1;
    }

    fn is_eof(self: &Self) -> bool {
        self.pos >= self.len
    }

    fn classify(c: i32) -> i32 {
        match c {
            // Digits 0-9
            48..=57 => 1,
            // Uppercase A-Z
            65..=90 => 2,
            // Lowercase a-z
            97..=122 => 3,
            // Underscore
            95 => 4,
            // Whitespace (space, tab, newline, carriage return)
            32 => 5,
            9 => 5,
            10 => 5,
            13 => 5,
            // Operators
            43 => 6,  // +
            45 => 6,  // -
            42 => 6,  // *
            47 => 6,  // /
            61 => 7,  // =
            60 => 7,  // <
            62 => 7,  // >
            33 => 7,  // !
            // Delimiters
            40 => 8,  // (
            41 => 8,  // )
            123 => 8, // {
            125 => 8, // }
            91 => 8,  // [
            93 => 8,  // ]
            // Punctuation
            44 => 9,  // ,
            59 => 9,  // ;
            58 => 9,  // :
            46 => 9,  // .
            // String delimiter
            34 => 10, // "
            // Unknown
            _ => 0,
        }
    }

    fn class_name(class: i32) -> i64 {
        match class {
            1 => 100,  // digit
            2 => 200,  // upper
            3 => 300,  // lower
            4 => 400,  // underscore
            5 => 500,  // whitespace
            6 => 600,  // operator
            7 => 700,  // comparison
            8 => 800,  // delimiter
            9 => 900,  // punctuation
            10 => 1000, // string
            _ => 0,    // unknown
        }
    }
}

fn main() {
    // Test character classification
    println!("=== Lexer Character Classification ===");

    // Digits
    println!("'0' (48): {}", Lexer::classify(48));
    println!("'5' (53): {}", Lexer::classify(53));
    println!("'9' (57): {}", Lexer::classify(57));

    // Letters
    println!("'A' (65): {}", Lexer::classify(65));
    println!("'Z' (90): {}", Lexer::classify(90));
    println!("'a' (97): {}", Lexer::classify(97));
    println!("'z' (122): {}", Lexer::classify(122));

    // Special
    println!("'_' (95): {}", Lexer::classify(95));
    println!("' ' (32): {}", Lexer::classify(32));
    println!("'+' (43): {}", Lexer::classify(43));
    println!("'=' (61): {}", Lexer::classify(61));
    println!("'(' (40): {}", Lexer::classify(40));
    println!("',' (44): {}", Lexer::classify(44));

    // Test lexer state
    println!("");
    println!("=== Lexer State ===");
    let mut lex = Lexer::new(10);
    println!("pos: {}", lex.peek());
    println!("eof: {}", lex.is_eof());
    lex.advance();
    lex.advance();
    lex.advance();
    println!("after 3 advances: {}", lex.peek());
    println!("eof: {}", lex.is_eof());
}
