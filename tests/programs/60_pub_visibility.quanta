// Test 60: pub visibility on functions
// pub functions are exported, private ones are internal

pub fn visible_add(a: i32, b: i32) -> i32 {
    a + b
}

fn helper(x: i32) -> i32 {
    x * 3
}

pub fn compute(x: i32) -> i32 {
    helper(x) + visible_add(x, 10)
}

fn main() {
    let a = visible_add(5, 10);
    println!("visible_add: {}", a);

    let b = helper(7);
    println!("helper: {}", b);

    let c = compute(4);
    println!("compute: {}", c);
}
