fn main() {
    // Test 1: Variable declared before while, used after
    let mut sum: i32 = 0;
    let mut i: i32 = 0;
    while i < 5 {
        sum = sum + i;
        i = i + 1;
    }
    assert!(sum == 10);
    assert!(i == 5);

    // Test 2: let inside while body does NOT shadow outer variable after loop
    let mut x: i32 = 100;
    let mut j: i32 = 0;
    while j < 3 {
        let x: i32 = j * 10;
        j = j + 1;
    }
    assert!(x == 100);
    assert!(j == 3);

    // Test 3: Nested while loops
    let mut total: i32 = 0;
    let mut a: i32 = 0;
    while a < 3 {
        let mut b: i32 = 0;
        while b < 4 {
            total = total + 1;
            b = b + 1;
        }
        a = a + 1;
    }
    assert!(total == 12);

    println!("While scope tests passed!");
}
