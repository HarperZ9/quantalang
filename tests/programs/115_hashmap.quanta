fn main() {
    let m = map_new();
    map_insert(m, "hello", 1.0);
    map_insert(m, "world", 2.0);

    assert(map_len(m) == 2);
    assert(map_get(m, "hello") == 1.0);
    assert(map_get(m, "world") == 2.0);
    assert(map_contains(m, "hello") == true);
    assert(map_contains(m, "missing") == false);

    map_insert(m, "hello", 99.0);
    assert(map_get(m, "hello") == 99.0);
    assert(map_len(m) == 2);

    map_remove(m, "world");
    assert(map_len(m) == 1);
    assert(map_contains(m, "world") == false);

    println("HashMap tests passed!");
}
