// ACES Filmic Tone Mapping
// The industry standard for HDR-to-LDR conversion
// Used in Unreal Engine, Unity, and most AAA games

// Per-component ACES curve: (x * (2.51x + 0.03)) / (x * (2.43x + 0.59) + 0.14)
fn aces_channel(x: f64) -> f64 {
    let a = 2.51;
    let b = 0.03;
    let c = 2.43;
    let d = 0.59;
    let e = 0.14;

    let num = x * (a * x + b);
    let den = x * (c * x + d) + e;
    let result = num / den;

    // Clamp to 0-1
    if result > 1.0 { 1.0 } else { if result < 0.0 { 0.0 } else { result } }
}

// Reinhard per-component: x / (1 + x)
fn reinhard_channel(x: f64) -> f64 {
    x / (1.0 + x)
}

fn main() {
    let hdr_color = vec3(2.0, 1.5, 0.8);

    println!("HDR input: ({}, {}, {})", hdr_color.x, hdr_color.y, hdr_color.z);

    // ACES tone mapping — component-wise
    let aces = vec3(
        aces_channel(hdr_color.x),
        aces_channel(hdr_color.y),
        aces_channel(hdr_color.z)
    );
    println!("ACES: ({}, {}, {})", aces.x, aces.y, aces.z);

    // Reinhard tone mapping — component-wise
    let reinhard = vec3(
        reinhard_channel(hdr_color.x),
        reinhard_channel(hdr_color.y),
        reinhard_channel(hdr_color.z)
    );
    println!("Reinhard: ({}, {}, {})", reinhard.x, reinhard.y, reinhard.z);
}
