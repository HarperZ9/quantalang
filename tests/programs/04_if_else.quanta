fn max(a: i32, b: i32) -> i32 {
    if a > b {
        a
    } else {
        b
    }
}

fn main() {
    let bigger: i32 = max(10, 20);
    println!("Max: {}", bigger);

    let x: i32 = 15;
    if x > 10 {
        println!("x is greater than 10");
    } else {
        println!("x is 10 or less");
    }
}
