// Lifetime Elision — single ref param rule.
// fn identity(x: &i32) -> &i32 has no explicit lifetimes.
// Elision rule: single ref param → return borrows from it.
// This should compile correctly without explicit 'a annotations.

fn identity(x: &i32) -> &i32 {
    x
}

fn add_ref(x: &i32, y: i32) -> &i32 {
    x
}

fn main() {
    let a: i32 = 42;
    let r: &i32 = identity(&a);
    let val: i32 = *r;
    println("{}", val);

    let b: i32 = 10;
    let r2: &i32 = add_ref(&b, 5);
    println("{}", *r2);
}
