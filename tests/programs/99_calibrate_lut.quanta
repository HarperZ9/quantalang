// Test 99: calibrate-pro port — 3D LUT generation
// Generate a small 5-point LUT and verify interpolation + .cube write

fn gamma_correct(c: f64, gamma: f64) -> f64 {
    if c <= 0.0 { 0.0 }
    else { pow(c, gamma) }
}

fn clamp01(x: f64) -> f64 {
    if x < 0.0 { 0.0 } else { if x > 1.0 { 1.0 } else { x } }
}

// Apply a warm color correction
fn warm_correct(r: f64, g: f64, b: f64) -> f64 {
    // Return corrected R channel (slight boost)
    clamp01(gamma_correct(r, 0.95) * 1.02)
}

fn lerp(a: f64, b: f64, t: f64) -> f64 {
    a + (b - a) * t
}

fn main() {
    // Generate 5-point 1D LUT (simplified from 17³)
    let lut0 = gamma_correct(0.0, 2.2);
    let lut1 = gamma_correct(0.25, 2.2);
    let lut2 = gamma_correct(0.5, 2.2);
    let lut3 = gamma_correct(0.75, 2.2);
    let lut4 = gamma_correct(1.0, 2.2);

    println!("LUT[0]: {}", lut0);
    println!("LUT[1]: {}", lut1);
    println!("LUT[2]: {}", lut2);
    println!("LUT[3]: {}", lut3);
    println!("LUT[4]: {}", lut4);

    // Interpolation between LUT points
    let interp_37 = lerp(lut1, lut2, 0.5);
    println!("interp(0.375): {}", interp_37);

    // Write .cube file header
    let wrote = write_file("/tmp/quanta_test_99.cube",
        "# Calibrate Pro QuantaLang LUT\nTITLE \"Test LUT\"\nLUT_3D_SIZE 5\n0.000 0.000 0.000\n0.250 0.250 0.250\n0.500 0.500 0.500\n0.750 0.750 0.750\n1.000 1.000 1.000\n");
    println!("wrote cube: {}", wrote);
    println!("cube exists: {}", file_exists("/tmp/quanta_test_99.cube"));

    // Warm correction
    let warm_r = warm_correct(0.5, 0.5, 0.5);
    println!("warm R(0.5): {}", warm_r);

    // Verify LUT is monotonic
    if lut1 > lut0 {
        if lut2 > lut1 {
            if lut3 > lut2 {
                println!("monotonic: true");
            } else { println!("monotonic: false"); }
        } else { println!("monotonic: false"); }
    } else { println!("monotonic: false"); }
}
