// ═══════════════════════════════════════════════════════════════════════════════
// Self-hosting Phase 6, Step 1: Option type from stdlib/core/option.quanta
// ═══════════════════════════════════════════════════════════════════════════════
//
// This is a simplified monomorphized version of the self-hosted Option<T>
// from quantalang/stdlib/core/option.quanta.
//
// Original uses: generic enum Option<T>, trait bounds (Copy, Clone, Deref),
//   closures as parameters (FnOnce), associated types, ? operator (Try trait),
//   never type (!), derive macros, lang items, references (&self, &mut self).
//
// Simplified here: monomorphized to i32, uses value self, no generics,
//   no trait bounds, no closures in signatures, no references.
//
// This proves the compiler can handle the CORE LOGIC of the stdlib Option type.
// ═══════════════════════════════════════════════════════════════════════════════

// Adapted from: quantalang/stdlib/core/option.quanta lines 38-43
enum Option {
    None,
    Some(i32),
}

impl Option {
    // Adapted from: option.quanta line 55-57
    fn is_some(self) -> bool {
        match self {
            Option::Some(_) => true,
            Option::None => false,
        }
    }

    // Adapted from: option.quanta line 61-63
    fn is_none(self) -> bool {
        match self {
            Option::Some(_) => false,
            Option::None => true,
        }
    }

    // Adapted from: option.quanta line 104-108
    fn unwrap_or(self, fallback: i32) -> i32 {
        match self {
            Option::Some(val) => val,
            Option::None => fallback,
        }
    }
}

// Adapted from: option.quanta line 150-154 (map)
// Original: fn map<U, F: FnOnce(T) -> U>(self, f: F) -> Option<U>
// Simplified: free function, applies a concrete add instead of closure
fn option_map_add(opt: Option, n: i32) -> Option {
    match opt {
        Option::Some(x) => Option::Some(x + n),
        Option::None => Option::None,
    }
}

// Adapted from: option.quanta line 284-288 (or)
// Original: fn or(self, optb: Option<T>) -> Option<T>
// Simplified: free function
fn option_or(a: Option, b: Option) -> Option {
    match a {
        Option::Some(_) => a,
        Option::None => b,
    }
}

fn find_value(n: i32) -> Option {
    if n > 0 {
        Option::Some(n * 10)
    } else {
        Option::None
    }
}

fn main() {
    // Test is_some / is_none
    let some = Option::Some(42);
    let none = Option::None;
    println!("some.is_some: {}", some.is_some());
    println!("none.is_none: {}", none.is_none());

    // Test unwrap_or (core stdlib logic)
    println!("some.unwrap_or(0): {}", some.unwrap_or(0));
    println!("none.unwrap_or(99): {}", none.unwrap_or(99));

    // Test map (simplified from closure-based map)
    let mapped = option_map_add(Option::Some(10), 5);
    let mapped_none = option_map_add(Option::None, 5);
    println!("map_add(Some(10),5): {}", mapped.unwrap_or(-1));
    println!("map_add(None,5): {}", mapped_none.unwrap_or(-1));

    // Test or
    let a = Option::None;
    let b = Option::Some(7);
    let c = option_or(a, b);
    println!("or(None,Some(7)): {}", c.unwrap_or(-1));

    // Test with function returning Option
    let found = find_value(5);
    let missing = find_value(-3);
    println!("find_value(5): {}", found.unwrap_or(0));
    println!("find_value(-3): {}", missing.unwrap_or(0));
}
