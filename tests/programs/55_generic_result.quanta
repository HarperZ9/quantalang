// Test 55: Result<T, E> with two type parameters
// Construct Ok/Err variants, match on them

enum Result<T, E> {
    Ok(T),
    Err(E),
}

fn safe_divide(a: i32, b: i32) -> i32 {
    if b == 0 {
        -1
    } else {
        a / b
    }
}

fn main() {
    let ok = Result::Ok(42);
    let err = Result::Err(-1);

    match ok {
        Result::Ok(val) => println!("Ok: {}", val),
        Result::Err(e) => println!("Err: {}", e),
    }

    match err {
        Result::Ok(val) => println!("Ok: {}", val),
        Result::Err(e) => println!("Err: {}", e),
    }

    // Use safe_divide
    let r1 = safe_divide(100, 4);
    println!("100/4 = {}", r1);

    let r2 = safe_divide(10, 0);
    println!("10/0 = {}", r2);
}
