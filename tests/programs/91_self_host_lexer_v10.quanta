// Self-Hosted Lexer v10 — Tokenizes "fn add(a, b) { a + b }"
// Uses integer array for source, &self/&mut self, range patterns.

const TK_EOF: i32 = 0;
const TK_IDENT: i32 = 1;
const TK_INT: i32 = 2;
const TK_PLUS: i32 = 3;
const TK_MINUS: i32 = 4;
const TK_STAR: i32 = 5;
const TK_EQ: i32 = 7;
const TK_LPAREN: i32 = 8;
const TK_RPAREN: i32 = 9;
const TK_LBRACE: i32 = 10;
const TK_RBRACE: i32 = 11;
const TK_COMMA: i32 = 13;
const TK_FN: i32 = 14;

fn is_alpha_or_underscore(c: i32) -> bool {
    match c {
        65..=90 => true,
        97..=122 => true,
        95 => true,
        _ => false,
    }
}

fn is_digit(c: i32) -> bool {
    match c {
        48..=57 => true,
        _ => false,
    }
}

fn is_whitespace(c: i32) -> bool {
    match c {
        32 => true,
        9 => true,
        10 => true,
        13 => true,
        _ => false,
    }
}

fn single_char_kind(c: i32) -> i32 {
    match c {
        43 => TK_PLUS,
        45 => TK_MINUS,
        42 => TK_STAR,
        61 => TK_EQ,
        40 => TK_LPAREN,
        41 => TK_RPAREN,
        123 => TK_LBRACE,
        125 => TK_RBRACE,
        44 => TK_COMMA,
        _ => 99,
    }
}

fn main() {
    // "fn add(a, b) { a + b }"
    let src = [102,110,32,97,100,100,40,97,44,32,98,41,32,123,32,97,32,43,32,98,32,125];
    let len: i64 = 22;
    let mut pos: i64 = 0;
    let mut count: i32 = 0;

    println!("=== Self-Hosted Lexer v10 ===");
    println!("Source: fn add(a, b) {{ a + b }}");
    println!("");

    loop {
        // Skip whitespace
        while pos < len {
            let c = src[pos as usize];
            if is_whitespace(c) {
                pos = pos + 1;
            } else {
                break;
            }
        }

        if pos >= len {
            println!("  EOF");
            count = count + 1;
            break;
        }

        let start = pos;
        let c = src[pos as usize];

        // Identifier or keyword
        if is_alpha_or_underscore(c) {
            while pos < len {
                let ch = src[pos as usize];
                if is_alpha_or_underscore(ch) || is_digit(ch) {
                    pos = pos + 1;
                } else {
                    break;
                }
            }
            let id_len = pos - start;

            // Check for "fn" keyword
            if id_len == 2 && src[start as usize] == 102 && src[(start + 1) as usize] == 110 {
                println!("  FN at {}", start);
            } else {
                println!("  IDENT at {} len={}", start, id_len);
            }
            count = count + 1;
        } else if is_digit(c) {
            while pos < len {
                let ch = src[pos as usize];
                if is_digit(ch) { pos = pos + 1; } else { break; }
            }
            println!("  INT at {} len={}", start, pos - start);
            count = count + 1;
        } else {
            let kind = single_char_kind(c);
            pos = pos + 1;
            if kind == TK_PLUS { println!("  PLUS at {}", start); }
            else if kind == TK_LPAREN { println!("  LPAREN at {}", start); }
            else if kind == TK_RPAREN { println!("  RPAREN at {}", start); }
            else if kind == TK_LBRACE { println!("  LBRACE at {}", start); }
            else if kind == TK_RBRACE { println!("  RBRACE at {}", start); }
            else if kind == TK_COMMA { println!("  COMMA at {}", start); }
            else { println!("  CHAR({}) at {}", kind, start); }
            count = count + 1;
        }

        if count > 20 { break; }
    }

    println!("");
    println!("Total: {} tokens", count);
}
