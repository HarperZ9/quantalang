// Test 109: Full annotation type showcase
// Demonstrates color spaces, gamuts, and the annotation system

struct Color {
    r: f64,
    g: f64,
    b: f64,
}

// Color space annotations
fn shade_linear(c: Color with ColorSpace<Linear>) -> Color with ColorSpace<Linear> {
    Color { r: c.r * 0.7, g: c.g * 0.7, b: c.b * 0.7 }
}

// Gamut annotations
fn rec709_to_p3(c: Color with Gamut<Rec709>) -> Color with Gamut<P3> {
    // Simplified gamut mapping (in reality this is a 3x3 matrix)
    Color { r: c.r * 0.9, g: c.g * 1.0, b: c.b * 1.1 }
}

fn p3_to_rec2020(c: Color with Gamut<P3>) -> Color with Gamut<Rec2020> {
    Color { r: c.r * 0.95, g: c.g * 1.0, b: c.b * 1.05 }
}

// Multiple annotations (color space + gamut)
fn display_prepare(
    c: Color with ColorSpace<Linear>
) -> Color with ColorSpace<sRGB> {
    // Apply sRGB gamma
    Color {
        r: pow(c.r, 0.416667),
        g: pow(c.g, 0.416667),
        b: pow(c.b, 0.416667),
    }
}

fn main() {
    // Standard pipeline
    let linear = Color { r: 0.5, g: 0.3, b: 0.1 };
    let shaded = shade_linear(linear);
    println!("shaded: ({}, {}, {})", shaded.r, shaded.g, shaded.b);

    // Gamut conversion chain: Rec.709 → P3 → Rec.2020
    let rec709 = Color { r: 0.8, g: 0.4, b: 0.2 };
    let p3 = rec709_to_p3(rec709);
    println!("P3: ({}, {}, {})", p3.r, p3.g, p3.b);

    let wide = p3_to_rec2020(p3);
    println!("Rec2020: ({}, {}, {})", wide.r, wide.g, wide.b);

    // Display preparation
    let display = display_prepare(shaded);
    println!("display: ({}, {}, {})", display.r, display.g, display.b);

    println!("annotations: WORKING");
}
