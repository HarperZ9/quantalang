// Test 88: Self return type carries trait bounds through generic chains.
// When trait method returns Self on a generic T, the result maintains
// T's trait bounds so subsequent method calls resolve correctly.

trait Transform {
    fn transform(self, factor: f64) -> Self;
}

trait Measure {
    fn value(self) -> f64;
}

struct Vec2 { x: f64, y: f64 }

impl Transform for Vec2 {
    fn transform(self, factor: f64) -> Vec2 {
        Vec2 { x: self.x * factor, y: self.y * factor }
    }
}

impl Measure for Vec2 {
    fn value(self) -> f64 {
        sqrt(self.x * self.x + self.y * self.y)
    }
}

// Chain: transform returns Self (T), then call value on the result
fn transform_and_measure<T: Transform + Measure>(x: T, f: f64) -> f64 {
    let transformed = x.transform(f);
    transformed.value()
}

fn main() {
    let v = Vec2 { x: 3.0, y: 4.0 };
    println!("{}", transform_and_measure(v, 2.0));
}
