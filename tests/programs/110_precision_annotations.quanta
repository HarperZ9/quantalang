// Test 110: Precision annotations on shader functions
// Demonstrates compile-time precision tracking for rendering pipelines

struct Color {
    r: f64,
    g: f64,
    b: f64,
}

// Full precision pass (f32, 23-bit mantissa)
fn pass_full(c: Color with Precision<Full>) -> Color with Precision<Full> {
    Color { r: c.r * 1.5, g: c.g * 1.5, b: c.b * 1.5 }
}

// Half precision pass (f16, 10-bit mantissa)
fn pass_half(c: Color with Precision<Half>) -> Color with Precision<Half> {
    Color { r: c.r * 0.5, g: c.g * 0.5, b: c.b * 0.5 }
}

// Downscale: Full → Half (explicit precision reduction)
fn downscale(c: Color with Precision<Full>) -> Color with Precision<Half> {
    Color { r: c.r, g: c.g, b: c.b }
}

fn main() {
    // Full precision pipeline
    let input = Color { r: 0.8, g: 0.4, b: 0.2 };
    let boosted = pass_full(input);
    println!("full: ({}, {}, {})", boosted.r, boosted.g, boosted.b);

    // Downscale to half for bandwidth savings
    let half = downscale(boosted);
    let result = pass_half(half);
    println!("half: ({}, {}, {})", result.r, result.g, result.b);

    // Precision annotations let you document and verify
    // which passes need full precision vs which can use half
    println!("precision tracking: ACTIVE");
}
