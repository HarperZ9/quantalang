// Test 95: quanta-finance port — Risk metrics
// Ported from APPS/quanta-finance/quanta_finance/risk.py
// Sharpe Ratio, Sortino Ratio, Max Drawdown

// Daily returns from prices
fn daily_return(prices: [f64; 10], i: i32) -> f64 {
    if i == 0 { 0.0 }
    else { (prices[i] - prices[i - 1]) / prices[i - 1] }
}

// Mean of returns
fn mean_return(prices: [f64; 10]) -> f64 {
    let mut sum = 0.0;
    let mut i = 1;
    while i < 10 {
        sum = sum + daily_return(prices, i);
        i = i + 1;
    }
    sum / 9.0
}

// Standard deviation of returns
fn std_return(prices: [f64; 10]) -> f64 {
    let mean = mean_return(prices);
    let mut sum_sq = 0.0;
    let mut i = 1;
    while i < 10 {
        let diff = daily_return(prices, i) - mean;
        sum_sq = sum_sq + diff * diff;
        i = i + 1;
    }
    sqrt(sum_sq / 8.0)
}

// Sharpe Ratio (annualized, assuming daily data, risk-free=0)
fn sharpe_ratio(prices: [f64; 10]) -> f64 {
    let mean = mean_return(prices);
    let std = std_return(prices);
    if std < 0.0001 { 0.0 }
    else { (mean / std) * sqrt(252.0) }
}

// Sortino Ratio (only penalizes downside volatility)
fn sortino_ratio(prices: [f64; 10]) -> f64 {
    let mean = mean_return(prices);
    let mut downside_sq = 0.0;
    let mut count = 0;
    let mut i = 1;
    while i < 10 {
        let ret = daily_return(prices, i);
        if ret < 0.0 {
            downside_sq = downside_sq + ret * ret;
            count = count + 1;
        }
        i = i + 1;
    }
    let downside_std = if count > 0 { sqrt(downside_sq / (count * 1.0)) } else { 0.0001 };
    (mean / downside_std) * sqrt(252.0)
}

// Maximum Drawdown
fn max_drawdown(prices: [f64; 10]) -> f64 {
    let mut peak = prices[0];
    let mut max_dd = 0.0;
    let mut i = 1;
    while i < 10 {
        if prices[i] > peak { peak = prices[i]; }
        let dd = (peak - prices[i]) / peak;
        if dd > max_dd { max_dd = dd; }
        i = i + 1;
    }
    max_dd
}

fn main() {
    // Uptrend with mild pullbacks
    let prices = [100.0, 102.0, 104.0, 103.0, 105.0, 107.0, 106.0, 108.0, 110.0, 109.0];

    let sharpe = sharpe_ratio(prices);
    println!("Sharpe: {}", sharpe);

    let sortino = sortino_ratio(prices);
    println!("Sortino: {}", sortino);

    let mdd = max_drawdown(prices);
    println!("MaxDD: {}", mdd);

    // Sharpe > 0 for uptrend
    if sharpe > 0.0 {
        println!("positive sharpe: true");
    } else {
        println!("positive sharpe: false");
    }

    // Sortino should be > Sharpe for asymmetric returns
    if sortino > sharpe {
        println!("sortino > sharpe: true");
    } else {
        println!("sortino > sharpe: false");
    }

    // Max drawdown should be small for mild pullbacks
    if mdd < 0.05 {
        println!("low drawdown: true");
    } else {
        println!("low drawdown: false");
    }
}
