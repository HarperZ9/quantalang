fn main() {
    let x: f64 = -3.7;
    let y: f64 = 2.0;

    // abs
    let a = x.abs();
    assert(a == 3.7);

    // floor/ceil
    let f = x.floor();
    assert(f == -4.0);
    let c = x.ceil();
    assert(c == -3.0);

    // sqrt
    let s = (4.0).sqrt();
    assert(s == 2.0);

    // powi
    let p = y.powi(3);
    assert(p == 8.0);

    // min/max
    let mx = x.max(y);
    assert(mx == 2.0);
    let mn = x.min(y);
    assert(mn == -3.7);

    // trig
    let pi = 3.14159265358979323846;
    let deg = pi.to_degrees();
    assert(deg > 179.9);
    assert(deg < 180.1);

    let rad = (180.0).to_radians();
    assert(rad > 3.14);
    assert(rad < 3.15);

    // sin/cos
    let sv = (0.0).sin();
    assert(sv == 0.0);
    let cv = (0.0).cos();
    assert(cv == 1.0);

    println("All primitive method tests passed!");
}
