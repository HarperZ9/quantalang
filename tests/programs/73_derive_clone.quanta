// Test 73: #[derive(Clone)] auto-generated clone method
// Struct with derive attribute gets a clone() method automatically

#[derive(Clone)]
struct Point {
    x: i32,
    y: i32,
}

struct Color {
    r: f64,
    g: f64,
    b: f64,
}

impl Color {
    fn brightness(self) -> f64 {
        (self.r + self.g + self.b) / 3.0
    }
}

fn main() {
    let p1 = Point { x: 10, y: 20 };
    let p2 = p1.clone();
    println!("p1: ({}, {})", p1.x, p1.y);
    println!("p2: ({}, {})", p2.x, p2.y);

    // Modify p1 should not affect p2 (value semantics)
    let p3 = Point { x: 99, y: 88 };
    let p4 = p3.clone();
    println!("p3: ({}, {})", p3.x, p3.y);
    println!("p4: ({}, {})", p4.x, p4.y);

    // Color without derive
    let c = Color { r: 0.5, g: 0.7, b: 0.3 };
    println!("brightness: {}", c.brightness());
}
