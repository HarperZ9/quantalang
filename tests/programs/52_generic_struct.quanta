// Test 52: Generic struct monomorphization
// Pair<T> { first: T, second: T } monomorphizes to Pair_i32, Pair_f64

struct Pair<T> {
    first: T,
    second: T,
}

fn add_pair(p: Pair<i32>) -> i32 {
    p.first + p.second
}

fn main() {
    let p1 = Pair { first: 10, second: 20 };
    let sum = add_pair(p1);
    println!("Pair sum: {}", sum);

    let p2 = Pair { first: 3, second: 7 };
    println!("Second pair: {} + {} = {}", p2.first, p2.second, p2.first + p2.second);
}
