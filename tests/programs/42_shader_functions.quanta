fn brightness(r: f64, g: f64, b: f64) -> f64 {
    r * 0.299 + g * 0.587 + b * 0.114
}

fn gamma_correct(value: f64, gamma: f64) -> f64 {
    pow(value, 1.0 / gamma)
}

fn main() {
    let luma = brightness(1.0, 0.5, 0.2);
    println!("Brightness: {}", luma);

    let corrected = gamma_correct(0.5, 2.2);
    println!("Gamma corrected: {}", corrected);

    // String comparison
    let name: str = "QuantaLang";
    if name != "" {
        println!("Name is not empty: {}", name);
    }
}
