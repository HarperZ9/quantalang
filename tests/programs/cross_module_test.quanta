// Cross-module import test: imports struct + functions from geometry.quanta
mod geometry;

fn approx(a: f64, b: f64, tol: f64) -> bool {
    let d = a - b;
    let abs = if d < 0.0 { 0.0 - d } else { d };
    abs < tol
}

fn main() {
    let a = geometry::make_point(0.0, 0.0);
    let b = geometry::make_point(3.0, 4.0);
    let d = geometry::distance(&a, &b);

    let mut pass = 0;
    if approx(d, 5.0, 0.001) { pass = pass + 1; }
    if approx(a.x, 0.0, 0.001) { pass = pass + 1; }
    if approx(b.y, 4.0, 0.001) { pass = pass + 1; }

    println!("{} / 3 cross-module tests passed", pass);
}
