fn main() {
    // Inclusive range
    let mut sum = 0;
    for i in 0..=5 {
        sum = sum + i;
    }
    assert(sum == 15);  // 0+1+2+3+4+5

    // Exclusive range with step_by
    let mut count = 0;
    for i in (0..10).step_by(2) {
        count = count + 1;
    }
    assert(count == 5);  // 0, 2, 4, 6, 8

    // Inclusive range with step_by
    let mut vals = vec![];
    for i in (0..=10).step_by(3) {
        vec_push(vals, i);
    }
    assert(vec_len(vals) == 4);  // 0, 3, 6, 9
    assert(vec_get(vals, 0) == 0);
    assert(vec_get(vals, 3) == 9);

    // Large range with step (CMF-like pattern)
    let mut wavelengths = vec![];
    for wl in (380..=780).step_by(5) {
        vec_push(wavelengths, wl);
    }
    assert(vec_len(wavelengths) == 81);  // (780-380)/5 + 1
    assert(vec_get(wavelengths, 0) == 380);
    assert(vec_get(wavelengths, 80) == 780);

    println!("Range step_by tests passed!");
}
