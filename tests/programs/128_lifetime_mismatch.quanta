// Interprocedural Lifetime Analysis — lifetime mismatch detection.
// fn bad<'a, 'b> declares return type &'a but returns y which has lifetime 'b.
// The type checker should reject this with a LifetimeMismatch error.

fn bad<'a, 'b>(x: &'a i32, y: &'b i32) -> &'a i32 {
    y
}

fn main() {
    let a: i32 = 1;
    let b: i32 = 2;
    let r: &i32 = bad(&a, &b);
    println("{}", *r);
}
