// Test 96: quanta-engine port — Prediction ensemble with weighted voting
// Ported from APPS/quanta-engine/quanta_engine/prediction_strategy.py

struct Prediction {
    model_name: i32,
    predicted_price: f64,
    confidence: f64,
}

struct EnsembleResult {
    weighted_price: f64,
    signal_strength: f64,
}

// Weighted ensemble: combine predictions using model accuracy weights
fn ensemble_predict(
    pred1: Prediction, w1: f64,
    pred2: Prediction, w2: f64,
    pred3: Prediction, w3: f64,
    current_price: f64
) -> EnsembleResult {
    let total_weight = w1 + w2 + w3;
    let weighted = (pred1.predicted_price * w1 + pred2.predicted_price * w2 + pred3.predicted_price * w3) / total_weight;
    let change_pct = (weighted - current_price) / current_price;
    let strength = if change_pct > 0.005 { change_pct }
        else { if change_pct < -0.005 { change_pct } else { 0.0 } };
    EnsembleResult { weighted_price: weighted, signal_strength: strength }
}

// Dynamic weight from accuracy: weight = accuracy^2
fn accuracy_weight(correct: f64, total: f64) -> f64 {
    if total == 0.0 { 1.0 }
    else {
        let acc = correct / total;
        acc * acc
    }
}

fn main() {
    // Three models with different predictions
    let arima = Prediction { model_name: 1, predicted_price: 105.0, confidence: 0.8 };
    let nn_model = Prediction { model_name: 2, predicted_price: 107.0, confidence: 0.6 };
    let prophet = Prediction { model_name: 3, predicted_price: 103.0, confidence: 0.7 };

    // Weights from accuracy history
    let w1 = accuracy_weight(8.0, 10.0);  // 80% accurate → 0.64
    let w2 = accuracy_weight(6.0, 10.0);  // 60% accurate → 0.36
    let w3 = accuracy_weight(7.0, 10.0);  // 70% accurate → 0.49

    println!("arima weight: {}", w1);
    println!("neural weight: {}", w2);
    println!("prophet weight: {}", w3);

    let result = ensemble_predict(arima, w1, nn_model, w2, prophet, w3, 100.0);
    println!("ensemble price: {}", result.weighted_price);
    println!("signal strength: {}", result.signal_strength);

    // Signal should be positive (all models predict up)
    if result.signal_strength > 0.0 {
        println!("signal: BUY");
    } else {
        if result.signal_strength < 0.0 {
            println!("signal: SELL");
        } else {
            println!("signal: HOLD");
        }
    }
}
