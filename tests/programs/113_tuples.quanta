fn swap(a: f64, b: f64) -> (f64, f64) {
    (b, a)
}

fn divide_and_remainder(a: i64, b: i64) -> (i64, i64) {
    let q = a / b;
    let r = a - q * b;
    (q, r)
}

fn main() {
    // Tuple return + destructuring
    let (x, y) = swap(1.0, 2.0);
    assert!(x == 2.0);
    assert!(y == 1.0);

    // Integer tuple
    let (quotient, remainder) = divide_and_remainder(17, 5);
    assert!(quotient == 3);
    assert!(remainder == 2);

    // Nested usage
    let (a, b) = swap(10.0, 20.0);
    let (c, d) = swap(a, b);
    assert!(c == 10.0);
    assert!(d == 20.0);

    println!("Tuple tests passed!");
}
