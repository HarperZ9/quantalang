// Test stdlib math functions — inlined to avoid module cross-reference issues

fn i32_abs(n: i32) -> i32 {
    if n < 0 { -n } else { n }
}

fn gcd(a: i32, b: i32) -> i32 {
    let mut x = i32_abs(a);
    let mut y = i32_abs(b);
    while y != 0 {
        let temp = y;
        y = x % y;
        x = temp;
    }
    x
}

fn lcm(a: i32, b: i32) -> i32 {
    if a == 0 || b == 0 {
        0
    } else {
        i32_abs(a) / gcd(a, b) * i32_abs(b)
    }
}

fn factorial(n: i32) -> i32 {
    if n <= 1 { 1 } else { n * factorial(n - 1) }
}

fn fibonacci(n: i32) -> i32 {
    if n <= 1 { n } else { fibonacci(n - 1) + fibonacci(n - 2) }
}

fn power(base: i32, exp: i32) -> i32 {
    if exp == 0 {
        1
    } else {
        let mut result: i32 = 1;
        let mut i: i32 = 0;
        while i < exp {
            result = result * base;
            i = i + 1;
        }
        result
    }
}

fn main() {
    println!("gcd(12, 8) = {}", gcd(12, 8));
    println!("lcm(4, 6) = {}", lcm(4, 6));
    println!("factorial(6) = {}", factorial(6));
    println!("fibonacci(10) = {}", fibonacci(10));
    println!("power(2, 10) = {}", power(2, 10));
}
