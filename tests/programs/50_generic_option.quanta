// Test 50: Option type with trait-based vtable generation
// Tests: enum + impl + trait + vtable infrastructure

trait Describable {
    fn describe(self) -> i32;
}

struct Dog {
    age: i32,
}

struct Cat {
    lives: i32,
}

impl Describable for Dog {
    fn describe(self) -> i32 {
        self.age
    }
}

impl Describable for Cat {
    fn describe(self) -> i32 {
        self.lives
    }
}

fn main() {
    let dog = Dog { age: 5 };
    let cat = Cat { lives: 9 };

    // Static dispatch through trait impls
    println!("Dog age: {}", dog.describe());
    println!("Cat lives: {}", cat.describe());

    // Test that vtable infrastructure generates correctly
    println!("Trait dispatch test complete");
}
