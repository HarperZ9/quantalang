// ═══════════════════════════════════════════════════════════════════════════════
// Self-hosting Phase 6, Step 3: Span from src/lexer.quanta + diagnostics/span
// ═══════════════════════════════════════════════════════════════════════════════
//
// This combines simplified versions of:
//   - quantalang/src/lexer.quanta: Span struct (lines 259-283)
//   - quantalang/src/diagnostics/span.quanta: BytePos, Span (lines 33-212)
//
// Original uses: tuple structs (BytePos(u32)), impl blocks with many methods,
//   Option<Span> return types, Range<usize>, PathBuf, trait impls (Display,
//   From, Add, Sub), derive macros, const items, references, Arc, RwLock,
//   HashMap, iterators, closures.
//
// Simplified here: uses regular structs, i32 fields, no generics, no traits,
//   no references, no Option for methods that can use sentinel values.
//
// This proves: compiling actual compiler data structures (struct + impl + logic).
// ═══════════════════════════════════════════════════════════════════════════════

// Adapted from: src/lexer.quanta lines 259-263
struct Span {
    start: i32,
    end: i32,
}

impl Span {
    // Adapted from: src/lexer.quanta lines 267-269
    fn new(start: i32, end: i32) -> Span {
        Span { start: start, end: end }
    }

    // Adapted from: src/lexer.quanta lines 280-282
    fn len(self) -> i32 {
        self.end - self.start
    }

    // Adapted from: diagnostics/span.quanta lines 119-121
    fn is_empty(self) -> bool {
        self.start == self.end
    }

    // Adapted from: diagnostics/span.quanta lines 149-151
    fn contains_pos(self, pos: i32) -> bool {
        if self.start <= pos {
            pos < self.end
        } else {
            false
        }
    }
}

// Adapted from: diagnostics/span.quanta lines 124-135 (merge)
fn span_merge(a: Span, b: Span) -> Span {
    let lo = min_i32(a.start, b.start);
    let hi = max_i32(a.end, b.end);
    Span { start: lo, end: hi }
}

fn min_i32(a: i32, b: i32) -> i32 {
    if a < b {
        a
    } else {
        b
    }
}

fn max_i32(a: i32, b: i32) -> i32 {
    if a > b {
        a
    } else {
        b
    }
}

// Adapted from: src/lexer.quanta lines 252-257 (Token struct, simplified)
struct Token {
    kind: i32,
    span_start: i32,
    span_end: i32,
}

fn token_span(tok: Token) -> Span {
    Span { start: tok.span_start, end: tok.span_end }
}

fn main() {
    // Test Span creation and methods
    let s = Span::new(10, 20);
    println!("span(10,20).len: {}", s.len());
    println!("span(10,20).is_empty: {}", s.is_empty());

    let empty = Span::new(5, 5);
    println!("span(5,5).is_empty: {}", empty.is_empty());

    // Test contains
    println!("span(10,20).contains(15): {}", s.contains_pos(15));
    println!("span(10,20).contains(5): {}", s.contains_pos(5));
    println!("span(10,20).contains(10): {}", s.contains_pos(10));
    println!("span(10,20).contains(20): {}", s.contains_pos(20));

    // Test merge
    let a = Span::new(10, 20);
    let b = Span::new(15, 30);
    let merged = span_merge(a, b);
    println!("merge(10-20, 15-30).start: {}", merged.start);
    println!("merge(10-20, 15-30).end: {}", merged.end);

    // Test with Token (simplified lexer data structure)
    let tok = Token { kind: 1, span_start: 0, span_end: 3 };
    let tok_span = token_span(tok);
    println!("token span len: {}", tok_span.len());
}
