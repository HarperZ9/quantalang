// Test 86: quanta-color port — Color space conversions
// Ported from APPS/quanta-color/quanta_color/spaces.py
// sRGB ↔ XYZ ↔ Lab with matrix multiplication

struct XYZ { x: f64, y: f64, z: f64, }
struct Lab { l: f64, a: f64, b: f64, }
struct RGB { r: f64, g: f64, b: f64, }

// sRGB gamma
fn srgb_to_linear(c: f64) -> f64 {
    if c <= 0.04045 { c / 12.92 }
    else { pow((c + 0.055) / 1.055, 2.4) }
}

fn linear_to_srgb(c: f64) -> f64 {
    if c <= 0.0031308 { c * 12.92 }
    else { 1.055 * pow(c, 1.0 / 2.4) - 0.055 }
}

// sRGB → XYZ (D65) using IEC 61966 matrix
fn rgb_to_xyz(rgb: RGB) -> XYZ {
    let r = srgb_to_linear(rgb.r);
    let g = srgb_to_linear(rgb.g);
    let b = srgb_to_linear(rgb.b);
    XYZ {
        x: 0.4124564 * r + 0.3575761 * g + 0.1804375 * b,
        y: 0.2126729 * r + 0.7151522 * g + 0.0721750 * b,
        z: 0.0193339 * r + 0.1191920 * g + 0.9503041 * b,
    }
}

// XYZ → sRGB (D65)
fn xyz_to_rgb(xyz: XYZ) -> RGB {
    let rl =  3.2404542 * xyz.x - 1.5371385 * xyz.y - 0.4985314 * xyz.z;
    let gl = -0.9692660 * xyz.x + 1.8760108 * xyz.y + 0.0415560 * xyz.z;
    let bl =  0.0556434 * xyz.x - 0.2040259 * xyz.y + 1.0572252 * xyz.z;
    RGB { r: linear_to_srgb(rl), g: linear_to_srgb(gl), b: linear_to_srgb(bl) }
}

// XYZ → Lab (D65 illuminant: Xn=0.95047, Yn=1.0, Zn=1.08883)
fn lab_f(t: f64) -> f64 {
    let delta = 6.0 / 29.0;
    if t > delta * delta * delta { pow(t, 1.0 / 3.0) }
    else { t / (3.0 * delta * delta) + 4.0 / 29.0 }
}

fn xyz_to_lab(xyz: XYZ) -> Lab {
    let fx = lab_f(xyz.x / 0.95047);
    let fy = lab_f(xyz.y / 1.0);
    let fz = lab_f(xyz.z / 1.08883);
    Lab {
        l: 116.0 * fy - 16.0,
        a: 500.0 * (fx - fy),
        b: 200.0 * (fy - fz),
    }
}

fn rgb_to_lab(rgb: RGB) -> Lab {
    xyz_to_lab(rgb_to_xyz(rgb))
}

fn main() {
    // White: sRGB (1,1,1) → XYZ → Lab
    let white_xyz = rgb_to_xyz(RGB { r: 1.0, g: 1.0, b: 1.0 });
    println!("white XYZ: ({}, {}, {})", white_xyz.x, white_xyz.y, white_xyz.z);

    let white_lab = xyz_to_lab(white_xyz);
    println!("white Lab L: {}", white_lab.l);

    // Red: sRGB (1,0,0) → Lab
    let red_lab = rgb_to_lab(RGB { r: 1.0, g: 0.0, b: 0.0 });
    println!("red Lab: ({}, {}, {})", red_lab.l, red_lab.a, red_lab.b);

    // Mid gray: sRGB (0.5,0.5,0.5) → Lab
    let gray_lab = rgb_to_lab(RGB { r: 0.5, g: 0.5, b: 0.5 });
    println!("gray Lab L: {}", gray_lab.l);

    // Round-trip: sRGB → XYZ → sRGB
    let original = RGB { r: 0.73, g: 0.42, b: 0.18 };
    let xyz = rgb_to_xyz(original);
    let roundtrip = xyz_to_rgb(xyz);
    println!("roundtrip r: {}", roundtrip.r);
    println!("roundtrip g: {}", roundtrip.g);
    println!("roundtrip b: {}", roundtrip.b);
}
