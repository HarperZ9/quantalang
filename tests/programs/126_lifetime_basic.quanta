// Interprocedural Lifetime Analysis — basic lifetime parameters.
// fn first<'a> takes two references with the same lifetime and returns one.
// This should compile correctly: returning x which has lifetime 'a.

fn first<'a>(x: &'a i32, y: &'a i32) -> &'a i32 {
    x
}

fn main() {
    let a: i32 = 10;
    let b: i32 = 20;
    let r: &i32 = first(&a, &b);
    let val: i32 = *r;
    println("{}", val);
}
