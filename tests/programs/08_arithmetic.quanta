fn main() {
    let a: i32 = 100;
    let b: i32 = 37;

    println!("a + b = {}", a + b);
    println!("a - b = {}", a - b);
    println!("a * b = {}", a * b);
    println!("a / b = {}", a / b);
    println!("a % b = {}", a % b);

    let neg: i32 = -a;
    println!("-a = {}", neg);

    let big: i32 = (a + b) * (a - b);
    println!("(a+b)*(a-b) = {}", big);
}
