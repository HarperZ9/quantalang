// Test 69: Pattern matching with enum destructuring
// Variant patterns, wildcard, multiple match arms

enum Color {
    Red,
    Green,
    Blue,
    Custom(i32),
}

fn color_value(c: Color) -> i32 {
    match c {
        Color::Red => 1,
        Color::Green => 2,
        Color::Blue => 3,
        Color::Custom(v) => v,
    }
}

enum Expr {
    Num(i32),
    Neg(i32),
}

fn eval(e: Expr) -> i32 {
    match e {
        Expr::Num(n) => n,
        Expr::Neg(n) => 0 - n,
    }
}

fn main() {
    println!("Red: {}", color_value(Color::Red));
    println!("Green: {}", color_value(Color::Green));
    println!("Blue: {}", color_value(Color::Blue));
    println!("Custom(42): {}", color_value(Color::Custom(42)));

    println!("Num(10): {}", eval(Expr::Num(10)));
    println!("Neg(7): {}", eval(Expr::Neg(7)));

    // Match with wildcard
    let x = 42;
    let label = match x {
        1 => 10,
        2 => 20,
        _ => 99,
    };
    println!("wildcard match: {}", label);
}
