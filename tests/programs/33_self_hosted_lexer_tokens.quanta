// ═══════════════════════════════════════════════════════════════════════════════
// Self-hosting Phase 6, Step 4: TokenKind enum from src/lexer.quanta
// ═══════════════════════════════════════════════════════════════════════════════
//
// This is a simplified version of the TokenKind enum from the self-hosted
// lexer at quantalang/src/lexer.quanta (lines 30-216).
//
// Original uses: enum with 100+ variants, several with associated data
//   (String, char, u128, Vec<u8>), nested enums (IntSuffix, FloatSuffix,
//   LexError), derive macros.
//
// Simplified here: subset of token kinds as simple enum (no associated data
//   on most variants), demonstrating the compiler can handle the token
//   classification logic that the self-hosted lexer performs.
//
// This proves: enums with many variants, match-based classification,
//   the core token structure of the compiler itself.
// ═══════════════════════════════════════════════════════════════════════════════

// Simplified from: src/lexer.quanta lines 30-216
// Just the operator and punctuation tokens (no associated data needed)
enum TokenKind {
    // Operators (from lexer.quanta lines 123-155)
    Plus,
    Minus,
    Star,
    Slash,
    EqEq,
    Ne,
    Lt,
    Le,
    Gt,
    Ge,
    // Punctuation (from lexer.quanta lines 185-203)
    LParen,
    RParen,
    LBrace,
    RBrace,
    Comma,
    Semi,
    Colon,
    Arrow,
    FatArrow,
    // Special
    Eof,
    Error,
}

fn token_name(kind: TokenKind) -> str {
    match kind {
        TokenKind::Plus => "+",
        TokenKind::Minus => "-",
        TokenKind::Star => "*",
        TokenKind::Slash => "/",
        TokenKind::EqEq => "==",
        TokenKind::Ne => "!=",
        TokenKind::Lt => "<",
        TokenKind::Le => "<=",
        TokenKind::Gt => ">",
        TokenKind::Ge => ">=",
        TokenKind::LParen => "(",
        TokenKind::RParen => ")",
        TokenKind::LBrace => "{",
        TokenKind::RBrace => "}",
        TokenKind::Comma => ",",
        TokenKind::Semi => ";",
        TokenKind::Colon => ":",
        TokenKind::Arrow => "->",
        TokenKind::FatArrow => "=>",
        TokenKind::Eof => "EOF",
        TokenKind::Error => "ERROR",
    }
}

// Simplified from: src/lexer.quanta scan_token (lines 344-451)
// Instead of scanning bytes, classify a single character code
fn classify_char(c: i32) -> TokenKind {
    if c == 43 {
        TokenKind::Plus
    } else {
        if c == 45 {
            TokenKind::Minus
        } else {
            if c == 42 {
                TokenKind::Star
            } else {
                if c == 47 {
                    TokenKind::Slash
                } else {
                    if c == 40 {
                        TokenKind::LParen
                    } else {
                        if c == 41 {
                            TokenKind::RParen
                        } else {
                            if c == 123 {
                                TokenKind::LBrace
                            } else {
                                if c == 125 {
                                    TokenKind::RBrace
                                } else {
                                    if c == 44 {
                                        TokenKind::Comma
                                    } else {
                                        if c == 59 {
                                            TokenKind::Semi
                                        } else {
                                            if c == 58 {
                                                TokenKind::Colon
                                            } else {
                                                if c == 0 {
                                                    TokenKind::Eof
                                                } else {
                                                    TokenKind::Error
                                                }
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }
    }
}

fn is_operator(kind: TokenKind) -> bool {
    match kind {
        TokenKind::Plus => true,
        TokenKind::Minus => true,
        TokenKind::Star => true,
        TokenKind::Slash => true,
        TokenKind::EqEq => true,
        TokenKind::Ne => true,
        TokenKind::Lt => true,
        TokenKind::Le => true,
        TokenKind::Gt => true,
        TokenKind::Ge => true,
        TokenKind::LParen => false,
        TokenKind::RParen => false,
        TokenKind::LBrace => false,
        TokenKind::RBrace => false,
        TokenKind::Comma => false,
        TokenKind::Semi => false,
        TokenKind::Colon => false,
        TokenKind::Arrow => false,
        TokenKind::FatArrow => false,
        TokenKind::Eof => false,
        TokenKind::Error => false,
    }
}

fn main() {
    // Test token classification (mimics what the lexer does)
    // ASCII: + = 43, - = 45, * = 42, / = 47, ( = 40, ) = 41
    //        { = 123, } = 125, , = 44, ; = 59, : = 58
    let t1 = classify_char(43);
    let t2 = classify_char(42);
    let t3 = classify_char(40);
    let t4 = classify_char(59);
    let t5 = classify_char(0);
    let t6 = classify_char(99);

    println!("char(+): {}", token_name(t1));
    println!("char(*): {}", token_name(t2));
    println!("char((): {}", token_name(t3));
    println!("char(;): {}", token_name(t4));
    println!("char(EOF): {}", token_name(t5));
    println!("char(c): {}", token_name(t6));

    // Test is_operator
    println!("+ is operator: {}", is_operator(TokenKind::Plus));
    println!("( is operator: {}", is_operator(TokenKind::LParen));
    println!("; is operator: {}", is_operator(TokenKind::Semi));

    // Test multi-char tokens (pre-classified)
    println!("-> name: {}", token_name(TokenKind::Arrow));
    println!("=> name: {}", token_name(TokenKind::FatArrow));
    println!("<= name: {}", token_name(TokenKind::Le));
    println!("!= name: {}", token_name(TokenKind::Ne));
}
