// Test 63: File I/O basics
// Tests that the file I/O runtime functions are accessible

fn main() {
    // Test file_exists on a known path
    let exists = file_exists("/tmp");
    if exists {
        println!("tmp exists: true");
    } else {
        println!("tmp exists: false");
    }

    // Test basic write and read cycle
    // write_file returns bool, read_file returns string
    let wrote = write_file("/tmp/quanta_test63.txt", "hello quanta");
    println!("wrote: {}", wrote);

    let content = read_file("/tmp/quanta_test63.txt");
    println!("read: {}", content);
}
