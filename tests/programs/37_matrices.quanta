fn main() {
    let v = vec4(1.0, 0.0, 0.0, 1.0);
    let m = mat4_identity();
    let result = m * v;
    println!("identity * v: ({}, {}, {}, {})", result.x, result.y, result.z, result.w);

    let t = mat4_translate(vec3(10.0, 20.0, 30.0));
    let translated = t * v;
    println!("translated: ({}, {}, {}, {})", translated.x, translated.y, translated.z, translated.w);
}
