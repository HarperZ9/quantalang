// QuantaLang Graphics Demo
// Demonstrates: effects + vectors + matrices + shader math
// This is what makes QuantaLang unique — engine code with effect-controlled rendering

effect Render {
    fn draw(description: str) -> (),
}

// A pure function — no effects, mathematically verifiable
fn phong_lighting(normal: vec3, light_dir: vec3) -> vec3 {
    let ambient = vec3(0.1, 0.1, 0.1);
    let n = normalize(normal);
    let l = normalize(light_dir);

    let diff = dot(n, l);
    let diffuse = if diff > 0.0 {
        vec3(diff, diff, diff)
    } else {
        vec3(0.0, 0.0, 0.0)
    };

    ambient + diffuse
}

// Scene rendering — uses the Render effect
fn render_scene() ~ Render {
    // Compute lighting using pure vector math
    let normal = vec3(0.0, 1.0, 0.0);
    let light_dir = normalize(vec3(1.0, 1.0, 0.5));
    let color = phong_lighting(normal, light_dir);
    println!("Lighting: ({}, {}, {})", color.x, color.y, color.z);

    // Model-view transform
    let model = mat4_translate(vec3(5.0, 1.0, 3.0));
    let point = vec4(0.0, 0.0, 0.0, 1.0);
    let world_pos = model * point;
    println!("World pos: ({}, {}, {}, {})", world_pos.x, world_pos.y, world_pos.z, world_pos.w);

    // Perform the effect — this is the key feature
    // The handler decides what "draw" means: OpenGL, Vulkan, mock, profiler
    perform Render.draw("player at (5, 1, 3)")
}

fn main() {
    // Production handler — could be swapped for a test mock
    handle {
        render_scene()
    } with {
        Render.draw(desc) => {
            println!("RENDER: {}", desc)
        },
    }
}
