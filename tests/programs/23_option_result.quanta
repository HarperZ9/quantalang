mod option;
mod result;

fn find_positive(n: i32) -> Option {
    if n > 0 {
        Option::Some(n)
    } else {
        Option::None
    }
}

fn safe_divide(a: i32, b: i32) -> Result {
    if b == 0 {
        Result::Err(-1)
    } else {
        Result::Ok(a / b)
    }
}

fn main() {
    let found = find_positive(42);
    let not_found = find_positive(-5);
    println!("found: {}", found.unwrap_or(0));
    println!("not_found: {}", not_found.unwrap_or(0));

    let ok = safe_divide(10, 3);
    let err = safe_divide(10, 0);
    println!("10/3: {}", ok.unwrap_or(-1));
    println!("10/0: {}", err.unwrap_or(-1));
}
