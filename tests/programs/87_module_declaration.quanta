// Test 87: Module declaration syntax
// Verifies that `module path::to::name` is parsed correctly.
// This is the ecosystem convention — every .quanta file starts with `module`.

module test::example::math

pub const PI: f64 = 3.14159265358979323846;

pub fn add(a: f64, b: f64) -> f64 {
    a + b
}

pub fn multiply(a: f64, b: f64) -> f64 {
    a * b
}

struct Vec2 {
    x: f64,
    y: f64,
}

impl Vec2 {
    fn length(self) -> f64 {
        sqrt(self.x * self.x + self.y * self.y)
    }
}

fn main() {
    println!("PI: {}", PI);
    println!("add: {}", add(2.0, 3.0));
    let v = Vec2 { x: 3.0, y: 4.0 };
    println!("length: {}", v.length());
}
