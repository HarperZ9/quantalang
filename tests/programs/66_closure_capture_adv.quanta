// Test 66: Advanced closure captures
// Multiple captured variables, nested closures, closures in loops

fn apply(f: fn(i32) -> i32, x: i32) -> i32 {
    f(x)
}

fn main() {
    // Capture multiple variables
    let a = 10;
    let b = 20;
    let add_both = |x: i32| -> i32 { x + a + b };
    println!("add_both(5): {}", add_both(5));

    // Closure with captured variable used directly
    let multiplier = 3;
    let triple = |x: i32| -> i32 { x * multiplier };
    println!("triple(7): {}", triple(7));

    // Closure in a loop
    let base = 100;
    let mut sum = 0;
    let adder = |x: i32| -> i32 { x + base };
    for i in 0..5 {
        sum = sum + adder(i);
    }
    println!("sum with base 100: {}", sum);

    // Chained operations
    let offset = 1000;
    let step1 = |x: i32| -> i32 { x * 2 };
    let step2 = |x: i32| -> i32 { x + offset };
    let val = step2(step1(5));
    println!("chain: {}", val);
}
