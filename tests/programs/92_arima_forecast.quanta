// Test 92: quanta-oracle port — AR(1) forecasting
// Simplified ARIMA: estimate AR coefficient, then forecast
// Ported from APPS/quanta-oracle/quanta_oracle/arima.py

// Estimate AR(1) coefficient via Yule-Walker: phi = autocorr(lag=1)
fn estimate_ar1(data: [f64; 10]) -> f64 {
    // Compute mean
    let mut mean = 0.0;
    let mut i = 0;
    while i < 10 { mean = mean + data[i]; i = i + 1; }
    mean = mean / 10.0;

    // Compute autocovariance at lag 0 and lag 1
    let mut c0 = 0.0;
    let mut c1 = 0.0;
    i = 0;
    while i < 10 {
        c0 = c0 + (data[i] - mean) * (data[i] - mean);
        if i > 0 {
            c1 = c1 + (data[i] - mean) * (data[i - 1] - mean);
        }
        i = i + 1;
    }
    c0 = c0 / 10.0;
    c1 = c1 / 9.0;

    // AR(1) coefficient = c1/c0
    if c0 > 0.0001 { c1 / c0 } else { 0.0 }
}

// Forecast h steps ahead using AR(1): x_{t+h} = mean + phi^h * (x_t - mean)
fn forecast_ar1(last_val: f64, mean: f64, phi: f64, steps: i32) -> f64 {
    let mut forecast = last_val;
    let mut s = 0;
    while s < steps {
        forecast = mean + phi * (forecast - mean);
        s = s + 1;
    }
    forecast
}

fn main() {
    // Synthetic AR(1) process: x_t = 0.8 * x_{t-1} + noise
    let data = [1.0, 1.8, 2.4, 2.9, 3.1, 2.8, 2.3, 1.9, 1.6, 1.5];

    let phi = estimate_ar1(data);
    println!("AR(1) phi: {}", phi);

    // Compute mean
    let mut mean = 0.0;
    let mut i = 0;
    while i < 10 { mean = mean + data[i]; i = i + 1; }
    mean = mean / 10.0;
    println!("mean: {}", mean);

    // Forecast 1 step
    let f1 = forecast_ar1(data[9], mean, phi, 1);
    println!("forecast +1: {}", f1);

    // Forecast 5 steps (should converge toward mean)
    let f5 = forecast_ar1(data[9], mean, phi, 5);
    println!("forecast +5: {}", f5);

    // Forecast 20 steps (should be very close to mean)
    let f20 = forecast_ar1(data[9], mean, phi, 20);
    println!("forecast +20: {}", f20);

    // Verify convergence: f20 should be closer to mean than f1
    let d1 = f1 - mean;
    let d20 = f20 - mean;
    let d1_abs = if d1 < 0.0 { 0.0 - d1 } else { d1 };
    let d20_abs = if d20 < 0.0 { 0.0 - d20 } else { d20 };
    if d20_abs < d1_abs {
        println!("converges: true");
    } else {
        println!("converges: false");
    }
}
