// Test 58: Array iteration with for-in
// for x in [10, 20, 30] desugars to index-based loop

fn main() {
    let arr = [10, 20, 30, 40, 50];
    let mut sum = 0;

    for x in arr {
        sum = sum + x;
    }

    println!("sum: {}", sum);

    // Iterate and print each
    let values = [1, 2, 3];
    let mut product = 1;
    for v in values {
        product = product * v;
    }
    println!("product: {}", product);

    // Count elements
    let items = [100, 200, 300, 400];
    let mut count = 0;
    for item in items {
        count = count + 1;
    }
    println!("count: {}", count);
}
