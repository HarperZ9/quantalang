// QuantaLang Color Science — Self-Verifying Test Suite
//
// Compiles to a native binary that checks all color conversions against
// known CIE 1976 and OKLab reference values. Returns nonzero if any fail.

struct RGB { r: f64, g: f64, b: f64 }
struct XYZ { x: f64, y: f64, z: f64 }
struct Lab { l: f64, a: f64, b: f64 }
struct OKLab { l: f64, a: f64, b: f64 }

impl RGB {
    fn new(r: f64, g: f64, b: f64) -> RGB { RGB { r, g, b } }
    fn linearize(c: f64) -> f64 {
        if c <= 0.04045 { c / 12.92 }
        else { pow((c + 0.055) / 1.055, 2.4) }
    }
    fn to_linear(&self) -> RGB {
        RGB::new(RGB::linearize(self.r), RGB::linearize(self.g), RGB::linearize(self.b))
    }
}

impl XYZ {
    fn new(x: f64, y: f64, z: f64) -> XYZ { XYZ { x, y, z } }
    fn from_linear_rgb(rgb: &RGB) -> XYZ {
        XYZ::new(
            0.4124564 * rgb.r + 0.3575761 * rgb.g + 0.1804375 * rgb.b,
            0.2126729 * rgb.r + 0.7151522 * rgb.g + 0.0721750 * rgb.b,
            0.0193339 * rgb.r + 0.1191920 * rgb.g + 0.9503041 * rgb.b,
        )
    }
}

impl Lab {
    fn new(l: f64, a: f64, b: f64) -> Lab { Lab { l, a, b } }
    fn f(t: f64) -> f64 {
        let delta = 6.0 / 29.0;
        if t > delta * delta * delta { pow(t, 1.0 / 3.0) }
        else { t / (3.0 * delta * delta) + 4.0 / 29.0 }
    }
    fn from_xyz(xyz: &XYZ) -> Lab {
        let fx = Lab::f(xyz.x / 0.95047);
        let fy = Lab::f(xyz.y / 1.00000);
        let fz = Lab::f(xyz.z / 1.08883);
        Lab::new(116.0 * fy - 16.0, 500.0 * (fx - fy), 200.0 * (fy - fz))
    }
}

impl OKLab {
    fn new(l: f64, a: f64, b: f64) -> OKLab { OKLab { l, a, b } }
    fn from_linear_rgb(rgb: &RGB) -> OKLab {
        let l = 0.4122214708 * rgb.r + 0.5363325363 * rgb.g + 0.0514459929 * rgb.b;
        let m = 0.2119034982 * rgb.r + 0.6806995451 * rgb.g + 0.1073969566 * rgb.b;
        let s = 0.0883024619 * rgb.r + 0.2817188376 * rgb.g + 0.6299787005 * rgb.b;
        let l_ = pow(l, 1.0 / 3.0);
        let m_ = pow(m, 1.0 / 3.0);
        let s_ = pow(s, 1.0 / 3.0);
        OKLab::new(
            0.2104542553 * l_ + 0.7936177850 * m_ - 0.0040720468 * s_,
            1.9779984951 * l_ - 2.4285922050 * m_ + 0.4505937099 * s_,
            0.0259040371 * l_ + 0.7827717662 * m_ - 0.8086757660 * s_,
        )
    }
}

fn approx_eq(a: f64, b: f64, tol: f64) -> bool {
    let diff = a - b;
    let abs_diff = if diff < 0.0 { 0.0 - diff } else { diff };
    abs_diff < tol
}

fn check_lab(r: f64, g: f64, b: f64, exp_l: f64, exp_a: f64, exp_b: f64) -> i32 {
    let lin = RGB::new(r, g, b).to_linear();
    let lab = Lab::from_xyz(&XYZ::from_linear_rgb(&lin));
    let tol = 0.01;
    if approx_eq(lab.l, exp_l, tol) && approx_eq(lab.a, exp_a, tol) && approx_eq(lab.b, exp_b, tol) {
        1
    } else {
        println!("FAIL Lab ({},{},{}): got ({},{},{})", r, g, b, lab.l, lab.a, lab.b);
        0
    }
}

fn check_oklab(r: f64, g: f64, b: f64, exp_l: f64, exp_a: f64, exp_b: f64) -> i32 {
    let lin = RGB::new(r, g, b).to_linear();
    let ok = OKLab::from_linear_rgb(&lin);
    let tol = 0.001;
    if approx_eq(ok.l, exp_l, tol) && approx_eq(ok.a, exp_a, tol) && approx_eq(ok.b, exp_b, tol) {
        1
    } else {
        println!("FAIL OKLab ({},{},{}): got ({},{},{})", r, g, b, ok.l, ok.a, ok.b);
        0
    }
}

fn main() {
    println!("=== QuantaLang Color Science Test Suite ===");
    let mut pass = 0;

    // CIE L*a*b* (D65) — reference values from CIE 1976 standard formulas
    pass = pass + check_lab(1.0, 0.0, 0.0,  53.2408,  80.0925,  67.2032);
    pass = pass + check_lab(0.0, 1.0, 0.0,  87.7347, -86.1827,  83.1793);
    pass = pass + check_lab(0.0, 0.0, 1.0,  32.2970,  79.1875, -107.8602);
    pass = pass + check_lab(1.0, 1.0, 1.0, 100.0000,   0.0000,   0.0000);
    pass = pass + check_lab(0.5, 0.5, 0.5,  53.3890,   0.0000,   0.0000);
    pass = pass + check_lab(1.0, 0.5, 0.0,  66.9566,  43.0719,  73.9594);

    // OKLab — reference values from Ottosson 2020 formulas
    pass = pass + check_oklab(1.0, 0.0, 0.0,  0.627955,  0.224863,  0.125846);
    pass = pass + check_oklab(0.0, 1.0, 0.0,  0.866440, -0.233888,  0.179498);
    pass = pass + check_oklab(0.0, 0.0, 1.0,  0.452014, -0.032457, -0.311528);
    pass = pass + check_oklab(1.0, 1.0, 1.0,  1.000000,  0.000000,  0.000000);
    pass = pass + check_oklab(0.5, 0.5, 0.5,  0.598181,  0.000000,  0.000000);
    pass = pass + check_oklab(1.0, 0.5, 0.0,  0.731143,  0.112587,  0.148197);

    println!("{} / 12 tests passed", pass);
    if pass == 12 {
        println!("=== ALL TESTS PASSED ===");
    } else {
        println!("=== TESTS FAILED ===");
    }
}
