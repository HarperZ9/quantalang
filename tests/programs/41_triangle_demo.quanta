// QuantaLang Triangle Demo — Test 41
// Demonstrates FFI to graphics stub library with a render loop.
// The stub prints what a real Vulkan backend would do.

extern "C" {
    fn quanta_gfx_init(width: i32, height: i32, title: &str) -> i32;
    fn quanta_gfx_should_close() -> i32;
    fn quanta_gfx_begin_frame();
    fn quanta_gfx_clear(r: f32, g: f32, b: f32, a: f32);
    fn quanta_gfx_draw(vertex_count: i32);
    fn quanta_gfx_end_frame();
    fn quanta_gfx_shutdown();
}

fn main() {
    quanta_gfx_init(800, 600, "QuantaLang Triangle");

    while quanta_gfx_should_close() == 0 {
        quanta_gfx_begin_frame();
        quanta_gfx_clear(0.1, 0.1, 0.2, 1.0);
        quanta_gfx_draw(3);
        quanta_gfx_end_frame();
    }

    quanta_gfx_shutdown();
}
