// Test 75: PBR BRDF material evaluation
// Disney/Cook-Torrance specular: Fresnel-Schlick, GGX NDF, geometry Smith

fn fresnel_schlick(cos_theta: f64, f0: f64) -> f64 {
    f0 + (1.0 - f0) * pow(1.0 - cos_theta, 5.0)
}

fn distribution_ggx(n_dot_h: f64, roughness: f64) -> f64 {
    let a = roughness * roughness;
    let a2 = a * a;
    let denom = n_dot_h * n_dot_h * (a2 - 1.0) + 1.0;
    a2 / (PI * denom * denom)
}

fn geometry_schlick_ggx(n_dot_v: f64, roughness: f64) -> f64 {
    let r = roughness + 1.0;
    let k = r * r / 8.0;
    n_dot_v / (n_dot_v * (1.0 - k) + k)
}

fn geometry_smith(n_dot_v: f64, n_dot_l: f64, roughness: f64) -> f64 {
    let ggx1 = geometry_schlick_ggx(n_dot_v, roughness);
    let ggx2 = geometry_schlick_ggx(n_dot_l, roughness);
    ggx1 * ggx2
}

fn cook_torrance(n_dot_h: f64, n_dot_v: f64, n_dot_l: f64, roughness: f64, f0: f64) -> f64 {
    let d = distribution_ggx(n_dot_h, roughness);
    let f = fresnel_schlick(n_dot_h, f0);
    let g = geometry_smith(n_dot_v, n_dot_l, roughness);
    let numerator = d * f * g;
    let denominator = 4.0 * n_dot_v * n_dot_l + 0.0001;
    numerator / denominator
}

fn main() {
    // Fresnel at normal incidence (cos_theta=1) should equal f0
    let f_normal = fresnel_schlick(1.0, 0.04);
    println!("fresnel(1.0, 0.04): {}", f_normal);

    // Fresnel at grazing angle (cos_theta=0) should approach 1.0
    let f_grazing = fresnel_schlick(0.0, 0.04);
    println!("fresnel(0.0, 0.04): {}", f_grazing);

    // GGX distribution peak at n_dot_h=1 with low roughness
    let d_peak = distribution_ggx(1.0, 0.1);
    println!("ggx_peak: {}", d_peak);

    // Full Cook-Torrance evaluation
    let spec = cook_torrance(0.9, 0.8, 0.7, 0.3, 0.04);
    println!("cook_torrance: {}", spec);

    // Rough material has lower specular
    let spec_rough = cook_torrance(0.9, 0.8, 0.7, 0.9, 0.04);
    if spec_rough < spec {
        println!("rough < smooth: true");
    } else {
        println!("rough < smooth: false");
    }

    // Metal has higher fresnel
    let spec_metal = cook_torrance(0.9, 0.8, 0.7, 0.3, 0.95);
    if spec_metal > spec {
        println!("metal > dielectric: true");
    } else {
        println!("metal > dielectric: false");
    }
}
