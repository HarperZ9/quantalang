// Test 81: Full calibration pipeline
// Simulate: measure → compute delta-E → generate correction → verify

struct Lab {
    l: f64,
    a: f64,
    b: f64,
}

fn delta_e_76(lab1: Lab, lab2: Lab) -> f64 {
    let dl = lab1.l - lab2.l;
    let da = lab1.a - lab2.a;
    let db = lab1.b - lab2.b;
    sqrt(dl * dl + da * da + db * db)
}

// Simulated display measurement: slightly off from target
fn measure_display(target_l: f64, target_a: f64, target_b: f64) -> Lab {
    // Simulate a display that's slightly warm and dark
    Lab {
        l: target_l - 2.0,
        a: target_a + 1.5,
        b: target_b + 3.0,
    }
}

// Compute correction needed
fn compute_correction(target: Lab, measured: Lab) -> Lab {
    Lab {
        l: target.l - measured.l,
        a: target.a - measured.a,
        b: target.b - measured.b,
    }
}

// Apply correction to a measured value
fn apply_correction(measured: Lab, correction: Lab) -> Lab {
    Lab {
        l: measured.l + correction.l,
        a: measured.a + correction.a,
        b: measured.b + correction.b,
    }
}

fn main() {
    // Step 1: Define target colors
    let target_white = Lab { l: 100.0, a: 0.0, b: 0.0 };
    let target_gray = Lab { l: 50.0, a: 0.0, b: 0.0 };

    // Step 2: Measure display (simulated)
    let meas_white = measure_display(100.0, 0.0, 0.0);
    let meas_gray = measure_display(50.0, 0.0, 0.0);

    // Step 3: Compute delta-E before correction
    let de_before_w = delta_e_76(target_white, meas_white);
    let de_before_g = delta_e_76(target_gray, meas_gray);
    println!("before white dE: {}", de_before_w);
    println!("before gray dE: {}", de_before_g);

    // Step 4: Compute corrections
    let corr_white = compute_correction(target_white, meas_white);
    let corr_gray = compute_correction(target_gray, meas_gray);
    println!("correction L: {}", corr_white.l);
    println!("correction a: {}", corr_white.a);
    println!("correction b: {}", corr_white.b);

    // Step 5: Apply corrections
    let corrected_white = apply_correction(meas_white, corr_white);
    let corrected_gray = apply_correction(meas_gray, corr_gray);

    // Step 6: Verify delta-E after correction
    let de_after_w = delta_e_76(target_white, corrected_white);
    let de_after_g = delta_e_76(target_gray, corrected_gray);
    println!("after white dE: {}", de_after_w);
    println!("after gray dE: {}", de_after_g);

    // Step 7: Verify corrected colors within tolerance
    if de_after_w < 1.0 {
        println!("white calibrated: true");
    } else {
        println!("white calibrated: false");
    }

    if de_after_g < 1.0 {
        println!("gray calibrated: true");
    } else {
        println!("gray calibrated: false");
    }

    // Step 8: Write calibration report
    let wrote = write_file("/tmp/quanta_calibration_81.txt", "CALIBRATION PASS");
    println!("report written: {}", wrote);
}
