// Test 72: Color conversion with reference verification
// sRGB to linear and back, verified against known values

fn srgb_to_linear(c: f64) -> f64 {
    if c <= 0.04045 {
        c / 12.92
    } else {
        pow((c + 0.055) / 1.055, 2.4)
    }
}

fn linear_to_srgb(c: f64) -> f64 {
    if c <= 0.0031308 {
        c * 12.92
    } else {
        1.055 * pow(c, 1.0 / 2.4) - 0.055
    }
}

fn main() {
    // Test known reference values for sRGB-to-linear
    // sRGB 0.0 -> linear 0.0
    let l0 = srgb_to_linear(0.0);
    println!("sRGB 0.0 -> linear: {}", l0);

    // sRGB 1.0 -> linear 1.0
    let l1 = srgb_to_linear(1.0);
    println!("sRGB 1.0 -> linear: {}", l1);

    // Round-trip: sRGB -> linear -> sRGB should be identity
    let original = 0.73;
    let linear = srgb_to_linear(original);
    let roundtrip = linear_to_srgb(linear);
    println!("roundtrip 0.73: {}", roundtrip);

    // Test gamma math
    let mid_gray_srgb = 0.5;
    let mid_gray_linear = srgb_to_linear(mid_gray_srgb);
    let mid_gray_back = linear_to_srgb(mid_gray_linear);
    println!("mid gray roundtrip: {}", mid_gray_back);

    // Verify linear mid-gray is ~0.214 (not 0.5)
    if mid_gray_linear < 0.22 {
        println!("gamma correct: true");
    } else {
        println!("gamma correct: false");
    }
}
