// Test 67: Pattern matching with guard clauses
// match arms with `if condition` guards

enum Shape {
    Circle(f64),
    Rectangle(f64),
    Triangle(f64),
}

fn classify(x: i32) -> i32 {
    match x {
        n if n < 0 => -1,
        n if n == 0 => 0,
        n if n < 10 => 1,
        n if n < 100 => 2,
        n => 3,
    }
}

fn main() {
    // Integer guards
    println!("classify(-5): {}", classify(-5));
    println!("classify(0): {}", classify(0));
    println!("classify(5): {}", classify(5));
    println!("classify(50): {}", classify(50));
    println!("classify(500): {}", classify(500));

    // Enum with guard clauses
    let s = Shape::Circle(5.0);
    match s {
        Shape::Circle(r) if r > 10.0 => println!("big circle"),
        Shape::Circle(r) if r > 0.0 => println!("small circle"),
        Shape::Circle(r) => println!("zero circle"),
        Shape::Rectangle(w) => println!("rectangle"),
        Shape::Triangle(b) => println!("triangle"),
    }
}
