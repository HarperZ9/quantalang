// Test 57: ? operator on generic Result<T, E>
// Early return on Err, extract Ok value

enum Result<T, E> {
    Ok(T),
    Err(E),
}

fn parse_positive(n: i32) -> Result<i32, i32> {
    if n > 0 {
        Result::Ok(n)
    } else {
        Result::Err(-1)
    }
}

fn double_positive(n: i32) -> Result<i32, i32> {
    let val = parse_positive(n)?;
    Result::Ok(val * 2)
}

fn main() {
    let r1 = double_positive(5);
    match r1 {
        Result::Ok(val) => println!("Ok: {}", val),
        Result::Err(e) => println!("Err: {}", e),
    }

    let r2 = double_positive(-3);
    match r2 {
        Result::Ok(val) => println!("Ok: {}", val),
        Result::Err(e) => println!("Err: {}", e),
    }

    let r3 = double_positive(0);
    match r3 {
        Result::Ok(val) => println!("Ok: {}", val),
        Result::Err(e) => println!("Err: {}", e),
    }
}
