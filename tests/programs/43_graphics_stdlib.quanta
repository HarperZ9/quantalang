// Test the graphics standard library functions
// Exercises color space, tone mapping, easing, interpolation, and PBR functions

fn rgb_to_luminance(r: f64, g: f64, b: f64) -> f64 {
    r * 0.2126 + g * 0.7152 + b * 0.0722
}

fn reinhard(x: f64) -> f64 { x / (1.0 + x) }

fn reinhard_extended(x: f64, max_white: f64) -> f64 {
    let numerator = x * (1.0 + x / (max_white * max_white));
    numerator / (1.0 + x)
}

fn aces_channel(x: f64) -> f64 {
    let a = 2.51;
    let b = 0.03;
    let c = 2.43;
    let d = 0.59;
    let e = 0.14;
    let result = (x * (a * x + b)) / (x * (c * x + d) + e);
    if result > 1.0 { 1.0 } else { if result < 0.0 { 0.0 } else { result } }
}

fn uncharted2_partial(x: f64) -> f64 {
    let a = 0.15;
    let b = 0.50;
    let c = 0.10;
    let d = 0.20;
    let e = 0.02;
    let f = 0.30;
    ((x * (a * x + c * b) + d * e) / (x * (a * x + b) + d * f)) - e / f
}

fn uncharted2(x: f64) -> f64 {
    let exposure_bias = 2.0;
    let curr = uncharted2_partial(x * exposure_bias);
    let white_scale = 1.0 / uncharted2_partial(11.2);
    curr * white_scale
}

fn ease_in_quad(t: f64) -> f64 { t * t }
fn ease_out_quad(t: f64) -> f64 { t * (2.0 - t) }
fn ease_in_out_quad(t: f64) -> f64 {
    if t < 0.5 { 2.0 * t * t } else { -1.0 + (4.0 - 2.0 * t) * t }
}
fn ease_in_cubic(t: f64) -> f64 { t * t * t }
fn ease_out_cubic(t: f64) -> f64 {
    let t1 = t - 1.0;
    t1 * t1 * t1 + 1.0
}

fn degrees_to_radians(deg: f64) -> f64 { deg * 3.14159265358979323846 / 180.0 }
fn radians_to_degrees(rad: f64) -> f64 { rad * 180.0 / 3.14159265358979323846 }

fn lerp_f64(a: f64, b: f64, t: f64) -> f64 { a + (b - a) * t }

fn inverse_lerp(a: f64, b: f64, value: f64) -> f64 {
    (value - a) / (b - a)
}

fn remap(value: f64, from_min: f64, from_max: f64, to_min: f64, to_max: f64) -> f64 {
    let t = inverse_lerp(from_min, from_max, value);
    lerp_f64(to_min, to_max, t)
}

fn smoothstep_f64(edge0: f64, edge1: f64, x: f64) -> f64 {
    let t = (x - edge0) / (edge1 - edge0);
    let tc = if t < 0.0 { 0.0 } else { if t > 1.0 { 1.0 } else { t } };
    tc * tc * (3.0 - 2.0 * tc)
}

fn fresnel_schlick(cos_theta: f64, f0: f64) -> f64 {
    let one_minus = 1.0 - cos_theta;
    let om2 = one_minus * one_minus;
    let om5 = om2 * om2 * one_minus;
    f0 + (1.0 - f0) * om5
}

fn ggx_distribution(n_dot_h: f64, roughness: f64) -> f64 {
    let a = roughness * roughness;
    let a2 = a * a;
    let denom = n_dot_h * n_dot_h * (a2 - 1.0) + 1.0;
    a2 / (3.14159265358979323846 * denom * denom)
}

fn main() {
    // === Color Space ===
    let luma = rgb_to_luminance(1.0, 0.5, 0.2);
    println!("luminance(1, 0.5, 0.2) = {}", luma);

    // === Tone Mapping ===
    println!("reinhard(2.0) = {}", reinhard(2.0));
    println!("reinhard(0.5) = {}", reinhard(0.5));
    println!("reinhard_ext(2.0, 4.0) = {}", reinhard_extended(2.0, 4.0));

    println!("aces(0.5) = {}", aces_channel(0.5));
    println!("aces(2.0) = {}", aces_channel(2.0));

    println!("uncharted2(1.0) = {}", uncharted2(1.0));

    // === Easing ===
    println!("ease_in_quad(0.5) = {}", ease_in_quad(0.5));
    println!("ease_out_quad(0.5) = {}", ease_out_quad(0.5));
    println!("ease_in_out_quad(0.25) = {}", ease_in_out_quad(0.25));
    println!("ease_in_out_quad(0.75) = {}", ease_in_out_quad(0.75));
    println!("ease_in_cubic(0.5) = {}", ease_in_cubic(0.5));
    println!("ease_out_cubic(0.5) = {}", ease_out_cubic(0.5));

    // === Geometric ===
    println!("deg_to_rad(180) = {}", degrees_to_radians(180.0));
    println!("rad_to_deg(3.14159) = {}", radians_to_degrees(3.14159265358979323846));

    // === Interpolation ===
    println!("lerp(0, 10, 0.3) = {}", lerp_f64(0.0, 10.0, 0.3));
    println!("inverse_lerp(0, 10, 3) = {}", inverse_lerp(0.0, 10.0, 3.0));
    println!("remap(5, 0, 10, 100, 200) = {}", remap(5.0, 0.0, 10.0, 100.0, 200.0));
    println!("smoothstep(0, 1, 0.5) = {}", smoothstep_f64(0.0, 1.0, 0.5));
    println!("smoothstep(0, 1, 0.0) = {}", smoothstep_f64(0.0, 1.0, 0.0));
    println!("smoothstep(0, 1, 1.0) = {}", smoothstep_f64(0.0, 1.0, 1.0));

    // === PBR ===
    let f = fresnel_schlick(0.5, 0.04);
    println!("fresnel(0.5, 0.04) = {}", f);
    let f2 = fresnel_schlick(0.0, 0.04);
    println!("fresnel(0.0, 0.04) = {}", f2);
    let f3 = fresnel_schlick(1.0, 0.04);
    println!("fresnel(1.0, 0.04) = {}", f3);

    let ggx = ggx_distribution(1.0, 0.5);
    println!("ggx(1.0, 0.5) = {}", ggx);
}
