// Test 54: Option<T> as a generic enum — end-to-end
// Construct, match, use with different types

enum Option<T> {
    Some(T),
    None,
}

fn find_positive(n: i32) -> i32 {
    if n > 0 {
        n
    } else {
        -1
    }
}

fn main() {
    // Construct Option::Some with i32 — triggers monomorphization
    let a = Option::Some(42);
    let b = Option::None;

    // Match on generic enum variants
    match a {
        Option::Some(val) => println!("Got value: {}", val),
        Option::None => println!("Got nothing"),
    }

    match b {
        Option::Some(val) => println!("Got value: {}", val),
        Option::None => println!("Got nothing"),
    }

    let result = find_positive(10);
    println!("Positive: {}", result);

    let result2 = find_positive(-5);
    println!("Negative: {}", result2);
}
