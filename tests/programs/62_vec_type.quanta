// Test 62: Vec type via QuantaVec runtime
// vec_new, vec_push, vec_get, vec_len, vec_pop

fn main() {
    // Create a new vector
    let v = vec_new();

    // Push values (vec_push takes pointer internally via runtime)
    vec_push(v, 10);
    vec_push(v, 20);
    vec_push(v, 30);
    vec_push(v, 40);

    // Get length
    let len = vec_len(v);
    println!("len: {}", len);

    // Get elements by index
    let first = vec_get(v, 0);
    let second = vec_get(v, 1);
    let third = vec_get(v, 2);

    println!("first: {}", first);
    println!("second: {}", second);
    println!("third: {}", third);

    // Pop last element
    let popped = vec_pop(v);
    println!("popped: {}", popped);
    println!("len after pop: {}", vec_len(v));

    // Sum all remaining elements
    let mut sum = 0;
    let mut i = 0;
    let remaining = vec_len(v);
    while i < remaining {
        sum = sum + vec_get(v, i);
        i = i + 1;
    }
    println!("sum: {}", sum);
}
