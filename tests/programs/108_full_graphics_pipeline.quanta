// Test 108: Complete graphics pipeline with color space safety
// Demonstrates the full QuantaLang value proposition:
// 1. Color space types prevent bugs
// 2. Same math compiles to CPU and GPU
// 3. Real PBR rendering algorithms

struct Color {
    r: f64,
    g: f64,
    b: f64,
}

// ==========================================
// COLOR SPACE CONVERSIONS (annotated)
// ==========================================

fn srgb_channel_to_linear(c: f64) -> f64 {
    if c <= 0.04045 { c / 12.92 }
    else { pow((c + 0.055) / 1.055, 2.4) }
}

fn linear_channel_to_srgb(c: f64) -> f64 {
    if c <= 0.0031308 { c * 12.92 }
    else { 1.055 * pow(c, 0.416667) - 0.055 }
}

fn to_linear(c: Color with ColorSpace<sRGB>) -> Color with ColorSpace<Linear> {
    Color {
        r: srgb_channel_to_linear(c.r),
        g: srgb_channel_to_linear(c.g),
        b: srgb_channel_to_linear(c.b),
    }
}

fn to_srgb(c: Color with ColorSpace<Linear>) -> Color with ColorSpace<sRGB> {
    Color {
        r: linear_channel_to_srgb(c.r),
        g: linear_channel_to_srgb(c.g),
        b: linear_channel_to_srgb(c.b),
    }
}

// ==========================================
// PBR RENDERING (requires linear light)
// ==========================================

fn fresnel_schlick(cos_theta: f64, f0: f64) -> f64 {
    let base = 1.0 - cos_theta;
    let b2 = base * base;
    f0 + (1.0 - f0) * b2 * b2 * base
}

fn ggx_distribution(n_dot_h: f64, roughness: f64) -> f64 {
    let a = roughness * roughness;
    let a2 = a * a;
    let d = n_dot_h * n_dot_h * (a2 - 1.0) + 1.0;
    a2 / (PI * d * d)
}

fn pbr_shade(
    albedo: Color with ColorSpace<Linear>,
    n_dot_l: f64,
    n_dot_h: f64,
    n_dot_v: f64,
    roughness: f64,
    metallic: f64
) -> Color with ColorSpace<Linear> {
    let f0_dielectric = 0.04;
    let f = fresnel_schlick(n_dot_h, f0_dielectric + metallic * (1.0 - f0_dielectric));
    let d = ggx_distribution(n_dot_h, roughness);

    let diffuse_factor = (1.0 - metallic) * n_dot_l / PI;
    let specular_factor = d * f / (4.0 * n_dot_v * n_dot_l + 0.0001);

    Color {
        r: albedo.r * diffuse_factor + specular_factor,
        g: albedo.g * diffuse_factor + specular_factor,
        b: albedo.b * diffuse_factor + specular_factor,
    }
}

// ==========================================
// TONE MAPPING (linear → display)
// ==========================================

fn aces_tonemap(x: f64) -> f64 {
    let a = 2.51;
    let b = 0.03;
    let c = 2.43;
    let d = 0.59;
    let e = 0.14;
    let num = x * (a * x + b);
    let den = x * (c * x + d) + e;
    num / den
}

fn apply_tonemap(c: Color with ColorSpace<Linear>) -> Color with ColorSpace<Linear> {
    Color {
        r: aces_tonemap(c.r),
        g: aces_tonemap(c.g),
        b: aces_tonemap(c.b),
    }
}

// ==========================================
// FULL PIPELINE
// ==========================================

fn main() {
    println!("=== QuantaLang Graphics Pipeline ===");

    // Input: sRGB texture color
    let tex_color = Color { r: 0.8, g: 0.4, b: 0.2 };
    println!("sRGB input: ({}, {}, {})", tex_color.r, tex_color.g, tex_color.b);

    // Step 1: Convert to linear (required for PBR)
    let linear = to_linear(tex_color);
    println!("linear: ({}, {}, {})", linear.r, linear.g, linear.b);

    // Step 2: PBR shade in linear space
    let shaded = pbr_shade(linear, 0.7, 0.9, 0.8, 0.3, 0.0);
    println!("PBR shaded: ({}, {}, {})", shaded.r, shaded.g, shaded.b);

    // Step 3: Tone map (still in linear)
    let tonemapped = apply_tonemap(shaded);
    println!("tonemapped: ({}, {}, {})", tonemapped.r, tonemapped.g, tonemapped.b);

    // Step 4: Convert to sRGB for display
    let display = to_srgb(tonemapped);
    println!("display sRGB: ({}, {}, {})", display.r, display.g, display.b);

    // The compiler GUARANTEES:
    // - PBR shading receives linear light (not gamma-encoded)
    // - Tone mapping operates in linear space
    // - sRGB conversion happens exactly once at the end
    // A color space mistake would be a COMPILE ERROR, not a visual bug.

    println!("pipeline: COMPLETE");
    println!("color safety: ENFORCED");
}
