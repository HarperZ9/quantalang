// Photon render: uses spectrum_core for color conversion
// Level 2 module (imported by main test)

mod spectrum_core;

fn tonemap_reinhard(hdr: f64) -> f64 {
    hdr / (1.0 + hdr)
}

fn apply_exposure(color: f64, exposure: f64) -> f64 {
    color * pow(2.0, exposure)
}

fn grade_color(linear_color: f64, exposure: f64) -> f64 {
    let exposed = apply_exposure(linear_color, exposure);
    let tonemapped = tonemap_reinhard(exposed);
    spectrum_core::linear_to_srgb(tonemapped)
}
