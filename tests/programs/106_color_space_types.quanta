// Test 106: Color space type annotations — Pillar 2A proof
// The `with` keyword annotates types with color space metadata
// This is the first QuantaLang program using type-level color space annotations

struct RGB {
    r: f64,
    g: f64,
    b: f64,
}

// Color space annotated function signatures
// `with ColorSpace<Linear>` declares the color space of the parameter
fn pbr_shade(albedo: RGB with ColorSpace<Linear>, n_dot_l: f64) -> RGB with ColorSpace<Linear> {
    RGB {
        r: albedo.r * n_dot_l / PI,
        g: albedo.g * n_dot_l / PI,
        b: albedo.b * n_dot_l / PI,
    }
}

fn srgb_to_linear_channel(c: f64) -> f64 {
    if c <= 0.04045 { c / 12.92 }
    else { pow((c + 0.055) / 1.055, 2.4) }
}

fn linear_to_srgb_channel(c: f64) -> f64 {
    if c <= 0.0031308 { c * 12.92 }
    else { 1.055 * pow(c, 0.416667) - 0.055 }
}

// Convert sRGB to linear — changes the color space annotation
fn srgb_to_linear(c: RGB with ColorSpace<sRGB>) -> RGB with ColorSpace<Linear> {
    RGB {
        r: srgb_to_linear_channel(c.r),
        g: srgb_to_linear_channel(c.g),
        b: srgb_to_linear_channel(c.b),
    }
}

// Convert linear to sRGB
fn linear_to_srgb(c: RGB with ColorSpace<Linear>) -> RGB with ColorSpace<sRGB> {
    RGB {
        r: linear_to_srgb_channel(c.r),
        g: linear_to_srgb_channel(c.g),
        b: linear_to_srgb_channel(c.b),
    }
}

fn main() {
    // sRGB input color
    let srgb_color = RGB { r: 0.8, g: 0.4, b: 0.2 };

    // Convert to linear for PBR shading
    let linear_color = srgb_to_linear(srgb_color);
    println!("linear r: {}", linear_color.r);

    // PBR shade in linear space
    let shaded = pbr_shade(linear_color, 0.7);
    println!("shaded r: {}", shaded.r);

    // Convert back to sRGB for display
    let display = linear_to_srgb(shaded);
    println!("display r: {}", display.r);
    println!("display g: {}", display.g);
    println!("display b: {}", display.b);

    // Round-trip: sRGB → linear → sRGB should be identity
    let white = RGB { r: 1.0, g: 1.0, b: 1.0 };
    let roundtrip = linear_to_srgb(srgb_to_linear(white));
    println!("roundtrip r: {}", roundtrip.r);

    println!("color space types: WORKING");
}
