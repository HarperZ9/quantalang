// Test 79: 3D LUT generation and interpolation
// Port of lut_engine.py core — generates a color correction LUT

// Apply a simple color correction: boost contrast + warm shift
fn correct_channel(c: f64, gamma: f64, gain: f64, offset: f64) -> f64 {
    let corrected = pow(c, gamma) * gain + offset;
    // Clamp to [0, 1]
    if corrected < 0.0 {
        0.0
    } else {
        if corrected > 1.0 {
            1.0
        } else {
            corrected
        }
    }
}

// Trilinear interpolation between two values
fn lerp(a: f64, b: f64, t: f64) -> f64 {
    a + (b - a) * t
}

// Generate a 1D LUT (simplified from 3D)
// In a real implementation this would be a 17^3 grid
fn generate_lut_value(input: f64, gamma: f64) -> f64 {
    correct_channel(input, gamma, 1.0, 0.0)
}

fn main() {
    // Generate LUT values at key points
    let lut_0 = generate_lut_value(0.0, 2.2);
    let lut_25 = generate_lut_value(0.25, 2.2);
    let lut_50 = generate_lut_value(0.5, 2.2);
    let lut_75 = generate_lut_value(0.75, 2.2);
    let lut_100 = generate_lut_value(1.0, 2.2);

    println!("LUT[0.00]: {}", lut_0);
    println!("LUT[0.25]: {}", lut_25);
    println!("LUT[0.50]: {}", lut_50);
    println!("LUT[0.75]: {}", lut_75);
    println!("LUT[1.00]: {}", lut_100);

    // Interpolate between LUT entries
    let interp = lerp(lut_25, lut_50, 0.5);
    println!("interp(0.375): {}", interp);

    // Verify monotonic: each entry >= previous
    if lut_25 >= lut_0 {
        if lut_50 >= lut_25 {
            if lut_75 >= lut_50 {
                if lut_100 >= lut_75 {
                    println!("monotonic: true");
                } else {
                    println!("monotonic: false");
                }
            } else {
                println!("monotonic: false");
            }
        } else {
            println!("monotonic: false");
        }
    } else {
        println!("monotonic: false");
    }

    // Correction with gain and offset
    let warm_r = correct_channel(0.5, 1.0, 1.1, 0.02);
    let warm_g = correct_channel(0.5, 1.0, 1.0, 0.0);
    let warm_b = correct_channel(0.5, 1.0, 0.9, -0.02);
    println!("warm R: {}", warm_r);
    println!("warm G: {}", warm_g);
    println!("warm B: {}", warm_b);
}
