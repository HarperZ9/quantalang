// Test 97: quanta-engine port — Adaptive feedback loop
// Ported from APPS/quanta-engine/quanta_engine/performance_tracker.py

struct PredictionRecord {
    predicted_up: i32,
    actual_up: i32,
    correct: i32,
}

// Evaluate a prediction: did we get the direction right?
fn evaluate(predicted_price: f64, actual_price: f64, current_price: f64) -> PredictionRecord {
    let pred_up = if predicted_price > current_price { 1 } else { 0 };
    let act_up = if actual_price > current_price { 1 } else { 0 };
    let correct = if pred_up == act_up { 1 } else { 0 };
    PredictionRecord { predicted_up: pred_up, actual_up: act_up, correct: correct }
}

// Run a simulation: 10 prediction cycles with feedback
fn main() {
    // Simulated prediction-outcome pairs
    // (current_price, predicted_price, actual_price)
    let current =   [100.0, 101.0, 103.0, 102.0, 104.0, 105.0, 103.0, 106.0, 107.0, 108.0];
    let predicted = [102.0, 103.0, 102.0, 104.0, 106.0, 104.0, 105.0, 108.0, 106.0, 110.0];
    let actual =    [101.0, 103.0, 102.0, 104.0, 105.0, 103.0, 106.0, 107.0, 108.0, 109.0];

    let mut total_correct = 0.0;
    let mut total = 0.0;
    let mut i = 0;
    while i < 10 {
        let record = evaluate(predicted[i], actual[i], current[i]);
        total_correct = total_correct + record.correct * 1.0;
        total = total + 1.0;
        i = i + 1;
    }

    let accuracy = total_correct / total;
    println!("total predictions: {}", total);
    println!("correct: {}", total_correct);
    println!("accuracy: {}", accuracy);

    // Dynamic weight = accuracy^2
    let weight = accuracy * accuracy;
    println!("model weight: {}", weight);

    // Should perform better than random (>50%)
    if accuracy > 0.5 {
        println!("better than random: true");
    } else {
        println!("better than random: false");
    }
}
