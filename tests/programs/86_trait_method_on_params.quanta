// Test 86: Trait method calls on type parameters
// Verifies that fn foo<T: Trait>(x: T) can call x.method()
// This was the REAL A1 blocker — method resolution through trait bounds.

trait Measurable {
    fn measure(self) -> f64;
    fn describe(self, prefix: i64) -> f64;
}

trait Scalable {
    fn scale(self, factor: f64) -> Self;
}

struct Circle {
    radius: f64,
}

impl Measurable for Circle {
    fn measure(self) -> f64 {
        3.14159 * self.radius * self.radius
    }

    fn describe(self, prefix: i64) -> f64 {
        self.radius * 2.0
    }
}

impl Scalable for Circle {
    fn scale(self, factor: f64) -> Circle {
        Circle { radius: self.radius * factor }
    }
}

// Single trait bound — method with no extra args
fn get_measurement<T: Measurable>(shape: T) -> f64 {
    shape.measure()
}

// Single trait bound — method WITH extra args (previously broken)
fn get_description<T: Measurable>(shape: T, prefix: i64) -> f64 {
    shape.describe(prefix)
}

// Multiple trait bounds — call methods from different traits on same T
fn measure_then_scale<T: Measurable + Scalable>(shape: T, factor: f64) -> f64 {
    let m = shape.measure();
    m * factor
}

fn main() {
    let c = Circle { radius: 5.0 };
    println!("measurement: {}", get_measurement(c));

    let c2 = Circle { radius: 3.0 };
    println!("description: {}", get_description(c2, 42));

    let c3 = Circle { radius: 2.0 };
    println!("scaled: {}", measure_then_scale(c3, 3.0));
}
