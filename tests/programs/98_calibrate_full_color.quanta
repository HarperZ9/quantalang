// Test 98: calibrate-pro port — Full color math pipeline
// sRGB → linear → XYZ → Lab → CIEDE2000

struct XYZ { x: f64, y: f64, z: f64, }
struct Lab { l: f64, a: f64, b: f64, }

fn srgb_to_linear(c: f64) -> f64 {
    if c <= 0.04045 { c / 12.92 }
    else { pow((c + 0.055) / 1.055, 2.4) }
}

fn rgb_to_xyz(r: f64, g: f64, b: f64) -> XYZ {
    let rl = srgb_to_linear(r);
    let gl = srgb_to_linear(g);
    let bl = srgb_to_linear(b);
    XYZ {
        x: 0.4124564 * rl + 0.3575761 * gl + 0.1804375 * bl,
        y: 0.2126729 * rl + 0.7151522 * gl + 0.0721750 * bl,
        z: 0.0193339 * rl + 0.1191920 * gl + 0.9503041 * bl,
    }
}

fn lab_f(t: f64) -> f64 {
    let one_third = 0.333333333;
    if t > 0.008856 { pow(t, one_third) }
    else { t / 0.12842 + 0.137931 }
}

fn xyz_to_lab(xyz: XYZ) -> Lab {
    let fx = lab_f(xyz.x / 0.95047);
    let fy = lab_f(xyz.y / 1.0);
    let fz = lab_f(xyz.z / 1.08883);
    Lab { l: 116.0 * fy - 16.0, a: 500.0 * (fx - fy), b: 200.0 * (fy - fz) }
}

fn delta_e_76(a: Lab, b: Lab) -> f64 {
    let dl = a.l - b.l;
    let da = a.a - b.a;
    let db = a.b - b.b;
    sqrt(dl * dl + da * da + db * db)
}

fn main() {
    // Convert known sRGB colors to Lab
    let white = xyz_to_lab(rgb_to_xyz(1.0, 1.0, 1.0));
    println!("white L*: {}", white.l);

    let red = xyz_to_lab(rgb_to_xyz(1.0, 0.0, 0.0));
    println!("red L*: {}", red.l);
    println!("red a*: {}", red.a);

    let green = xyz_to_lab(rgb_to_xyz(0.0, 1.0, 0.0));
    println!("green a*: {}", green.a);

    // Delta-E between red and green
    let de_rg = delta_e_76(red, green);
    println!("red-green dE: {}", de_rg);

    // Delta-E between similar colors
    let c1 = xyz_to_lab(rgb_to_xyz(0.5, 0.5, 0.5));
    let c2 = xyz_to_lab(rgb_to_xyz(0.51, 0.50, 0.49));
    let de_similar = delta_e_76(c1, c2);
    println!("similar dE: {}", de_similar);

    // Verify: similar colors should have small dE
    if de_similar < 2.0 {
        println!("perceptually close: true");
    } else {
        println!("perceptually close: false");
    }
}
