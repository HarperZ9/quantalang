fn abs_val(n: i32) -> i32 {
    if n < 0 {
        -n
    } else {
        n
    }
}

fn sign(n: i32) -> i32 {
    if n > 0 {
        1
    } else if n < 0 {
        -1
    } else {
        0
    }
}

fn main() {
    println!("abs(-42) = {}", abs_val(-42));
    println!("abs(42) = {}", abs_val(42));
    println!("sign(-5) = {}", sign(-5));
    println!("sign(0) = {}", sign(0));
    println!("sign(5) = {}", sign(5));
}
