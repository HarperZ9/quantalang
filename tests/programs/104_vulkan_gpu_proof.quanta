// Test 104: Vulkan GPU proof — load QuantaLang-compiled SPIR-V on real GPU
// This test:
// 1. Initializes Vulkan (creates instance, picks GPU, creates device)
// 2. Loads a SPIR-V shader compiled from QuantaLang
// 3. Verifies the shader module creation succeeds
// 4. Runs the same math on CPU for comparison

fn fresnel(cos_theta: f64, f0: f64) -> f64 {
    let base = 1.0 - cos_theta;
    let b2 = base * base;
    let b5 = b2 * b2 * base;
    f0 + (1.0 - f0) * b5
}

fn main() {
    // CPU math — same functions that compile to SPIR-V
    println!("=== CPU Results ===");
    println!("fresnel(0.5): {}", fresnel(0.5, 0.04));
    println!("fresnel(0.0): {}", fresnel(0.0, 0.04));
    println!("fresnel(1.0): {}", fresnel(1.0, 0.04));

    // Initialize Vulkan runtime
    println!("=== GPU Init ===");
    let ok = quanta_vk_init();
    if ok == 1 {
        println!("vulkan: initialized");
    } else {
        println!("vulkan: failed");
    }

    // Load the pre-compiled SPIR-V shader
    // (compiled separately: quantac test102.quanta --target spirv -o test102.spv)
    let loaded = quanta_vk_load_shader_file("quanta_test102.spv");
    if loaded == 1 {
        println!("shader: loaded on GPU");
    } else {
        println!("shader: load failed (expected if .spv not present)");
    }

    // Shutdown
    quanta_vk_shutdown();
    println!("=== Complete ===");
}
