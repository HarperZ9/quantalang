// Test 65: Stdlib math constants and generic functions
// PI, E, TAU, plus abs, sqrt, pow, min, max

fn main() {
    // Math constants
    println!("PI: {}", PI);
    println!("E: {}", E);
    println!("TAU: {}", TAU);

    // Math functions
    let x = sqrt(144.0);
    println!("sqrt(144): {}", x);

    let y = pow(2.0, 10.0);
    println!("2^10: {}", y);

    let z = abs(-42.0);
    println!("abs(-42): {}", z);

    // Trig
    let s = sin(0.0);
    println!("sin(0): {}", s);

    let c = cos(0.0);
    println!("cos(0): {}", c);

    // Min/max
    let m1 = min(10, 20);
    let m2 = max(10, 20);
    println!("min: {}", m1);
    println!("max: {}", m2);

    // Floor/ceil
    let f = floor(3.7);
    let g = ceil(3.2);
    println!("floor(3.7): {}", f);
    println!("ceil(3.2): {}", g);
}
