struct Vec3 {
    x: f64,
    y: f64,
    z: f64,
}

impl Vec3 {
    fn new(x: f64, y: f64, z: f64) -> Self {
        Vec3 { x: x, y: y, z: z }
    }
}

pub mod math_utils {
    use super::*;

    pub fn dot(a: Vec3, b: Vec3) -> f64 {
        a.x * b.x + a.y * b.y + a.z * b.z
    }

    pub fn length(v: Vec3) -> f64 {
        sqrt(dot(v, v))
    }
}

fn main() {
    let v = Vec3::new(1.0, 2.0, 2.0);
    let d = math_utils::dot(v, v);
    assert(d == 9.0);

    let len = math_utils::length(Vec3::new(3.0, 4.0, 0.0));
    assert(len == 5.0);

    println("Inline module tests passed!");
}
