mod core;

fn main() {
    // Integer utilities - these work correctly with cross-module calls
    let a1: i32 = core::i32_abs(-42);
    println!("abs(-42) = {}", a1);
    let mn: i32 = core::i32_min(3, 7);
    println!("min(3, 7) = {}", mn);
    let mx: i32 = core::i32_max(3, 7);
    println!("max(3, 7) = {}", mx);
    let c1: i32 = core::i32_clamp(150, 0, 100);
    println!("clamp(150, 0, 100) = {}", c1);
    let c2: i32 = core::i32_clamp(-5, 0, 100);
    println!("clamp(-5, 0, 100) = {}", c2);
    let c3: i32 = core::i32_clamp(50, 0, 100);
    println!("clamp(50, 0, 100) = {}", c3);

    // Comparison helpers (print via if/else since bool printf is not wired)
    if core::is_even(42) {
        println!("is_even(42) = true");
    } else {
        println!("is_even(42) = false");
    }

    if core::is_odd(7) {
        println!("is_odd(7) = true");
    } else {
        println!("is_odd(7) = false");
    }

    if core::is_positive(10) {
        println!("is_positive(10) = true");
    } else {
        println!("is_positive(10) = false");
    }

    if core::is_negative(-3) {
        println!("is_negative(-3) = true");
    } else {
        println!("is_negative(-3) = false");
    }

    if core::is_zero(0) {
        println!("is_zero(0) = true");
    } else {
        println!("is_zero(0) = false");
    }

    // Higher-order math utilities (these use intra-module calls)
    let g1: i32 = core::gcd(12, 8);
    println!("gcd(12, 8) = {}", g1);
    let g2: i32 = core::gcd(-18, 24);
    println!("gcd(-18, 24) = {}", g2);
    let l1: i32 = core::lcm(4, 6);
    println!("lcm(4, 6) = {}", l1);
    let f1: i32 = core::factorial(5);
    println!("factorial(5) = {}", f1);
    let fib: i32 = core::fibonacci(10);
    println!("fibonacci(10) = {}", fib);
    let p1: i32 = core::power(2, 10);
    println!("power(2, 10) = {}", p1);
}
