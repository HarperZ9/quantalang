fn main() {
    let arg_count = args_count();
    println!("Arg count: {}", arg_count);

    if arg_count > 1 {
        let first = args_get(1);
        println!("First arg: {}", first);
    }

    // String ops
    let s = "Hello, World!";
    let idx = s.index_of("World");
    println!("Index of World: {}", idx);

    let replaced = s.replace("World", "QuantaLang");
    println!("Replaced: {}", replaced);

    let sub = s.substring(0, 5);
    println!("Substring: {}", sub);

    let num = "42".parse_int();
    assert(num == 42);

    let pi = "3.14".parse_float();
    assert(pi > 3.13);
    assert(pi < 3.15);

    println("CLI primitives test passed!");
}
