// Test 68: HashMap via runtime builtins
// map_new, map_insert, map_get, map_contains, map_len, map_remove

fn main() {
    let m = map_new();

    // Insert key-value pairs
    map_insert(m, 1, 100);
    map_insert(m, 2, 200);
    map_insert(m, 3, 300);

    // Check length
    println!("len: {}", map_len(m));

    // Get values
    println!("get(1): {}", map_get(m, 1, -1));
    println!("get(2): {}", map_get(m, 2, -1));
    println!("get(3): {}", map_get(m, 3, -1));
    println!("get(99): {}", map_get(m, 99, -1));

    // Contains
    if map_contains(m, 2) {
        println!("contains 2: true");
    } else {
        println!("contains 2: false");
    }

    if map_contains(m, 99) {
        println!("contains 99: true");
    } else {
        println!("contains 99: false");
    }

    // Update existing key
    map_insert(m, 2, 999);
    println!("get(2) after update: {}", map_get(m, 2, -1));

    // Remove
    map_remove(m, 1);
    println!("len after remove: {}", map_len(m));
    println!("get(1) after remove: {}", map_get(m, 1, -1));
}
