// PBR Material Evaluation
// The standard shading model for modern game engines (UE4, Unity, Frostbite)

fn fresnel_schlick(cos_theta: f64, f0: f64) -> f64 {
    let one_minus = 1.0 - cos_theta;
    let om2 = one_minus * one_minus;
    let om5 = om2 * om2 * one_minus;
    f0 + (1.0 - f0) * om5
}

fn ggx_distribution(n_dot_h: f64, roughness: f64) -> f64 {
    let a = roughness * roughness;
    let a2 = a * a;
    let denom = n_dot_h * n_dot_h * (a2 - 1.0) + 1.0;
    a2 / (3.14159265 * denom * denom)
}

fn smith_ggx_geometry(n_dot_v: f64, roughness: f64) -> f64 {
    let r = roughness + 1.0;
    let k = r * r / 8.0;
    n_dot_v / (n_dot_v * (1.0 - k) + k)
}

fn cook_torrance_brdf(
    n_dot_l: f64, n_dot_v: f64, n_dot_h: f64,
    roughness: f64, metallic: f64, f0: f64
) -> f64 {
    let d = ggx_distribution(n_dot_h, roughness);
    let f = fresnel_schlick(n_dot_h, f0);
    let g = smith_ggx_geometry(n_dot_l, roughness) * smith_ggx_geometry(n_dot_v, roughness);

    let numerator = d * f * g;
    let denominator = 4.0 * n_dot_l * n_dot_v;
    if denominator > 0.001 {
        numerator / denominator
    } else {
        0.0
    }
}

fn main() {
    // Evaluate PBR BRDF for different materials
    let n_dot_l = 0.8;
    let n_dot_v = 0.6;
    let n_dot_h = 0.9;

    // Smooth plastic (low roughness, non-metallic)
    let plastic = cook_torrance_brdf(n_dot_l, n_dot_v, n_dot_h, 0.1, 0.0, 0.04);
    println!("Plastic BRDF: {}", plastic);

    // Rough metal (high roughness, metallic)
    let rough_metal = cook_torrance_brdf(n_dot_l, n_dot_v, n_dot_h, 0.8, 1.0, 0.95);
    println!("Rough metal BRDF: {}", rough_metal);

    // Gold (metallic with characteristic F0)
    let gold = cook_torrance_brdf(n_dot_l, n_dot_v, n_dot_h, 0.3, 1.0, 0.83);
    println!("Gold BRDF: {}", gold);

    // Individual components
    println!("Fresnel(0.5, 0.04): {}", fresnel_schlick(0.5, 0.04));
    println!("GGX D(0.9, 0.5): {}", ggx_distribution(0.9, 0.5));
    println!("Smith G(0.8, 0.5): {}", smith_ggx_geometry(0.8, 0.5));
}
