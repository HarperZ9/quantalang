fn is_even(n: i32) -> bool {
    n % 2 == 0
}

fn classify(n: i32) -> i32 {
    if is_even(n) {
        if n > 100 {
            3
        } else {
            2
        }
    } else {
        1
    }
}

fn main() {
    println!("classify(42) = {}", classify(42));
    println!("classify(102) = {}", classify(102));
    println!("classify(7) = {}", classify(7));
}
