// Showcase: QuantaLang's algebraic effect system
//
// Effects let you declare side-effect interfaces and handle them
// at call sites, giving you control over I/O, errors, state, etc.
// This test demonstrates a simple greeting effect with a single
// perform dispatching to its handler.

effect Greeting {
    fn greet(name: str) -> (),
}

fn welcome() ~ Greeting {
    perform Greeting.greet("Alice");
}

fn main() {
    handle {
        welcome()
    } with {
        Greeting.greet(name) => {
            println!("Hello, {}!", name)
        },
    }
}
