// Test 85: Method calls on user-defined types
// Previously blocked by type checker rejecting .method() on structs
// This test verifies A1 (type checker inherent method resolution)

struct Point {
    x: f64,
    y: f64,
}

impl Point {
    fn distance(self) -> f64 {
        sqrt(self.x * self.x + self.y * self.y)
    }

    fn translate(self, dx: f64, dy: f64) -> Point {
        Point { x: self.x + dx, y: self.y + dy }
    }

    fn scale(self, factor: f64) -> Point {
        Point { x: self.x * factor, y: self.y * factor }
    }
}

struct Color {
    r: f64,
    g: f64,
    b: f64,
}

impl Color {
    fn luminance(self) -> f64 {
        0.2126 * self.r + 0.7152 * self.g + 0.0722 * self.b
    }

    fn grayscale(self) -> Color {
        let l = self.luminance();
        Color { r: l, g: l, b: l }
    }
}

fn main() {
    // Point methods
    let p = Point { x: 3.0, y: 4.0 };
    println!("distance: {}", p.distance());

    let p2 = Point { x: 1.0, y: 0.0 };
    let p3 = p2.translate(2.0, 3.0);
    println!("translated: ({}, {})", p3.x, p3.y);

    let p4 = Point { x: 5.0, y: 10.0 };
    let p5 = p4.scale(0.5);
    println!("scaled: ({}, {})", p5.x, p5.y);

    // Color methods
    let white = Color { r: 1.0, g: 1.0, b: 1.0 };
    println!("white lum: {}", white.luminance());

    let red = Color { r: 0.8, g: 0.2, b: 0.1 };
    let gray = red.grayscale();
    println!("gray r: {}", gray.r);
}
