// ═══════════════════════════════════════════════════════════════════════════════
// Self-hosting Phase 6, Step 2: Ordering enum from stdlib/core/cmp.quanta
// ═══════════════════════════════════════════════════════════════════════════════
//
// This is a simplified version of the self-hosted cmp module from
// quantalang/stdlib/core/cmp.quanta.
//
// Original uses: trait definitions with supertraits (PartialEq, Eq, Ord),
//   default trait methods, generic structs (Reverse<T>), trait bounds,
//   ?Sized bounds, macros (macro_rules!), never type (!), raw pointers,
//   references (&self, &Rhs), const generics, tuples up to 12 elements.
//
// Simplified here: just the Ordering enum with its methods (lines 29-115),
//   plus a free compare function instead of traits.
//
// This proves: enum with explicit discriminants, match on self, method chaining.
// ═══════════════════════════════════════════════════════════════════════════════

// Adapted from: quantalang/stdlib/core/cmp.quanta lines 29-36
// Original: #[repr(i8)] pub enum Ordering { Less = -1, Equal = 0, Greater = 1 }
// Simplified: no repr, no explicit discriminant values
enum Ordering {
    Less,
    Equal,
    Greater,
}

impl Ordering {
    // Adapted from: cmp.quanta lines 41-43
    fn is_lt(self) -> bool {
        match self {
            Ordering::Less => true,
            Ordering::Equal => false,
            Ordering::Greater => false,
        }
    }

    // Adapted from: cmp.quanta lines 47-49
    fn is_eq(self) -> bool {
        match self {
            Ordering::Less => false,
            Ordering::Equal => true,
            Ordering::Greater => false,
        }
    }

    // Adapted from: cmp.quanta lines 53-55
    fn is_gt(self) -> bool {
        match self {
            Ordering::Less => false,
            Ordering::Equal => false,
            Ordering::Greater => true,
        }
    }
}

// Adapted from: cmp.quanta lines 81-87 (Ordering::reverse)
fn ordering_reverse(ord: Ordering) -> Ordering {
    match ord {
        Ordering::Less => Ordering::Greater,
        Ordering::Equal => Ordering::Equal,
        Ordering::Greater => Ordering::Less,
    }
}

// Adapted from: cmp.quanta lines 98-103 (Ordering::then)
// Original: chains two orderings for lexicographic compare
fn ordering_then(first: Ordering, second: Ordering) -> Ordering {
    match first {
        Ordering::Equal => second,
        Ordering::Less => Ordering::Less,
        Ordering::Greater => Ordering::Greater,
    }
}

// Simplified from: cmp.quanta Ord trait (lines 263-269)
// Original: trait Ord { fn cmp(&self, other: &Self) -> Ordering; }
// Simplified: free function for i32
fn compare_i32(a: i32, b: i32) -> Ordering {
    if a < b {
        Ordering::Less
    } else {
        if a > b {
            Ordering::Greater
        } else {
            Ordering::Equal
        }
    }
}

fn ordering_to_str(ord: Ordering) -> str {
    match ord {
        Ordering::Less => "Less",
        Ordering::Equal => "Equal",
        Ordering::Greater => "Greater",
    }
}

fn main() {
    // Test basic ordering
    let lt = compare_i32(1, 5);
    let eq = compare_i32(3, 3);
    let gt = compare_i32(9, 2);

    println!("compare(1,5): {}", ordering_to_str(lt));
    println!("compare(3,3): {}", ordering_to_str(eq));
    println!("compare(9,2): {}", ordering_to_str(gt));

    // Test query methods
    println!("Less.is_lt: {}", lt.is_lt());
    println!("Equal.is_eq: {}", eq.is_eq());
    println!("Greater.is_gt: {}", gt.is_gt());

    // Test reverse
    let rev = ordering_reverse(Ordering::Less);
    println!("reverse(Less): {}", ordering_to_str(rev));
    let rev2 = ordering_reverse(Ordering::Greater);
    println!("reverse(Greater): {}", ordering_to_str(rev2));

    // Test then (lexicographic chaining)
    let t1 = ordering_then(Ordering::Equal, Ordering::Less);
    println!("then(Equal,Less): {}", ordering_to_str(t1));
    let t2 = ordering_then(Ordering::Greater, Ordering::Less);
    println!("then(Greater,Less): {}", ordering_to_str(t2));
}
