enum Result {
    Ok(i32),
    Err(i32),
}

fn divide(a: i32, b: i32) -> Result {
    if b == 0 {
        Result::Err(-1)
    } else {
        Result::Ok(a / b)
    }
}

fn compute() -> Result {
    let x = divide(100, 5)?;
    let y = divide(x, 4)?;
    Result::Ok(x + y)
}

fn compute_fail() -> Result {
    let x = divide(100, 0)?;
    Result::Ok(x)
}

fn main() {
    let r1 = compute();
    let r2 = compute_fail();

    match r1 {
        Result::Ok(v) => println!("compute: Ok({})", v),
        Result::Err(e) => println!("compute: Err({})", e),
    }

    match r2 {
        Result::Ok(v) => println!("compute_fail: Ok({})", v),
        Result::Err(e) => println!("compute_fail: Err({})", e),
    }
}
