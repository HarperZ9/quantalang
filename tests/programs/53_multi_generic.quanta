// Test 53: Multi-type-parameter generics
// KeyValue<K, V> with two independent type parameters

struct KeyValue<K, V> {
    key: K,
    value: V,
}

fn make_pair<T>(a: T, b: T) -> T {
    if a > b {
        a
    } else {
        b
    }
}

fn main() {
    let kv = KeyValue { key: 42, value: 100 };
    println!("key: {}", kv.key);
    println!("value: {}", kv.value);

    // Multi-param generic function
    let bigger = make_pair(10, 25);
    println!("bigger: {}", bigger);
}
