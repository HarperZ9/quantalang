// Test 64: Format strings and string building
// to_string_i32, to_string_f64, string concatenation

fn main() {
    // Convert numbers to strings
    let s1 = to_string_i32(42);
    println!("i32 string: {}", s1);

    let s2 = to_string_f64(3.14);
    println!("f64 string: {}", s2);

    // Use in expressions
    let x = 100;
    let y = 200;
    let sum = x + y;
    println!("sum: {}", sum);

    // Print formatted with precision
    let pi_approx = 3.14159;
    println!("pi: {}", pi_approx);

    // Multiple values
    let a = 10;
    let b = 20;
    let c = a * b;
    println!("{} * {} = {}", a, b, c);
}
