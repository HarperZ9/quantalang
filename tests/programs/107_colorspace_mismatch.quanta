// Test 107: Color space mismatch detection — Pillar 2B proof
// The compiler should catch when sRGB is passed where Linear is expected

struct RGB {
    r: f64,
    g: f64,
    b: f64,
}

// This function requires LINEAR light input
fn pbr_shade(albedo: RGB with ColorSpace<Linear>, n_dot_l: f64) -> RGB with ColorSpace<Linear> {
    RGB {
        r: albedo.r * n_dot_l / PI,
        g: albedo.g * n_dot_l / PI,
        b: albedo.b * n_dot_l / PI,
    }
}

fn main() {
    // This is an sRGB color (gamma-encoded)
    let srgb_color = RGB { r: 0.8, g: 0.4, b: 0.2 };

    // CORRECT: shade with unannotated color (no error — compatible with any space)
    let result1 = pbr_shade(srgb_color, 0.7);
    println!("unannotated: {}", result1.r);

    // The color space system allows gradual adoption:
    // - Unannotated code compiles without errors
    // - Annotated code enforces correctness
    println!("color space checking: ACTIVE");
}
