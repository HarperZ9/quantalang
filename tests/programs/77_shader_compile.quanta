// Test 77: Shader-style functions compiled to C
// Demonstrates functions that would compile to SPIR-V for GPU execution

fn srgb_to_linear(c: f64) -> f64 {
    if c <= 0.04045 {
        c / 12.92
    } else {
        pow((c + 0.055) / 1.055, 2.4)
    }
}

fn pbr_diffuse(albedo: f64, n_dot_l: f64) -> f64 {
    albedo * n_dot_l / PI
}

fn pbr_specular(roughness: f64, n_dot_h: f64) -> f64 {
    let a = roughness * roughness;
    let a2 = a * a;
    let d = n_dot_h * n_dot_h * (a2 - 1.0) + 1.0;
    a2 / (PI * d * d)
}

fn shade_pixel(albedo: f64, roughness: f64, metallic: f64, n_dot_l: f64, n_dot_h: f64) -> f64 {
    let linear_albedo = srgb_to_linear(albedo);
    let diffuse = pbr_diffuse(linear_albedo, n_dot_l) * (1.0 - metallic);
    let specular = pbr_specular(roughness, n_dot_h) * 0.04;
    diffuse + specular
}

fn main() {
    // Shade a dielectric surface (non-metal)
    let pixel1 = shade_pixel(0.8, 0.5, 0.0, 0.7, 0.9);
    println!("dielectric pixel: {}", pixel1);

    // Shade a metallic surface
    let pixel2 = shade_pixel(0.8, 0.3, 1.0, 0.7, 0.9);
    println!("metallic pixel: {}", pixel2);

    // Verify metal has less diffuse
    if pixel2 < pixel1 {
        println!("metal < dielectric: true");
    } else {
        println!("metal < dielectric: false");
    }

    // Rough surface
    let pixel3 = shade_pixel(0.5, 0.9, 0.0, 0.7, 0.9);
    println!("rough pixel: {}", pixel3);

    // Smooth surface (higher specular peak)
    let pixel4 = shade_pixel(0.5, 0.1, 0.0, 0.7, 0.9);
    if pixel4 > pixel3 {
        println!("smooth > rough: true");
    } else {
        println!("smooth > rough: false");
    }
}
