// Test 61: Custom iterator pattern with next() method
// Demonstrates the iterator building blocks

enum IterResult {
    Value(i32),
    Done,
}

struct Counter {
    current: i32,
    max: i32,
}

fn counter_next(c: Counter) -> IterResult {
    if c.current < c.max {
        IterResult::Value(c.current)
    } else {
        IterResult::Done
    }
}

fn main() {
    // Iterate manually using counter_next
    let c1 = Counter { current: 0, max: 3 };
    let r1 = counter_next(c1);
    match r1 {
        IterResult::Value(v) => println!("iter 0: {}", v),
        IterResult::Done => println!("done"),
    }

    let c2 = Counter { current: 1, max: 3 };
    let r2 = counter_next(c2);
    match r2 {
        IterResult::Value(v) => println!("iter 1: {}", v),
        IterResult::Done => println!("done"),
    }

    let c3 = Counter { current: 2, max: 3 };
    let r3 = counter_next(c3);
    match r3 {
        IterResult::Value(v) => println!("iter 2: {}", v),
        IterResult::Done => println!("done"),
    }

    let c4 = Counter { current: 3, max: 3 };
    let r4 = counter_next(c4);
    match r4 {
        IterResult::Value(v) => println!("iter 3: {}", v),
        IterResult::Done => println!("done"),
    }

    // Sum using a loop
    let mut sum = 0;
    for i in 0..5 {
        sum = sum + i;
    }
    println!("sum 0..5: {}", sum);
}
