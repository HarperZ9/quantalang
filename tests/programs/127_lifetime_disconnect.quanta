// Interprocedural Lifetime Analysis — disconnected lifetimes.
// fn pick_first<'a, 'b> returns &'a, so 'b arg does NOT contribute to
// the returned borrow. With the old heuristic (all ref args are sources),
// this would incorrectly flag y as escaping scope. With lifetime-aware
// tracking, only x's borrow propagates to r.

fn pick_first<'a, 'b>(x: &'a i32, y: &'b i32) -> &'a i32 {
    x
}

fn main() {
    let a: i32 = 42;
    let r: &i32 = pick_first(&a, &a);
    let val: i32 = *r;
    println("{}", val);
}
