// Test 80: ICC profile generation basics
// Port of icc_profile.py — generates ICC profile header data

// ICC profile header is 128 bytes
// Key fields: size (4 bytes), signature 'acsp' (4 bytes), version, etc.

fn icc_magic() -> i32 {
    // 'acsp' = 0x61637370
    1633837168
}

fn icc_header_size() -> i32 {
    128
}

// Pack a 32-bit value as big-endian bytes
fn byte0(val: i32) -> i32 {
    (val / 16777216) % 256
}

fn byte1(val: i32) -> i32 {
    (val / 65536) % 256
}

fn byte2(val: i32) -> i32 {
    (val / 256) % 256
}

fn byte3(val: i32) -> i32 {
    val % 256
}

// Fixed-point 15.16 format used in ICC
fn to_fixed_16_16(val: f64) -> i32 {
    let fixed = val * 65536.0;
    if fixed > 2147483647.0 {
        2147483647
    } else {
        if fixed < 0.0 {
            0
        } else {
            floor(fixed)
        }
    }
}

fn main() {
    // Verify ICC magic number
    let magic = icc_magic();
    println!("magic: {}", magic);

    // Header size
    println!("header: {}", icc_header_size());

    // Big-endian byte extraction
    let test_val = 1633837168; // 'acsp'
    println!("byte0: {}", byte0(test_val));
    println!("byte1: {}", byte1(test_val));
    println!("byte2: {}", byte2(test_val));
    println!("byte3: {}", byte3(test_val));

    // Fixed-point conversion
    let fixed_1 = to_fixed_16_16(1.0);
    println!("fixed(1.0): {}", fixed_1);

    let fixed_d50_x = to_fixed_16_16(0.9505);
    println!("fixed(D50.x): {}", fixed_d50_x);

    let fixed_d50_y = to_fixed_16_16(1.0);
    println!("fixed(D50.y): {}", fixed_d50_y);

    let fixed_d50_z = to_fixed_16_16(1.0890);
    println!("fixed(D50.z): {}", fixed_d50_z);

    // Write ICC header test
    let wrote = write_file("/tmp/quanta_test_80.icc", "ICC_TEST_HEADER");
    println!("wrote icc: {}", wrote);

    let exists = file_exists("/tmp/quanta_test_80.icc");
    println!("icc exists: {}", exists);
}
