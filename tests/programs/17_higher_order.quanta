// Test 17: Higher-Order Functions
// Multiple closures composed through higher-order function patterns

fn map_int(f: fn(i32) -> i32, value: i32) -> i32 {
    f(value)
}

fn twice(f: fn(i32) -> i32, x: i32) -> i32 {
    f(f(x))
}

fn main() {
    let increment = |x: i32| -> i32 { x + 1 };
    let square = |x: i32| -> i32 { x * x };
    let triple = |x: i32| -> i32 { x * 3 };

    println!("increment(5) = {}", map_int(increment, 5));
    println!("square(4) = {}", map_int(square, 4));
    println!("triple(7) = {}", map_int(triple, 7));
    println!("twice(increment, 10) = {}", twice(increment, 10));
    println!("twice(triple, 2) = {}", twice(triple, 2));
}
