// Test 82: ACES Reference Rendering Transform
// Port of aces.py — Academy Color Encoding System tone mapping

// ACES RRT simplified (Narkowicz 2015 fit)
fn aces_rrt(x: f64) -> f64 {
    let a = 2.51;
    let b = 0.03;
    let c = 2.43;
    let d = 0.59;
    let e = 0.14;
    let num = x * (a * x + b);
    let den = x * (c * x + d) + e;
    let result = num / den;
    if result < 0.0 { 0.0 }
    else { if result > 1.0 { 1.0 } else { result } }
}

// ACES Output Display Transform (simplified)
fn aces_odt(linear: f64) -> f64 {
    // Apply gamma 2.2 for display
    if linear <= 0.0 {
        0.0
    } else {
        pow(linear, 1.0 / 2.2)
    }
}

// Full ACES pipeline: scene-linear → RRT → ODT → display
fn aces_pipeline(scene_linear: f64, exposure: f64) -> f64 {
    let exposed = scene_linear * pow(2.0, exposure);
    let rrt = aces_rrt(exposed);
    aces_odt(rrt)
}

fn main() {
    // ACES RRT at key values
    println!("rrt(0.0): {}", aces_rrt(0.0));
    println!("rrt(0.18): {}", aces_rrt(0.18));
    println!("rrt(1.0): {}", aces_rrt(1.0));
    println!("rrt(10.0): {}", aces_rrt(10.0));

    // Verify monotonic behavior
    let v0 = aces_rrt(0.0);
    let v1 = aces_rrt(0.5);
    let v2 = aces_rrt(1.0);
    let v3 = aces_rrt(5.0);
    if v0 < v1 {
        if v1 < v2 {
            if v2 < v3 {
                println!("monotonic: true");
            } else { println!("monotonic: false"); }
        } else { println!("monotonic: false"); }
    } else { println!("monotonic: false"); }

    // Full pipeline
    let display = aces_pipeline(0.18, 0.0);
    println!("pipeline(0.18, 0EV): {}", display);

    let bright = aces_pipeline(0.18, 3.0);
    println!("pipeline(0.18, +3EV): {}", bright);

    // Verify HDR compression: high input still maps to [0,1]
    let extreme = aces_pipeline(100.0, 0.0);
    if extreme <= 1.0 {
        println!("hdr clamped: true");
    } else {
        println!("hdr clamped: false");
    }
}
