// QuantaLang Standard Library - I/O Module
// File I/O functions are provided by the runtime.
// These are available as built-in functions:
//   read_file(path: str) -> str
//   write_file(path: str, content: str) -> bool
//   file_exists(path: str) -> bool

// Convenience wrappers
fn print_line(msg: str) {
    println!("{}", msg);
}
