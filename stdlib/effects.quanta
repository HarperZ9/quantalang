// QuantaLang Standard Effects Library
// These effect definitions are the foundation of QuantaLang's approach
// to side effects, error handling, and concurrency.

// --- Error Handling ---

effect Fail<E> {
    fn fail(error: E) -> !,
}

// --- Console I/O ---

effect Console {
    fn print(message: str) -> (),
    fn read_line() -> str,
}

// --- Mutable State ---

effect State<S> {
    fn get() -> S,
    fn set(value: S) -> (),
}

// --- Logging ---

effect Log {
    fn debug(message: str) -> (),
    fn info(message: str) -> (),
    fn warn(message: str) -> (),
    fn error(message: str) -> (),
}

// --- Random ---

effect Random {
    fn random_int(low: i32, high: i32) -> i32,
    fn random_float() -> f64,
}

// --- Async ---

effect Async {
    fn yield_now() -> (),
    fn sleep(ms: i32) -> (),
}
