// QuantaLang Standard Library - String Building Module
// Functions for constructing and manipulating strings.

/// Repeat a string N times.
fn repeat_str(s: str, n: i32) -> str {
    let mut result = "";
    let mut i: i32 = 0;
    while i < n {
        result = result + s;
        i = i + 1;
    }
    result
}

/// Join two strings with a separator.
fn str_join(a: str, b: str, sep: str) -> str {
    a + sep + b
}

/// Concatenate two strings (alias for +).
fn str_concat(a: str, b: str) -> str {
    a + b
}

/// Convert an integer to a string.
fn int_to_str(n: i32) -> str {
    to_string_i32(n)
}

/// Convert a float to a string.
fn float_to_str(n: f64) -> str {
    to_string_f64(n)
}

/// Check if a string is empty.
fn str_is_empty(s: str) -> bool {
    s == ""
}
